<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-5xl mx-auto">
    <div class="mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <div class="mb-3 flex items-center gap-3">
          <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-400 uppercase">Area Kerja</span>
          <div class="h-3 w-px bg-slate-300"></div>
          <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-800 uppercase">Kehadiran</span>
        </div>

        <h1 class="text-3xl font-semibold tracking-tighter text-slate-950">Pusat Administrasi Cuti</h1>
        <p class="mt-1.5 text-sm font-medium text-slate-500 max-w-xl">
          Persetujuan permohonan staf, arsip riwayat, beserta konfigurasi hari libur nasional secara terpusat.
        </p>
      </div>

      <form action="/leave/manage-requests/generate-balances" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin melakukan generate/reset saldo seluruh Pegawai pada tahun <%= selectedYear %>?');" class="flex items-center gap-4 bg-amber-50/50 border border-amber-200/60 p-3 rounded-2xl shadow-sm">
        <input type="hidden" name="year" value="<%= selectedYear %>">

        <div class="text-[11px] text-amber-900 leading-tight hidden xl:block font-semibold">
          Reset & sesuaikan jatah (12 hari) <br /> untuk tahun <%= selectedYear %>
        </div>

        <button type="submit" class="bg-amber-600 hover:bg-amber-700 text-white font-bold text-[12px] py-3 px-5 rounded-xl shadow-lg shadow-amber-600/20 transition-all active:scale-[0.98] flex items-center gap-2 whitespace-nowrap cursor-pointer">
          <i class="fa-solid fa-rotate text-[10px]"></i> Sync Saldo <%= selectedYear %>
        </button>
      </form>
    </div>
    <div class="flex items-center gap-2 mb-6 border-b border-slate-200/60 pb-px">
      <button type="button" onclick="switchTab('active')" id="tab-btn-active" class="tab-btn px-4 py-2.5 text-[13px] font-bold border-b-2 border-blue-600 text-blue-600 transition-all duration-150 outline-none cursor-pointer flex items-center gap-1.5">
        Permintaan Aktif
        <span class="ml-1 px-1.5 py-0.5 text-[10px] bg-blue-50 text-blue-600 rounded-md tabular-nums font-bold">
          <%= activeLeaves.length %>
        </span>
      </button>

      <button type="button" onclick="switchTab('history')" id="tab-btn-history" class="tab-btn px-4 py-2.5 text-[13px] font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-800 transition-all duration-150 outline-none cursor-pointer flex items-center gap-1.5">
        Riwayat Persetujuan
        <span class="ml-1 px-1.5 py-0.5 text-[10px] bg-slate-100 text-slate-600 rounded-md tabular-nums font-bold">
          <%= historyLeaves.length %>
        </span>
      </button>

      <button type="button" onclick="switchTab('calendar')" id="tab-btn-calendar" class="tab-btn px-4 py-2.5 text-[13px] font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-800 transition-all duration-150 outline-none cursor-pointer flex items-center gap-1.5">
        <i class="fa-solid fa-calendar-days text-[11px] text-slate-400"></i> Kelola Kalender
        <span class="ml-1 px-1.5 py-0.5 text-[10px] bg-slate-100 text-slate-600 rounded-md tabular-nums font-bold">
          <%= holidays.length %>
        </span>
      </button>
    </div>

    <div id="tab-content-active" class="tab-pane block">
      <div class="bg-white rounded-xl border border-slate-200/60 shadow-sm overflow-hidden">
        <div class="p-4 border-b border-slate-100 bg-slate-50/50">
          <h3 class="text-[13px] font-bold text-slate-800">Menunggu Review Anda</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-5 py-3">Nama Pegawai</th>
                <th class="px-5 py-3 text-left">Jenis Pengajuan</th>
                <th class="px-5 py-3">Tipe Cuti</th>
                <th class="px-5 py-3">Tanggal Pelaksanaan</th>
                <th class="px-5 py-3 text-center">Durasi</th>
                <th class="px-5 py-3 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (activeLeaves.length===0) { %>
              <tr>
                <td colspan="5" class="px-5 py-12 text-center text-slate-400">
                  <i class="fa-regular fa-circle-check text-3xl mb-2 block text-slate-300"></i>
                  Bersih! Tidak ada permohonan cuti aktif yang memerlukan tindakan Anda.
                </td>
              </tr>
              <% } else { %>
              <% activeLeaves.forEach(leave=> { %>
              <tr class="hover:bg-slate-50/50 transition duration-150">
                <td class="px-5 py-4 font-bold text-slate-900">
                  <%= leave.userId && leave.userId.employeeData ? leave.userId.employeeData.fullName
                            : "Pegawai" %>
                </td>
                <td class="px-5 py-4">
                  <% if (leave.status==='CANCELLATION_PENDING' ) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-200/60">
                    <i class="fa-solid fa-ban text-[9px]"></i> Minta Batal
                  </span>
                  <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-blue-50 text-blue-700 border border-blue-200/60">
                    <i class="fa-solid fa-file-circle-plus text-[9px]"></i> Cuti Baru
                  </span>
                  <% } %>
                </td>
                <td class="px-5 py-4">
                  <span class="px-2 py-0.5 rounded bg-slate-100 text-[11px] font-medium text-slate-600">
                    <%= leave.leaveTypeId.name %>
                  </span>
                </td>
                <td class="px-5 py-4 text-slate-500">
                  <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: 'numeric' , month: 'short' ,
                            year: 'numeric' }) %>
                  <span class="text-slate-300 mx-1">s/d</span>
                  <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: 'numeric' , month: 'short' ,
                              year: 'numeric' }) %>
                </td>
                <td class="px-5 py-4 text-center font-bold text-blue-600 tabular-nums">
                  <%= leave.totalDays %> Hari
                </td>
                <td class="px-5 py-4 text-right">
                  <a href="/leave/detail/<%= leave._id %>" class="inline-flex items-center gap-1.5 px-3.5 py-2 border border-slate-200 text-[11.5px] font-bold rounded-xl text-slate-700 bg-white hover:bg-slate-50 transition duration-150 active:scale-[0.97]">

                    <%= leave.status === 'CANCELLATION_PENDING' ? 'Periksa Pembatalan' : 'Periksa Cuti' %>

                    <svg class="w-3.5 h-3.5 text-slate-400 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane hidden">
      <div class="bg-white rounded-xl border border-slate-200/60 shadow-sm overflow-hidden">
        <div class="p-4 border-b border-slate-100 bg-slate-50/50">
          <h3 class="text-[13px] font-bold text-slate-800">Arsip Pengajuan Selesai</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-5 py-3">Nama Pegawai</th>
                <th class="px-5 py-3 text-left">Jenis Pengajuan</th>

                <th class="px-5 py-3">Tipe Cuti</th>
                <th class="px-5 py-3">Tanggal Pelaksanaan</th>
                <th class="px-5 py-3 text-center">Durasi</th>
                <th class="px-5 py-3">Status Final</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (historyLeaves.length===0) { %>
              <tr>
                <td colspan="5" class="px-5 py-12 text-center text-slate-400">
                  <i class="fa-regular fa-folder text-3xl mb-2 block text-slate-300"></i>
                  Belum ada riwayat arsip pemrosesan dokumen cuti.
                </td>
              </tr>
              <% } else { %>
              <% historyLeaves.forEach(leave=> { %>
              <tr class="hover:bg-slate-50/50 transition duration-150">
                <td class="px-5 py-4 font-bold text-slate-900">
                  <%= leave.userId && leave.userId.employeeData ? leave.userId.employeeData.fullName
                            : "Pegawai" %>
                </td>
                <td class="px-5 py-4">
                  <% if (leave.status==='CANCELLED' ) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-200/60">
                    <i class="fa-solid fa-ban text-[9px]"></i> Minta Batal
                  </span>
                  <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-blue-50 text-blue-700 border border-blue-200/60">
                    <i class="fa-solid fa-file-circle-plus text-[9px]"></i> Cuti Baru
                  </span>
                  <% } %>
                </td>
                <td class="px-5 py-4">
                  <span class="px-2 py-0.5 rounded bg-slate-100 text-[11px] font-medium text-slate-600">
                    <%= leave.leaveTypeId.name %>
                  </span>
                </td>
                <td class="px-5 py-4 text-slate-500">
                  <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: 'numeric' , month: 'short' ,
                            year: 'numeric' }) %>
                  <span class="text-slate-300 mx-1">s/d</span>
                  <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: 'numeric' , month: 'short' ,
                              year: 'numeric' }) %>
                </td>
                <td class="px-5 py-4 text-center font-medium text-slate-600 tabular-nums">
                  <%= leave.totalDays %> Hari
                </td>
                <td class="px-5 py-4">
                  <% if (leave.status === 'APPROVED') { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-emerald-50 text-emerald-700 border border-emerald-200/60">
                    <i class="fa-solid fa-circle-check text-[10px]"></i> Disetujui
                  </span>

                  <% } else if (leave.status === 'PENDING') { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-emerald-50 text-emerald-700 border border-emerald-200/60">
                    <i class="fa-solid fa-circle-check text-[10px]"></i> Disetujui
                  </span>

                  <% } else if (leave.status === 'CANCELLATION_PENDING') { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-emerald-50 text-emerald-700 border border-emerald-200/60">
                    <i class="fa-solid fa-circle-check text-[10px]"></i> Disetujui
                  </span>

                  <% } else if (leave.status === 'CANCELLED') { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-emerald-50 text-emerald-700 border border-emerald-200/60">
                    <i class="fa-solid fa-circle-check text-[10px]"></i> Disetujui
                  </span>

                  <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-rose-50 text-rose-700 border border-rose-200/60">
                    <i class="fa-solid fa-circle-xmark text-[10px]"></i> Ditolak
                  </span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="tab-content-calendar" class="tab-pane hidden">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

        <div class="bg-white p-5 rounded-xl border border-slate-200/60 shadow-sm">
          <h3 id="form-calendar-title" class="text-[13px] font-bold text-slate-800 mb-3 flex items-center gap-2">
            <i class="fa-solid fa-calendar-plus text-blue-600"></i> Tambah Hari Libur
          </h3>

          <% if (user.role !=='WAKIL_DIREKTUR' ) { %>
          <div class="p-3 bg-amber-50/70 rounded-lg text-[11px] text-amber-800 border border-amber-200/50 mb-3">
            <i class="fa-solid fa-circle-info text-amber-600"></i> Form dinonaktifkan. Hanya divisi/role
            <strong>WAKIL_DIREKTUR</strong> yang memiliki hak modifikasi kalender perusahaan.
          </div>
          <% } %>

          <form id="holiday-form" action="/leave/manage-calendar/create?tab=calendar" method="POST" class="space-y-3.5">
            <div>
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1">Nama Hari
                Libur / Agenda</label>
              <input type="text" name="name" id="form-name" required placeholder="Contoh: Cuti Bersama Lebaran" class="w-full rounded-lg border-slate-200 border p-2 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800" <%=user.role !=='WAKIL_DIREKTUR' ? 'disabled' : '' %>>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1">Mulai
                  Tanggal</label>
                <input type="date" name="date" id="form-date" required class="w-full rounded-lg border-slate-200 border p-2 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800" <%=user.role !=='WAKIL_DIREKTUR' ? 'disabled' : '' %>>
              </div>
              <div>
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1">Selesai
                  (Opsional)</label>
                <input type="date" name="endDate" id="form-enddate" class="w-full rounded-lg border-slate-200 border p-2 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800" <%=user.role !=='WAKIL_DIREKTUR' ? 'disabled' : '' %>>
              </div>
            </div>

            <div>
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1">Kategori
                Libur</label>
              <select name="type" id="form-type" required class="w-full rounded-lg border-slate-200 border p-2 text-xs bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800" <%=user.role !=='WAKIL_DIREKTUR' ? 'disabled' : '' %>>
                <option value="NATIONAL">Nasional (Tanggal Merah)</option>
                <option value="COMPANY">Internal Perusahaan</option>
                <option value="RELIGIOUS">Keagamaan</option>
              </select>
            </div>

            <div class="space-y-2 p-3 bg-slate-50 rounded-lg border border-slate-100 text-xs">
              <label class="flex items-center gap-2 text-slate-700 cursor-pointer font-medium">
                <input type="checkbox" name="isDeductLeave" id="form-deduct" value="true" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500/20" <%=user.role !=='WAKIL_DIREKTUR'
                        ? 'disabled' : '' %>>
                <span>Potong Kuota Cuti Tahunan?</span>
              </label>
              <p id="form-deduct-info" class="text-[11px] mt-1 font-medium transition-all duration-200"></p>
            </div>


            <div>
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1">Keterangan</label>
              <textarea name="description" id="form-description" rows="2" placeholder="Catatan opsional..." class="w-full rounded-lg border-slate-200 border p-2 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none placeholder-slate-400 text-slate-800" <%=user.role !=='WAKIL_DIREKTUR' ? 'disabled' : '' %>></textarea>
            </div>

            <div class="flex flex-col gap-2">
              <button type="submit" id="form-submit-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 rounded-lg text-xs shadow-sm transition duration-150 flex items-center justify-center gap-1.5" <%=user.role !=='WAKIL_DIREKTUR' ? 'disabled' : 'style=cursor:pointer' %>>
                <i class="fa-solid fa-floppy-disk"></i> Simpan Agenda
              </button>
              <button type="button" id="form-cancel-btn" onclick="resetFormToCreate()" class="w-full hidden bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold py-2 rounded-lg text-xs transition duration-150 text-center cursor-pointer">
                Batal Edit (Buat Baru)
              </button>
            </div>
          </form>
        </div>

        <div class="bg-white p-5 rounded-xl border border-slate-200/60 shadow-sm lg:col-span-2">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-[13px] font-bold text-slate-800">Agenda Terdaftar Tahun <%= selectedYear %></h3>
            <form method="GET" action="/leave/manage-requests">
              <input type="hidden" name="tab" value="calendar">
              <select name="year" onchange="this.form.submit()" class="border border-slate-200 rounded-lg py-1 px-2 text-xs font-bold text-slate-700 bg-white focus:outline-none cursor-pointer">
                <% const yr=new Date().getFullYear(); %>
                <option value="<%= yr %>" <%=selectedYear===yr ? 'selected' : '' %>><%= yr %></option>
                <option value="<%= yr + 1 %>" <%=selectedYear===(yr + 1) ? 'selected' : '' %>><%= yr + 1 %></option>
              </select>
            </form>
          </div>

          <% if (holidays.length !== 0) { %>
          <div class="flex flex-wrap gap-1 mb-3 bg-slate-100/80 p-1 rounded-lg w-fit">
            <button type="button" onclick="filterQuarter('ALL')" class="q-btn px-2.5 py-1 text-[11px] font-bold rounded-md bg-white text-blue-600 shadow-sm transition-all duration-150">Semua</button>
            <button type="button" onclick="filterQuarter('Q1')" class="q-btn px-2.5 py-1 text-[11px] font-medium rounded-md text-slate-600 hover:text-slate-800 transition-all duration-150">Q1 (Jan-Mar)</button>
            <button type="button" onclick="filterQuarter('Q2')" class="q-btn px-2.5 py-1 text-[11px] font-medium rounded-md text-slate-600 hover:text-slate-800 transition-all duration-150">Q2 (Apr-Jun)</button>
            <button type="button" onclick="filterQuarter('Q3')" class="q-btn px-2.5 py-1 text-[11px] font-medium rounded-md text-slate-600 hover:text-slate-800 transition-all duration-150">Q3 (Jul-Sep)</button>
            <button type="button" onclick="filterQuarter('Q4')" class="q-btn px-2.5 py-1 text-[11px] font-medium rounded-md text-slate-600 hover:text-slate-800 transition-all duration-150">Q4 (Okt-Des)</button>
          </div>
          <% } %>
          <div class="space-y-2 max-h-[480px] overflow-y-auto pr-1.5 scrollbar-thin scrollbar-thumb-slate-200" id="holiday-list-container">
            <% if (holidays.length===0) { %>
            <div class="text-center py-10 text-slate-400 text-xs">Belum ada agenda libur terdaftar.</div>
            <% } else { %>
            <% holidays.forEach(h=> { %>
            <% const hMonth = new Date(h.date).getMonth(); %>
            <div class="holiday-card flex items-center justify-between p-3 rounded-lg border border-slate-100 bg-slate-50/40 transition duration-150 <%= !h.isActive ? 'opacity-50 bg-slate-200/30' : 'hover:border-slate-200/80' %>" data-month="<%= hMonth %>">

              <div class="flex items-center gap-3.5">
                <div class="p-2 rounded-lg text-center font-bold text-[13px] min-w-[52px] tabular-nums <%= !h.isActive ? 'bg-slate-200 text-slate-500 border border-slate-300' : h.isDeductLeave ? 'bg-rose-50 text-rose-700 border border-rose-100' : 'bg-blue-50 text-blue-700 border border-blue-100' %>">
                  <%= new Date(h.date).toLocaleDateString('id-ID', { day: '2-digit' }) %>
                  <span class="block text-[9px] font-bold uppercase tracking-wide">
                    <%= new Date(h.date).toLocaleDateString('id-ID', { month: 'short' }) %>
                  </span>
                </div>
                <div>
                  <h4 class="font-bold text-slate-800 text-xs flex items-center gap-2">
                    <%= h.name %>
                    <% if(!h.isActive) { %>
                    <span class="text-[9px] bg-slate-400 text-white font-bold px-1 rounded">Diarsipkan</span>
                    <% } %>
                  </h4>
                  <p class="text-[11px] text-slate-400 mt-0.5">
                    <%= h.description || 'Tidak ada deskripsi tambahan' %>
                  </p>
                  <div class="flex gap-1.5 mt-1">
                    <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-slate-200/70 text-slate-600 uppercase tracking-wider">
                      <%= h.type %>
                    </span>
                    <% if(h.isDeductLeave) { %>
                    <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-rose-100/70 text-rose-600">
                      <i class="fa-solid fa-scissors mr-0.5"></i> Potong Cuti
                    </span>
                    <% } %>
                  </div>
                </div>
              </div>

              <% const isWakilDirektur=user && user.role==='WAKIL_DIREKTUR' ; %>
              <% if (isWakilDirektur) { %>
              <div class="flex items-center gap-1">
                <button type="button" onclick="prepareEditHoliday('<%= encodeURIComponent(JSON.stringify(h)) %>')" class="text-blue-600 hover:text-blue-800 p-1.5 rounded-md hover:bg-blue-50 transition duration-150 cursor-pointer" title="Ubah data">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                  </svg>
                </button>

                <button type="button" onclick="toggleHolidayStatus('<%= h._id %>', <%= h.isActive %>)" class="p-1.5 rounded-md transition duration-150 cursor-pointer <%= h.isActive ? 'text-amber-600 hover:text-amber-800 hover:bg-amber-50' : 'text-emerald-600 hover:text-emerald-800 hover:bg-emerald-50' %>" title="<%= h.isActive ? 'Arsipkan agenda' : 'Aktifkan kembali' %>">
                  <% if (h.isActive) { %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
                  </svg>
                  <% } else { %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                  </svg>
                  <% } %>
                </button>
              </div>
              <% } %>
            </div>
            <% }) %>
            <% } %>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>
<script>
  function switchTab(tabName) {
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.replace('block', 'hidden');
    });

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('border-blue-600', 'text-blue-600', 'font-bold');
      btn.classList.add('border-transparent', 'text-slate-500', 'font-medium');
    });

    const targetPane = document.getElementById(`tab-content-${tabName}`);
    if (targetPane) targetPane.classList.replace('hidden', 'block');

    const targetBtn = document.getElementById(`tab-btn-${tabName}`);
    if (targetBtn) {
      targetBtn.classList.remove('border-transparent', 'text-slate-500', 'font-medium');
      targetBtn.classList.add('border-blue-600', 'text-blue-600', 'font-bold');
    }
  }

  // ==========================================
  // LOGIC SINKRONISASI KATEGORI & POTONG CUTI
  // ==========================================
  function handleTypeChange() {
    const typeSelect = document.getElementById('form-type');
    const deductCheckbox = document.getElementById('form-deduct');
    const deductInfo = document.getElementById('form-deduct-info'); // Elemen teks info

    if (!typeSelect || !deductCheckbox) return;

    const value = typeSelect.value;
    const parentLabel = deductCheckbox.parentElement;

    if (value === 'COMPANY') {
      deductCheckbox.checked = true;
      deductCheckbox.disabled = true;
      if (parentLabel) parentLabel.classList.add('opacity-75', 'cursor-not-allowed');

      if (deductInfo) {
        deductInfo.innerHTML = '<i class="fa-solid fa-circle-exclamation text-amber-500 mr-1"></i> Kebijakan Perusahaan: Cuti bersama internal otomatis memotong kuota tahunan Pegawai.';
        deductInfo.className = "text-[11px] mt-1 font-medium text-amber-600";
      }
    } else if (value === 'NATIONAL') {
      deductCheckbox.checked = false;
      deductCheckbox.disabled = true;
      if (parentLabel) parentLabel.classList.add('opacity-50', 'cursor-not-allowed');

      if (deductInfo) {
        deductInfo.innerHTML = '<i class="fa-solid fa-circle-check text-emerald-500 mr-1"></i> Sesuai Regulasi: Libur nasional / tanggal merah resmi tidak memotong kuota cuti.';
        deductInfo.className = "text-[11px] mt-1 font-medium text-emerald-600";
      }
    } else if (value === 'RELIGIOUS') {
      deductCheckbox.disabled = false;
      if (parentLabel) parentLabel.classList.remove('opacity-50', 'opacity-75', 'cursor-not-allowed');

      if (deductInfo) {
        deductInfo.innerHTML = '<i class="fa-solid fa-circle-info text-blue-500 mr-1"></i> Opsional: Silakan tentukan apakah agenda keagamaan ini memotong kuota cuti tahunan atau tidak.';
        deductInfo.className = "text-[11px] mt-1 font-medium text-blue-600";
      }
    }
  }

  function prepareEditHoliday(holidayDataRaw) {
    const holiday = JSON.parse(decodeURIComponent(holidayDataRaw));

    document.getElementById('form-calendar-title').innerHTML = '<i class="fa-solid fa-pen-to-square text-blue-600"></i> Edit Hari Libur';

    document.getElementById('holiday-form').action = `/leave/manage-calendar/update/${holiday._id}?tab=calendar`;

    document.getElementById('form-submit-btn').innerHTML = '<i class="fa-solid fa-check"></i> Simpan Perubahan';
    document.getElementById('form-cancel-btn').classList.remove('hidden');

    document.getElementById('form-name').value = holiday.name;
    document.getElementById('form-date').value = new Date(holiday.date).toISOString().split('T')[0];

    if (holiday.endDate) {
      document.getElementById('form-enddate').value = new Date(holiday.endDate).toISOString().split('T')[0];
    } else {
      document.getElementById('form-enddate').value = '';
    }

    document.getElementById('form-type').value = holiday.type;

    handleTypeChange();

    document.getElementById('form-deduct').checked = holiday.isDeductLeave;
    document.getElementById('form-description').value = holiday.description || '';

    document.getElementById('holiday-form').scrollIntoView({
      behavior: 'smooth'
    });
  }

  function resetFormToCreate() {
    document.getElementById('form-calendar-title').innerHTML = '<i class="fa-solid fa-calendar-plus text-blue-600"></i> Tambah Hari Libur';

    document.getElementById('holiday-form').action = '/leave/manage-calendar/create?tab=calendar';

    document.getElementById('form-submit-btn').innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Simpan Agenda';
    document.getElementById('form-cancel-btn').classList.add('hidden');
    document.getElementById('holiday-form').reset();

    handleTypeChange();
  }

  async function toggleHolidayStatus(id, currentStatus) {
    const message = currentStatus ?
      "Apakah Anda yakin ingin mengarsipkan hari libur ini? Data tidak akan terhapus namun dinonaktifkan dari sistem berjalan." :
      "Aktifkan kembali hari libur yang telah diarsipkan ini?";

    if (!confirm(message)) return;

    try {
      const response = await fetch(`/leave/manage-calendar/toggle/${id}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json'
        }
      });
      const result = await response.json();
      if (result.success) {
        window.location.href = window.location.pathname + '?tab=calendar';
      } else {
        alert("Gagal memproses data: " + result.message);
      }
    } catch (err) {
      console.error(err);
      alert("Gagal menghubungi server database.");
    }
  }

  document.addEventListener("DOMContentLoaded", function() {
    const typeSelect = document.getElementById('form-type');

    if (typeSelect) {
      typeSelect.addEventListener('change', handleTypeChange);
    }

    const currentUrlParams = new URLSearchParams(window.location.search);
    const activeTab = currentUrlParams.get('tab');

    if (activeTab) {
      switchTab(activeTab);
    } else if (currentUrlParams.has('year')) {
      switchTab('calendar');
    }

    handleTypeChange();
  });

  function filterQuarter(quarter) {
    const buttons = document.querySelectorAll('.q-btn');
    const targetButton = window.event ? window.event.currentTarget : null;

    buttons.forEach(btn => {
      btn.classList.remove('bg-white', 'text-blue-600', 'shadow-sm', 'font-bold');
      btn.classList.add('text-slate-600', 'font-medium');
    });

    if (targetButton) {
      targetButton.classList.remove('text-slate-600', 'font-medium');
      targetButton.classList.add('bg-white', 'text-blue-600', 'shadow-sm', 'font-bold');
    }

    document.querySelectorAll('.holiday-card').forEach(card => {
      const month = parseInt(card.getAttribute('data-month'));

      if (quarter === 'ALL') {
        card.classList.remove('hidden');
      } else if (quarter === 'Q1' && month >= 0 && month <= 2) { // Jan - Mar
        card.classList.remove('hidden');
      } else if (quarter === 'Q2' && month >= 3 && month <= 5) { // Apr - Jun
        card.classList.remove('hidden');
      } else if (quarter === 'Q3' && month >= 6 && month <= 8) { // Jul - Sep
        card.classList.remove('hidden');
      } else if (quarter === 'Q4' && month >= 9 && month <= 11) { // Okt - Des
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }
</script>
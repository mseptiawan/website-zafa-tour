<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-7xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-xl font-medium text-slate-800">
        Perjalanan Saya
      </h1>

      <p class="text-sm text-slate-500 mt-1">
        Daftar pengajuan dinas luar yang kamu ajukan
      </p>
    </div>

    <!-- TABLE -->
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">

      <div class="overflow-x-auto">

        <table class="w-full text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-xs uppercase tracking-wide text-slate-500">
              <th class="px-5 py-4 text-left">Judul</th>
              <th class="px-5 py-4 text-left">Tujuan</th>
              <th class="px-5 py-4 text-left">Tanggal</th>
              <th class="px-5 py-4 text-left">Budget</th>
              <th class="px-5 py-4 text-left">Timeline</th>
              <th class="px-5 py-4 text-left">Contact</th>
              <th class="px-5 py-4 text-left">Step</th>
              <th class="px-5 py-4 text-left">Status</th>
            </tr>
          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (!trips || trips.length === 0) { %>
              <tr>
                <td colspan="8" class="px-5 py-14 text-center">
                  <div class="text-sm font-medium text-slate-600">
                    Belum ada pengajuan perjalanan
                  </div>
                  <p class="text-xs text-slate-400 mt-1">
                    Silakan buat pengajuan dinas luar terlebih dahulu
                  </p>
                </td>
              </tr>
            <% } %>

            <% trips.forEach(trip => { %>

              <tr class="hover:bg-slate-50 transition">

                <!-- TITLE -->
                <td class="px-5 py-4 font-medium text-slate-800">
                  <%= trip.title %>
                </td>

                <!-- DESTINATION -->
                <td class="px-5 py-4 text-slate-600">
                  <%= trip.destination %>
                </td>

                <!-- DATE -->
                <td class="px-5 py-4 text-xs text-slate-600">
                  <div>
                    <span class="text-slate-400">Mulai:</span>
                    <%= new Date(trip.startDate).toLocaleDateString('id-ID') %>
                  </div>
                  <div>
                    <span class="text-slate-400">Selesai:</span>
                    <%= new Date(trip.endDate).toLocaleDateString('id-ID') %>
                  </div>
                </td>

                <!-- BUDGET -->
                <td class="px-5 py-4 font-medium text-slate-700">
                  Rp <%= Number(trip.budget || 0).toLocaleString('id-ID') %>
                </td>

                <!-- TIMELINE -->
                <td class="px-5 py-4 text-xs text-slate-600">

                  <% if (trip.timeline && trip.timeline.length) { %>

                    <div class="space-y-1">

                      <% trip.timeline.slice(0, 3).forEach((t, i) => { %>
                        <div>
                          <span class="text-slate-400"><%= i + 1 %>.</span>
                          <%= t.address %>
                        </div>
                      <% }) %>

                      <% if (trip.timeline.length > 3) { %>
                        <div class="text-slate-400">
                          +<%= trip.timeline.length - 3 %> lainnya
                        </div>
                      <% } %>

                    </div>

                  <% } else { %>
                    <span class="text-slate-400">-</span>
                  <% } %>

                </td>

                <!-- CONTACT PERSON -->
                <td class="px-5 py-4 text-xs text-slate-600">

                  <% if (trip.contactPerson?.name || trip.contactPerson?.phone) { %>

                    <div class="font-medium text-slate-700">
                      <%= trip.contactPerson?.name || '-' %>
                    </div>

                    <div class="text-slate-400">
                      <%= trip.contactPerson?.phone || '-' %>
                    </div>

                  <% } else { %>
                    <span class="text-slate-400">-</span>
                  <% } %>

                </td>

                <!-- CURRENT STEP -->
                <td class="px-5 py-4 text-xs text-slate-600">
                  <%= trip.currentStep || '-' %>
                </td>

                <!-- STATUS -->
                <td class="px-5 py-4">

                  <% if (trip.status === 'PENDING') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-amber-50 text-amber-600 border border-amber-100 font-medium">
                      Pending
                    </span>

                  <% } else if (trip.status === 'IN_REVIEW') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-blue-50 text-blue-600 border border-blue-100 font-medium">
                      In Review
                    </span>

                  <% } else if (trip.status === 'APPROVED') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-emerald-50 text-emerald-600 border border-emerald-100 font-medium">
                      Approved
                    </span>

                  <% } else { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-rose-50 text-rose-600 border border-rose-100 font-medium">
                      Rejected
                    </span>

                  <% } %>

                </td>

              </tr>

            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>
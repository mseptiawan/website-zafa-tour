<%- layout('layouts/main', { title }) %>

<div class=" min-h-screen md:ml-72 bg-slate-50/60 p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
  <div class="max-w-none mx-auto">

    <% 
      const APPROVER_ROLES = ["MANAGER_ADMINISTRASI", "WAKIL_DIREKTUR", "DIREKTUR_UTAMA"];
      // FIX: Tambahkan .trim() untuk mencegah bug spasi di back link
      const userRoleRaw = (user.role || '').toUpperCase().trim();
      const isManagement = APPROVER_ROLES.includes(userRoleRaw);
      const backLink = isManagement ? '/trip/approval' : '/trip/my';
    %>
    <a href="<%= backLink %>" class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 mb-6 transition-colors group">
      <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Kembali
    </a>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-5 px-4 py-3 rounded-xl border border-red-200 bg-red-50 text-red-700 text-[13px] font-medium">
        <%= error %>
      </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
      
      <div class="lg:col-span-2 space-y-6">
        
        <div class="bg-white border border-slate-200/60 rounded-2xl  overflow-hidden">
          
          <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-white">
            <div class="flex items-center gap-4 min-w-0 flex-1">
              <div class="w-10 h-10 rounded-xl bg-slate-50 border border-slate-200/60 flex items-center justify-center text-slate-500 flex-shrink-0">
                <i class="fa-solid fa-file-signature text-sm"></i>
              </div>
              <div class="min-w-0 flex-1">
                <h1 class="text-[15px] font-semibold text-slate-900 tracking-tight leading-none mb-2 break-words">
                  <%= trip.title %>
                </h1>
                <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">
                  Detail Lembar Persetujuan Perjalanan
                </p>
              </div>
            </div>

            <div class="flex items-center gap-2 flex-shrink-0">
              <span class="inline-flex items-center px-3 py-1 text-[10px] font-semibold tracking-wider rounded-full border uppercase
                <%= trip.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200'
                  : trip.status === 'REJECTED' ? 'bg-red-50 text-red-700 border-red-200'
                  : 'bg-blue-50 text-blue-700 border-blue-200' %>">
                <%= trip.status %>
              </span>
            </div>
          </div>

          <div class="p-8 space-y-8">
            
            <div class="grid grid-cols-2 gap-x-12 gap-y-6">
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Nama Pengaju</div>
                <div class="text-[14px] font-semibold text-slate-800 break-words"><%= trip.userId?.username || '-' %></div>
              </div>
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Kota / Lokasi Tujuan</div>
                <div class="text-[14px] font-semibold text-slate-800 break-words"><%= trip.destination || '-' %></div>
              </div>
            </div>

            <div class="border-t border-slate-100 pt-6">
              <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Total Alokasi Anggaran (Budget)</div>
              <div class="text-[18px] font-bold text-slate-900 tabular-nums mb-4">
                Rp <%= (typeof trip.budget === 'number' ? trip.budget : (trip.budget?.total || 0)).toLocaleString('id-ID') %>
              </div>

              <% if (trip.budget && typeof trip.budget === 'object' && trip.budget.items && trip.budget.items.length > 0) { %>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-[220px] overflow-y-auto pr-1">
                  <% trip.budget.items.forEach(function(item) { %>
                    <div class="flex items-start justify-between bg-slate-50/60 border border-slate-200/30 rounded-xl p-3 hover:bg-slate-50 transition-colors gap-3">
                      <div class="space-y-0.5 leading-tight min-w-0 flex-1">
                        <span class="text-[11px] font-semibold text-slate-700 block break-words"><%= item.title %></span>
                        <% if (item.description) { %>
                          <span class="text-[10px] text-slate-400 block mt-0.5 break-words"><%= item.description %></span>
                        <% } %>
                      </div>
                      <span class="text-[11px] font-bold text-slate-800 whitespace-nowrap tabular-nums flex-shrink-0">
                        Rp <%= (item.allocatedAmount || 0).toLocaleString('id-ID') %>
                      </span>
                    </div>
                  <% }); %>
                </div>
              <% } %>
            </div>

            <div class="relative pl-5 border-l-2 border-slate-200 pt-0.5">
              <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-2">Deskripsi / Maksud Dinas</div>
              <p class="text-[13px] text-slate-600 leading-relaxed italic break-words whitespace-pre-line">"<%= trip.description || 'Tidak ada deskripsi tambahan.' %>"</p>
            </div>

            <div class="space-y-3 pt-2 border-t border-slate-100/60">
              <label class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest block">Rute & Runtunan Linimasa Perjalanan</label>
              <div class="relative pl-5 space-y-4 before:absolute before:left-[4px] before:top-2 before:bottom-2 before:w-[1px] before:bg-slate-200">
                <% (trip.timeline || []).forEach((item)=> { %>
                  <div class="relative group flex items-start">
                    <div class="absolute -left-[23px] top-1.5 w-2.5 h-2.5 rounded-full border border-white bg-slate-300 group-hover:bg-slate-500 transition-colors  ring-4 ring-white flex-shrink-0"></div>
                    <div class="text-[12px] font-medium text-slate-600 group-hover:text-slate-900 transition-colors leading-snug break-words max-w-full">
                      <%= item.address %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>

          </div>
        </div>

        <% 
          // 1. NORMALISASI ROLE & STEP (Penting: .toUpperCase() dan .trim() agar bebas dari spasi tersembunyi)
          const currentRole = (user.role || '').toUpperCase().trim();
          const currentStep = (trip.currentStep || '').toUpperCase().trim();
          
          const isFinal = ['APPROVED', 'REJECTED'].includes(trip.status); 

          // 2. CEK STATUS DELEGASI
          const isDelegatedToWadir = trip.delegation?.active === true && trip.delegation?.to === 'WAKIL_DIREKTUR'; 
          
          // 3. LOGIC DELEGASI SPESIFIK
          // Wakil Direktur hanya bisa bertindak jika memang didelegasikan SAAT stepnya ada di DIREKTUR_UTAMA
          const isWadirStep = isDelegatedToWadir && currentRole === 'WAKIL_DIREKTUR' && currentStep === 'DIREKTUR_UTAMA'; 
          // Jika didelegasikan, Direktur Utama di-block dari action UI
          const isPimpinanBlocked = currentRole === 'DIREKTUR_UTAMA' && isDelegatedToWadir && currentStep === 'DIREKTUR_UTAMA'; 
          
          // 4. SIMPLIFIKASI canApprove
          const canApprove = !isFinal && (currentRole === currentStep || isWadirStep); 
          
          // 5. LOGIC ACTION DELEGATE BUTTON
          const requesterRoleNormal = (trip.requesterRole || '').toUpperCase().trim();
          const requesterIsWadir = requesterRoleNormal === 'WAKIL_DIREKTUR'; 
          const canDelegate = currentRole === 'DIREKTUR_UTAMA' && currentStep === 'DIREKTUR_UTAMA' && !isDelegatedToWadir && !isFinal && !requesterIsWadir; 
        %>


        <% if (canApprove && !isPimpinanBlocked) { %>
          <div class="bg-white/90 backdrop-blur-xl rounded-3xl p-8 border border-slate-200 ">
            <h3 class="text-sm font-semibold text-slate-800 mb-5 flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center text-blue-700">
                <i class="fa-solid fa-check-double"></i>
              </div>
              Evaluasi & Verifikasi Dokumen Dinas
            </h3>

            <form method="POST" action="/trip/approval/<%= trip._id %>" id="action-master-form" class="space-y-4">
              <div class="space-y-1.5">
                <label class="text-[11px] font-semibold text-slate-400 uppercase tracking-widest block pl-0.5">
                  Catatan / Alasan Penolakan
                </label>
                <div class="relative w-full">
                  <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                    <i class="fa-solid fa-pen text-xs"></i>
                  </div>
                  <input type="text" name="note" id="approval-note-input"
                    placeholder="Wajib diisi jika Anda bermaksud menolak pengajuan ini..."
                    class="w-full bg-slate-50/50 border border-slate-200/80 rounded-xl pl-10 pr-4 py-2.5 text-[13px] text-slate-700 placeholder-slate-400 outline-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100 transition-all " />
                </div>
              </div>

              <div class="flex items-center justify-end gap-3 pt-2">
                <button type="button" onclick="submitWithAction('REJECT')"
                  class="cursor-pointer px-5 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 text-xs font-bold hover:bg-slate-50 transition active:scale-[0.98] whitespace-nowrap">
                  Tolak Pengajuan
                </button>

                <button type="button" onclick="submitWithAction('APPROVE')"
                  class="cursor-pointer px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold  transition active:scale-[0.98] whitespace-nowrap">
                  Setujui Pengajuan
                </button>

                <input type="hidden" name="action" id="action-type-value" value="" />
              </div>
            </form>
          </div>
        <% } %>

        <% if (!canApprove || isPimpinanBlocked) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl p-5 flex items-center justify-between text-[13px]">
            <div class="text-slate-500 font-medium flex items-center gap-2">
              <% if (trip.status === 'APPROVED') { %>
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                <span class="text-slate-600 font-medium">Pengajuan perjalanan dinas luar telah disetujui sepenuhnya</span>
              <% } else if (trip.status === 'REJECTED') { %>
                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                <span class="text-slate-600 font-medium">Pengajuan perjalanan dinas ditolak</span>
              <% } else { %>
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
                <span class="text-slate-600 font-medium">Berkas sedang dalam proses tinjauan manajemen</span>
              <% } %>
            </div>

            <span class="inline-flex items-center px-2.5 py-0.5 text-[10px] font-bold rounded-md border uppercase tracking-wider
              <%= trip.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-600 border-emerald-100'
                : trip.status === 'REJECTED' ? 'bg-red-50 text-red-700 border-red-100'
                : 'bg-blue-50 text-blue-700 border-blue-200' %>">
              <%= trip.delegation?.active ? 'Wakil Direktur (DELEGATED)' : (trip.currentStep || 'SELESAI') %>
            </span>
          </div>
        <% } %>


        <% if (canDelegate) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="space-y-0.5">
              <h4 class="text-[13px] font-semibold text-slate-800">
                Pendelegasian Berkas Otoritas
              </h4>
              <p class="text-[11px] text-slate-400 leading-normal">
                Alihkan peninjauan data anggaran ke departemen Wakil Direktur untuk pemeriksaan berkas fisik.
              </p>
            </div>

            <form method="POST" action="/trip/<%= trip._id %>/delegate" class="flex-shrink-0">
              <button type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 bg-white hover:bg-amber-50/50 text-amber-600 hover:text-amber-700 border border-amber-200 rounded-xl px-4 py-2.5 text-[12.5px] font-semibold transition-all   active:scale-[0.98] cursor-pointer">
                <i class="fa-solid fa-shuffle text-[10px]"></i> Delegasikan ke Wakil Direktur
              </button>
            </form>
          </div>
        <% } %>

      </div>

      <div class="space-y-6">
        <div class="bg-white border border-slate-200/60 rounded-2xl  p-6">
          <div class="mb-8">
            <h2 class="text-xs font-bold text-slate-900 uppercase tracking-wider">Jejak Log Pemeriksaan</h2>
            <p class="text-[10px] text-slate-400 mt-0.5">Alur dan status persetujuan berkas dinas</p>
          </div>

          <div class="relative pl-6 space-y-8 before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-100">
            <% if (!trip.approvals || trip.approvals.length === 0) { %>
              <div class="text-xs text-slate-400 italic py-2">Belum ada riwayat tracker approval.</div>
            <% } %>

            <% (trip.approvals || []).forEach((app, index) => { %>
              <div class="relative mb-6">
                <div class="absolute -left-[27px] top-0 w-6 h-6 rounded-full border-4 border-white flex items-center justify-center
                  <%= app.status === 'APPROVED' ? 'bg-emerald-500' : app.status === 'REJECTED' ? 'bg-rose-500' : 'bg-amber-400' %>">
                  <span class="text-[8px] text-white font-bold"><%= index + 1 %></span>
                </div>

                <div class="flex flex-col gap-1">
                  <div class="flex items-center justify-between gap-2">
                    <span class="text-[11px] font-bold text-slate-900 tracking-wide uppercase truncate"><%= app.step %></span>
                    <span class="text-[9px] font-bold px-2 py-0.5 rounded-full uppercase border flex-shrink-0
                      <%= app.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' 
                        : app.status === 'REJECTED' ? 'bg-rose-50 text-rose-700 border-rose-200' 
                        : 'bg-amber-50 text-amber-700 border-amber-200' %>">
                      <%= app.status %>
                    </span>
                  </div>

                  <div class="flex items-center gap-2 text-[10px] text-slate-500">
                    <span class="font-semibold text-slate-700"><%= app.actor || 'Sistem / Staff' %></span>
                    <span class="text-slate-300">|</span>
                    <span><%= app.actionDate ? new Date(app.actionDate).toLocaleString('id-ID', {day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit'}) : 'Selesai' %></span>
                  </div>

                  <% if (app.status !== 'PENDING' && app.note) { %>
                    <div class="mt-2 text-[10px] bg-slate-50 p-2.5 rounded-lg border border-slate-100 text-slate-600 italic break-words">
                      "<%= app.note %>"
                    </div>
                  <% } %>
                </div>
              </div>
            <% }) %>

            <% const isFinalState = ['APPROVED', 'REJECTED', 'CANCELLED'].includes(trip.status); %>
            <% if (!isFinalState && trip.currentStep) { %>
              <div class="relative mb-6">
                <div class="absolute -left-[27px] top-0 w-6 h-6 rounded-full border-4 border-white bg-blue-500 flex items-center justify-center animate-pulse">
                  <span class="text-[8px] text-white font-bold"><%= (trip.approvals || []).length + 1 %></span>
                </div>

                <div class="flex flex-col gap-1">
                  <div class="flex items-center justify-between gap-2">
                    <span class="text-[11px] font-bold text-slate-900 tracking-wide uppercase truncate">
                      <%= trip.delegation?.active ? 'Wakil Direktur (DELEGATED)' : trip.currentStep %>
                    </span>
                    <span class="text-[9px] font-bold px-2 py-0.5 rounded-full uppercase border flex-shrink-0 bg-blue-50 text-blue-700 border-blue-200">
                      PENDING
                    </span>
                  </div>

                  <div class="flex items-center gap-2 text-[10px] text-slate-400">
                    <span class="font-semibold text-slate-500">Otoritas Peninjau</span>
                    <span class="text-slate-300">|</span>
                    <span>Menunggu Tindakan</span>
                  </div>

                  <div class="mt-2 text-[10px] bg-blue-50/40 p-2.5 rounded-lg border border-blue-100/50 text-blue-600 italic leading-relaxed break-words">
                    "Menunggu konfirmasi pada langkah otoritas saat ini."
                  </div>
                </div>
              </div>
            <% } %>

            <% if (trip.status === 'CANCELLED') { %>
              <div class="relative mt-4 pl-3 border-l border-slate-200">
                <div class="flex flex-col gap-1">
                  <div class="flex items-center justify-between">
                    <span class="text-[10px] font-semibold text-slate-500 tracking-wide uppercase">Pengajuan Dibatalkan</span>
                    <span class="text-[9px] font-medium px-2 py-0.5 rounded-md uppercase border bg-slate-50 text-slate-600 border-slate-200">Cancelled</span>
                  </div>
                  <div class="mt-1.5 text-[10px] text-slate-500 bg-slate-50/50 p-2 rounded-lg border border-slate-100/80 italic leading-relaxed">
                    "Pengajuan perjalanan dinas luar telah dibatalkan resmi oleh pemohon."
                  </div>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function submitWithAction(actionType) {
    const form = document.getElementById('action-master-form');
    const inputAction = document.getElementById('action-type-value');
    const noteInput = document.getElementById('approval-note-input');

    inputAction.value = actionType;

    if (actionType === 'REJECT' && !noteInput.value.trim()) {
      noteInput.reportValidity();
      noteInput.focus();
      return;
    }

    form.submit();
  }
</script>
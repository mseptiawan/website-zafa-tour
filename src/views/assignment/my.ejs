<%- layout('layouts/main', { title: title }) %>

<div class=" min-h-screen bg-slate-50/50 p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
  <div class="mx-auto max-w-5xl">
    <div class="mb-10">
      <%- include('../partials/page-header.ejs', { 
    section: 'Area Kerja', 
    module: 'Penugasan', 
    title: 'Penugasan Saya', 
    description: 'Kelola daftar riwayat dan pantau penugasan aktif yang diberikan kepada Anda.' 
}) %>
    </div>

    <% if(assignments.length===0) { %>
    <div class="rounded-2xl border border-slate-200/60 bg-white p-12 text-center shadow-sm">
      <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl border border-slate-100 bg-slate-50 text-slate-400">
        <svg class="h-5 w-5 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
      </div>
      <p class="text-[13px] font-medium text-slate-700">Belum ada penugasan</p>
      <p class="mt-0.5 text-[11px] text-slate-400">
        Saat ini Anda tidak memiliki surat perintah atau tugas aktif.
      </p>
    </div>
    <% } else { %>

    <div class="space-y-3">
      <% assignments.forEach(a=> { %>
      <a href="/assignment/<%= a._id %>" class="group block rounded-2xl border border-slate-200/60 bg-white p-5 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50/30 hover:shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 space-y-1">
            <h2 class="text-[14px] font-semibold break-words text-slate-800 transition-colors group-hover:text-blue-600">
              <%= a.title %>
            </h2>
            <p class="line-clamp-1 pr-4 text-[13px] leading-relaxed break-words text-slate-400">
              <%= a.description || 'Tidak ada deskripsi tambahan untuk penugasan ini' %>
            </p>
          </div>

          <div class="flex-shrink-0">
            <% if(a.endDate && new Date(a.endDate)>= new Date()) { %>
            <span class="inline-flex items-center rounded-lg border border-emerald-100 bg-emerald-50/60 px-2.5 py-1 text-[11px] font-medium tracking-wide text-emerald-600">
              <span class="mr-1.5 h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
              Active
            </span>
            <% } else { %>
            <span class="inline-flex items-center rounded-lg border border-slate-200/60 bg-slate-50 px-2.5 py-1 text-[11px] font-medium tracking-wide text-slate-400">
              <span class="mr-1.5 h-1.5 w-1.5 rounded-full bg-slate-300"></span>
              Completed
            </span>
            <% } %>
          </div>
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-slate-100/70 pt-3.5 text-[12px] font-medium text-slate-400">
          <div>
            Tipe:
            <span class="ml-0.5 text-slate-600"><%= a.type %></span>
          </div>
          <div class="flex items-center">
            <span class="mr-4 hidden h-1 w-1 rounded-full bg-slate-200 sm:block"></span>
            Lokasi:
            <span class="ml-0.5 max-w-[120px] truncate text-slate-600 sm:max-w-none">
              <%= a.location || '-' %>
            </span>
          </div>
          <div class="flex items-center">
            <span class="mr-4 hidden h-1 w-1 rounded-full bg-slate-200 sm:block"></span>
            Durasi:
            <span class="ml-0.5 text-slate-600">
              <%= new Date(a.startDate).toLocaleDateString("id-ID", { day: 'numeric' , month:
              'short' }) %> - <%= new Date(a.endDate).toLocaleDateString("id-ID", { day: 'numeric' ,
              month: 'short' , year: 'numeric' }) %>
            </span>
          </div>
        </div>

        <% if(a.attachment) { %>
        <div class="mt-3.5 flex items-center justify-between border-t border-dashed border-slate-100 pt-3">
          <div class="inline-flex items-center gap-1.5 rounded-md border border-blue-100/60 bg-blue-50/50 px-2.5 py-0.5 text-[11px] font-medium text-blue-600">
            <svg class="h-3.5 w-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l4.5-4.5a4.5 4.5 0 011.243-0.88m6.364 6.364l-.001-.001m1.036-1.036a4.5 4.5 0 001.24-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364l4.5 4.5a4.5 4.5 0 001.242.88" />
            </svg>
            Surat Tugas Terlampir
          </div>

          <span class="flex items-center gap-1 text-[11px] text-slate-400 transition-colors group-hover:text-blue-500">
            Lihat Detail
            <svg class="h-3 w-3 transform transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </div>
        <% } %>
      </a>
      <% }) %>
    </div>
    <% } %> <% if (pagination.totalPages> 1) { %>
    <div class="mt-6 flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-5 py-4 text-[13px] antialiased shadow-sm">
      <div class="font-medium text-slate-500">
        Menampilkan halaman
        <span class="font-bold text-slate-900"><%= pagination.page %></span>
        dari
        <span class="font-bold text-slate-900"><%= pagination.totalPages %></span>
      </div>

      <div class="flex items-center gap-2">
        <a href="?page=<%= pagination.page - 1 %>" class="<%= pagination.hasPrev ? 'text-slate-700 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %> flex items-center gap-1.5 rounded-xl border border-slate-100 border-slate-200 bg-slate-50/50 bg-white px-4 py-2 font-bold transition-all hover:bg-slate-50 focus:ring-4 focus:ring-slate-100">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Prev
        </a>

        <a href="?page=<%= pagination.page + 1 %>" class="<%= pagination.hasNext ? 'text-slate-700 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %> flex items-center gap-1.5 rounded-xl border border-slate-100 border-slate-200 bg-slate-50/50 bg-white px-4 py-2 font-bold transition-all hover:bg-slate-50 focus:ring-4 focus:ring-slate-100">
          Next
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
    <% } %>
  </div>
</div>
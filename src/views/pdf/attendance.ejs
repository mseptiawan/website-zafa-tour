<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Rekapitulasi Absensi Pegawai</title>
  <style>
    @page {
      size: A4;
      margin: 20mm 15mm 20mm 15mm;
    }
    
    *, *::before, *::after {
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      color: #1e293b;
      background-color: #ffffff;
      line-height: 1.4;
    }

    .main-content {
      padding: 0;
    }

    .meta-container {
      width: 100%;
      margin-bottom: 20px;
      border-collapse: collapse;
    }

    .doc-title {
      font-size: 13pt;
      font-weight: bold;
      text-transform: uppercase;
      color: #1a365d;
      margin: 0;
      letter-spacing: 0.5px;
    }

    .stats-grid {
      width: 100%;
      border-collapse: separate;
      border-spacing: 12px 0;
      margin: 0 -12px 20px -12px;
    }

    .stats-card {
      width: 33.33%;
      border: 1px solid #1a365d;
      background-color: #f8fafc;
      padding: 10px 14px;
      border-radius: 4px;
    }

    .stats-label {
      font-size: 7.5pt;
      font-weight: bold;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stats-value {
      font-size: 11.5pt;
      font-weight: bold;
      color: #0f172a;
      margin-top: 2px;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 35px;
      font-size: 9pt;
    }

    .data-table th {
      background-color: #1a365d;
      color: #ffffff;
      font-weight: bold;
      text-transform: uppercase;
      font-size: 8.5pt;
      border: 1px solid #1a365d;
      padding: 10px 12px;
    }

    .data-table td {
      border: 1px solid #cbd5e1;
      padding: 10px 12px;
      color: #334155;
      vertical-align: middle;
    }

    .data-table tbody tr:nth-child(even) {
      background-color: #f8fafc;
    }

    .text-center { text-align: center; }
    .text-left { text-align: left; }
    .text-right { text-align: right; }
    .font-bold { font-weight: bold; }
    .font-mono { font-family: monospace; }
  </style>
</head>
<body>

  <!-- INCLUDE KOP SURAT TERPUSAT -->
  <%- include('../partials/pdf-header') %>

  <div class="main-content">
    
    <!-- METADATA DOKUMEN -->
    <table class="meta-container" style="margin-top: 15px;">
      <tr>
        <td>
          <h2 class="doc-title">Laporan Rekapitulasi Absensi Pegawai</h2>
          <p style="font-size: 9pt; color: #64748b; margin: 3px 0 0 0;">Periode Saring : <span class="font-bold"><%= filters.startDate %> s/d <%= filters.endDate %></span></p>
        </td>
        <td style="text-align: right; font-size: 9.5pt; color: #334155; vertical-align: bottom;">
          Tanggal Cetak: <span class="font-bold"><%= exportDate %></span>
        </td>
      </tr>
    </table>

    <!-- RINGKASAN METRIK ANALYTICS -->
    <table class="stats-grid">
      <tr>
        <td class="stats-card">
          <div class="stats-label">Total Presensi Sukses</div>
          <div class="stats-value"><%= analytics.totalHadir %> Rekor</div>
        </td>
        <td class="stats-card">
          <div class="stats-label">Total Kasus Terlambat</div>
          <div class="stats-value" style="color: #ea580c;"><%= analytics.totalLateDays %> Hari</div>
        </td>
        <td class="stats-card">
          <div class="stats-label">Akumulasi Menit Terlambat</div>
          <div class="stats-value" style="color: #dc2626;"><%= analytics.totalLateMinutes %> Menit</div>
        </td>
      </tr>
    </table>

    <!-- TABEL DATA REKAP ABSENSI -->
    <table class="data-table">
      <thead>
        <tr>
          <th style="width: 6%;" class="text-center">NO</th>
          <th style="width: 34%;" class="text-left">NAMA REKAN KERJA</th>
          <th style="width: 15%;" class="text-center">HADIR TEPAT WAKTU</th>
          <th style="width: 15%;" class="text-center">FREKUENSI TELAT</th>
          <th style="width: 15%;" class="text-right">DURASI TERLAMBAT</th>
          <th style="width: 15%;" class="text-center">JUMLAH ALPA</th>
        </tr>
      </thead>
      <tbody>
        <% if (summaryData && summaryData.length > 0) { %>
          <% summaryData.forEach((row, idx) => { %>
            <tr>
              <td class="text-center"><%= idx + 1 %></td>
              <td class="font-bold" style="color: #1a365d;"><%= row.name %></td>
              <td class="text-center"><%= row.hadir %> Hari</td>
              <td class="text-center" style="color: #ea580c; font-weight: 600;"><%= row.telat %> Kali</td>
              <td class="text-right font-mono" style="color: #dc2626;"><%= row.menitTelat %> Menit</td>
              <td class="text-center" style="color: #64748b;"><%= row.alpa %> Hari</td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center" style="padding: 20px; color: #94a3b8;">Tidak ada data log absensi dalam rentang tanggal ini.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <!-- SIGNATURE ZONE -->
    <table style="width: 100%; border-collapse: collapse; margin-top: 20px; page-break-inside: avoid;">
      <tr>
        <td style="font-size: 8pt; color: #94a3b8; font-style: italic; width: 55%; vertical-align: top; line-height: 1.5;">
          * Data rekapitulasi kehadiran ini diunduh secara digital langsung dari sistem administrasi Kantor Utama Palembang PT Zafa Mulia Mandiri.
        </td>
        <td style="text-align: right; width: 45%;">
          <div style="font-size: 9.5pt; color: #334155; margin-bottom: 65px;">
            Palembang, <%= exportDate %><br>
            <span class="font-bold" style="text-transform: uppercase; display: block; margin-top: 3px;">Manajer Administrasi / HRD</span>
          </div>
          <div style="font-weight: bold; color: #0f172a; border-top: 1.5px solid #0f172a; padding-top: 5px; display: inline-block; width: 190px; text-align: center; font-size: 9.5pt;">
            Verifikasi Aplikasi
          </div>
        </td>
      </tr>
    </table>

  </div>
</body>
</html>
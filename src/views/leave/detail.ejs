<%- layout('layouts/main', { title }) %>

<% 
  // LOGIKA UTAMA PENGECEKAN VIEW APPROVER
  isApproverView = approvals.some(app => {
    if (app.status !== 'PENDING') return false;
    if (app.step === 'HANDOVER') {
      return leave.handoverUserId && leave.handoverUserId._id && leave.handoverUserId._id.toString() === user._id.toString();
    }
    return (app.step || '').toUpperCase() === (user.role || '').toUpperCase();
  });

  const APPROVER_ROLES = ["MANAGER", "HR", "PIMPINAN", "GENERAL_MANAGER"];
  const isManagement = APPROVER_ROLES.includes((user.role || '').toUpperCase());
  const backLink = isManagement ? '/leave/manage-requests' : (isApproverView ? '/leave/my-delegations' : '/leave/my-history');
%>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50  sm:p-6 md:p-10 antialiased pb-32 md:pb-8">
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-6">

    <a href="<%= backLink %>" class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 transition-colors group select-none">
      <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Kembali</span>
    </a>

    <% if ((leave.status==='REJECTED' || leave.status==='CANCELED' || leave.status==='CANCELLED') && leave.userId && leave.userId._id.toString()===user._id.toString()) { %>
      <div class="border border-blue-100 bg-blue-50/30 rounded-2xl p-4 md:p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h2 class="text-sm font-semibold text-blue-900">Pengajuan Dihentikan</h2>
          <p class="text-[12px] md:text-[13px] text-blue-700/90 mt-0.5">
            Anda dapat melakukan penyesuaian data dan mengirim ulang berkas ini kembali.
          </p>
        </div>
        <a href="/leave/resubmit/<%= leave._id %>" class="inline-flex items-center justify-center h-9 px-4 bg-blue-600 text-white text-[13px] font-medium rounded-xl hover:bg-blue-700 transition shadow-xs active:scale-95 text-center shrink-0">
          Resubmit Pengajuan
        </a>
      </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 md:gap-6 items-start">

      <div class="lg:col-span-2 space-y-5 md:space-y-6 w-full">

        <div class="bg-white border border-slate-200/60 rounded-2xl overflow-hidden shadow-2xs">
          
          <div class="p-4 md:px-8 md:py-5 border-b border-slate-100 flex items-start justify-between gap-4 bg-white">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-200/50 flex items-center justify-center text-slate-400 shrink-0 hidden sm:flex">
                <i class="fa-solid fa-user-gear text-sm"></i>
              </div>
              <div class="min-w-0">
                <h1 class="text-[14px] md:text-[15px] font-semibold text-slate-900 tracking-tight truncate mb-1">
                  <%= (leave.userId && leave.userId.employeeData) ? leave.userId.employeeData.fullName : 'Detail Pengajuan Cuti' %>
                </h1>

                <p class="text-[10px] md:text-[11px] font-semibold text-slate-400 uppercase tracking-wider truncate">
                  Tujuan: 
                  <span class="<%= leave.status === 'CANCELLATION_PENDING' ? 'text-amber-600' : 'text-slate-700' %>">
                    <%= leave.status==='CANCELLATION_PENDING' ? 'Pembatalan Cuti' : 'Permohonan Cuti Baru' %>
                  </span>
                </p>

                <div class="flex flex-wrap items-center gap-x-2.5 gap-y-0.5 text-[10px] md:text-[11px] font-medium mt-1.5 text-slate-400">
                  <span class="truncate max-w-[140px] sm:max-w-none">
                    Unit: <span class="text-slate-600 font-semibold"><%= (leave.userId && leave.userId.employeeData && leave.careerData?.unitId?.name) ? leave.careerData.unitId.name : 'Umum' %></span>
                  </span>
                  <span>•</span>
                  <span class="tabular-nums">
                    Sisa Kuota: <span class="text-slate-600 font-semibold"><%= (leave.userId && leave.userId.leaveBalanceData) ? leave.userId.leaveBalanceData.remaining : '0' %> Hari</span>
                  </span>
                </div>
              </div>
            </div>

            <div>
              <span class="px-2.5 py-0.5 md:px-3 md:py-1 rounded-full font-bold text-[9.5px] md:text-[10px] uppercase tracking-wider border shrink-0 select-none
                <%= leave.status === 'PENDING' ? 'bg-amber-50 text-amber-700 border-amber-200/50'
                  : leave.status === 'CANCELLATION_PENDING' ? 'bg-orange-50 text-orange-700 border-orange-200/50'
                  : leave.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50'
                  : leave.status === 'REJECTED' ? 'bg-rose-50 text-rose-700 border-rose-200/50'
                  : 'bg-slate-50 text-slate-500 border-slate-200' %>">
                <%= leave.status==='CANCELLATION_PENDING' ? 'MINTA BATAL' : leave.status %>
              </span>
            </div>
          </div>

          <div class="p-4 md:p-8 space-y-6">
            <div class="grid grid-cols-2 gap-x-4 gap-y-5 md:gap-x-12 md:gap-y-6">
              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Tipe / Jenis Cuti</div>
                <div class="text-[13.5px] md:text-[15px] font-semibold text-slate-800"><%= leave.leaveTypeId?.name || '-' %></div>
              </div>

              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Total Durasi</div>
                <div class="text-[13.5px] md:text-[15px] font-bold text-slate-900 tabular-nums"><%= leave.totalDays %> Hari Kerja</div>
              </div>

              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Tanggal Mulai</div>
                <div class="text-[13.5px] md:text-[15px] font-semibold text-slate-800 tabular-nums">
                  <%= leave.startDate ? new Date(leave.startDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %>
                </div>
              </div>

              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Tanggal Selesai</div>
                <div class="text-[13.5px] md:text-[15px] font-semibold text-slate-800 tabular-nums">
                  <%= leave.endDate ? new Date(leave.endDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %>
                </div>
              </div>

              <div class="col-span-2 pt-1">
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Delegasi Tugas (Handover To)</div>
                <div class="text-[13px] md:text-[14px] font-medium text-slate-700 flex items-center gap-2">
                  <i class="fa-solid fa-handshake-angle text-slate-400 text-xs shrink-0"></i>
                  <span class="truncate font-semibold text-slate-800">
                    <%= (leave.handoverUserId && leave.handoverUserId.employeeData) ? leave.handoverUserId.employeeData.fullName : 'Tidak ada delegasi tugas' %>
                  </span>
                </div>
              </div>
            </div>

            <div class="bg-slate-50/60 rounded-xl p-3.5 border border-slate-200/40">
              <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Alasan / Kepentingan Cuti</span>
              <p class="text-[12px] text-slate-600 leading-relaxed italic whitespace-pre-line break-words">
                "<%= leave.reason || '-' %>"
              </p>
            </div>

            <div class="pt-5 border-t border-slate-100">
              <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-2.5">Lampiran Dokumen Pendukung</div>
              <% if (leave.documentPath) { %>
                <div class="flex items-center justify-between border border-slate-200/60 rounded-xl p-2.5 bg-slate-50/30 hover:border-slate-300 transition-colors">
                  <div class="flex items-center gap-2.5 min-w-0">
                    <div class="w-7 h-7 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-400 shrink-0">
                      <i class="fa-solid fa-file-pdf text-[11px]"></i>
                    </div>
                    <span class="text-[11.5px] font-semibold text-slate-700 truncate">Berkas_Lampiran_Cuti.pdf</span>
                  </div>
                  <a href="<%= leave.documentPath %>" target="_blank" class="text-[9.5px] font-bold text-blue-600 bg-blue-50 border border-blue-100 px-2.5 py-1.5 rounded-lg shrink-0 transition-all active:scale-95">VIEW</a>
                </div>
              <% } else { %>
                <div class="flex flex-col items-center justify-center p-5 rounded-xl bg-slate-50/40 border border-slate-200/40 text-center">
                  <i class="fa-solid fa-file-circle-xmark text-slate-300 text-lg mb-1.5"></i>
                  <p class="text-[11px] font-medium text-slate-400">Tidak ada lampiran berkas pendukung</p>
                </div>
              <% } %>
            </div>

          </div>
        </div>

        <% 
          const activeApproval = approvals.find(app => {
            if (app.status !== 'PENDING') return false;
            if (app.step === 'HANDOVER') {
              return leave.handoverUserId && leave.handoverUserId._id && leave.handoverUserId._id.toString() === user._id.toString();
            }
            return (app.step || '').toUpperCase() === (user.role || '').toUpperCase();
          });
        %>

        <% if (activeApproval) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 md:p-6 shadow-2xs">
            <h3 class="text-sm font-semibold text-slate-800 mb-4 flex items-center gap-3 select-none">
              <div class="w-8.5 h-8.5 rounded-xl <%= leave.status === 'CANCELLATION_PENDING' ? 'bg-orange-50 text-orange-600' : 'bg-blue-50 text-blue-600' %> flex items-center justify-center text-xs shrink-0">
                <i class="fa-solid fa-check-double"></i>
              </div>
              <div class="min-w-0">
                <div class="text-[13.5px] font-bold text-slate-900 leading-tight">
                  <%= leave.status==='CANCELLATION_PENDING' ? 'Tinjauan Pembatalan Cuti' : 'Evaluasi & Otorisasi Cuti' %>
                </div>
                <div class="text-[10.5px] font-medium text-slate-400 mt-0.5">
                  Bertindak selaku: <span class="font-bold text-slate-500"><%= activeApproval.step %></span>
                </div>
              </div>
            </h3>

            <textarea id="reviewNote" name="note" rows="3" 
              placeholder="<%= leave.status === 'CANCELLATION_PENDING' ? 'Masukkan alasan mengevaluasi permohonan pembatalan...' : 'Masukkan catatan evaluasi keputusan Anda di sini...' %>" 
              class="w-full text-[13px] text-slate-700 bg-slate-50 border border-slate-200 rounded-xl p-3.5 mb-4 focus:ring-4 focus:ring-blue-500/5 focus:border-blue-500 outline-none transition-all resize-none focus:bg-white" 
              oninput="document.querySelectorAll('.sync-note').forEach(input => input.value = this.value)"></textarea>

            <div class="flex items-center justify-end gap-2.5 w-full">
              <% 
                const approveUrl = activeApproval.step==='HANDOVER' ? `/leave/delegation/approve/${activeApproval._id}` : `/leave/approval/approve/${activeApproval._id}`; 
                const rejectUrl = activeApproval.step==='HANDOVER' ? `/leave/delegation/reject/${activeApproval._id}` : `/leave/approval/reject/${activeApproval._id}`; 
              %>

              <form action="<%= rejectUrl %>" method="POST" class="inline m-0">
                <input type="hidden" name="note" class="sync-note" value="">
                <button type="submit" class="h-9 px-4 border border-slate-200 bg-white text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-50 transition-all active:scale-[0.97] cursor-pointer">
                  <%= leave.status==='CANCELLATION_PENDING' ? 'Tolak Pembatalan' : 'Tolak' %>
                </button>
              </form>

              <form action="<%= approveUrl %>" method="POST" class="inline m-0">
                <input type="hidden" name="note" class="sync-note" value="">
                <button type="submit" class="h-9 px-4 bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold rounded-xl transition-all active:scale-[0.97] cursor-pointer">
                  <%= leave.status==='CANCELLATION_PENDING' ? 'Setujui Batal' : 'Terima' %>
                </button>
              </form>
            </div>
          </div>
        <% } %>

      </div>

      <div class="bg-white border border-slate-200/60 rounded-2xl p-4 md:p-6 shadow-2xs lg:col-span-1 w-full">
        <div class="mb-6 select-none">
          <h2 class="text-[13.5px] font-bold text-slate-900 tracking-tight">Jejak Log Pemeriksaan</h2>
          <p class="text-[11px] text-slate-400 mt-0.5">Alur dan birokrasi persetujuan berkas</p>
        </div>

        <div class="relative pl-5 space-y-6 before:absolute before:left-[9px] before:top-2 before:bottom-2 before:w-[1.5px] before:bg-slate-100">
          <% approvals.forEach((app, index) => { %>
            <div class="relative group text-[12.5px]">
              
              <div class="absolute -left-[23px] top-0 w-5 h-5 rounded-full border-4 border-white flex items-center justify-center transition-colors select-none text-white text-[8px] font-bold
                <%= app.status === 'APPROVED' ? 'bg-emerald-500' : app.status === 'REJECTED' ? 'bg-rose-500' : 'bg-amber-400' %>">
                <%= index + 1 %>
              </div>

              <div class="flex flex-col gap-1">
                <div class="flex items-center justify-between gap-2">
                  <span class="text-[11px] font-bold text-slate-800 tracking-wide uppercase"><%= app.step %></span>
                  <span class="text-[9px] font-bold px-2 py-0.5 rounded-full uppercase border shrink-0
                    <%= app.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50' 
                      : app.status === 'REJECTED' ? 'bg-rose-50 text-rose-700 border-rose-200/50' 
                      : 'bg-amber-50 text-amber-700 border-amber-200/50' %>">
                    <%= app.status %>
                  </span>
                </div>

                <div class="flex flex-wrap items-center gap-x-1.5 text-[11px] text-slate-400 font-medium">
                  <span class="text-slate-600 font-semibold truncate max-w-[120px] sm:max-w-none">
                    <%= (app.approverId && app.approverId.employeeData) ? app.approverId.employeeData.fullName.split(' ')[0] : 'Sistem' %>
                  </span>
                  <span>|</span>
                  <span class="tabular-nums">
                    <%= app.actionDate ? new Date(app.actionDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) + ' ' + new Date(app.actionDate).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) : 'Menunggu' %>
                  </span>
                </div>

                <% if (app.note) { %>
                  <div class="mt-1.5 text-[11.5px] text-slate-600 bg-slate-50 border border-slate-100 p-2.5 rounded-lg leading-relaxed italic break-words">
                    "<%= app.note %>"
                  </div>
                <% } %>
              </div>

            </div>
          <% }) %>
        </div>
      </div>

    </div>

  </div>
</div>
<%- layout('layouts/main', { title: 'Ajukan Klaim Beban' }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    <div class="max-w-2xl mx-auto">

      <div class="mb-8">
        <nav class="flex items-center gap-2 mb-2 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
          <span>Area Kerja</span>
          <span class="text-slate-300">/</span>
          <span class="text-slate-900">Beban</span>
        </nav>
        <h1 class="text-2xl font-bold text-slate-900">Ajukan Klaim Beban</h1>
        <p class="text-slate-500 mt-1 text-sm">Input pengeluaran operasional dan lampirkan bukti transaksi</p>
      </div>

      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">
        <form action="/expense/create" method="POST" enctype="multipart/form-data" class="p-8 space-y-6">

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Judul Pengeluaran</label>
            <input type="text" name="title" required placeholder="Contoh: Bensin Perjalanan Dinas"
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[13px] font-bold text-slate-700">Kategori</label>
              <select name="category" required
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 transition-all">
                <option value="" disabled selected>Pilih Kategori</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat.code %>"><%= cat.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="text-[13px] font-bold text-slate-700">Tanggal Transaksi</label>
              <input type="date" name="expenseDate" required
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 transition-all" />
            </div>
          </div>

        <div class="space-y-1.5">
  <label class="text-[13px] font-bold text-slate-700">Nominal</label>
  <input type="text" id="nominalInput" required placeholder="0"
    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 transition-all" />
  
  <input type="hidden" name="amount" id="amountReal" />
</div>

          <div id="fileSection" class="space-y-1.5 transition-opacity duration-300">
            <label class="text-[13px] font-bold text-slate-700">Bukti Transaksi</label>

            <div id="dropzone-empty"
              class="relative w-full border border-slate-200 border-dashed rounded-xl p-6 bg-white hover:bg-slate-50/50 transition flex flex-col items-center justify-center text-center cursor-pointer">
              <input type="file" name="proofFile" id="file-input"
                class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="handleFileSelect(this)" />
              <svg class="w-5 h-5 text-slate-400 mb-2" fill="none" stroke="currentColor" stroke-width="1.5"
                viewBox="0 0 24 24">
                <path
                  d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
              </svg>
              <span class="text-[13px] font-medium text-slate-600">Pilih Berkas atau Drop File</span>
            </div>

            <div id="dropzone-filled"
              class="hidden flex items-center justify-between border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-sm">
              <div class="text-[13px] font-medium text-slate-700" id="name-preview">file.jpg</div>
              <button type="button" onclick="resetFile()" class="text-xs text-rose-600 font-medium">Ganti</button>
            </div>
          </div>

          <label class="flex items-center gap-3 bg-slate-50 border border-slate-100 p-4 rounded-xl cursor-pointer">
            <input type="checkbox" id="noReceipt" name="noReceipt" onchange="toggleReceiptMode()"
              class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
            <span class="text-[13px] font-medium text-slate-600">Tidak ada bukti transaksi (Self Declaration)</span>
          </label>

          <div id="extraSections" class="hidden space-y-4">
            <div class="space-y-1.5">
              <label class="text-[13px] font-bold text-slate-700">Alasan Tidak Ada Bukti</label>
              <textarea name="noReceiptReason" rows="2"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs outline-none focus:bg-white"></textarea>
            </div>

            <label class="flex items-start gap-3 bg-blue-50/50 border border-blue-100 p-4 rounded-xl">
              <input type="checkbox" name="selfDeclaration"
                class="mt-0.5 w-4 h-4 rounded border-slate-300 text-blue-600" />
              <div>
                <p class="text-[13px] font-bold text-slate-800">Pernyataan Pengajuan</p>
                <p class="text-[11px] text-slate-500">Saya menyatakan pengeluaran ini benar dan dapat
                  dipertanggungjawabkan.</p>
              </div>
            </label>
          </div>

          <div class="pt-6 border-t border-slate-100 flex justify-end gap-3">
            <button type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50">Submit
              Klaim</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    function toggleReceiptMode() {
      const isChecked = document.getElementById("noReceipt").checked;
      const fileSection = document.getElementById("fileSection");
      const extraSections = document.getElementById("extraSections");
      const fileInput = document.getElementById("file-input");

      if (isChecked) {
        fileSection.style.opacity = "0.3";
        fileInput.disabled = true;
        extraSections.classList.remove("hidden");
      } else {
        fileSection.style.opacity = "1";
        fileInput.disabled = false;
        extraSections.classList.add("hidden");
      }
    }

    function handleFileSelect(input) {
      if (input.files.length > 0) {
        document.getElementById("name-preview").textContent = input.files[0].name;
        document.getElementById("dropzone-empty").classList.add("hidden");
        document.getElementById("dropzone-filled").classList.remove("hidden");
      }
    }

    function resetFile() {
      document.getElementById("file-input").value = "";
      document.getElementById("dropzone-empty").classList.remove("hidden");
      document.getElementById("dropzone-filled").classList.add("hidden");
    }

    document.addEventListener("DOMContentLoaded", () => {
      const nominalInput = document.getElementById("nominalInput");
      const amountReal = document.getElementById("amountReal");

      if (nominalInput && amountReal) {
        nominalInput.addEventListener("input", function (e) {
          let value = this.value.replace(/[^0-9]/g, "");
          
          amountReal.value = value;

          if (value) {
            this.value = formatRupiah(value);
          } else {
            this.value = "";
          }
        });
      }

      function formatRupiah(angka) {
        return angka.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      }
    });
  </script>
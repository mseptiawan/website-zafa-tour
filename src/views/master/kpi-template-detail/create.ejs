<%- layout('layouts/main', { title: title }) %>

<div class="max-w-xl mx-auto py-4 md:py-8">
  <div class="bg-white rounded-2xl border border-slate-200/60 overflow-hidden transform transition-all duration-200">
    
    <div class="p-5 space-y-4 border-b border-slate-100">
      <div class="flex items-center gap-2.5 text-blue-600">
        <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center text-xs">
          <i class="fa-solid fa-square-plus"></i>
        </div>
        <h3 class="text-sm font-semibold text-slate-800">Form Tambah KPI</h3>
      </div>
      <p class="text-xs text-slate-500 leading-relaxed">
        Tambahkan butir indikator kinerja baru ke dalam struktur template penilaian standar ini.
      </p>
    </div>

    <div class="p-6">
      <form action="/master/kpi-template/<%= templateId %>/details" method="POST" class="space-y-4">
        
        <div>
          <label for="areaKinerja" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Area Kinerja</label>
          <input type="text" id="areaKinerja" name="areaKinerja" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" placeholder="Contoh: Penerusan Informasi" required>
        </div>

        <div>
          <label for="indikator" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Indikator KPI</label>
          <textarea id="indikator" name="indikator" rows="3" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" placeholder="Contoh: Ketepatan meneruskan informasi ke unit terkait" required></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="bobot" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Bobot (%)</label>
            <input type="number" id="bobot" name="bobot" min="1" max="100" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" placeholder="25" required>
          </div>
          <div>
            <label for="target" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Target</label>
            <input type="text" id="target" name="target" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" placeholder="Contoh: 95% atau 2 Jam" required>
          </div>
        </div>

        <div>
          <label for="order" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Urutan Tampilan (Order)</label>
          <input type="number" id="order" name="order" value="1" min="1" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700">
          <p class="mt-1.5 text-[11px] text-slate-400 italic">Menentukan prioritas urutan baris saat form penilaian diisi oleh atasan.</p>
        </div>

        <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
          <a href="/master/kpi-template/<%= templateId %>/details" class="inline-flex items-center justify-center h-8.5 px-3.5 border border-slate-200 text-slate-600 text-xs font-semibold rounded-xl hover:bg-slate-50 transition-colors">
            Kembali
          </a>
          <button type="submit" class="inline-flex items-center justify-center h-8.5 px-4 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold rounded-xl transition-all cursor-pointer">
            Simpan Indikator
          </button>
        </div>

      </form>
    </div>
  </div>
</div>
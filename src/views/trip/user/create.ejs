<%- layout('layouts/main', { title: 'Ajukan Reimbursement' }) %>

<div class="overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0 space-y-5">

    <div class="mb-5 border-b border-slate-200/60 pb-5">
      <%- include('../../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Dinas Luar', 
          title: 'Pengajuan Dinas Luar', 
          description: 'Form pengajuan perjalanan dinas operasional resmi perusahaan.' 
      }) %>
    </div>

    <div class="bg-white border-0 md:border md:border-slate-200/60 rounded-2xl shadow-3xs overflow-hidden max-w-2xl">
      <form action="/trip/" method="POST" class="p-4 sm:p-6 md:p-8 space-y-5">

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Judul Perjalanan
          </label>
          <input type="text" name="title" placeholder="Masukkan judul agenda perjalanan..." minlength="5" maxlength="100" required
            class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs" />
        </div>

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Tujuan Perjalanan
          </label>

          <div class="relative w-full" id="custom-dropdown">
            <input type="hidden" name="purpose" id="purpose-value" required>

            <button type="button" onclick="toggleDropdown()"
              class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 text-left flex items-center justify-between outline-none focus:bg-white focus:border-slate-400 transition-colors cursor-pointer shadow-3xs">
              <span id="dropdown-label" class="text-slate-400 font-normal italic">Pilih tujuan perjalanan</span>
              <svg id="dropdown-arrow" class="w-3.5 h-3.5 text-slate-400 stroke-[2.5] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <div id="dropdown-menu" class="hidden absolute z-30 w-full mt-1.5 bg-white border border-slate-200/80 rounded-xl shadow-md p-1 space-y-0.5 backdrop-blur-sm">
              <button type="button" onclick="selectOption('KUNJUNGAN_SALES', 'Kunjungan Sales')" class="w-full text-left px-3 py-2.5 text-[12px] font-semibold text-slate-700 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors cursor-pointer">
                <span>Kunjungan Sales</span>
                <span class="w-1.5 h-1.5 rounded-full bg-slate-900 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
              <button type="button" onclick="selectOption('RAPAT', 'Rapat / Meeting')" class="w-full text-left px-3 py-2.5 text-[12px] font-semibold text-slate-700 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors cursor-pointer">
                <span>Rapat / Meeting</span>
                <span class="w-1.5 h-1.5 rounded-full bg-slate-900 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
              <button type="button" onclick="selectOption('PELATIHAN', 'Pelatihan / Training')" class="w-full text-left px-3 py-2.5 text-[12px] font-semibold text-slate-700 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors cursor-pointer">
                <span>Pelatihan / Training</span>
                <span class="w-1.5 h-1.5 rounded-full bg-slate-900 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
              <button type="button" onclick="selectOption('SURVEI', 'Survei Lapangan')" class="w-full text-left px-3 py-2.5 text-[12px] font-semibold text-slate-700 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors cursor-pointer">
                <span>Survei Lapangan</span>
                <span class="w-1.5 h-1.5 rounded-full bg-slate-900 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
              <button type="button" onclick="selectOption('LAINNYA', 'Lainnya')" class="w-full text-left px-3 py-2.5 text-[12px] font-semibold text-slate-700 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors cursor-pointer">
                <span>Lainnya</span>
                <span class="w-1.5 h-1.5 rounded-full bg-slate-900 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
              Tanggal Mulai
            </label>
            <input type="date" name="startDate" required
              class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs cursor-pointer" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
              Tanggal Selesai
            </label>
            <input type="date" name="endDate" required
              class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs cursor-pointer" />
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Tujuan / Lokasi
          </label>
          <input type="text" name="destination" placeholder="Masukkan kota atau nama instansi tujuan..." minlength="3" maxlength="150" required
            class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs" />
        </div>

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Deskripsi Kegiatan
          </label>
          <textarea name="description" rows="4" minlength="10" maxlength="1000" required placeholder="Jelaskan detail agenda dan target operasional perjalanan dinas Anda..."
            class="w-full bg-slate-50 border border-slate-200/80 rounded-xl px-4 py-3 text-[12.5px] font-medium text-slate-800 outline-none resize-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs"></textarea>
        </div>

        <div class="space-y-3.5 pt-2" id="budget-section">
          <div class="flex items-center justify-between select-none">
            <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
              Rincian Anggaran Kunjungan
            </label>
            <button type="button" id="add-budget-item" class="inline-flex items-center gap-1 text-[11px] font-semibold text-slate-700 hover:text-black transition-colors outline-none cursor-pointer">
              <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Tambah Item
            </button>
          </div>

          <div id="budget-items-container" class="space-y-2.5">
            <div class="budget-item bg-slate-50/50 border border-slate-200/60 rounded-xl p-3.5 space-y-2 relative group/item">
              <div class="grid grid-cols-12 gap-2.5">
                <div class="col-span-7">
                  <input type="text" name="budget[items][0][title]" placeholder="Nama pengeluaran (misal: Bensin & Tol)" required
                    class="w-full h-9 bg-white border border-slate-200 rounded-lg text-[11.5px] font-semibold px-3 text-slate-800 outline-none focus:border-slate-400 transition-colors shadow-3xs" />
                </div>
                <div class="col-span-5 pr-7">
                  <input type="text" placeholder="Rp 0" oninput="formatCurrency(this)"
                    class="budget-amount-display w-full h-9 bg-white border border-slate-200 rounded-lg text-[11.5px] font-semibold px-3 text-slate-800 text-right outline-none focus:border-slate-400 transition-colors shadow-3xs tabular-nums" />
                  <input type="hidden" name="budget[items][0][allocatedAmount]" class="budget-amount-raw" value="0" />
                </div>
              </div>
              <div>
                <input type="text" name="budget[items][0][description]" placeholder="Keterangan opsional..."
                  class="w-full h-8 bg-white border border-slate-200 rounded-lg text-[11px] font-medium px-3 text-slate-400 placeholder-slate-400/70 outline-none focus:border-slate-400 transition-colors shadow-3xs" />
              </div>
              <button type="button" onclick="removeBudgetItem(this)" class="delete-budget-btn absolute top-3.5 right-3 text-slate-300 hover:text-rose-600 transition-colors hidden cursor-pointer">
                <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-16v1a3 3 0 003 3h10M9 7h6" />
                </svg>
              </button>
            </div>
          </div>

          <div class="flex justify-between items-center bg-slate-50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-[11.5px] select-none shadow-3xs">
            <span class="font-semibold text-slate-400 uppercase tracking-wider text-[10px]">Estimasi Total Anggaran:</span>
            <span id="budget-total-display" class="font-semibold text-slate-800 tabular-nums text-[12.5px]">Rp 0</span>
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Bertemu dengan (Klien / PIC)
          </label>
          <input type="text" name="meetWith" placeholder="Contoh: M Septiawan" required
            class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs" />
        </div>

        <div class="space-y-4 pt-1">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide block select-none">
            Timeline Rute Perjalanan
          </label>

          <div class="relative pl-7 space-y-4 before:absolute before:left-[9px] before:top-3 before:bottom-3 before:w-[1.5px] before:bg-slate-200/60">
            <div id="timelineBox" class="space-y-3.5">
              <div class="relative flex gap-3 items-center timeline-item group">
                <div class="absolute -left-[22px] flex items-center justify-center w-2 h-2 rounded-full bg-slate-900 ring-4 ring-slate-100 z-10 transition-all duration-200"></div>
                
                <input type="text" name="timeline[0][address]" placeholder="Lokasi keberangkatan / alamat titik awal..." required
                  class="flex-1 h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs" />

                <input type="hidden" name="timeline[0][order]" value="1" />

                <button type="button" onclick="removeTimeline(this)"
                  class="px-2.5 h-9 rounded-xl bg-slate-50 text-slate-400 border border-slate-200/40 hover:bg-rose-50 hover:text-rose-600 border hover:border-rose-200/40 transition-all opacity-0 group-hover:opacity-100 focus:opacity-100 cursor-pointer shadow-3xs">
                  <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            </div>

            <div class="relative flex items-center pt-1 select-none">
              <div class="absolute -left-[26px] flex items-center justify-center w-4 h-4 rounded-full bg-white border border-slate-200 text-slate-400 z-10 shadow-3xs">
                <svg class="w-2.5 h-2.5 stroke-[3]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
              </div>
              <button type="button" onclick="addTimeline()" 
                class="text-[11.5px] font-semibold text-slate-400 hover:text-slate-800 transition-colors pl-1.5 cursor-pointer focus:outline-none">
                Tambah destinasi kunjungan berikutnya...
              </button>
            </div>
          </div>
        </div>

        <div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-2.5">
          <a href="/trip/my" class="inline-flex items-center justify-center h-9 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 rounded-xl px-5 text-[11.5px] font-semibold transition-all active:scale-[0.99]">
            Batal
          </a>
          <button type="submit" class="bg-blue-600 text-white h-9 px-6 rounded-xl text-[11.5px] font-semibold transition-all active:scale-[0.99] cursor-pointer shadow-3xs outline-none">
            <%= typeof mode !== 'undefined' ? (mode === 'CREATE' ? 'Ajukan Perjalanan' : (mode === 'EDIT' ? 'Simpan Perubahan' : 'Kirim Ulang Form')) : 'Ajukan Perjalanan' %>
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
  let timelineIndex = 1;    
  let budgetItemIndex = 1;  

  function formatCurrency(input) {
    let value = input.value.replace(/\D/g, ""); 
    let rawInput = input.closest('.col-span-5').querySelector('.budget-amount-raw');
    rawInput.value = value; 

    if (!value) {
      input.value = "";
      calculateTotalBudget();
      return;
    }

    input.value = "Rp " + Number(value).toLocaleString("id-ID");
    calculateTotalBudget();
  }

  function calculateTotalBudget() {
    let total = 0;
    document.querySelectorAll('.budget-amount-raw').forEach(input => {
      total += Number(input.value || 0);
    });
    document.getElementById('budget-total-display').innerText = 'Rp ' + total.toLocaleString('id-ID');
  }

  document.getElementById('add-budget-item').addEventListener('click', function() {
    const container = document.getElementById('budget-items-container');
    const newItem = document.createElement('div');
    newItem.className = 'budget-item bg-slate-50/50 border border-slate-200/60 rounded-xl p-3.5 space-y-2 relative group/item shadow-3xs';
    newItem.innerHTML = `
      <div class="grid grid-cols-12 gap-2.5">
        <div class="col-span-7">
          <input type="text" name="budget[items][${budgetItemIndex}][title]" placeholder="Nama pengeluaran..." required
            class="w-full h-9 bg-white border border-slate-200 rounded-lg text-[11.5px] font-semibold px-3 text-slate-800 outline-none focus:border-slate-400 transition-colors shadow-3xs" />
        </div>
        <div class="col-span-5 pr-7">
          <input type="text" placeholder="Rp 0" oninput="formatCurrency(this)"
            class="budget-amount-display w-full h-9 bg-white border border-slate-200 rounded-lg text-[11.5px] font-semibold px-3 text-slate-800 text-right outline-none focus:border-slate-400 transition-colors shadow-3xs tabular-nums" />
          <input type="hidden" name="budget[items][${budgetItemIndex}][allocatedAmount]" class="budget-amount-raw" value="0" />
        </div>
      </div>
      <div>
        <input type="text" name="budget[items][${budgetItemIndex}][description]" placeholder="Keterangan opsional..."
          class="w-full h-8 bg-white border border-slate-200 rounded-lg text-[11px] font-medium px-3 text-slate-400 placeholder-slate-400/70 outline-none focus:border-slate-400 transition-colors shadow-3xs" />
      </div>
      <button type="button" onclick="removeBudgetItem(this)" class="delete-budget-btn absolute top-3.5 right-3 text-slate-300 hover:text-rose-600 transition-colors cursor-pointer">
        <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-16v1a3 3 0 003 3h10M9 7h6" />
        </svg>
      </button>
    `;
    
    container.appendChild(newItem);
    budgetItemIndex++;
    toggleDeleteButtons();
  });

  function removeBudgetItem(button) {
    const itemRow = button.closest('.budget-item');
    itemRow.remove();
    reIndexItems();
    calculateTotalBudget();
    toggleDeleteButtons();
  }

  function toggleDeleteButtons() {
    const rows = document.querySelectorAll('.budget-item');
    rows.forEach(row => {
      const btn = row.querySelector('.delete-budget-btn');
      if (rows.length === 1) {
        btn.classList.add('hidden');
      } else {
        btn.classList.remove('hidden');
      }
    });
  }

  function reIndexItems() {
    const rows = document.querySelectorAll('.budget-item');
    budgetItemIndex = 0;
    rows.forEach((row, idx) => {
      row.querySelector('input[name*="[title]"]').setAttribute('name', `budget[items][${idx}][title]`);
      row.querySelector('input[class*="budget-amount-raw"]').setAttribute('name', `budget[items][${idx}][allocatedAmount]`);
      row.querySelector('input[name*="[description]"]').setAttribute('name', `budget[items][${idx}][description]`);
      budgetItemIndex = idx + 1;
    });
  }

  function addTimeline() {
    const box = document.getElementById("timelineBox");
    const div = document.createElement("div");
    div.className = "relative flex gap-3 items-center timeline-item group animate-fadeIn";

    div.innerHTML = `
      <div class="absolute -left-[22px] flex items-center justify-center w-2 h-2 rounded-full bg-slate-300 ring-4 ring-slate-50 z-10 group-hover:bg-slate-800 transition-all duration-200"></div>
      
      <input type="text"
        name="timeline[${timelineIndex}][address]"
        placeholder="Alamat tujuan berikutnya..."
        required
        class="flex-1 h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs" />

      <input type="hidden"
        name="timeline[${timelineIndex}][order]"
        value="${timelineIndex + 1}" />

      <button type="button"
        onclick="removeTimeline(this)"
        class="px-2.5 h-9 rounded-xl bg-slate-50 text-slate-400 border border-slate-200/40 hover:bg-rose-50 hover:text-rose-600 border hover:border-rose-200/40 transition-all opacity-0 group-hover:opacity-100 focus:opacity-100 cursor-pointer shadow-3xs">
        <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    `;

    box.appendChild(div);
    timelineIndex++;
  }

  function removeTimeline(btn) {
    btn.parentElement.remove();
  }

  function toggleDropdown() {
    const menu = document.getElementById('dropdown-menu');
    const arrow = document.getElementById('dropdown-arrow');

    if (menu.classList.contains('hidden')) {
      menu.classList.remove('hidden');
      setTimeout(() => {
        menu.classList.remove('opacity-0', 'scale-95');
        menu.classList.add('opacity-100', 'scale-100');
      }, 10);
      arrow.classList.add('rotate-180');
    } else {
      closeDropdown();
    }
  }

  function closeDropdown() {
    const menu = document.getElementById('dropdown-menu');
    const arrow = document.getElementById('dropdown-arrow');

    menu.classList.remove('opacity-100', 'scale-100');
    menu.classList.add('opacity-0', 'scale-95');
    arrow.classList.remove('rotate-180');

    setTimeout(() => {
      menu.classList.add('hidden');
    }, 150);
  }

  function selectOption(value, label) {
    document.getElementById('purpose-value').value = value;
    const labelEl = document.getElementById('dropdown-label');
    labelEl.textContent = label;
    labelEl.classList.remove('text-slate-400', 'font-normal', 'italic');
    labelEl.classList.add('text-slate-800', 'font-semibold');
    closeDropdown();
  }

  window.addEventListener('click', function (e) {
    const dropdown = document.getElementById('custom-dropdown');
    if (dropdown && !dropdown.contains(e.target)) {
      closeDropdown();
    }
  });
</script>
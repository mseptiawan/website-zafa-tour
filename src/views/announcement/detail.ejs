<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-[#F8FAFC] p-8 antialiased">
  <div class="max-w-4xl mx-auto">
    
    <!-- Navigation Back -->
    <a href="/announcement" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-800 mb-6 transition-colors group">
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Kembali ke Daftar
    </a>

    <!-- MAIN CARD -->
    <div class="bg-white border border-slate-200/60 rounded-3xl shadow-sm overflow-hidden">
      
      <!-- HEADER SECTION -->
      <div class="px-8 py-8 border-b border-slate-50">
        <div class="flex flex-col gap-4">
          
          <!-- Badges -->
          <div class="flex items-center gap-2">
            <% if(announcement.category === "OFFICIAL") { %>
              <span class="bg-rose-50 text-rose-600 border border-rose-100 px-3 py-1 rounded-lg text-[10px] font-bold tracking-wider uppercase">
                Pengumuman Resmi
              </span>
            <% } else { %>
              <span class="bg-slate-100 text-slate-600 border border-slate-200 px-3 py-1 rounded-lg text-[10px] font-bold tracking-wider uppercase">
                Pengumuman Ringan
              </span>
            <% } %>

            <% if(announcement.isPinned) { %>
              <span class="bg-amber-50 text-amber-600 border border-amber-100 px-3 py-1 rounded-lg text-[10px] font-bold tracking-wider uppercase flex items-center gap-1">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 4a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 18V4z"/></svg>
                Disematkan
              </span>
            <% } %>
          </div>

          <!-- Title -->
         <h1 class="text-3xl font-extrabold text-slate-900 leading-tight tracking-tight break-words">
  <%= announcement.title %>
</h1>

          <!-- Meta Info -->
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-[11px] font-bold text-slate-500 uppercase">
              <%= announcement.createdBy?.username ? announcement.createdBy.username.charAt(0) : '?' %>
            </div>
            <div class="flex flex-col">
              <span class="text-[13px] font-bold text-slate-800 leading-none mb-1">
                <%= announcement.createdBy?.username || 'Unknown' %>
              </span>
              <span class="text-[11px] text-slate-400 font-medium">
                Diterbitkan pada <%= new Date(announcement.createdAt).toLocaleDateString("id-ID", { day: "2-digit", month: "long", year: "numeric" }) %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- CONTENT SECTION -->
      <div class="px-8 py-10">
        <article class="text-[16px] text-slate-700 leading-[1.8] whitespace-pre-line font-normal italic-none">
          <%= announcement.content %>
        </article>

       <!-- ATTACHMENT DISPLAY -->
<% if(announcement.attachment) { %>
  <div class="mt-12 space-y-4">
    <h3 class="text-sm font-bold text-slate-900 flex items-center gap-2">
      <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
      Lampiran Dokumen
    </h3>

    <div class="group border border-slate-200 rounded-2xl overflow-hidden bg-slate-50 transition-all hover:border-slate-300 shadow-sm">
      
      <!-- IF IMAGE: Fixed Preview with Object Contain -->
      <% if (announcement.attachment.match(/\.(jpg|jpeg|png|gif|webp)$/i)) { %>
        <div class="w-full bg-slate-100 flex items-center justify-center p-4">
          <div class="relative w-full max-w-full overflow-hidden rounded-xl border border-slate-200 bg-white shadow-inner">
            <img 
              src="/uploads/files/<%= announcement.attachment %>" 
              class="w-full h-auto max-h-[500px] object-contain block mx-auto transition-transform duration-500 group-hover:scale-[1.02]" 
              alt="Preview Lampiran"
            >
          </div>
        </div>
      <% } %>

      <!-- Attachment Info Bar -->
      <div class="p-5 flex items-center justify-between bg-white border-t border-slate-100">
        <div class="flex items-center gap-4 min-w-0">
          <div class="p-2.5 bg-indigo-50 rounded-xl text-indigo-600 flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-slate-800 truncate">
              <%= announcement.attachment %>
            </p>
            <p class="text-[11px] text-slate-400 font-medium">Klik tombol untuk mengunduh atau melihat dokumen penuh</p>
          </div>
        </div>

        <a
          href="/uploads/files/<%= announcement.attachment %>"
          target="_blank"
          class="bg-slate-900 hover:bg-black text-white px-6 py-2.5 rounded-xl text-[13px] font-bold transition-all flex items-center gap-2 flex-shrink-0 ml-4 shadow-lg shadow-slate-100"
        >
          Lihat File
        </a>
      </div>
    </div>
  </div>
<% } %>

        <!-- ACTION: PUBLISH (DRAFT ONLY) -->
        <% if(announcement.category === "OFFICIAL" && announcement.status === "DRAFT") { %>
          <div class="mt-12 pt-8 border-t border-slate-100">
            <div class="bg-indigo-50 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-4 border border-indigo-100">
              <div>
                <h4 class="text-indigo-900 font-bold text-sm">Status: Draft (Belum Publik)</h4>
                <p class="text-indigo-600/80 text-[12px] mt-0.5">Pengumuman resmi ini perlu konfirmasi publikasi agar dapat dilihat seluruh karyawan.</p>
              </div>
              
              <form method="POST" action="/announcement/<%= announcement._id %>/publish">
                <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-md shadow-indigo-100 transition-all active:scale-95 whitespace-nowrap">
                  Publish Pengumuman
                </button>
              </form>
            </div>
          </div>
        <% } %>

      </div>
    </div>

    <!-- Footer Meta -->
    <div class="mt-8 text-center">
      <p class="text-[12px] text-slate-400">
        ID Referensi Dokumen: <span class="font-mono uppercase"><%= announcement._id %></span>
      </p>
    </div>

  </div>
</div>
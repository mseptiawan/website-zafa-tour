<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8">
  <div class="max-w-5xl mx-auto">

  <div class="flex items-end justify-between mb-10">
  <div>
    <div class="mb-3 flex items-center gap-3">
      <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-400 uppercase">
        Area Kerja
      </span>
      <div class="h-3 w-px bg-slate-300"></div>
      <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-800 uppercase">
        Kehadiran
      </span>
    </div>

    <h1 class="text-3xl font-semibold tracking-tighter text-slate-950">
      Riwayat Absensi
    </h1>
    <p class="mt-1.5 text-sm font-medium text-slate-500">
      Pantau seluruh catatan kehadiran Pegawai secara real-time.
    </p>
  </div>

  <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-2xl px-5 py-3 shadow-sm">
    <span class="text-[12px] font-medium text-slate-500 uppercase tracking-wide">Total Entri:</span>
    <span class="text-lg font-bold text-slate-900"><%= data.length %></span>
  </div>
</div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[700px]">
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
            <tr>
              <th class="text-left px-6 py-4">Tanggal</th>
              <th class="text-left px-6 py-4">Masuk</th>
              <th class="text-left px-6 py-4">Keluar</th>
              <th class="text-left px-6 py-4">Status</th>
              <th class="text-center px-6 py-4">Foto</th>
              <th class="text-center px-6 py-4">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (data.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center py-10 text-slate-400">Belum ada data absensi</td>
              </tr>
            <% } %>

            <% data.forEach(d => { 
                const statusColors = {
                  'HADIR': 'text-emerald-600 bg-emerald-50/70 border-emerald-200/50',
                  'TELAT': 'text-amber-600 bg-amber-50/70 border-amber-200/50',
                  'ALPHA': 'text-rose-600 bg-rose-50/70 border-rose-200/50'
                };
            %>
              <tr class="hover:bg-slate-50 transition">
                <td class="px-6 py-4 font-medium text-slate-800">
                  <%= new Date(d.createdAt).toLocaleDateString("id-ID") %>
                </td>
                <td class="px-6 py-4 text-slate-600">
                  <%= d.checkIn ? new Date(d.checkIn).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}) : '-' %>
                </td>
                <td class="px-6 py-4 text-slate-600">
                  <%= d.checkOut ? new Date(d.checkOut).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}) : '-' %>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full border text-[10px] font-medium uppercase tracking-wide <%= statusColors[d.status] || 'text-slate-500 bg-slate-50 border-slate-200' %>">
                    <%= d.status %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  <% if (d.photo) { %>
                    <img src="<%= d.photo %>" class="w-10 h-10 mx-auto rounded-lg object-cover border border-slate-200" />
                  <% } else { %>
                    <span class="text-slate-400">-</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-center">
                  <button class="openModal inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 hover:text-slate-800 transition"
                    data-date="<%= new Date(d.createdAt).toLocaleDateString('id-ID') %>"
                    data-status="<%= d.status %>"
                    data-checkin="<%= d.checkIn ? new Date(d.checkIn).toLocaleString('id-ID') : '-' %>"
                    data-checkout="<%= d.checkOut ? new Date(d.checkOut).toLocaleString('id-ID') : '-' %>"
                    data-duration="<%= d.workDuration || 0 %>"
                    data-photo="<%= d.photo || '' %>"
                    data-type="<%= d.type %>">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9a3 3 0 100 6 3 3 0 000-6z"/></svg>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="detailModal" class="fixed inset-0 bg-slate-900/20 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
  <div class="bg-white w-full max-w-sm rounded-2xl shadow-xl overflow-hidden border border-slate-100">
    <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
      <h2 class="font-semibold text-slate-800 text-sm">Detail Absensi</h2>
      <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600 transition">✕</button>
    </div>

    <div class="p-5 space-y-4 text-sm">
      <div class="flex justify-between border-b border-slate-50 pb-2"><span class="text-slate-400">Tanggal</span><span class="font-medium text-slate-700" id="mDate"></span></div>
      <div class="flex justify-between border-b border-slate-50 pb-2"><span class="text-slate-400">Status</span><span class="font-medium text-slate-700" id="mStatus"></span></div>
      <div class="flex justify-between border-b border-slate-50 pb-2"><span class="text-slate-400">Tipe</span><span class="font-medium text-slate-700 uppercase" id="mType"></span></div>
      <div class="flex justify-between border-b border-slate-50 pb-2"><span class="text-slate-400">Masuk</span><span class="font-medium text-slate-700" id="mIn"></span></div>
      <div class="flex justify-between border-b border-slate-50 pb-2"><span class="text-slate-400">Keluar</span><span class="font-medium text-slate-700" id="mOut"></span></div>
      <div class="flex justify-between"><span class="text-slate-400">Durasi</span><span class="font-medium text-slate-700"><span id="mDuration"></span> menit</span></div>

      <div id="photoBox" class="hidden pt-2">
        <img id="mPhoto" class="w-full h-48 object-cover rounded-xl border border-slate-200 shadow-sm">
      </div>
    </div>
  </div>
</div>

<script>
const modal = document.getElementById("detailModal");
document.querySelectorAll(".openModal").forEach(btn => {
  btn.addEventListener("click", (e) => {
    const dataset = e.currentTarget.dataset;
    document.getElementById("mDate").textContent = dataset.date || "-";
    document.getElementById("mStatus").textContent = dataset.status || "-";
    document.getElementById("mType").textContent = dataset.type || "-";
    document.getElementById("mIn").textContent = dataset.checkin || "-";
    document.getElementById("mOut").textContent = dataset.checkout || "-";
    document.getElementById("mDuration").textContent = dataset.duration || "0";
    
    const photoBox = document.getElementById("photoBox");
    const mPhoto = document.getElementById("mPhoto");
    if (dataset.photo && dataset.photo !== "") {
      photoBox.classList.remove("hidden");
      mPhoto.src = dataset.photo;
    } else {
      photoBox.classList.add("hidden");
    }
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  });
});

function closeModal() { modal.classList.add("hidden"); modal.classList.remove("flex"); }
modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
</script>
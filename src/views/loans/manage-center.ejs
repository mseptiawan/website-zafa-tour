<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
  <div class="max-w-6xl mx-auto">
    
    <div class="mb-10">
      <div class="mb-3 flex items-center gap-3">
        <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-400 uppercase">Area Kerja</span>
        <div class="h-3 w-px bg-slate-300"></div>
        <span class="text-[10px] font-semibold tracking-[0.2em]  uppercase">Finance</span>
      </div>
      
      <h1 class="text-3xl font-semibold tracking-tight text-slate-950">Pusat Administrasi Pinjaman</h1>
      <p class="mt-1.5 text-sm font-medium text-slate-500 max-w-xl">
        Kelola, tinjau, dan otorisasi seluruh permohonan pinjaman karyawan secara efisien dan terpusat.
      </p>
    </div>

    <div class="flex items-center gap-2 mb-6 border-b border-slate-200/60">
      <button type="button" onclick="switchTab('active')" id="tab-btn-active"
        class="tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-blue-600 text-blue-600 transition-all duration-150 outline-none cursor-pointer">
        Permintaan Aktif (<span id="count-active"><%= activeLoans.length %></span>)
      </button>

      <button type="button" onclick="switchTab('history')" id="tab-btn-history"
        class="tab-btn px-4 py-2.5 text-xs font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-800 transition-all duration-150 outline-none cursor-pointer">
        Riwayat Persetujuan (<span id="count-history"><%= historyLoans.length %></span>)
      </button>
    </div>

    <div id="tab-content-active" class="tab-pane block">
      <div class="bg-white rounded-2xl border border-slate-200/60 overflow-hidden">
         <div class="p-4 border-b border-slate-100 bg-slate-50/50">
            <h3 class="text-[13px] font-bold text-slate-800">Menunggu Review Anda</h3>
          </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/60 text-slate-400 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-5 py-3.5">Tgl Pengajuan</th>
                <th class="px-5 py-3.5">Nama Karyawan</th>
                <th class="px-5 py-3.5 text-right">Jumlah Pinjaman</th>
                <th class="px-5 py-3.5 text-center">Tenor</th>
                <th class="px-5 py-3.5 text-right">Cicilan / Bulan</th>
                <th class="px-5 py-3.5 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (activeLoans.length === 0) { %>
                <tr>
                  <td colspan="6" class="px-5 py-16 text-center text-slate-400 font-medium">
                    <div class="flex flex-col items-center justify-center gap-2">
                      <svg class="w-5 h-5 text-slate-300 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span>Tidak ada permohonan pinjaman aktif yang memerlukan tindakan Anda.</span>
                    </div>
                  </td>
                </tr>
              <% } else { %>
                <% activeLoans.forEach(loan => { %>
                  <tr class="hover:bg-slate-50/40 transition-colors duration-150 group">
                    <td class="px-5 py-4 text-slate-400">
                      <%= new Date(loan.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td class="px-5 py-4 font-bold text-slate-900 group-hover:text-blue-600 transition-colors">
                      <%= loan.employeeId && loan.employeeId.fullName ? loan.employeeId.fullName : "Karyawan" %>
                    </td>
                    <td class="px-5 py-4 text-right font-mono font-bold text-slate-950">
                      Rp <%= loan.amountRequested.toLocaleString('id-ID') %>
                    </td>
                    <td class="px-5 py-4 text-center">
                      <span class="inline-flex bg-slate-100 px-2 py-0.5 rounded-md text-[11px] font-medium text-slate-600">
                        <%= loan.tenorMonths %> Bulan
                      </span>
                    </td>
                    <td class="px-5 py-4 text-right font-mono text-slate-500">
                      Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %>
                    </td>
                    <td class="px-5 py-4 text-right">
                      <a href="/loans/detail/<%= loan._id %>"
                        class="inline-flex items-center gap-1.5 px-3.5 py-2 border border-slate-200 text-[11.5px] font-bold rounded-xl text-slate-700 bg-white hover:bg-slate-50 transition duration-150 active:scale-[0.97]">
                        Periksa
                        <svg class="w-3.5 h-3.5 text-slate-400 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane hidden">
      <div class="bg-white rounded-2xl border border-slate-200/60 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/60 text-slate-400 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-5 py-3.5">Nama Karyawan</th>
                <th class="px-5 py-3.5 text-right">Jumlah Total</th>
                <th class="px-5 py-3.5 text-center">Status Akhir</th>
                <th class="px-5 py-3.5">Catatan Evaluasi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (historyLoans.length === 0) { %>
                <tr>
                  <td colspan="4" class="px-5 py-12 text-center text-slate-400">
                    Belum ada riwayat arsip pemrosesan dokumen pinjaman.
                  </td>
                </tr>
              <% } else { %>
                <% historyLoans.forEach(loan => { %>
                  <tr class="hover:bg-slate-50/30 transition-colors duration-150">
                    <td class="px-5 py-4 font-bold text-slate-900">
                      <%= loan.employeeId && loan.employeeId.fullName ? loan.employeeId.fullName : "Karyawan" %>
                    </td>
                    <td class="px-5 py-4 text-right font-mono font-bold text-slate-950">
                      Rp <%= loan.amountRequested.toLocaleString('id-ID') %>
                    </td>
                    <td class="px-5 py-4 text-center">
                      <% if (loan.approvalStatus === 'APPROVED') { %>
                        <span class="inline-flex items-center gap-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200/30 px-2.5 py-0.5 rounded-lg text-[10px] font-bold uppercase tracking-wide">
                          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                          Approved
                        </span>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1.5 bg-rose-50 text-rose-700 border border-rose-200/30 px-2.5 py-0.5 rounded-lg text-[10px] font-bold uppercase tracking-wide">
                          <span class="h-1.5 w-1.5 rounded-full bg-rose-500"></span>
                          Rejected
                        </span>
                      <% } %>
                    </td>
                    <td class="px-5 py-4 text-slate-500 italic max-w-xs truncate">
                      <%= loan.note || '-' %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  function switchTab(tabName) {
    // 1. Sembunyikan seluruh content pane
    document.querySelectorAll(".tab-pane").forEach((p) => {
      p.classList.replace("block", "hidden");
    });
    
    // 2. Kembalikan semua button ke style pasif bawaan dashboard
    document.querySelectorAll(".tab-btn").forEach((b) => {
      b.className = "tab-btn cursor-pointer border-b-2 border-transparent px-4 py-2.5 text-xs font-medium text-slate-400 transition-all duration-150 outline-none focus:outline-none hover:text-slate-800";
    });

    // 3. Munculkan content pane pilihan
    document.getElementById(`tab-content-${tabName}`).classList.replace("hidden", "block");
    
    // 4. Set state aktif ke tab terpilih
    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    activeBtn.className = "tab-btn cursor-pointer border-b-2 border-blue-600 px-4 py-2.5 text-xs font-bold text-blue-600 transition-all duration-150 outline-none focus:outline-none";
  }
</script>
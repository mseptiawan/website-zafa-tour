<div
  id="toastContainer"
  class="pointer-events-auto fixed top-5 right-5 z-[99999] flex flex-col gap-3.5"
></div>

<script>
  function triggerGlobalToast({ title = "Info", message = "", type = "success" }) {
    const container = document.getElementById("toastContainer");
    if (!container) return;

    // Desain Baru: Glassmorphism dengan Border Aksen di Sebelah Kiri
    const styles = {
      success: {
        icon: "fa-circle-check",
        iconColor: "text-emerald-500",
        accentBorder: "border-l-emerald-500"
      },
      error: {
        icon: "fa-circle-xmark",
        iconColor: "text-rose-500",
        accentBorder: "border-l-rose-500"
      }
    };

    const s = styles[type] || styles.success;
    const toast = document.createElement("div");

    // Base Class: Menggunakan border-l-4 untuk aksen warna di kiri, dan bg-white/80 + backdrop-blur untuk efek kaca murni
    toast.className = "w-[360px] rounded-xl border border-slate-200/60 border-l-4 " + s.accentBorder + " bg-white/95 backdrop-blur-md shadow-[0_8px_30px_rgb(0,0,0,0.06)] p-4 transform translate-x-20 opacity-0 transition-all duration-300 ease-out";

    toast.innerHTML =
      '<div class="flex items-start gap-3">' +
        '<div class="flex-shrink-0 mt-0.5">' +
          '<i class="fa-solid ' + s.icon + ' ' + s.iconColor + ' text-lg"></i>' +
        '</div>' +
        '<div class="flex-1 min-w-0 text-left">' +
          '<h4 class="text-[13px] font-bold text-slate-900 tracking-tight">' + title + '</h4>' +
          '<p class="mt-0.5 text-xs font-medium text-slate-500 leading-relaxed break-words">' + message + '</p>' +
        '</div>' +
        '<button class="text-slate-400 hover:text-slate-600 transition-colors flex-shrink-0 p-0.5 hover:bg-slate-100 rounded-lg">' +
          '<i class="fa-solid fa-xmark text-xs"></i>' +
        '</button>' +
      '</div>';

    container.appendChild(toast);

    // Animasi masuk: Smooth pop-in
    setTimeout(() => {
      toast.classList.remove("translate-x-20", "opacity-0");
      toast.classList.add("translate-x-0", "opacity-100");
    }, 50);

    const closeToast = () => {
      toast.classList.remove("translate-x-0", "opacity-100");
      toast.classList.add("translate-x-10", "opacity-0");
      setTimeout(() => toast.remove(), 300);
    };

    toast.querySelector("button").addEventListener("click", closeToast);
    setTimeout(closeToast, 4000);
  }

  document.addEventListener("DOMContentLoaded", () => {
    const successMessage = <%- (typeof success !== 'undefined' && success && success.length) ? JSON.stringify(success[0]) : 'null' %>;
    const errorMessage = <%- (typeof error !== 'undefined' && error && error.length) ? JSON.stringify(error[0]) : 'null' %>;

    if (successMessage) {
      triggerGlobalToast({ title: "Berhasil", message: successMessage, type: "success" });
    }
    if (errorMessage) {
      triggerGlobalToast({ title: "Gagal", message: errorMessage, type: "error" });
    }
  });
</script>

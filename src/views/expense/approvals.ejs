<%- layout('layouts/main', { title }) %>

<div>
  <div class="max-w-none mx-auto space-y-6 sm:space-y-8">

    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Manajemen Reimbursement', 
        title: 'Persetujuan Reimbursement', 
        description: 'Tinjau pengajuan reimbursement pegawai sebelum diteruskan ke bagian keuangan.' 
    }) %>

    <% 
      const activeExpenses = expenses.filter(e => e.status === 'PENDING_MANAGER');
      const historyExpenses = expenses.filter(e => e.status === 'PENDING_FINANCE' || e.status === 'PAID' || e.status === 'REJECTED');
    %>

    <%- include('../partials/_stats-grid', {
      items: [
        { label: 'Perlu Verifikasi', value: activeExpenses.length, unit: 'Berkas', icon: 'fa-solid fa-file-signature', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-amber-50 text-amber-600 border-amber-100' },
        { label: 'Selesai Direview', value: historyExpenses.length, unit: 'Berkas', icon: 'fa-solid fa-check-double', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-emerald-50 text-emerald-600 border-emerald-100' },


        { 
  label: 'Total Dokumen', 
  value: expenses.length, 
  unit: 'Berkas', 
  icon: 'fa-solid fa-folder-open', 
  bgClass: 'bg-white border-slate-200/60',
  labelClass: 'text-slate-400',
  valueClass: 'text-slate-800',
  unitClass: 'text-slate-400', 
  iconBoxClass: 'bg-blue-50 text-blue-600 border border-blue-100' 
}
      ]
    }) %>

    <%- include('../partials/_tab-nav', {
      tabs: [
        { id: 'active', label: `Permintaan Aktif (${activeExpenses.length})` },
        { id: 'history', label: `Riwayat (${historyExpenses.length})` }
      ]
    }) %>

    <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300">

      <div class="hidden lg:block bg-white rounded-2xl border border-slate-200/60 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100 select-none">
                <th class="px-6 py-4 w-48">Tgl Pengajuan</th>
                <th class="px-6 py-4">Nama Pegawai</th>
                <th class="px-6 py-4">Kategori</th>
                <th class="px-6 py-4 text-right">Nominal</th>
                <th class="px-6 py-4 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-slate-600 font-medium bg-white">
              <% if (activeExpenses.length === 0) { %>
              <tr>
                <td colspan="5" class="px-6 py-12 text-center text-slate-400">Belum ada berkas pengajuan baru yang membutuhkan persetujuan.</td>
              </tr>
              <% } else { %>
              <% activeExpenses.forEach(e => { %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4 text-slate-500 whitespace-nowrap tabular-nums">
                  <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </td>
                <td class="px-6 py-4 font-semibold text-slate-800">
                  <%= e.employeeId?.fullName || 'Pegawai' %>
                </td>
                <td class="px-6 py-4">
                  <span class="bg-slate-100 text-slate-700 text-[12px] px-3 py-1 rounded-md font-semibold inline-block whitespace-nowrap">
                    <%= e.category?.name || 'Kategori' %>
                  </span>
                </td>
                <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">
                  Rp <%= e.amount.toLocaleString('id-ID') %>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-center">
                    <a href="/expense/detail/<%= e._id %>" title="Periksa Berkas" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95] decoration-none">
                      <i class="fa-solid fa-chevron-right text-[11px]"></i>
                    </a>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="lg:hidden space-y-4">
        <% if (activeExpenses.length === 0) { %>
        <div class="p-8 text-center text-slate-400 text-xs bg-white border border-dashed border-slate-200 rounded-2xl">
          Belum ada berkas pengajuan baru yang membutuhkan persetujuan.
        </div>
        <% } else { %>
        <% activeExpenses.forEach(e => { %>
        <div class="bg-white rounded-2xl border border-slate-200/70 p-4 space-y-3.5">
          <div class="flex justify-between items-start gap-2">
            <div class="min-w-0">
              <h3 class="font-bold text-slate-900 text-xs sm:text-sm truncate"><%= e.employeeId?.fullName || 'Pegawai' %></h3>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                Diajukan: <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </p>
            </div>
            <div class="text-right shrink-0">
              <span class="font-bold text-slate-900 text-xs sm:text-sm tabular-nums block">Rp <%= e.amount.toLocaleString('id-ID') %></span>
              <span class="inline-flex px-1.5 py-0.5 rounded border bg-amber-50 text-amber-600 border-amber-100 text-[9px] font-bold mt-1 uppercase"><%= e.category?.name || 'Kategori' %></span>
            </div>
          </div>

          <div class="flex items-center justify-between text-[11px] pt-2.5 border-t border-slate-100 text-slate-500 font-medium">
            <span><i class="fa-solid fa-shield-halved mr-1 text-slate-400"></i> Butuh Persetujuan</span>
            <a href="/expense/detail/<%= e._id %>" class="h-8 px-4 bg-slate-100 hover:bg-slate-200/70 text-slate-700 text-[11px] font-semibold border border-slate-200/60 rounded-lg flex items-center justify-center tracking-wide active:scale-95 transition-all decoration-none">TINJAU</a>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>

    </div>

    <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300">

      <div class="hidden lg:block bg-white rounded-2xl border border-slate-200/60 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100 select-none">
                <th class="px-6 py-4 w-48">Tgl Pengajuan</th>
                <th class="px-6 py-4">Nama Pegawai</th>
                <th class="px-6 py-4">Kategori</th>
                <th class="px-6 py-4 text-right">Nominal</th>
                <th class="px-6 py-4 text-center">Status Akhir</th>
                <th class="px-6 py-4 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-slate-600 font-medium bg-white">
              <% if (historyExpenses.length === 0) { %>
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-slate-400">Belum ada jejak rekam riwayat pemeriksaan reimbursement dari Anda.</td>
              </tr>
              <% } else { %>
              <% historyExpenses.forEach(e => { %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4 text-slate-500 whitespace-nowrap tabular-nums">
                  <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </td>
                <td class="px-6 py-4 font-semibold text-slate-800">
                  <%= e.employeeId?.fullName %>
                </td>
                <td class="px-6 py-4">
                  <span class="bg-slate-100 text-slate-700 text-[12px] px-3 py-1 rounded-md font-semibold inline-block whitespace-nowrap">
                    <%= e.category?.name || 'Kategori' %>
                  </span>
                </td>
                <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">
                  Rp <%= e.amount.toLocaleString('id-ID') %>
                </td>
                <td class="px-6 py-4 text-center select-none">
                  <% 
                        const labels = { 'PENDING_FINANCE': 'DIPROSES FINANCE', 'PAID': 'APPROVED', 'REJECTED': 'REJECTED' }; 
                        const texts = { 'PENDING_FINANCE': 'text-blue-600', 'PAID': 'text-emerald-600', 'REJECTED': 'text-rose-600' };
                        const bgs = { 'PENDING_FINANCE': 'bg-blue-50/70', 'PAID': 'bg-emerald-50/70', 'REJECTED': 'bg-rose-50/70' };
                        const borders = { 'PENDING_FINANCE': 'border-blue-200/50', 'PAID': 'border-emerald-200/50', 'REJECTED': 'border-rose-200/50' };
                        const dots = { 'PENDING_FINANCE': 'bg-blue-500', 'PAID': 'bg-emerald-500 animate-pulse', 'REJECTED': 'bg-rose-500' };
                      %>
                  <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= texts[e.status] %> <%= bgs[e.status] %> <%= borders[e.status] %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= dots[e.status] %>"></span>
                    <span><%= labels[e.status] %></span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-center">
                    <a href="/expense/detail/<%= e._id %>" title="Lihat Riwayat" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95] decoration-none">
                      <i class="fa-solid fa-eye text-[11px]"></i>
                    </a>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="lg:hidden space-y-4">
        <% if (historyExpenses.length === 0) { %>
        <div class="p-8 text-center text-slate-400 text-xs bg-white border border-dashed border-slate-200 rounded-2xl">
          Belum ada jejak rekam riwayat pemeriksaan reimbursement dari Anda.
        </div>
        <% } else { %>
        <% historyExpenses.forEach(e => { %>
        <div class="bg-white rounded-2xl border border-slate-200/70 p-4 space-y-3.5">
          <div class="flex justify-between items-start gap-2">
            <div class="min-w-0">
              <h3 class="font-bold text-slate-900 text-xs sm:text-sm truncate"><%= e.employeeId?.fullName %></h3>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                Diajukan: <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </p>
            </div>
            <div class="text-right shrink-0 flex flex-col items-end gap-1.5">
              <span class="font-bold text-slate-900 text-xs sm:text-sm tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></span>

              <% 
                    const labels = { 'PENDING_FINANCE': 'Finance', 'PAID': 'Approved', 'REJECTED': 'Rejected' }; 
                    const texts = { 'PENDING_FINANCE': 'text-blue-600', 'PAID': 'text-emerald-600', 'REJECTED': 'text-rose-600' };
                    const bgs = { 'PENDING_FINANCE': 'bg-blue-50/70', 'PAID': 'bg-emerald-50/70', 'REJECTED': 'bg-rose-50/70' };
                    const borders = { 'PENDING_FINANCE': 'border-blue-200/50', 'PAID': 'border-emerald-200/50', 'REJECTED': 'border-rose-200/50' };
                    const dots = { 'PENDING_FINANCE': 'bg-blue-500', 'PAID': 'bg-emerald-500', 'REJECTED': 'bg-rose-500' };
                  %>
              <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= texts[e.status] %> <%= bgs[e.status] %> <%= borders[e.status] %>">
                <span class="w-1 h-1 rounded-full <%= dots[e.status] %>"></span>
                <span><%= labels[e.status] %></span>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-between text-[11px] pt-2.5 border-t border-slate-100 text-slate-500 font-medium">
            <span><i class="fa-solid fa-box-archive text-slate-400 mr-1"></i> Arsip Selesai</span>
            <a href="/expense/detail/<%= e._id %>" class="h-8 px-4 bg-slate-100 hover:bg-slate-200/70 text-slate-700 text-[11px] font-semibold border border-slate-200/60 rounded-lg flex items-center justify-center tracking-wide active:scale-95 transition-all decoration-none">LIHAT</a>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>

    </div>

  </div>
</div>
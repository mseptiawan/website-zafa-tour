<%- layout('layouts/main', { title }) %>

  <div class="bg-slate-50 min-h-screen antialiased font-sans lg:ml-72 p-4 md:p-6 text-slate-800">
    <div class="max-w-5xl mx-auto space-y-5">

      <!-- TOP BAR: JUDUL & DATEPICKER -->
      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white border border-slate-200 p-4 rounded-xl shadow-sm">
        <div>
          <h1 class="text-lg font-bold text-slate-900 tracking-tight">Daily Activity Log</h1>
          <p class="text-[12px] text-slate-500 mt-0.5">Selamat bekerja, <%= user.fullName %>! Kelola log aktivitas
              harian Anda dengan ringkas.</p>
        </div>

        <!-- Datepicker -->
        <div
          class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-end border-t sm:border-0 pt-3 sm:pt-0 border-slate-100">
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tanggal</label>
          <input type="date" id="log-date"
            class="bg-slate-50 border border-slate-200 rounded-lg px-3 py-1.5 text-[12.5px] font-semibold text-slate-700 outline-none focus:border-slate-400 focus:bg-white transition cursor-pointer w-full sm:w-auto max-w-[160px]" />
        </div>
      </div>

      <!-- ACTION BAR -->
      <div
        class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 bg-white border border-slate-200 p-3 rounded-xl shadow-sm">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-slate-400 animate-pulse"></span>
          <span id="date-status" class="text-[12px] font-semibold text-slate-600">Memuat data lembar kerja...</span>
        </div>

        <!-- Tombol Salin Tugas Pending Hari Kemarin (Carry Over) -->
        <button type="button" id="btn-carry-over" onclick="executeCarryOver()"
          class="hidden w-full sm:w-auto inline-flex items-center justify-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg px-3 py-1.5 text-[11.5px] font-bold transition active:scale-95">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l-3 3m3-3l3 3" />
          </svg>
          Salin Tugas Pending Kemarin
        </button>
      </div>

      <!-- FORM ADD ACTIVITY -->
      <div id="container-form-add" class="bg-white border border-slate-200 p-4 rounded-xl shadow-sm">
        <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2.5"
            viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Tambah Aktivitas Baru
        </h2>

        <form id="form-create-activity" onsubmit="submitFormCreate(event)"
          class="grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
          <!-- Input Judul -->
          <div class="md:col-span-6">
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Judul Aktivitas /
              Tugas</label>
            <input type="text" id="add-judul" name="judul" placeholder="Contoh: Integrasi API Payment Gateway Sanyru..."
              required
              class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-[12.5px] font-medium text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition" />
          </div>

          <!-- Input Kategori -->
          <div class="md:col-span-3">
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Kategori</label>
            <select id="add-kategori" name="kategori"
              class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-[12.5px] font-medium text-slate-600 outline-none focus:bg-white focus:border-slate-400 transition">
              <option value="Core Task">Core Task</option>
              <option value="Meeting">Meeting</option>
              <option value="Support">Support</option>
            </select>
          </div>

          <!-- Tombol Submit -->
          <div class="md:col-span-3">
            <button type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-[12.5px] px-4 py-2 rounded-lg transition active:scale-[0.98] flex items-center justify-center gap-1.5 shadow-sm">
              Simpan Aktivitas
            </button>
          </div>
        </form>
      </div>

      <!-- COMPACT & RESPONSIVE DATA CONTAINER -->
      <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
        <!-- Desktop Table (Hidden on Mobile) -->
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr
                class="bg-slate-50 border-b border-slate-200 text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                <th class="py-3 px-4 w-32 text-center">Status</th>
                <th class="py-3 px-4 w-28">Kategori</th>
                <th class="py-3 px-4">Judul Aktivitas / Tugas</th>
                <th class="py-3 px-4 w-44">Lampiran Bukti</th>
                <th class="py-3 px-4 w-12 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody id="task-table-body" class="divide-y divide-slate-100">
              <!-- Di-render oleh JavaScript -->
            </tbody>
          </table>
        </div>

        <!-- Mobile List View (Hidden on Desktop) -->
        <div id="task-mobile-list" class="block md:hidden divide-y divide-slate-100">
          <!-- Di-render oleh JavaScript -->
        </div>

        <!-- Empty State Indicator -->
        <div id="empty-state" class="hidden p-10 text-center space-y-1.5">
          <svg class="w-8 h-8 text-slate-300 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5"
            viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.03 0 1.9.693 2.166 1.638m-7.377 2.24l-.4 2.055a2.25 2.25 0 001.542 2.58l.107.031" />
          </svg>
          <p class="text-[12.5px] font-bold text-slate-600">Tidak ada aktivitas</p>
          <p class="text-[11px] text-slate-400">Silakan tambahkan aktivitas baru melalui form di atas.</p>
        </div>
      </div>

    </div>

    <!-- JAVASCRIPT INTEGRATION -->
    <script>
      const todayStr = new Date().toISOString().split('T')[0];
      const datePicker = document.getElementById('log-date');
      datePicker.value = todayStr;

      // Redesain Status Styles: Lebih monokrom & bersih, hanya teks border tipis
      const statusStyles = {
        "Pending": "bg-slate-50 text-amber-700 border-amber-200",
        "In Progress": "bg-slate-50 text-blue-700 border-blue-200",
        "Completed": "bg-slate-50 text-emerald-700 border-emerald-200",
        "Canceled": "bg-slate-50 text-slate-400 border-slate-200"
      };

      // 1. FETCH DATA DARI BACKEND
      async function loadDailyLog() {
        const selectedDate = datePicker.value;
        const dateStatus = document.getElementById('date-status');
        const btnCarryOver = document.getElementById('btn-carry-over');
        const containerFormAdd = document.getElementById('container-form-add');

        if (selectedDate === todayStr) {
          dateStatus.innerText = "Lembar Kerja: Hari Ini";
          btnCarryOver.classList.remove('hidden');
          containerFormAdd.classList.remove('hidden');
        } else {
          dateStatus.innerText = `Arsip Riwayat: ${selectedDate}`;
          btnCarryOver.classList.add('hidden');
          containerFormAdd.classList.add('hidden');
        }

        try {
          const response = await fetch(`/daily-log/api/data?tanggal=${selectedDate}`);
          const result = await response.json();

          if (result.success) {
            renderTableData(result.data);
          } else {
            alert(result.message || "Gagal memuat log.");
          }
        } catch (err) {
          console.error(err);
          alert("Terjadi kesalahan koneksi ke server.");
        }
      }

      // 2. RENDER DATA (DESKTOP & MOBILE RESPONSIVE)
      function renderTableData(tasks) {
        const tbody = document.getElementById('task-table-body');
        const mobileList = document.getElementById('task-mobile-list');
        const emptyState = document.getElementById('empty-state');

        tbody.innerHTML = "";
        mobileList.innerHTML = "";

        if (!tasks || tasks.length === 0) {
          emptyState.classList.remove('hidden');
          return;
        }
        emptyState.classList.add('hidden');

        tasks.forEach(task => {
          let titleStyle = "text-[12.5px] font-semibold text-slate-800";
          if (task.status === "Completed") titleStyle = "text-[12.5px] text-slate-400 font-normal line-through";
          if (task.status === "Canceled") titleStyle = "text-[12.5px] text-slate-300 font-normal line-through opacity-70";

          // Konten Form Template agar tidak menulis dua kali
          const formInnerHTML = `
          <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
            <div class="sm:col-span-2">
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Judul Tugas</label>
              <input type="text" name="judul" value="${task.judul}" class="w-full bg-slate-50 border border-slate-200 rounded px-2.5 py-1.5 text-[12.5px] font-medium text-slate-800 outline-none focus:bg-white focus:border-slate-400" required />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Kategori</label>
              <select name="kategori" class="w-full bg-slate-50 border border-slate-200 rounded px-2 py-1.5 text-[12.5px] font-medium text-slate-600 outline-none focus:bg-white focus:border-slate-400">
                <option value="Core Task" ${task.kategori === 'Core Task' ? 'selected' : ''}>Core Task</option>
                <option value="Meeting" ${task.kategori === 'Meeting' ? 'selected' : ''}>Meeting</option>
                <option value="Support" ${task.kategori === 'Support' ? 'selected' : ''}>Support</option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Status Kerja</label>
              <select name="status" class="w-full bg-slate-50 border border-slate-200 rounded px-2 py-1.5 text-[12.5px] font-bold ${statusStyles[task.status]} outline-none focus:bg-white focus:border-slate-400">
                <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Penjelasan Hasil / Kendala Kerja</label>
            <textarea name="penjelasanHasil" rows="2" class="w-full bg-slate-50 border border-slate-200 rounded px-2.5 py-1.5 text-[12.5px] font-medium text-slate-700 outline-none resize-none focus:bg-white focus:border-slate-400">${task.penjelasanHasil || ''}</textarea>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 pt-2 border-t border-slate-100">
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Lampiran Bukti</label>
              ${task.fileLampiran ? `
                <div id="file-status-container-${task._id}" class="flex items-center gap-2">
                  <span class="text-[11px] text-slate-500 truncate max-w-[180px]">📎 ${task.fileLampiran}</span>
                  <button type="button" onclick="switchToEditFile('${task._id}')" class="text-[10px] font-bold text-slate-500 hover:text-slate-900 bg-slate-100 px-2 py-0.5 rounded border border-slate-200 transition">Ubah</button>
                </div>
                <input type="file" id="input-file-${task._id}" name="attachment" class="hidden text-[11.5px] text-slate-500 file:mr-2 file:py-0.5 file:px-2 file:rounded file:border file:border-slate-200 file:bg-slate-50 file:text-[11px] file:font-semibold cursor-pointer" />
              ` : `
                <input type="file" name="attachment" class="text-[11.5px] text-slate-500 file:mr-2 file:py-0.5 file:px-2 file:rounded file:border file:border-slate-200 file:bg-slate-50 file:text-[11px] file:font-semibold cursor-pointer" />
              `}
            </div>
            <div class="flex gap-2 justify-end">
              <button type="button" onclick="toggleExpandRow('${task._id}')" class="text-[11.5px] font-bold text-slate-500 bg-slate-50 hover:bg-slate-100 border border-slate-200 px-3 py-1.5 rounded transition">Tutup</button>
              <button type="submit" class="text-[11.5px] font-bold text-white bg-blue-600 hover:bg-blue-700 px-4 py-1.5 rounded transition shadow-sm">Simpan</button>
            </div>
          </div>
        `;

          // --- DESKTOP VIEW ROW ---
          const rowHTML = `
          <tr class="hover:bg-slate-50/50 transition-colors group" id="row-view-${task._id}">
            <td class="py-3 px-4 text-center">
              <select onchange="quickUpdateStatus('${task._id}', this.value)" class="text-[11px] font-bold rounded-md px-2 py-1 outline-none border cursor-pointer transition ${statusStyles[task.status]}">
                <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
              </select>
            </td>
            <td class="py-3 px-4">
              <span class="text-[10px] font-bold ${task.kategori === 'Meeting' ? 'text-amber-700 bg-slate-50 border-amber-100' : task.kategori === 'Support' ? 'text-purple-700 bg-slate-50 border-purple-100' : 'text-slate-700 bg-slate-50 border-slate-200'} px-2 py-0.5 rounded border">
                ${task.kategori}
              </span>
            </td>
            <td class="py-3 px-4">
              <div class="flex flex-col">
                <span class="${titleStyle}">${task.judul}</span>
                <span class="text-[11px] text-slate-400 font-normal truncate max-w-md mt-0.5 italic ${task.penjelasanHasil ? '' : 'hidden'}">
                  Hasil: ${task.penjelasanHasil}
                </span>
              </div>
            </td>
            <td class="py-3 px-4">
              ${task.fileLampiran ? `
                <a href="/uploads/files/${task.fileLampiran}" target="_blank" class="inline-flex items-center gap-1 text-[11px] font-medium text-slate-500 hover:text-slate-900 transition truncate max-w-[140px]">
                  <svg class="w-3.5 h-3.5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
                  <span>Lihat Bukti</span>
                </a>
              ` : '<span class="text-slate-300 text-[11px]">—</span>'}
            </td>
            <td class="py-3 px-4 text-center">
              <button type="button" onclick="toggleExpandRow('${task._id}')" id="arrow-btn-${task._id}" class="w-6 h-6 inline-flex items-center justify-center text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded transition">
                <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
            </td>
          </tr>

          <!-- EXPANDABLE INLINE FORM DESKTOP -->
          <tr class="expanded-form-row hidden bg-slate-50/50" id="row-expand-${task._id}">
            <td colspan="5" class="p-4 border-t border-slate-100">
              <form id="form-update-${task._id}" onsubmit="submitFormUpdate(event, '${task._id}')" enctype="multipart/form-data" class="max-w-2xl mx-auto space-y-3 bg-white p-4 rounded-lg border border-slate-200">
                ${formInnerHTML}
              </form>
            </td>
          </tr>
        `;

          // --- MOBILE VIEW CARD ---
          const mobileHTML = `
          <div class="p-4 space-y-3 bg-white transition-colors" id="mobile-card-${task._id}">
            <div class="flex items-start justify-between gap-2">
              <div class="space-y-1">
                <span class="text-[9px] font-bold ${task.kategori === 'Meeting' ? 'text-amber-700 bg-amber-50 border-amber-100' : task.kategori === 'Support' ? 'text-purple-700 bg-purple-50 border-purple-100' : 'text-slate-700 bg-slate-50 border-slate-200'} px-1.5 py-0.5 rounded border">
                  ${task.kategori}
                </span>
                <h3 class="${titleStyle} pt-1">${task.judul}</h3>
                ${task.penjelasanHasil ? `<p class="text-[11px] text-slate-400 italic">Hasil: ${task.penjelasanHasil}</p>` : ''}
              </div>
              <button type="button" onclick="toggleExpandRow('${task._id}')" id="arrow-btn-mob-${task._id}" class="w-7 h-7 flex-shrink-0 inline-flex items-center justify-center text-slate-400 border border-slate-200 rounded">
                <svg class="w-3.5 h-3.5 stroke-[2.5] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
            </div>

            <div class="flex items-center justify-between gap-4 pt-1 border-t border-slate-100">
              <select onchange="quickUpdateStatus('${task._id}', this.value)" class="text-[11px] font-bold rounded px-2 py-1 outline-none border cursor-pointer ${statusStyles[task.status]}">
                <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
              </select>

              ${task.fileLampiran ? `
                <a href="/uploads/files/${task.fileLampiran}" target="_blank" class="text-[11px] font-medium text-slate-500 underline truncate max-w-[120px]">📎 Lihat Bukti</a>
              ` : '<span class="text-slate-300 text-[11px]">Tidak ada bukti</span>'}
            </div>

            <!-- EXPANDABLE INLINE FORM MOBILE (MANDIRI) -->
            <div class="hidden mt-3 pt-3 border-t border-slate-200" id="row-expand-mob-${task._id}">
              <form id="form-update-mob-${task._id}" onsubmit="submitFormUpdate(event, '${task._id}', true)" enctype="multipart/form-data" class="space-y-3 bg-white">
                ${formInnerHTML}
              </form>
            </div>
          </div>
        `;

          tbody.insertAdjacentHTML('beforeend', rowHTML);
          mobileList.insertAdjacentHTML('beforeend', mobileHTML);
        });
      }

      // 3. LOGIKA INTERAKTIF (EXPAND/COMPACT) - SINKRON DESKTOP & MOBILE
      function toggleExpandRow(id) {
        const expandRowDesktop = document.getElementById(`row-expand-${id}`);
        const expandRowMobile = document.getElementById(`row-expand-mob-${id}`);
        const arrowBtnDesktop = document.getElementById(`arrow-btn-${id}`);
        const arrowBtnMobile = document.getElementById(`arrow-btn-mob-${id}`);
        const mobileCard = document.getElementById(`mobile-card-${id}`);

        // Toggle Desktop Form jika ada
        if (expandRowDesktop) expandRowDesktop.classList.toggle('hidden');
        if (arrowBtnDesktop) arrowBtnDesktop.classList.toggle('rotate-180');

        // Toggle Mobile Form jika ada
        if (expandRowMobile) {
          expandRowMobile.classList.toggle('hidden');
          mobileCard.classList.toggle('bg-slate-50/50');
        }
        if (arrowBtnMobile) arrowBtnMobile.classList.toggle('rotate-180');
      }
      // 4. POST: SUBMIT AKTIVITAS BARU
      // 6. PUT: SUBMIT FORM EDIT LENGKAP (OTOMATIS PILIH FORM DESKTOP / MOBILE)
      async function submitFormUpdate(event, id, isMobile = false) {
        event.preventDefault();

        // Deteksi form mana yang sedang di-submit aktif oleh user
        const formId = isMobile ? `form-update-mob-${id}` : `form-update-${id}`;
        const form = document.getElementById(formId);
        const formData = new FormData(form);

        try {
          const response = await fetch(`/daily-log/api/${id}`, {
            method: 'PUT',
            body: formData
          });
          const result = await response.json();

          if (result.success) {
            alert("Aktivitas berhasil diperbarui!");
            loadDailyLog();
          } else {
            alert(result.message);
          }
        } catch (err) {
          console.error(err);
          alert("Gagal menyimpan perubahan.");
        }
      }

      // 5. PUT: UPDATE STATUS LANGSUNG VIA DROPDOWN UTAMA
      async function quickUpdateStatus(id, newStatus) {
        try {
          const response = await fetch(`/daily-log/api/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
          });
          const result = await response.json();
          if (result.success) {
            loadDailyLog();
          } else {
            alert(result.message);
          }
        } catch (err) {
          console.error(err);
        }
      }
      async function submitFormCreate(event) {
        event.preventDefault();

        const form = document.getElementById('form-create-activity');

        const formData = {
          judul: document.getElementById('add-judul').value,
          kategori: document.getElementById('add-kategori').value,
          tanggal: document.getElementById('log-date').value
        };

        try {
          const response = await fetch('/daily-log/api/data', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
            alert("Aktivitas berhasil ditambahkan!");

            form.reset();

            document.getElementById('add-kategori').value = 'Core Task';

            loadDailyLog();
          } else {
            alert(result.message || "Gagal menambahkan aktivitas");
          }
        } catch (err) {
          console.error(err);
          alert("Terjadi kesalahan server");
        }
      }


      function switchToEditFile(id) {
        const statusContainer = document.getElementById(`file-status-container-${id}`);
        const inputFile = document.getElementById(`input-file-${id}`);

        if (statusContainer && inputFile) {
          statusContainer.classList.add('hidden');
          inputFile.classList.remove('hidden');
        }
      }

      // 7. POST: EKSEKUSI CARRY OVER TUGAS PENDING KEMARIN
      async function executeCarryOver() {
        try {
          const response = await fetch('/daily-log/api/carry-over', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tanggalHariIni: datePicker.value })
          });
          const result = await response.json();

          alert(result.message);
          if (result.success) {
            loadDailyLog();
          }
        } catch (err) {
          console.error(err);
          alert("Gagal menyalin tugas."); la
        }
      }

      datePicker.addEventListener('change', loadDailyLog);

      window.onload = function () {
        loadDailyLog();
      };
    </script>
  </div>
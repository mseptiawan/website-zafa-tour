<%- layout('layouts/main', { title: 'Input KPI Karyawan' }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8">
  <div class="max-w-5xl mx-auto">
    
    <div class="flex items-end justify-between mb-10">
  <div>
    <div class="flex items-center gap-3 mb-3">
      <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Area Kerja</span>
      <div class="w-px h-3 bg-slate-300"></div>
      <span class="text-[10px] font-semibold text-slate-800 uppercase tracking-[0.2em]">Performance</span>
    </div>
    
    <h1 class="text-3xl font-semibold text-slate-950 tracking-tighter">Input Penilaian KPI</h1>
    <p class="text-slate-500 mt-2 text-sm font-medium">Kelola penilaian kinerja karyawan per kuartal secara akurat.</p>
  </div>

  <div class="flex items-center gap-3 bg-white px-5 py-3 rounded-2xl border border-slate-200/60 shadow-sm">
    <span class="text-[9px] font-semibold text-slate-400 uppercase tracking-[0.2em]">Total Karyawan</span>
    <div class="h-4 w-px bg-slate-200"></div>
    <span class="text-sm font-black text-slate-900 tabular-nums"><%= employees.length %></span>
  </div>
</div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[800px]">
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
            <tr>
              <th class="text-left px-6 py-4">Karyawan</th>
              <th class="text-left px-6 py-4">Unit Kerja</th>
              <th class="text-left px-6 py-4">Bidang</th>
              <th class="text-center px-6 py-4">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (employees.length === 0) { %>
              <tr>
                <td colspan="4" class="text-center py-10 text-slate-400">Belum ada data karyawan</td>
              </tr>
            <% } %>

            <% employees.forEach(emp => { %>
              <% 
                const isEvaluated = evaluatedIds.includes(emp._id.toString());
                const currentMonth = 6; // Set untuk testing
                const isPeriodOpen = [3, 6, 9, 12].includes(currentMonth);
              %>
              <tr class="hover:bg-slate-50 transition">
                <td class="px-6 py-4">
                  <div class="font-medium text-slate-800"><%= emp.fullName %></div>
                </td>
           <td class="px-6 py-4">
  <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold text-slate-600 bg-slate-50 border border-slate-100">
    <%= emp.unitId?.name || '-' %>
  </span>
</td>
                <td class="px-6 py-4 text-slate-500"><%= emp.bidangId?.name || '-' %></td>
                
                <td class="px-6 py-4 text-center">
                  <% if (isEvaluated) { %>
                    <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border bg-emerald-50/70 border-emerald-200/50 text-emerald-600 text-[10px] font-medium">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                      Sudah Dinilai
                    </div>
                  <% } else if (!isPeriodOpen) { %>
                    <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border bg-slate-50 border-slate-200 text-slate-400 text-[10px] font-medium">
                      Menunggu Kuartal
                    </div>
                  <% } else { %>
                    <a href="/kpi/input/<%= emp._id %>" 
                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-[11px] font-medium rounded-lg transition-all shadow-sm shadow-indigo-200">
                      Nilai Kinerja
                    </a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
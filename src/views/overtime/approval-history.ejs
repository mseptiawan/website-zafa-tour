<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6 text-center">
      <h1 class="text-xl font-medium text-slate-800">
        Riwayat Approval Lembur
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Semua data lembur yang sudah diproses
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-xl p-4">

      <div class="overflow-x-auto">

        <table class="w-full text-sm">

          <!-- HEADER -->
          <thead>
            <tr class="text-left text-xs text-slate-500 border-b border-slate-200">
              <th class="py-2 px-3 font-normal">Karyawan</th>
              <th class="py-2 px-3 font-normal">Tanggal</th>
              <th class="py-2 px-3 font-normal">Jam</th>
              <th class="py-2 px-3 font-normal">Total</th>
              <th class="py-2 px-3 font-normal">Status</th>
              <th class="py-2 px-3 font-normal text-center">Dibuat</th>
            </tr>
          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (overtimes.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center py-6 text-slate-400">
                  Tidak ada data riwayat approval
                </td>
              </tr>
            <% } %>

            <% overtimes.forEach(o => { %>
              <tr class="hover:bg-slate-50">

                <!-- KARYAWAN -->
                <td class="py-3 px-3 text-slate-700">
           <%= o.employeeName %>
                </td>

                <!-- TANGGAL -->
                <td class="py-3 px-3 text-slate-600">
                  <%= new Date(o.date).toLocaleDateString("id-ID") %>
                </td>

                <!-- JAM -->
                <td class="py-3 px-3 text-slate-600">
                  <%= o.startTime %> - <%= o.endTime %>
                </td>

                <!-- TOTAL -->
                <td class="py-3 px-3 text-slate-600">
                  <%= o.totalHours %> jam
                </td>

                <!-- STATUS -->
                <td class="py-3 px-3">
                  <% if (o.status === "Approved") { %>
                    <span class="text-xs px-2 py-1 rounded bg-green-100 text-green-600">
                      Approved
                    </span>
                  <% } else if (o.status === "Rejected") { %>
                    <span class="text-xs px-2 py-1 rounded bg-red-100 text-red-600">
                      Rejected
                    </span>
                  <% } else { %>
                    <span class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600">
                      <%= o.status %>
                    </span>
                  <% } %>
                </td>

                <!-- CREATED -->
                <td class="py-3 px-3 text-center text-slate-500 text-xs">
                  <%= new Date(o.createdAt).toLocaleString("id-ID") %>
                </td>

              </tr>
            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>
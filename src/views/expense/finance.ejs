<%- layout('layouts/main', { title }) %>

<div class="min-h-screen md:ml-72 bg-slate-50/50 sm:p-8 antialiased">
  <div class="max-w-none mx-auto space-y-6 sm:space-y-8">
    
    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Finance', 
        title: 'Validasi & Pencairan Klaim', 
        description: 'Persetujuan dana klaim pengeluaran staf dan rekam jejak pembayaran finansial terpusat.' 
    }) %>

    <% 
      const activeExpenses = expenses.filter(e => e.status === 'PENDING_FINANCE' || e.status === 'PENDING_MANAGER');
      const historyExpenses = expenses.filter(e => e.status === 'PAID' || e.status === 'REJECTED');
    %>

    <%- include('../partials/_stats-grid', {
      items: [
        { label: 'Menunggu Transfer', value: expenses.filter(e => e.status === 'PENDING_FINANCE').length, unit: 'Berkas', icon: 'fa-solid fa-money-bill-transfer', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-amber-50 text-amber-600 border-amber-100' },
        { label: 'Dana Dicairkan', value: historyExpenses.filter(e => e.status === 'PAID').length, unit: 'Berkas', icon: 'fa-solid fa-sack-dollar', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-emerald-50 text-emerald-600 border-emerald-100' },
        { label: 'Total Volume Klaim', value: expenses.length, unit: 'Transaksi', icon: 'fa-solid fa-vault', bgClass: 'bg-gradient-to-br from-slate-900 to-slate-800 border-slate-800', labelClass: 'text-slate-300', valueClass: 'text-white', unitClass: 'text-slate-400', iconBoxClass: 'bg-white/10 text-white border-transparent' }
      ]
    }) %>

    <%- include('../partials/_tab-nav', {
      tabs: [
        { id: 'active', label: `Perlu Diproses (${activeExpenses.length})` },
        { id: 'history', label: `Riwayat Pencairan (${historyExpenses.length})` }
      ]
    }) %>

    <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300">
      
      <div class="hidden lg:block bg-white rounded-2xl border border-slate-200/60 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100 select-none">
                <th class="px-6 py-4 w-48">Tgl Pengajuan</th>
                <th class="px-6 py-4">Nama Pegawai</th>
                <th class="px-6 py-4">Kategori</th>
                <th class="px-6 py-4 text-right">Nominal Klaim</th>
                <th class="px-6 py-4 text-center">Status</th>
                <th class="px-6 py-4 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-slate-600 font-medium bg-white">
              <% if (activeExpenses.length === 0) { %>
                <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400">Tidak ada klaim aktif yang memerlukan tindakan keuangan.</td></tr>
              <% } else { %>
                <% activeExpenses.forEach(e => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="px-6 py-4 text-slate-500 whitespace-nowrap tabular-nums">
                      <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td class="px-6 py-4 font-semibold text-slate-800">
                      <%= e.employeeId?.fullName || 'Pegawai' %>
                    </td>
                    <td class="px-6 py-4">
                      <span class="bg-slate-100 text-slate-700 text-[12px] px-3 py-1 rounded-md font-semibold inline-block whitespace-nowrap">
                        <%= e.category?.name || 'Kategori' %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">
                      Rp <%= e.amount.toLocaleString('id-ID') %>
                    </td>
                    <td class="px-6 py-4 text-center select-none">
                      <% if (e.status === 'PENDING_FINANCE') { %>
                        <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border text-blue-600 bg-blue-50/70 border-blue-200/50">
                          <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                          <span>SIAP BAYAR</span>
                        </div>
                      <% } else { %>
                        <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border text-slate-500 bg-slate-50/70 border-slate-200/50">
                          <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                          <span>REVIEW MANAGER</span>
                        </div>
                      <% } %>
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex items-center justify-center">
                        <a href="/expense/detail/<%= e._id %>" title="Periksa Berkas & Cairkan" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95] decoration-none">
                          <i class="fa-solid fa-chevron-right text-[11px]"></i>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="lg:hidden space-y-4">
        <% if (activeExpenses.length === 0) { %>
          <div class="p-8 text-center text-slate-400 text-xs bg-white border border-dashed border-slate-200 rounded-2xl">
            Tidak ada klaim aktif yang memerlukan tindakan keuangan.
          </div>
        <% } else { %>
          <% activeExpenses.forEach(e => { %>
            <div class="bg-white rounded-2xl border border-slate-200/70 p-4 space-y-3.5">
              <div class="flex justify-between items-start gap-2">
                <div class="min-w-0">
                  <h3 class="font-bold text-slate-900 text-xs sm:text-sm truncate"><%= e.employeeId?.fullName || 'Pegawai' %></h3>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    Diajukan: <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                  </p>
                </div>
                <div class="text-right shrink-0">
                  <span class="font-bold text-slate-900 text-xs sm:text-sm tabular-nums block">Rp <%= e.amount.toLocaleString('id-ID') %></span>
                  <span class="inline-flex px-1.5 py-0.5 rounded border bg-slate-50 text-slate-600 border-slate-200 text-[9px] font-bold mt-1 uppercase"><%= e.category?.name || 'Kategori' %></span>
                </div>
              </div>
              
              <div class="flex items-center justify-between text-[11px] pt-2.5 border-t border-slate-100 text-slate-500 font-medium">
                <div>
                  <% if (e.status === 'PENDING_FINANCE') { %>
                    <span class="inline-flex items-center gap-1 text-[10px] font-bold text-blue-600"><span class="w-1 h-1 rounded-full bg-blue-500"></span> Siap Bayar</span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 text-[10px] font-medium text-slate-500"><span class="w-1 h-1 rounded-full bg-slate-400"></span> Review Manager</span>
                  <% } %>
                </div>
                <a href="/expense/detail/<%= e._id %>" class="h-8 px-4 bg-slate-100 hover:bg-slate-200/70 text-slate-700 text-[11px] font-semibold border border-slate-200/60 rounded-lg flex items-center justify-center tracking-wide active:scale-95 transition-all decoration-none">TINJAU</a>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

    </div>

    <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300">
      
      <div class="hidden lg:block bg-white rounded-2xl border border-slate-200/60 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100 select-none">
                <th class="px-6 py-4 w-48">Tgl Pengajuan</th>
                <th class="px-6 py-4">Nama Pegawai</th>
                <th class="px-6 py-4">Kategori</th>
                <th class="px-6 py-4 text-right">Nominal Klaim</th>
                <th class="px-6 py-4 text-center">Status Akhir</th>
                <th class="px-6 py-4 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-slate-600 font-medium bg-white">
              <% if (historyExpenses.length === 0) { %>
                <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400">Belum ada jejak rekam riwayat pencairan klaim.</td></tr>
              <% } else { %>
                <% historyExpenses.forEach(e => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="px-6 py-4 text-slate-500 whitespace-nowrap tabular-nums">
                      <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td class="px-6 py-4 font-semibold text-slate-800">
                      <%= e.employeeId?.fullName %>
                    </td>
                    <td class="px-6 py-4">
                      <span class="bg-slate-100 text-slate-700 text-[12px] px-3 py-1 rounded-md font-semibold inline-block whitespace-nowrap">
                        <%= e.category?.name || 'Kategori' %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">
                      Rp <%= e.amount.toLocaleString('id-ID') %>
                    </td>
                    <td class="px-6 py-4 text-center select-none">
                      <% 
                        const labels = { 'PAID': 'LUNAS & CAIR', 'REJECTED': 'REJECTED' }; 
                        const texts = { 'PAID': 'text-emerald-600', 'REJECTED': 'text-rose-600' };
                        const bgs = { 'PAID': 'bg-emerald-50/70', 'REJECTED': 'bg-rose-50/70' };
                        const borders = { 'PAID': 'border-emerald-200/50', 'REJECTED': 'border-rose-200/50' };
                        const dots = { 'PAID': 'bg-emerald-500 animate-pulse', 'REJECTED': 'bg-rose-500' };
                      %>
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= texts[e.status] %> <%= bgs[e.status] %> <%= borders[e.status] %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= dots[e.status] %>"></span>
                        <span><%= labels[e.status] %></span>
                      </div>
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex items-center justify-center">
                        <a href="/expense/detail/<%= e._id %>" title="Lihat Rekam Jejak" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95] decoration-none">
                          <i class="fa-solid fa-eye text-[11px]"></i>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="lg:hidden space-y-4">
        <% if (historyExpenses.length === 0) { %>
          <div class="p-8 text-center text-slate-400 text-xs bg-white border border-dashed border-slate-200 rounded-2xl">
            Belum ada jejak rekam riwayat pencairan klaim.
          </div>
        <% } else { %>
          <% historyExpenses.forEach(e => { %>
            <div class="bg-white rounded-2xl border border-slate-200/70 p-4 space-y-3.5">
              <div class="flex justify-between items-start gap-2">
                <div class="min-w-0">
                  <h3 class="font-bold text-slate-900 text-xs sm:text-sm truncate"><%= e.employeeId?.fullName %></h3>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    Diajukan: <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                  </p>
                </div>
                <div class="text-right shrink-0 flex flex-col items-end gap-1.5">
                  <span class="font-bold text-slate-900 text-xs sm:text-sm tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></span>
                  
                  <% 
                    const labels = { 'PAID': 'Lunas', 'REJECTED': 'Rejected' }; 
                    const texts = { 'PAID': 'text-emerald-600', 'REJECTED': 'text-rose-600' };
                    const bgs = { 'PAID': 'bg-emerald-50/70', 'REJECTED': 'bg-rose-50/70' };
                    const borders = { 'PAID': 'border-emerald-200/50', 'REJECTED': 'border-rose-200/50' };
                    const dots = { 'PAID': 'bg-emerald-500', 'REJECTED': 'bg-rose-500' };
                  %>
                  <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border shrink-0 <%= texts[e.status] %> <%= bgs[e.status] %> <%= borders[e.status] %>">
                    <span class="w-1 h-1 rounded-full <%= dots[e.status] %>"></span>
                    <span><%= labels[e.status] %></span>
                  </div>
                </div>
              </div>
              
              <div class="flex items-center justify-between text-[11px] pt-2.5 border-t border-slate-100 text-slate-500 font-medium">
                <span><i class="fa-solid fa-box-archive text-slate-400 mr-1"></i> Arsip Selesai</span>
                <a href="/expense/detail/<%= e._id %>" class="h-8 px-4 bg-slate-100 hover:bg-slate-200/70 text-slate-700 text-[11px] font-semibold border border-slate-200/60 rounded-lg flex items-center justify-center tracking-wide active:scale-95 transition-all decoration-none">LIHAT</a>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

    </div>

  </div>
</div>
<%- layout('layouts/main', { title }) %>

<div class=" min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-6xl mx-auto space-y-8">

    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Finance', 
        title: 'Validasi & Pencairan Klaim', 
        description: 'Persetujuan dana klaim pengeluaran staf dan rekam jejak pembayaran finansial terpusat.' 
    }) %>

    <% 
      const activeExpenses = expenses.filter(e => e.status === 'PENDING_FINANCE' || e.status === 'PENDING_MANAGER');
      const historyExpenses = expenses.filter(e => e.status === 'PAID' || e.status === 'REJECTED');
    %>

    <%- include('../partials/_stats-grid', {
      items: [
        { label: 'Menunggu Transfer', value: expenses.filter(e => e.status === 'PENDING_FINANCE').length, unit: 'Berkas', icon: 'fa-solid fa-money-bill-transfer', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-amber-50 text-amber-600 border-amber-100' },
        { label: 'Dana Dicairkan', value: historyExpenses.filter(e => e.status === 'PAID').length, unit: 'Berkas', icon: 'fa-solid fa-sack-dollar', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-emerald-50 text-emerald-600 border-emerald-100' },
        { label: 'Total Volume Klaim', value: expenses.length, unit: 'Transaksi', icon: 'fa-solid fa-vault', bgClass: 'bg-gradient-to-br from-slate-900 to-slate-800 border-slate-800', labelClass: 'text-slate-300', valueClass: 'text-white', unitClass: 'text-slate-400', iconBoxClass: 'bg-white/10 text-white border-transparent' }
      ]
    }) %>

    <%- include('../partials/_tab-nav', {
      tabs: [
        { id: 'active', label: `Perlu Diproses (${activeExpenses.length})` },
        { id: 'history', label: `Riwayat Pencairan (${historyExpenses.length})` }
      ]
    }) %>

    <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300">
      <div class="bg-white rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-6 py-4">Pegawai</th>
                <th class="px-6 py-4">Detail Pengajuan</th>
                <th class="px-6 py-4 text-center">Lampiran</th>
                <th class="px-6 py-4">Status Otorisasi</th>
                <th class="px-6 py-4 text-right">Nominal Tagihan</th>
                <th class="px-6 py-4 text-center">Tindakan Pembayaran</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (activeExpenses.length === 0) { %>
                <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400">Tidak ada klaim aktif yang memerlukan pencairan dana.</td></tr>
              <% } else { %>
                <% activeExpenses.forEach(e => { %>
                  <tr class="hover:bg-slate-50/40 transition">
                    <td class="px-6 py-4 font-bold text-slate-900"><%= e.employeeId?.fullName %></td>
                    <td class="px-6 py-4 font-semibold text-slate-800"><%= e.title %></td>
                    <td class="px-6 py-4 text-center">
                      <% if (!e.proofFile) { %>
                        <span class="text-[11px] text-slate-400 italic">Tanpa Nota</span>
                      <% } else { %>
                        <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="group inline-flex items-center gap-1.5 text-[11px] font-medium text-slate-500 hover:text-blue-600 transition-colors">
                          <i class="fa-solid fa-arrow-down-to-bracket text-slate-400 group-hover:text-blue-600 transition-colors"></i>
                          Unduh Nota
                        </a>
                      <% } %>
                    </td>
                    <td class="px-6 py-4">
                      <% if (e.status === 'PENDING_FINANCE') { %>
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-bold bg-blue-50 text-blue-700 border border-blue-200/60"><i class="fa-solid fa-hourglass-half"></i> Siap Bayar</span>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-medium bg-slate-100 text-slate-500 border border-slate-200/60"><i class="fa-solid fa-user-tie"></i> Review Manager</span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></td>
                    <td class="px-6 py-4 text-center">
                      <% if (e.status === 'PENDING_FINANCE') { %>
                        <form action="/expense/<%= e._id %>/pay" method="POST" enctype="multipart/form-data" class="flex items-center justify-center gap-2">
                          <label for="tf-<%= e._id %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 text-[10px] font-medium rounded-lg cursor-pointer transition-colors group">
                            <i class="fa-solid fa-paperclip text-slate-400 group-hover:text-slate-600 transition-colors"></i> <span id="lbl-<%= e._id %>">Bukti TF</span>
                          </label>
                          <input type="file" id="tf-<%= e._id %>" name="transferProof" onchange="document.getElementById('lbl-<%= e._id %>').innerText = 'File OK'; this.parentElement.querySelector('label').classList.replace('text-slate-600', 'text-emerald-600'); this.parentElement.querySelector('i').classList.replace('text-slate-400', 'text-emerald-600')" class="hidden" required />
                          <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-50 hover:bg-emerald-600 text-emerald-600 hover:text-white text-[11px] font-bold rounded-lg transition-colors"><i class="fa-solid fa-money-bill-transfer"></i> Lunasi</button>
                        </form>
                      <% } else { %>
                        <span class="text-[10px] text-slate-400 italic">Menunggu Approval Atasan</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300">
      <div class="bg-white rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-6 py-4">Pegawai</th>
                <th class="px-6 py-4">Detail Pengajuan</th>
                <th class="px-6 py-4 text-center">Lampiran Klaim</th>
                <th class="px-6 py-4 text-center">Bukti Transfer</th>
                <th class="px-6 py-4 text-right">Nominal</th>
                <th class="px-6 py-4">Status Akhir</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (historyExpenses.length === 0) { %>
                <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400">Belum ada jejak rekam riwayat pencairan klaim.</td></tr>
              <% } else { %>
                <% historyExpenses.forEach(e => { %>
                  <tr class="hover:bg-slate-50/40 transition">
                    <td class="px-6 py-4 font-bold text-slate-900"><%= e.employeeId?.fullName %></td>
                    <td class="px-6 py-4 font-semibold text-slate-800"><%= e.title %></td>
                    <td class="px-6 py-4 text-center">
                      <% if (!e.proofFile) { %><span class="text-[11px] text-slate-400 italic">Tanpa Nota</span><% } else { %>
                        <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="group inline-flex items-center gap-1.5 text-[11px] font-medium text-slate-500 hover:text-blue-600 transition-colors"><i class="fa-solid fa-arrow-down-to-bracket text-slate-400 group-hover:text-blue-600 transition-colors"></i> Unduh Nota</a>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-center">
                      <% if (e.transferProofFile) { %>
                        <a href="/uploads/files/<%= e.transferProofFile %>" target="_blank" download class="group inline-flex items-center gap-1.5 text-[11px] font-medium text-emerald-600 hover:text-emerald-700 transition-colors"><i class="fa-solid fa-receipt text-emerald-500"></i> Unduh Resi</a>
                      <% } else { %>
                        <span class="text-[11px] text-slate-400 italic">-</span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></td>
                    <td class="px-6 py-4">
                      <% 
                        const labels = { 'PAID': 'Selesai & Lunas', 'REJECTED': 'Ditolak' }; 
                        const texts = { 'PAID': 'text-emerald-600', 'REJECTED': 'text-rose-600' };
                        const bgs = { 'PAID': 'bg-emerald-50/70', 'REJECTED': 'bg-rose-50/70' };
                        const borders = { 'PAID': 'border-emerald-200/50', 'REJECTED': 'border-rose-200/50' };
                        const dots = { 'PAID': 'bg-emerald-500', 'REJECTED': 'bg-rose-500' };
                      %>
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-medium tracking-wide <%= texts[e.status] %> <%= bgs[e.status] %> <%= borders[e.status] %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= dots[e.status] %> <%= e.status === 'PAID' ? 'animate-pulse' : '' %>"></span>
                        <span><%= labels[e.status] %></span>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>
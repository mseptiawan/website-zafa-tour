<%- layout('layouts/main', { title: title }) %>

<div class=" min-h-screen bg-slate-50/50 p-8">
  <div class="max-w-5xl mx-auto">
    
 <div class="mb-10">
  <div>
    <div class="mb-3 flex items-center gap-3">
      <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-400 uppercase">
        Area Kerja
      </span>
      <div class="h-3 w-px bg-slate-300"></div>
      <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-800 uppercase">
        Kehadiran
      </span>
    </div>

    <h1 class="text-3xl font-semibold tracking-tighter text-slate-950">
      Dashboard Kehadiran
    </h1>
    <p class="mt-1.5 text-sm font-medium text-slate-500">
      Monitoring real-time kehadiran Pegawai - <%= new Date().toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) %>
    </p>
  </div>
</div>

    <div class="flex items-center gap-3 mb-6">
      <input type="text" id="searchInput" placeholder="Cari berdasarkan nama..." 
        class="w-full sm:w-64 px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all outline-none shadow-sm">
      
      <select id="statusFilter" class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none shadow-sm text-slate-600">
        <option value="ALL">Semua Status</option>
        <option value="BELUM ABSEN">Belum Absen</option>
        <option value="HADIR">Hadir</option>
        <option value="TELAT">Telat</option>
      </select>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[700px]">
          <thead class="bg-slate-50 text-slate-500 text-[10px] uppercase tracking-wider">
            <tr>
              <th class="text-left px-6 py-4">Nama Pegawai</th>
              <th class="text-center px-6 py-4">Status</th>
              <th class="text-center px-6 py-4">Check In</th>
              <th class="text-center px-6 py-4">Check Out</th>
              <th class="text-center px-6 py-4">Tipe</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" id="attendanceTable">
            <% data.forEach(row => { %>
              <tr class="hover:bg-slate-50/50 transition" data-status="<%= row.status %>">
                <td class="px-6 py-4 font-medium text-slate-800"><%= row.name %></td>
                
                <td class="px-6 py-4 text-center">
                  <% 
                    let color = 'bg-slate-100 text-slate-600 border-slate-200';
                    if (row.status === 'HADIR') color = 'bg-emerald-50 text-emerald-600 border-emerald-100';
                    if (row.status === 'TELAT') color = 'bg-amber-50 text-amber-600 border-amber-100';
                  %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-medium <%= color %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= row.status === 'HADIR' ? 'bg-emerald-500' : row.status === 'TELAT' ? 'bg-amber-500' : 'bg-slate-400' %>"></span>
                    <%= row.status %>
                  </span>
                </td>

                <td class="px-6 py-4 text-center text-slate-500 font-mono text-xs">
                  <%= row.attendance?.checkIn ? new Date(row.attendance.checkIn).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}) : '-' %>
                </td>
                <td class="px-6 py-4 text-center text-slate-500 font-mono text-xs">
                  <%= row.attendance?.checkOut ? new Date(row.attendance.checkOut).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}) : '-' %>
                </td>
                <td class="px-6 py-4 text-center text-slate-500 text-xs italic">
                  <%= row.attendance?.type || '-' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  const filterTable = () => {
    const status = document.getElementById('statusFilter').value;
    const term = document.getElementById('searchInput').value.toLowerCase();
    
    document.querySelectorAll('#attendanceTable tr').forEach(tr => {
      const name = tr.querySelector('td').textContent.toLowerCase();
      const statusMatch = (status === 'ALL' || tr.dataset.status === status);
      const nameMatch = name.includes(term);
      tr.style.display = (statusMatch && nameMatch) ? '' : 'none';
    });
  };

  document.getElementById('statusFilter').addEventListener('change', filterTable);
  document.getElementById('searchInput').addEventListener('keyup', filterTable);
</script>
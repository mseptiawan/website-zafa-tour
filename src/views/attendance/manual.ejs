<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 p-8 bg-slate-50 min-h-screen">

  <!-- HEADER -->
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-slate-800">
      Input Absensi Manual
    </h1>
    <p class="text-sm text-slate-500">
      HR dapat menambahkan absensi karyawan secara manual
    </p>
  </div>

  <!-- CARD -->
  <div class="max-w-xl bg-white border border-slate-200 rounded-xl p-6 shadow-sm">

    <form method="POST" class="space-y-4 text-sm">

      <!-- EMPLOYEE SELECT -->
      <div>
        <label class="text-xs text-slate-500">Karyawan</label>

        <select
          name="userId"
          class="w-full mt-1 px-3 py-2 border border-slate-200 rounded-lg"
          required
        >
          <option value="">Pilih Karyawan</option>

          <% employees.forEach(e => { %>
            <option value="<%= e.userId._id %>">
              <%= e.fullName %> - <%= e.userId.username %>
            </option>
          <% }) %>

        </select>
      </div>

      <!-- CHECK IN -->
      <div>
        <label class="text-xs text-slate-500">Check In</label>
        <input
          type="datetime-local"
          name="checkIn"
          class="w-full mt-1 px-3 py-2 border rounded-lg"
          required
        >
      </div>

      <!-- CHECK OUT -->
      <div>
        <label class="text-xs text-slate-500">Check Out</label>
        <input
          type="datetime-local"
          name="checkOut"
          class="w-full mt-1 px-3 py-2 border rounded-lg"
        >
      </div>

      <!-- TYPE -->
      <div>
        <label class="text-xs text-slate-500">Type</label>
        <select name="type" class="w-full mt-1 px-3 py-2 border rounded-lg">
          <option value="KANTOR">Kantor</option>
          <option value="LUAR KANTOR">Luar Kantor</option>
        </select>
      </div>

      <!-- STATUS -->
      <div>
        <label class="text-xs text-slate-500">Status</label>
        <select name="status" class="w-full mt-1 px-3 py-2 border rounded-lg">
          <option value="HADIR">Hadir</option>
          <option value="TELAT">Telat</option>
        </select>
      </div>

      <!-- NOTE -->
      <div>
        <label class="text-xs text-slate-500">Catatan</label>
        <textarea
          name="note"
          rows="3"
          class="w-full mt-1 px-3 py-2 border rounded-lg"
        ></textarea>
      </div>

      <button class="w-full bg-slate-900 text-white py-2 rounded-lg">
        Simpan Absensi
      </button>

    </form>

  </div>
</div>
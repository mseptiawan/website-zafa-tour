<%- layout('layouts/main', { title }) %>

<style>
  /* =========================================================================
     KONTROL PRINT & LAYOUT MINIMALIS DOKUMEN KUNING
     ========================================================================= */
  #report-print-zone {
    display: none;
  }

  @media print {
    html, body, body * {
      visibility: hidden !important;
      background: transparent !important;
    }
    
    #report-print-zone, #report-print-zone * {
      visibility: visible !important;
    }
    
    #report-print-zone {
      display: block !important;
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      border: none !important;
      box-shadow: none !important;
      color: black !important;
    }

    .yellow-print-header {
      background-color: #facc15 !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color: black !important;
    }
  }

  .formal-print-text {
    font-family: 'Times New Roman', Times, serif;
    font-weight: normal !important;
  }
  
  .formal-print-text th, 
  .formal-print-text td, 
  .formal-print-text span, 
  .formal-print-text h2, 
  .formal-print-text h3, 
  .formal-print-text p {
    font-weight: normal !important;
  }

  .yellow-print-header {
    background-color: #facc15;
    color: black;
  }
</style>

<div class="ml-72 min-h-screen bg-[#f8fafc] p-8 antialiased text-slate-800">
  <div class="mx-auto max-w-7xl space-y-6">

    <!-- HEADER MONITOR UTAMA (PURE CLEAN & FLAT) -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white border border-slate-200/60 rounded-xl p-6 shadow-xs no-print">
      <div>
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block mb-1">Internal Operations</span>
        <h1 class="text-base font-bold tracking-tight text-slate-950">Laporan Eksekutif Data Pegawai</h1>
      </div>
      
      <div class="flex items-center gap-3">
        <!-- TOMBOL EXPORT MONOKROM -->
        <button onclick="executePrintEmployeeReport()" class="bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-medium h-9 px-4 rounded-lg shadow-xs transition-all flex items-center gap-1.5 cursor-pointer">
          <i class="fa-solid fa-file-pdf text-[12px]"></i> Export PDF Data Induk
        </button>
      </div>
    </div>

    <!-- DIAGRAM 1: BLOK PROPORSI DEMOGRAFI GENDER MURNI MONOKROM -->
    <% 
      let lakiCount = 0; let perempuanCount = 0;
      employees.forEach(emp => {
        if(emp.jenis_kelamin === 'Laki-Laki') lakiCount++;
        if(emp.jenis_kelamin === 'Perempuan') perempuanCount++;
      });
      let totalEmp = employees.length || 1;
      let pctLaki = Math.round((lakiCount / totalEmp) * 100);
      let pctPerempuan = Math.round((perempuanCount / totalEmp) * 100);
    %>
    <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-xs no-print">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Diagram Proporsi Demografi Gender</h3>
        <span class="text-[10px] text-slate-400 font-mono">Kekuatan SDM: <%= employees.length %> Orang</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Blok Laki-Laki -->
        <div class="p-4 bg-slate-50 border border-slate-200/70 rounded-xl flex items-center justify-between transition-colors hover:bg-slate-100/40">
          <div class="space-y-1">
            <span class="text-[11px] font-semibold text-slate-800 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-900 block"></span> Pegawai Laki-Laki
            </span>
            <span class="text-xs text-slate-400 block"><%= lakiCount %> Orang terdaftar</span>
          </div>
          <div class="text-right">
            <span class="text-xl font-bold text-slate-900 tracking-tight font-mono"><%= pctLaki %>%</span>
          </div>
        </div>

        <!-- Blok Perempuan -->
        <div class="p-4 bg-slate-50 border border-slate-200/70 rounded-xl flex items-center justify-between transition-colors hover:bg-slate-100/40">
          <div class="space-y-1">
            <span class="text-[11px] font-semibold text-slate-700 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-400 block"></span> Pegawai Perempuan
            </span>
            <span class="text-xs text-slate-400 block"><%= perempuanCount %> Orang terdaftar</span>
          </div>
          <div class="text-right">
            <span class="text-xl font-bold text-slate-700 tracking-tight font-mono"><%= pctPerempuan %>%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- DIAGRAM 2: MATRIKS DATA SHEET (PURE MONOKROM GRID) -->
    <div class="bg-white border border-slate-200 rounded-xl p-5 space-y-4 no-print">
      <div class="flex items-center justify-between border-b border-slate-100 pb-3">
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Matriks Master Registrasi Pegawai</h3>
        <span class="text-[10px] bg-slate-50 border border-slate-200 px-2 py-0.5 rounded text-slate-600 font-medium tracking-wide">MASTER DATA SHEET</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        <% employees.forEach((emp) => { %>
          <!-- Semua kartu seragam memakai bg-slate-50 tanpa highlight warna mencolok -->
          <div class="p-3 bg-slate-50 border border-slate-200 rounded-xl text-xs space-y-2 transition-all hover:bg-white hover:shadow-[0_4px_12px_rgba(0,0,0,0.02)]">
            <div class="flex justify-between items-start border-b border-slate-200/60 pb-1.5">
              <span class="font-bold text-slate-900 truncate pr-2"><%= emp.fullName %></span>
              <span class="text-[10px] bg-slate-200 border border-slate-300/50 px-1.5 py-0.5 rounded text-slate-700 font-mono font-semibold shrink-0"><%= emp.employeeIdNumber %></span>
            </div>
            
            <div class="grid grid-cols-2 gap-y-1 text-slate-500 font-mono text-[11px]">
              <span>Gender:</span>
              <span class="text-slate-900 font-medium text-right"><%= emp.jenis_kelamin %></span>
              <span>Asal / Lahir:</span>
              <span class="text-slate-900 font-medium text-right truncate"><%= emp.tempat_lahir %></span>
              <span>Pernikahan:</span>
              <span class="text-slate-900 font-medium text-right"><%= emp.status_pernikahan %></span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- AREA INJEKSI CETAK FORMAL KUNING -->
    <div id="report-print-zone" class="bg-white p-2 space-y-6 text-black formal-print-text"></div>

  </div>
</div>

<script>
  // Ambil data mentah dari server ke client-side
  const clientEmployeeData = <%- JSON.stringify(employees) %>;

  function executePrintEmployeeReport() {
    let employeeRowsHTML = '';
    
    clientEmployeeData.forEach((emp, idx) => {
      employeeRowsHTML += `
        <tr class="h-8" style="font-family: 'Times New Roman', Times, serif;">
          <td class="p-2 border-r border-black text-center" style="font-weight: normal !important;">${idx + 1}</td>
          <td class="p-2 border-r border-black font-normal" style="font-weight: normal !important; text-align: left;">${emp.employeeIdNumber}</td>
          <td class="p-2 border-r border-black font-normal" style="font-weight: normal !important; text-align: left;">${emp.fullName}</td>
          <td class="p-2 border-r border-black text-center" style="font-weight: normal !important;">${emp.jenis_kelamin}</td>
          <td class="p-2 border-r border-black text-center" style="font-weight: normal !important;">${emp.tempat_lahir}</td>
          <td class="p-2 text-center" style="font-weight: normal !important;">${emp.status_pernikahan}</td>
        </tr>`;
    });

    const finalPrintTemplate = `
      <div class="flex justify-between items-start">
        <div class="border border-black px-6 py-1 mt-2">
          <span class="text-xs tracking-wide" style="color: #f43f5e; font-weight: normal !important;">Master Induk Dokumen</span>
        </div>
        <div class="text-center space-y-0.5">
          <div class="inline-flex flex-col items-center justify-center">
            <span class="text-2xl tracking-tighter" style="font-family: 'Times New Roman', Times, serif; font-weight: normal !important;">ZM</span>
            <span class="text-[8px] tracking-widest uppercase -mt-1" style="font-weight: normal !important;">ZAFA TOUR</span>
          </div>
          <div class="text-[10px] uppercase tracking-tight" style="font-weight: normal !important;">Zafa Mulia Mandiri</div>
        </div>
      </div>

      <div class="pt-1">
        <h2 class="text-xs" style="font-weight: normal !important; text-align: left;">PT Zafa Mulia Mandiri</h2>
      </div>

      <div class="space-y-0.5" style="text-align: left;">
        <h3 class="text-xs" style="font-weight: normal !important;">Laporan Data Induk Pegawai Terdaftar</h3>
        <p class="text-xs" style="font-weight: normal !important;">Tanggal Unduh : ${new Date().toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      </div>

      <!-- Tabel Berformat Cetakan Kuning Slip Gaji Formal -->
      <div class="border border-black mt-4">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="yellow-print-header border-b border-black">
              <th class="p-2 border-r border-black font-normal text-center" style="font-weight: normal !important; width: 5%;">No</th>
              <th class="p-2 border-r border-black font-normal text-left" style="font-weight: normal !important; width: 15%;">ID Pegawai</th>
              <th class="p-2 border-r border-black font-normal text-left" style="font-weight: normal !important; width: 35%;">Nama Lengkap</th>
              <th class="p-2 border-r border-black font-normal text-center" style="font-weight: normal !important; width: 15%;">Gender</th>
              <th class="p-2 border-r border-black font-normal text-center" style="font-weight: normal !important; width: 15%;">Tempat Lahir</th>
              <th class="p-2 font-normal text-center" style="font-weight: normal !important; width: 15%;">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-black">
            ${employeeRowsHTML}
          </tbody>
        </table>
      </div>

      <div class="pt-6 flex justify-between items-start text-xs">
        <div class="text-[10px] text-gray-400 italic">
          *Dokumen diunduh secara resmi melalui Database Inti HRIS Kantor Utama Palembang.
        </div>
        <div class="text-center pr-12 space-y-12">
          <span class="block" style="font-weight: normal !important;">Manager Administrasi (HRD)</span>
          <span class="block border-t border-black pt-1 w-40" style="font-weight: normal !important;">Otorisasi Sistem</span>
        </div>
      </div>

      <div class="border-b border-black pt-4"></div>

      <div class="flex items-center gap-1.5 text-[10px] pt-1">
        <span style="font-family: 'Times New Roman', Times, serif; font-weight: normal !important;">ZM</span>
        <span style="font-weight: normal !important;">PT Zafa Mulia Mandiri</span>
      </div>
    `;

    const printZone = document.getElementById('report-print-zone');
    if (printZone) {
      printZone.innerHTML = finalPrintTemplate;
      window.print();
    }
  }
</script>
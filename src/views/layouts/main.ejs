<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
  <link class="apple-touch-icon" href="/images/apple-touch-icon.png" />
  <link rel="manifest" href="/images/site.webmanifest" />

  <title><%= typeof title !== 'undefined' ? title : 'Zafa Tour HRIS' %></title>

  <link rel="stylesheet" href="/css/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
</head>

<body class="h-screen overflow-hidden md:bg-[#f8fafc] text-slate-800 antialiased selection:bg-indigo-50 selection:text-indigo-600">
  <div class="flex h-screen w-screen overflow-hidden pb-16 md:pb-0">
    <%- include('../partials/sidebar') %>

    <main class="relative flex h-full flex-1 flex-col overflow-y-auto px-4 py-5 pt-6 md:px-8 md:pt-20">
      <div class="absolute top-5 right-4 z-[100] hidden md:right-8 md:block" id="notificationDropdown">
        <button id="notifButton" class="group relative flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200/60 bg-white shadow-xs transition-all duration-200 hover:bg-slate-50 focus:outline-none active:scale-[0.96]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="stroke-[2.2] text-slate-600 transition-colors group-hover:text-slate-900">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"></path>
          </svg>
          <span id="notifBadge" class="absolute top-2 right-2 hidden h-2 w-2 rounded-full bg-amber-500 ring-2 ring-white">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-amber-400 opacity-75"></span>
          </span>
        </button>

        <div id="notifMenu" class="absolute right-0 z-[100] mt-2.5 hidden w-[calc(100vw-2rem)] origin-top-right flex-col rounded-2xl border border-slate-200/50 bg-white shadow-xl shadow-slate-950/[0.05] transition-all duration-200 sm:w-96">
          <div class="flex items-center justify-between rounded-t-2xl border-b border-slate-100 bg-white px-5 py-4">
            <h1 class="flex items-center gap-2 text-[13px] font-bold tracking-tight text-slate-950">
              Notifikasi
              <span id="notifCountText" class="hidden inline-flex min-w-[18px] items-center justify-center rounded-md bg-blue-600 px-2 py-0.5 text-[10px] font-bold text-white">0</span>
            </h1>
            <button id="markAllReadBtn" class="text-[11px] font-bold text-blue-600 transition-colors hover:text-blue-700">Tandai semua dibaca</button>
          </div>
          <div id="notifContainer" class="max-h-[380px] divide-y divide-slate-50 overflow-y-auto">
            <div class="p-6 text-center text-xs text-slate-400">Tidak ada notifikasi baru.</div>
          </div>
        </div>
      </div>

      <div class="ml-0 min-h-screen flex-1 bg-slate-50/30 p-2 antialiased md: md:p-8">

        <% if (typeof title !== 'undefined' && title.toLowerCase().includes('dashboard')) { %>
        <div class="mb-6 block rounded-3xl  shadow-[0_4px_20px_rgba(0,0,0,0.015)] md:hidden">
          <div class="flex items-center justify-between mb-5 px-1">
            <div>
              <h1 class="text-xl font-extrabold tracking-tight text-slate-900">Beranda</h1>
              <p class="text-[10px] font-medium text-slate-400 mt-0.5">Halo, <%= typeof user !== 'undefined' ? user.username : 'Pegawai' %> 👋</p>
            </div>
            <!-- Opsional: Sisi Kanan bisa diisi icon kecil info atau dibiarkan kosong agar clean -->
            <div class="w-8 h-8 rounded-xl bg-slate-50 border border-slate-200/60 flex items-center justify-center text-slate-400">
              <i class="fa-solid fa-sparkles text-xs text-amber-500"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-blue-600 via-indigo-600 to-slate-900 rounded-3xl pt-8 pb-10 px-6 text-white shadow-[0_8px_30px_rgb(59,130,246,0.15)] relative overflow-hidden mb-6 min-h-[160px] flex flex-col justify-between">

            <div class="absolute -right-4 -top-10 w-36 h-36 bg-white/10 rounded-full blur-2xl pointer-events-none"></div>
            <div class="absolute -right-10 -bottom-10 w-44 h-44 bg-indigo-500/20 rounded-full blur-xl pointer-events-none"></div>

            <div class="flex justify-between items-start w-full relative z-10">
              <div class="space-y-0.5">
                <p class="text-[10px] font-bold text-blue-100 uppercase tracking-[0.15em] opacity-90">Status Kehadiran</p>
                <h2 id="liveClockMobile" class="text-3xl font-extrabold tracking-tight mt-1 bg-gradient-to-r from-white via-white to-blue-100 bg-clip-text text-transparent">00:00:00</h2>
              </div>

              <a href="/attendance" class="bg-white/10 hover:bg-white/20 border border-white/20 active:scale-[0.97] transition-all duration-200 text-white px-4 py-2.5 rounded-2xl text-xs font-bold flex items-center gap-2 backdrop-blur-md shadow-xs">
                <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
                <i class="fa-solid fa-camera text-[12px]"></i> Check In
              </a>
            </div>

            <div class="w-full pt-4 relative z-10">
              <div class="flex items-center gap-1.5 text-[11px] text-blue-100/80 font-semibold tracking-wide">
                <i class="fa-regular fa-calendar-check text-xs text-blue-300"></i>
                <span><%= new Date().toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></span>
              </div>
            </div>

          </div>
          <h3 class="text-xs font-bold  uppercase tracking-wider mb-6">Featured</h3>
          <div class="grid grid-cols-4 gap-x-2 gap-y-6">



            <!-- CUTI -->
            <!-- CUTI & IZIN (AGREGATOR HUB) -->
            <a href="/leave-permit" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-indigo-50/70 text-indigo-600 border border-indigo-100/20 shadow-[0_6px_16px_rgba(79,70,229,0.02)] transition-all duration-200 active:scale-95 group-hover:bg-indigo-100/50">
                <i class="fa-solid fa-calendar-check text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Cuti & Izin</span>
            </a>

            <!-- LEMBUR -->
            <a href="/overtime/new" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-purple-50/70 text-purple-600 border border-purple-100/20 shadow-[0_6px_16px_rgba(139,92,246,0.03)] transition-all duration-200 active:scale-95 group-hover:bg-purple-100/50">
                <i class="fa-solid fa-user-clock text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Lembur</span>
            </a>

            <!-- DINAS LUAR -->
            <a href="/trip/new" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-indigo-50/70 text-indigo-600 border border-indigo-100/20 shadow-[0_6px_16px_rgba(79,70,229,0.03)] transition-all duration-200 active:scale-95 group-hover:bg-indigo-100/50">
                <i class="fa-solid fa-route text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Dinas Luar</span>
            </a>

            <!-- SALES VISIT -->
            <a href="/sales/new" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-rose-50/70 text-rose-600 border border-rose-100/20 shadow-[0_6px_16px_rgba(244,63,94,0.03)] transition-all duration-200 active:scale-95 group-hover:bg-rose-100/50">
                <i class="fa-solid fa-map-pin text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Kunjungan Sales</span>
            </a>

            <!-- JURNAL -->
            <a href="/daily-log" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-teal-50/70 text-teal-600 border border-teal-100/20 shadow-[0_6px_16px_rgba(20,184,166,0.03)] transition-all duration-200 active:scale-95 group-hover:bg-teal-100/50">
                <i class="fa-solid fa-pen-to-square text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Jurnal</span>
            </a>

            <!-- SLIP GAJI -->
            <a href="/payroll/my-slip" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-orange-50/70 text-orange-600 border border-orange-100/20 shadow-[0_6px_16px_rgba(249,115,22,0.03)] transition-all duration-200 active:scale-95 group-hover:bg-orange-100/50">
                <i class="fa-solid fa-receipt text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Slip Gaji</span>
            </a>

            <!-- KLAIM -->
            <a href="/expense/create" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-cyan-50/70 text-cyan-600 border border-cyan-100/20 shadow-[0_6px_16px_rgba(6,182,212,0.03)] transition-all duration-200 active:scale-95 group-hover:bg-cyan-100/50">
                <i class="fa-solid fa-file-invoice text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Klaim Beban</span>
            </a>

            <!-- PINJAMAN -->
            <a href="/loans/new" class="group flex flex-col items-center gap-2 text-center">
              <div class="flex h-13 w-13 items-center justify-center rounded-2xl bg-violet-50/70 text-violet-600 border border-violet-100/20 shadow-[0_6px_16px_rgba(109,40,217,0.03)] transition-all duration-200 active:scale-95 group-hover:bg-violet-100/50">
                <i class="fa-solid fa-hand-holding-dollar text-base"></i>
              </div>
              <span class="text-[11px] font-medium text-slate-600 tracking-tight leading-none">Kasbon</span>
            </a>

          </div>
          <div class="mt-10 px-1">
            <h3 class="text-xs font-bold uppercase tracking-wider mb-6">Management Hub</h3>
            <div class="grid grid-cols-4 gap-3">

              <a href="/management/employees" class="group flex flex-col items-center gap-1.5 text-center">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-slate-900 text-white  shadow-xs transition-all active:scale-95">
                  <i class="fa-solid fa-users text-sm"></i>
                </div>
                <span class="text-[10px] font-bold text-slate-700 tracking-tight leading-none">Data Pegawai</span>
              </a>

              <a href="/management/kpi" class="group flex flex-col items-center gap-1.5 text-center">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-50 text-purple-600 border border-purple-100/30 shadow-xs transition-all active:scale-95">
                  <i class="fa-solid fa-chart-simple text-sm"></i>
                </div>
                <span class="text-[10px] font-bold text-slate-700 tracking-tight leading-none">Lihat KPI</span>
              </a>

              <a href="/management/report/attendance" class="group flex flex-col items-center gap-1.5 text-center">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-600 border border-blue-100/30 shadow-xs transition-all active:scale-95">
                  <i class="fa-solid fa-calendar-check text-sm"></i>
                </div>
                <span class="text-[10px] font-bold text-slate-700 tracking-tight leading-none">Lap. Absen</span>
              </a>

              <a href="/management/report/analytics" class="group flex flex-col items-center gap-1.5 text-center">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-rose-50 text-rose-600 border border-rose-100/30 shadow-xs transition-all active:scale-95">
                  <i class="fa-solid fa-chart-line text-sm"></i>
                </div>
                <span class="text-[10px] font-bold text-slate-700 tracking-tight leading-none">Lap. Lengkap</span>
              </a>

            </div>
          </div>
          <div class="mt-8 border-t border-slate-100 pt-6">
           <div class="flex items-center justify-between mb-5 border-b border-slate-100/80 pb-3">
  <h3 class="text-[13px] font-semibold text-slate-700 tracking-tight">
    Pengumuman Terbaru
  </h3>
  
  <div class="flex items-center gap-4">
    <a href="/announcement/new" class="inline-flex items-center gap-1 text-[12px] font-medium text-slate-500 hover:text-blue-600 transition-colors">
      <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      <span class="hidden sm:inline">Buat</span>
    </a>

    <a href="/announcement" class="text-[12px] font-medium text-blue-600 hover:text-blue-700 transition-colors">
      Lihat Semua
    </a>
  </div>
</div>
            <div class="space-y-3">
              <% if (typeof latestAnnouncements !== 'undefined' && latestAnnouncements.length > 0) { %>
              <% latestAnnouncements.slice(0, 2).forEach(ann => { %>
              <a href="/announcement/<%= ann._id %>" class="flex items-center gap-4 p-4 rounded-2xl border border-slate-200/40 bg-slate-50/40 hover:bg-slate-50 transition">

                <% if (ann.category === 'OFFICIAL') { %>
                <div class="w-11 h-11 rounded-xl bg-blue-50 border border-blue-100/40 flex items-center justify-center text-blue-600 shrink-0">
                  <i class="fa-solid fa-bullhorn text-sm"></i>
                </div>
                <% } else { %>
                <div class="w-11 h-11 rounded-xl bg-slate-50 border border-slate-200/50 flex items-center justify-center text-slate-500 shrink-0">
                  <i class="fa-solid fa-leaf text-sm text-emerald-600"></i>
                </div>
                <% } %>

                <div class="min-w-0 flex-1 space-y-0.5">
                  <p class="text-xs font-bold text-slate-800 truncate tracking-tight"><%= ann.title %></p>

                  <!-- DESKRIPSI ISI PENGUMUMAN DENGAN PEMBATASAN SATU BARIS -->
                  <p class="text-[11px] text-slate-400 font-normal line-clamp-1 leading-tight">
                    <%= ann.content %>
                  </p>

                  <p class="text-[10px] text-slate-400/80 font-medium tracking-wide pt-0.5">
                    <%= ann.category === 'OFFICIAL' ? 'Resmi' : 'Umum' %> •
                    <%= new Date(ann.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </p>
                </div>
              </a>
              <% }) %>
              <% } else { %>
              <div class="p-5 text-center text-xs text-slate-400 bg-slate-50/50 rounded-2xl border border-slate-200/20">
                Belum ada pengumuman terbaru.
              </div>
              <% } %>
            </div>
          </div>

        </div>
        <% } %>

        <div class="<%= typeof title !== 'undefined' && title.toLowerCase().includes('dashboard') ? 'hidden md:block' : '' %>">
          <%- body -%>
        </div>
      </div>
    </main>
  </div>

  <div class="fixed inset-x-0 bottom-0 z-[999] flex items-center justify-around border-t border-slate-200/60 bg-white px-2 py-2 shadow-[0_-4px_16px_rgba(0,0,0,0.02)] md:hidden">
    <a href="/dashboard" class="flex flex-1 flex-col items-center gap-1 text-blue-600 transition">
      <i class="fa-solid fa-house text-lg"></i>
      <span class="text-[10px] font-medium">Beranda</span>
    </a>
    <a href="/attendance/history" class="flex flex-1 flex-col items-center gap-1 text-slate-500 transition hover:text-blue-600">
      <i class="fa-solid fa-clock-rotate-left text-lg"></i>
      <span class="text-[10px] font-medium">Absensi</span>
    </a>
    <div class="flex-1 flex justify-center relative -top-4">
      <button type="button" onclick="toggleQuickMenuMobile()" class="w-12 h-12 bg-blue-600 hover:bg-blue-700 text-white rounded-full flex items-center justify-center shadow-md shadow-blue-600/20 active:scale-95 transition border-4 border-white">
        <i id="quickMenuIconMobile" class="fa-solid fa-plus text-lg transition-transform duration-200"></i>
      </button>
    </div>

    <a href="/leave/manage-requests" class="relative flex flex-1 flex-col items-center gap-1 text-slate-500 transition hover:text-blue-600">
      <i class="fa-solid fa-envelope-open-text text-lg"></i>
      <span class="text-[10px] font-medium">Persetujuan</span>
      <span class="absolute top-0 right-4 flex h-4 min-w-4 items-center justify-center rounded-full border border-white bg-red-500 px-1 text-[8px] font-bold text-white">0</span>
    </a>

    <div class="relative flex flex-1 flex-col items-center gap-1 text-slate-500 transition">
      <button type="button" onclick="toggleAccountMenuMobile()" class="flex flex-col items-center gap-1 text-slate-500 hover:text-blue-600 focus:outline-none">
        <i class="fa-solid fa-circle-user text-lg"></i>
        <span class="text-[10px] font-medium">Akun</span>
      </button>

      <div id="accountDropdownMobile" class="hidden absolute bottom-14 right-2 w-44 bg-white border border-slate-200/60 rounded-2xl shadow-xl p-1.5 flex flex-col space-y-0.5 z-[1000]">
        <a href="/employee/detail/<%= typeof user !== 'undefined' ? user?.employeeId : '' %>" class="w-full text-left px-3 py-2 text-[11px] font-semibold text-slate-700 hover:bg-slate-50 rounded-xl flex items-center gap-2">
          <i class="fa-solid fa-user text-slate-400 w-3.5"></i> Lihat Informasi
        </a>
        <a href="/settings" class="w-full text-left px-3 py-2 text-[11px] font-semibold text-slate-700 hover:bg-slate-50 rounded-xl flex items-center gap-2">
          <i class="fa-solid fa-user-gear text-slate-400 w-3.5"></i> Edit Akun
        </a>
        <div class="border-t border-slate-100 my-1"></div>
        <a href="/logout" onclick="localStorage.clear();" class="w-full text-left px-3 py-2 text-[11px] font-bold text-red-600 hover:bg-red-50 rounded-xl flex items-center gap-2">
          <i class="fa-solid fa-right-from-bracket text-red-400 w-3.5"></i> Keluar
        </a>
      </div>
    </div>
  </div>

  <div id="quickActionMenuMobile" class="fixed inset-0 z-[998] hidden bg-slate-950/30 backdrop-blur-xs md:hidden transition-opacity duration-200" onclick="toggleQuickMenuMobile()">
    <div class="absolute bottom-20 inset-x-4 bg-white rounded-3xl p-5 shadow-2xl space-y-3 transform translate-y-10 transition-transform duration-200" onclick="event.stopPropagation()">
      <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider px-1">Buat Pengajuan</h3>
      <div class="grid grid-cols-3 gap-2">
        <a href="/leave/apply" class="flex flex-col items-center p-3 rounded-2xl bg-slate-50 hover:bg-blue-50 border border-slate-100 text-center gap-1.5">
          <div class="w-9 h-9 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center"><i class="fa-solid fa-plane-departure text-xs"></i></div>
          <span class="text-[10px] font-semibold text-slate-700">Cuti</span>
        </a>
        <a href="/permit/new" class="flex flex-col items-center p-3 rounded-2xl bg-slate-50 hover:bg-amber-50 border border-slate-100 text-center gap-1.5">
          <div class="w-9 h-9 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center"><i class="fa-solid fa-shield-halved text-xs"></i></div>
          <span class="text-[10px] font-semibold text-slate-700">Izin</span>
        </a>
        <a href="/loans/new" class="flex flex-col items-center p-3 rounded-2xl bg-slate-50 hover:bg-purple-50 border border-slate-100 text-center gap-1.5">
          <div class="w-9 h-9 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center"><i class="fa-solid fa-wallet text-xs"></i></div>
          <span class="text-[10px] font-semibold text-slate-700">Pinjaman</span>
        </a>
      </div>
    </div>
  </div>

  <div id="confirmModal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-slate-950/50 p-4 backdrop-blur-sm">
    <div class="w-full max-w-md overflow-hidden rounded-3xl bg-white shadow-2xl">
      <div class="relative border-b border-slate-100 px-6 py-5">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-amber-500 via-orange-500 to-red-500"></div>
        <div class="flex items-start gap-4">
          <div id="confirmModalIcon" class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-amber-50">
            <i class="fas fa-triangle-exclamation text-xl text-amber-600"></i>
          </div>
          <div class="flex-1">
            <h3 id="confirmModalTitle" class="text-lg font-semibold text-slate-900">Konfirmasi Tindakan</h3>
            <p class="mt-1 text-sm text-slate-500">Mohon periksa kembali sebelum melanjutkan.</p>
          </div>
        </div>
      </div>
      <div class="px-6 py-5">
        <p id="confirmModalMessage" class="text-sm leading-relaxed text-slate-600">Apakah Anda yakin ingin melanjutkan tindakan ini?</p>
      </div>
      <div class="flex items-center justify-end gap-3 border-t border-slate-100 bg-slate-50/70 px-6 py-4">
        <button type="button" onclick="closeConfirmModal()" class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Batal</button>
        <button type="button" id="confirmModalButton" class="rounded-xl bg-red-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-red-700">Ya, Lanjutkan</button>
      </div>
    </div>
  </div>

  <div id="toastContainer" class="pointer-events-auto fixed top-5 right-5 z-[99999] flex flex-col gap-3.5"></div>

  <script src="/js/custom-modal.js"></script>
  <script src="/js/sidebar-handler.js"></script>
  <script src="/js/notification-handler.js"></script>

  <script>
    function toggleQuickMenuMobile() {
      const menu = document.getElementById('quickActionMenuMobile');
      const icon = document.getElementById('quickMenuIconMobile');
      document.getElementById('accountDropdownMobile').classList.add('hidden');
      if (menu.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        setTimeout(() => menu.querySelector('div').classList.remove('translate-y-10'), 10);
        icon.classList.add('rotate-45');
      } else {
        menu.querySelector('div').classList.add('translate-y-10');
        setTimeout(() => menu.classList.add('hidden'), 150);
        icon.classList.remove('rotate-45');
      }
    }

    function toggleAccountMenuMobile() {
      const dropdown = document.getElementById('accountDropdownMobile');
      dropdown.classList.toggle('hidden');
    }

    document.addEventListener('click', function(e) {
      const dropdown = document.getElementById('accountDropdownMobile');
      if (dropdown && !dropdown.contains(e.target) && !e.target.closest('button[onclick="toggleAccountMenuMobile()"]')) {
        dropdown.classList.add('hidden');
      }
    });

    if (document.getElementById('liveClockMobile')) {
      setInterval(() => {
        const now = new Date();
        document.getElementById('liveClockMobile').textContent = now.toLocaleTimeString('id-ID', {
          hour12: false
        });
      }, 1000);
    }

    function triggerGlobalToast({
      title = "Info",
      message = "",
      type = "success"
    }) {
      const container = document.getElementById("toastContainer");
      if (!container) return;
      const styles = {
        success: {
          icon: "fa-circle-check",
          iconColor: "text-emerald-500",
          accentBorder: "border-l-emerald-500"
        },
        error: {
          icon: "fa-circle-xmark",
          iconColor: "text-rose-500",
          accentBorder: "border-l-rose-500"
        }
      };
      const s = styles[type] || styles.success;
      const toast = document.createElement("div");
      toast.className = "w-[360px] rounded-xl border border-slate-200/60 border-l-4 " + s.accentBorder + " bg-white/95 backdrop-blur-md shadow-md p-4 transform translate-x-20 opacity-0 transition-all duration-300 ease-out";
      toast.innerHTML =
        '<div class="flex items-start gap-3">' +
        '<div class="flex-shrink-0 mt-0.5"><i class="fa-solid ' + s.icon + ' ' + s.iconColor + ' text-lg"></i></div>' +
        '<div class="flex-1 min-w-0 text-left">' +
        '<h4 class="text-[13px] font-bold text-slate-900 tracking-tight">' + title + '</h4>' +
        '<p class="mt-0.5 text-xs font-medium text-slate-500 leading-relaxed break-words">' + message + '</p>' +
        '</div>' +
        '<button class="text-slate-400 hover:text-slate-600 transition-colors flex-shrink-0 p-0.5 hover:bg-slate-100 rounded-lg"><i class="fa-solid fa-xmark text-xs"></i></button>' +
        '</div>';
      container.appendChild(toast);
      setTimeout(() => {
        toast.classList.remove("translate-x-20", "opacity-0");
        toast.classList.add("translate-x-0", "opacity-100");
      }, 50);
      const closeToast = () => {
        toast.classList.remove("translate-x-0", "opacity-100");
        toast.classList.add("translate-x-10", "opacity-0");
        setTimeout(() => toast.remove(), 300);
      };
      toast.querySelector("button").addEventListener("click", closeToast);
      setTimeout(closeToast, 4000);
    }
  </script>
</body>

</html>
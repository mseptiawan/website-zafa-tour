<%- layout('layouts/main', { title }) %>

<style>
  /* Efek Glassmorphism Halus untuk UI Monitor */
  .dashboard-card {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.8);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
    transition: all 0.2s ease-in-out;
  }
  .dashboard-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
    border-color: rgba(191, 219, 254, 1); 
  }
</style>

<div class="min-h-screen ml-72 bg-[#f8fafc] p-8 antialiased text-slate-800">
  <div class="mx-auto max-w-none space-y-8">

    <div class="mb-6 border-b border-slate-200/60 pb-5">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        
        <div class="grow">
          <%- include('../partials/page-header', { 
              section: 'Operasional Finansial', 
              module: 'Informasi', 
              title: 'Rekapitulasi Penggajian Pegawai', 
              description: 'Halaman terpusat pantauan akumulasi beban bruto, total potongan, serta take home pay bersih karyawan.' 
          }) %>
        </div>

        <div class="flex flex-wrap items-center gap-3 self-end md:self-center shrink-0">
          <form method="GET" action="/report/payroll" class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl p-1 h-10 shadow-2xs">
            <div class="flex items-center gap-2 px-2">
              <i class="fa-solid fa-filter text-slate-400 text-[10px]"></i>
              <span class="text-slate-400 text-xs font-bold uppercase tracking-wider">Periode:</span>
              <input type="month" name="periodMonth" id="filterPeriod" value="<%= filters.periodMonth %>" class="bg-transparent text-xs font-bold text-slate-700 outline-none cursor-pointer">
            </div>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold h-8 px-4 rounded-lg transition-all cursor-pointer">
              Saring
            </button>
          </form>

          <a href="/report/payroll/download-pdf?periodMonth=<%= filters.periodMonth %>" 
             class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold h-10 px-5 rounded-xl shadow-xs transition-all flex items-center gap-2 cursor-pointer active:scale-95">
            <i class="fa-solid fa-file-pdf text-sm"></i> Unduh PDF Laporan
          </a>
        </div>

      </div>
    </div>

    <%
      const statItems = [
        {
          label: 'Akumulasi Gaji Bruto',
          value: new Intl.NumberFormat('id-ID').format(analytics.totalEarnings),
          icon: 'fa-solid fa-wallet',
          iconBoxClass: 'bg-blue-50 text-blue-600'
        },
        {
          label: 'Total Retensi & Potongan',
          value: new Intl.NumberFormat('id-ID').format(analytics.totalDeductions),
          icon: 'fa-solid fa-percentage',
          iconBoxClass: 'bg-blue-50 text-blue-600'
        },
        {
          label: 'Beban Bersih (Take Home Pay)',
          value: new Intl.NumberFormat('id-ID').format(analytics.totalNet),
          icon: 'fa-solid fa-money-bill-wave',
          iconBoxClass: 'bg-emerald-50 text-emerald-600'
        }
      ];
    %>

    <div class="grid grid-cols-3 gap-5 w-full select-none">
      <% statItems.forEach(item => { %>
        <div class="bg-white rounded-2xl p-5 flex items-center justify-between shadow-xs border border-slate-200/80 w-full min-w-0 dashboard-card">
          <div class="space-y-1 min-w-0 flex-1">
            <span class="text-[12px] font-bold text-slate-400 uppercase tracking-wider block md:truncate">
              <%= item.label %>
            </span>
            <span class="text-2xl font-bold text-slate-900 tracking-tight tabular-nums block truncate">
              <span class="text-sm font-medium text-slate-400">Rp</span> <%= item.value %> 
            </span>
          </div>
          <div class="flex w-10 h-10 rounded-xl items-center justify-center <%= item.iconBoxClass %> shrink-0 ml-2">
            <i class="<%= item.icon %> text-sm"></i>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 space-y-4">
      <div>
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Matriks Komparasi Gaji Pegawai</h3>
        <p class="text-[11px] text-slate-500">Rincian lembar data slip gaji resmi yang diterbitkan untuk tim</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% if (listPayroll.length === 0) { %>
          <div class="col-span-full p-8 text-center text-slate-400 text-xs border border-dashed border-slate-200 rounded-xl bg-slate-50/50">
            Belum ada data slip gaji yang di-generate (Tutup Buku) untuk periode ini.
          </div>
        <% } else { %>
          <% listPayroll.forEach((p) => { 
               let empName = p.employeeId && p.employeeId.fullName ? p.employeeId.fullName : "Anonim";
          %>
            <div class="dashboard-card p-4 rounded-xl text-xs space-y-3">
              <div class="flex justify-between items-start border-b border-slate-100 pb-2">
                <div class="truncate pr-2">
                  <span class="font-bold text-slate-900 block truncate text-sm">
                    <%= empName %>
                  </span>
                </div>
                <span class="text-[9px] bg-slate-100 text-slate-600 px-2 py-0.5 rounded font-bold tracking-wider uppercase shrink-0">
                  <%= p.status %>
                </span>
              </div>
              
              <div class="flex justify-between items-center text-[11px]">
                <div class="space-y-1 font-medium text-slate-500">
                  <span class="block">Bruto : <span class="text-slate-800 font-semibold">Rp <%= new Intl.NumberFormat('id-ID').format(p.totalEarnings) %></span></span>
                  <span class="block">Potongan : <span class="text-slate-800 font-semibold">Rp <%= new Intl.NumberFormat('id-ID').format(p.totalDeductions) %></span></span>
                </div>
                <div class="text-right border-l border-slate-100 pl-3 bg-blue-50/60 border border-blue-100 p-2 rounded-lg min-w-[125px]">
                  <span class="block text-[9px] text-blue-500 font-bold uppercase tracking-wider mb-0.5">Take Home Pay</span>
                  <span class="block font-bold text-blue-700 text-xs">Rp <%= new Intl.NumberFormat('id-ID').format(p.netTakeHomePay) %></span>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

  </div>
</div>
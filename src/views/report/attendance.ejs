<%- layout('layouts/main', { title }) %>

<style>
  /* =========================================================================
     DESAIN PREMIUM & KONTROL CETAK ELEGAN
     ========================================================================= */
  #report-print-zone {
    display: none;
  }

  /* Efek Glassmorphism Halus untuk UI Monitor */
  .dashboard-card {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.8);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
    transition: all 0.2s ease-in-out;
  }
  .dashboard-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
    border-color: rgba(191, 219, 254, 1); 
  }

  @media print {
    html, body, body * {
      visibility: hidden !important;
      background: transparent !important;
    }
    
    #report-print-zone, #report-print-zone * {
      visibility: visible !important;
    }
    
    #report-print-zone {
      display: block !important;
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      border: none !important;
      box-shadow: none !important;
      color: #0f172a !important;
    }

    .yellow-print-header {
      background-color: #fef08a !important; 
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color: #1e293b !important;
    }

    tr { page-break-inside: avoid; }
  }

  .formal-print-text {
    color: #1e293b;
  }
</style>

<div class="min-h-screen ml-72 bg-[#f8fafc] p-8 antialiased text-slate-800">
  <div class="mx-auto max-w-7xl space-y-8">

    <div class="mb-6 border-b border-slate-200/60 pb-5 no-print">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        
        <div class="grow">
          <%- include('../partials/page-header', { 
              section: 'Operasional Internal', 
              module: 'Informasi', 
              title: 'Metrik Kehadiran Kerja', 
              description: 'Pantau catatan presensi, tren sebaran lokasi penugasan, dan durasi keterlambatan tim secara berkala.' 
          }) %>
        </div>

        <div class="flex flex-wrap items-center gap-3 self-end md:self-center shrink-0">
          <form method="GET" action="/report/attendance" class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl p-1 h-10 shadow-2xs">
            <div class="flex items-center gap-1 px-2">
              <i class="fa-solid fa-filter text-slate-400 text-[10px]"></i>
              <input type="date" name="startDate" id="filterStartDate" value="<%= filters.startDate %>" class="bg-transparent text-xs font-semibold text-slate-600 outline-none">
              <span class="text-slate-300 text-xs">-</span>
              <input type="date" name="endDate" id="filterEndDate" value="<%= filters.endDate %>" class="bg-transparent text-xs font-semibold text-slate-600 outline-none">
            </div>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold h-8 px-4 rounded-lg transition-all cursor-pointer">
              Saring
            </button>
          </form>

          <button onclick="executePrintAttendanceReport()" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold h-10 px-5 rounded-xl shadow-xs transition-all flex items-center gap-2 cursor-pointer active:scale-95">
            <i class="fa-solid fa-file-pdf text-sm"></i> Cetak Laporan
          </button>
        </div>

      </div>
    </div>

    <% 
      let kantorCount = 0; let luarKantorCount = 0;
      listAttendance.forEach(item => {
        if(item.type === 'KANTOR') kantorCount++;
        if(item.type === 'LUAR KANTOR') luarKantorCount++;
      });
      let totalLoc = (kantorCount + luarKantorCount) || 1;
      let pctKantor = Math.round((kantorCount / totalLoc) * 100);
      let pctLuar = Math.round((luarKantorCount / totalLoc) * 100);
    %>
    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-xs no-print space-y-4 select-none">
      <div class="flex items-center justify-between border-b border-slate-100 pb-3">
        <div>
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Sebaran Lokasi Kerja</h3>
          <p class="text-[11px] text-slate-500">Perbandingan riwayat absensi masuk berdasarkan titik koordinat presensi</p>
        </div>
        <span class="text-xs bg-slate-50 text-slate-600 font-bold px-3 py-1 rounded-lg border border-slate-200/60">
          Total Log: <%= listAttendance.length %> Baris
        </span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="dashboard-card p-4 rounded-xl flex items-center justify-between bg-white border border-slate-100">
          <div class="flex items-center gap-3.5 min-w-0">
            <div class="w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center shrink-0 text-blue-600">
              <i class="fa-solid fa-building text-sm"></i>
            </div>
            <div class="min-w-0">
              <span class="text-xs font-bold text-slate-900 block mb-0.5">Kantor Utama Palembang</span>
              <span class="text-[11px] text-slate-500 block truncate font-medium"><%= kantorCount %> Kali validasi koordinat</span>
            </div>
          </div>
          <div class="text-right shrink-0">
            <span class="inline-flex items-center justify-center bg-blue-50 text-blue-700 font-bold px-2.5 py-1 rounded-md text-xs border border-blue-100">
              <%= pctKantor %>%
            </span>
          </div>
        </div>

        <div class="dashboard-card p-4 rounded-xl flex items-center justify-between bg-white border border-slate-100">
          <div class="flex items-center gap-3.5 min-w-0">
            <div class="w-10 h-10 rounded-xl bg-blue-50/60 border border-blue-100/70 flex items-center justify-center shrink-0 text-blue-400">
              <i class="fa-solid fa-map-location-dot text-sm"></i>
            </div>
            <div class="min-w-0">
              <span class="text-xs font-bold text-slate-900 block mb-0.5">Dinas Luar / Lapangan</span>
              <span class="text-[11px] text-slate-500 block truncate font-medium"><%= luarKantorCount %> Kali pelacakan GPS</span>
            </div>
          </div>
          <div class="text-right shrink-0">
            <span class="inline-flex items-center justify-center bg-blue-50 text-blue-600 font-bold px-2.5 py-1 rounded-md text-xs border border-blue-100">
              <%= pctLuar %>%
            </span>
          </div>
        </div>
      </div>
    </div>

    <%
      let userReportMap = {};
      listAttendance.forEach(item => {
        let name = item.fullName;
        if (!name || name === "-" || name.trim() === "") {
          if (item.userId && (item.userId.username || item.userId)) {
            name = item.userId.username || item.userId;
          } else {
            return;
          }
        }
        name = name.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join(' ');

        if(!userReportMap[name]) {
          userReportMap[name] = { hadir: 0, telat: 0, menitTelat: 0, alpa: 0 };
        }
        if(item.status === 'HADIR') userReportMap[name].hadir++;
        if(item.status === 'TELAT') {
          userReportMap[name].telat++;
          userReportMap[name].menitTelat += parseInt(item.lateDuration || 0);
        }
        if(item.status === 'BELUM ABSEN' || item.status === 'ALPHA') {
          userReportMap[name].alpa++;
        }
      });
    %>

    <%
      const statItems = [
        {
          label: 'Presensi Sukses',
          value: analytics.totalHadir,
          unit: 'Log masuk',
          icon: 'fa-solid fa-square-check',
          labelClass: 'text-slate-400',
          valueClass: 'text-slate-900',
          unitClass: 'text-slate-500',
          iconBoxClass: 'bg-blue-50 text-blue-600'
        },
        {
          label: 'Total Keterlambatan',
          value: analytics.totalLateDays,
          unit: 'Hari kerja',
          icon: 'fa-solid fa-triangle-exclamation',
          labelClass: 'text-slate-400',
          valueClass: 'text-slate-900',
          unitClass: 'text-slate-500',
          iconBoxClass: 'bg-blue-50 text-blue-600'
        },
        {
          label: 'Beban Kebocoran Waktu',
          value: analytics.totalLateMinutes,
          unit: 'Menit terbuang',
          icon: 'fa-solid fa-hourglass-half',
          labelClass: 'text-slate-400',
          valueClass: 'text-slate-900',
          unitClass: 'text-slate-500',
          iconBoxClass: 'bg-amber-50 text-amber-600'
        }
      ];
    %>

    <div class="grid grid-cols-3 gap-1.5 sm:gap-3 md:gap-5 w-full select-none no-print">
      <% statItems.forEach(item => { %>
        <div class="bg-white rounded-xl md:rounded-2xl p-2 md:p-5 flex items-center justify-between shadow-xs border border-slate-200/80 w-full min-w-0 dashboard-card">
          <div class="space-y-0.5 md:space-y-1 min-w-0 flex-1">
            <span class="text-[8.5px] sm:text-[11px] md:text-[12px] font-bold <%= item.labelClass || 'text-slate-400' %> uppercase tracking-wider block whitespace-normal break-words leading-tight md:truncate">
              <%= item.label %>
            </span>
            <span class="text-sm sm:text-base md:text-2xl font-bold <%= item.valueClass || 'text-slate-900' %> tracking-tight tabular-nums block truncate">
              <%= item.value %> 
              <% if (item.unit) { %>
                <span class="text-[8px] sm:text-[9.5px] md:text-xs font-semibold <%= item.unitClass || 'text-slate-500' %> inline-block"><%= item.unit %></span>
              <% } %>
            </span>
          </div>
          <div class="hidden md:flex w-10 h-10 rounded-xl items-center justify-center <%= item.iconBoxClass || 'bg-slate-50 text-slate-600' %> shrink-0 ml-2">
            <i class="<%= item.icon %> text-sm"></i>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 space-y-4 no-print">
      <div class="flex items-center justify-between border-b border-slate-100 pb-3">
        <div>
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Matriks Kedisiplinan Rekan Kerja</h3>
          <p class="text-[11px] text-slate-500">Rincian komparasi total kehadiran serta akumulasi waktu terlambat</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% Object.keys(userReportMap).sort().forEach((name) => { 
             let uData = userReportMap[name];
        %>
          <div class="dashboard-card p-4 rounded-xl text-xs space-y-3">
            <span class="font-bold text-slate-900 block border-b border-slate-100 pb-2 text-sm truncate"><%= name %></span>
            
            <div class="flex justify-between items-center text-[11px]">
              <div class="space-y-1 font-medium text-slate-500">
                <span class="block">Hadir : <span class="text-slate-800 font-bold"><%= uData.hadir %> Hari</span></span>
                <span class="block">Telat : <span class="text-slate-800 font-bold"><%= uData.telat %> Kali</span></span>
              </div>
              <div class="text-right border-l border-slate-100 pl-3 bg-blue-50/60 border border-blue-100 p-2 rounded-lg min-w-[110px]">
                <span class="block text-[9px] text-blue-500 font-bold uppercase tracking-wider mb-0.5">Waktu Telat / Bulan</span>
                <span class="block font-bold text-blue-700 text-xs"><%= uData.menitTelat %> Menit</span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div id="report-print-zone" class="bg-white p-4 space-y-6 text-black formal-print-text"></div>

  </div>
</div>

<script>
  const clientAttendanceData = <%- JSON.stringify(listAttendance) %>;

  function executePrintAttendanceReport() {
    const sDate = document.getElementById('filterStartDate').value;
    const eDate = document.getElementById('filterEndDate').value;

    let dynamicSummaryMap = {};
    let dynamicTotalHadir = 0;
    let dynamicTotalLateDays = 0;
    let dynamicTotalLateMinutes = 0;

    clientAttendanceData.forEach(item => {
      let name = item.fullName;
      if (!name || name === "-" || name.trim() === "") {
        if (item.userId && (item.userId.username || item.userId)) {
          name = item.userId.username || item.userId;
        } else {
          return; 
        }
      }
      name = name.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join(' ');

      if (!dynamicSummaryMap[name]) {
        dynamicSummaryMap[name] = { hadir: 0, telat: 0, menitTelat: 0, alpa: 0, sakitIzin: 0 };
      }

      let currentStatus = item.status ? item.status.toUpperCase() : "ALPHA";

      if (item.isMissing || currentStatus === 'BELUM ABSEN' || currentStatus === 'ALPHA') {
        dynamicSummaryMap[name].alpa++;
      } 
      else if (currentStatus === 'HADIR') {
        dynamicSummaryMap[name].hadir++;
        dynamicTotalHadir++;
      } 
      else if (currentStatus === 'TELAT') {
        dynamicSummaryMap[name].telat++;
        let minutes = parseInt(item.lateDuration || 0);
        dynamicSummaryMap[name].menitTelat += minutes;
        
        dynamicTotalLateDays++;
        dynamicTotalLateMinutes += minutes;
      } 
      else if (currentStatus === 'SAKIT' || currentStatus === 'IZIN' || currentStatus === 'CUTI') {
        dynamicSummaryMap[name].sakitIzin++;
      }
    });

    let summaryRowsHTML = '';
    let counter = 1;
    Object.keys(dynamicSummaryMap).sort().forEach(name => {
      const uData = dynamicSummaryMap[name];
      summaryRowsHTML += `
        <tr style="border-bottom: 0.5px solid #000;">
          <td class="p-2 border-r border-black text-center">${counter++}</td>
          <td class="p-2 border-r border-black text-left" style="font-weight: bold !important;">${name}</td>
          <td class="p-2 text-center border-r border-black">${uData.hadir} Hari</td>
          <td class="p-2 text-center border-r border-black">${uData.telat} Kali</td>
          <td class="p-2 text-right border-r border-black">${uData.menitTelat} Menit</td>
          <td class="p-2 text-center">${uData.alpa} Hari</td>
        </tr>`;
    });

    const finalPrintTemplate = `
      <div class="flex justify-between items-center border-b-2 border-black pb-4">
        <div class="text-left">
          <div class="text-xl font-bold uppercase tracking-tight">PT ZAFA MULIA MANDIRI</div>
          <div class="text-[10px] tracking-wide text-gray-600">Jalan Utama Kantor Pusat, Kota Palembang</div>
          <div class="text-[9px] text-gray-500">Sistem Aplikasi Keuangan Terintegrasi</div>
        </div>
        <div class="text-right flex flex-col items-end">
          <div class="border border-black px-4 py-1 rounded-sm bg-slate-50">
            <span class="text-[10px] font-bold tracking-widest uppercase text-slate-700">AUDIT INTERNAL</span>
          </div>
          <span class="text-[16px] font-bold tracking-widest text-amber-500 mt-1">ZAFA TOUR</span>
        </div>
      </div>

      <div class="pt-4 flex justify-between items-end text-xs">
        <div class="space-y-0.5">
          <h2 class="text-sm font-bold uppercase tracking-wide">Laporan Rekapitulasi Absensi Pegawai</h2>
          <p class="text-gray-600">Periode Saring : ${sDate || '-'} s/d ${eDate || '-'}</p>
        </div>
        <div class="text-right text-[11px]">
          <div>Tanggal Cetak: <span class="font-bold">${new Date().toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span></div>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-4 text-xs pt-4">
        <div class="border border-black p-3" style="text-align: left;">
          <span class="block text-[10px] text-gray-500 uppercase font-bold tracking-wide">Total Presensi Sukses</span>
          <span class="text-sm font-bold">${dynamicTotalHadir} Rekor</span>
        </div>
        <div class="border border-black p-3" style="text-align: left;">
          <span class="block text-[10px] text-gray-500 uppercase font-bold tracking-wide">Total Kasus Terlambat</span>
          <span class="text-sm font-bold">${dynamicTotalLateDays} Hari</span>
        </div>
        <div class="border border-black p-3" style="text-align: left;">
          <span class="block text-[10px] text-gray-500 uppercase font-bold tracking-wide">Akumulasi Menit Terlambat</span>
          <span class="text-sm font-bold">${dynamicTotalLateMinutes} Menit</span>
        </div>
      </div>

      <div class="border-2 border-black mt-4 overflow-hidden rounded-xs">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="yellow-print-header border-b-2 border-black">
              <th class="p-2 border-r border-black text-center font-bold" style="width: 5%;">NO</th>
              <th class="p-2 border-r border-black text-left font-bold" style="width: 35%;">NAMA REKAN KERJA</th>
              <th class="p-2 border-r border-black text-center font-bold" style="width: 15%;">HADIR TEPAT WAKTU</th>
              <th class="p-2 border-r border-black text-center font-bold" style="width: 15%;">FREKUENSI TELAT</th>
              <th class="p-2 border-r border-black text-right font-bold" style="width: 15%;">DURASI TERLAMBAT</th>
              <th class="p-2 text-center font-bold">JUMLAH ALPA</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-black bg-white">
            ${summaryRowsHTML}
          </tbody>
        </table>
      </div>

      <div class="pt-8 flex justify-between items-start text-xs">
        <div class="text-[9px] text-gray-400 italic max-w-sm">
          *Data rekapitulasi kehadiran ini diunduh secara digital langsung dari sistem administrasi HRIS Kantor Utama Palembang PT Zafa Mulia Mandiri.
        </div>
        <div class="text-center pr-8 space-y-16">
          <div class="space-y-1">
            <span class="block font-medium">Palembang, ${new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            <span class="block font-bold uppercase">Manajer Administrasi / HRD</span>
          </div>
          <div class="inline-block border-t-2 border-black pt-1 px-8 font-bold">
            Verifikasi Aplikasi HRIS
          </div>
        </div>
      </div>
    `;

    const printZone = document.getElementById('report-print-zone');
    if (printZone) {
      printZone.innerHTML = finalPrintTemplate;
      window.print();
    }
  }
</script>
<%- layout('layouts/main', { title: 'Pusat Approval Lembur' }) %>

<div class=" min-h-screen md:ml-72 bg-slate-50/50  antialiased selection:bg-blue-50 selection:text-blue-600">
  <div class="w-full max-w- mx-auto space-y-8">

    <%- include('../partials/page-header', {
      section: 'Kepegawaian',
      module: 'Manajemen Waktu',
      title: 'Pusat Approval Lembur',
      description: 'Sistem pengawasan, persetujuan, dan pencatatan riwayat lembur pegawai.'
    }) %>

    <%- include('../partials/_stats-grid', {
      items: [
        { 
          label: 'Menunggu Approval', 
          value: activeOvertimes.length, 
          unit: 'Berkas', 
          icon: 'fa-solid fa-clock-rotate-left', 
          bgClass: 'bg-white border-slate-200/60', 
          iconBoxClass: 'bg-amber-50 text-amber-600 border-amber-100' 
        },
        { 
          label: 'Selesai Diproses', 
          value: historyOvertimes.length, 
          unit: 'Berkas', 
          icon: 'fa-solid fa-circle-check', 
          bgClass: 'bg-white border-slate-200/60', 
          iconBoxClass: 'bg-blue-50 text-blue-600 border-blue-100' 
        },
        { 
          label: 'Total Pengajuan', 
          value: (activeOvertimes.length + historyOvertimes.length), 
          unit: 'Keseluruhan', 
          icon: 'fa-solid fa-chart-pie', 
          bgClass: 'bg-gradient-to-br from-slate-900 to-slate-800 border-slate-800', 
          labelClass: 'text-slate-300', 
          valueClass: 'text-white', 
          unitClass: 'text-slate-400',
          iconBoxClass: 'bg-white/10 text-white border-transparent' 
        }
      ]
    }) %>

    <%- include('../partials/_tab-nav', {
      tabs: [
        { id: 'active', label: `Permintaan Aktif (${activeOvertimes.length})` },
        { id: 'history', label: `Riwayat Approval (${historyOvertimes.length})` }
      ]
    }) %>

    <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300 transform translate-y-0">
      <%- include('partials/_overtime-table', { 
        overtimes: activeOvertimes, 
  query: query,
        pagination: activePagination, 
        type: 'active' 
      }) %>
    </div>

    <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300 transform translate-y-2">
      <%- include('partials/_overtime-table', { 
        overtimes: historyOvertimes, 
      query: query,
        pagination: historyPagination, 
        type: 'history' 
      }) %>
    </div>

  </div>
</div>

<script>
  // Fungsi untuk menjaga tab tetap aktif jika ada parameter filter/pagination di URL
  document.addEventListener("DOMContentLoaded", () => {
    const urlParams = new URLSearchParams(window.location.search);
    const activeTab = urlParams.get('tab') || 'active';
    if(activeTab === 'history') {
      switchTab('history');
    }
  });
</script>
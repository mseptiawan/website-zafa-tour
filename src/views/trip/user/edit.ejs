<%- layout('layouts/main', { title }) %>

  <% const isRejected=trip.status==="REJECTED" ; const action=isRejected ? `/trip/${trip._id}/resubmit` :
    `/trip/${trip._id}`; const method=isRejected ? "POST" : "PUT" ; const lastReject=trip.approvals ?.slice() .reverse()
    .find(a=> a.status === "REJECTED");
    %>

    <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

      <div class="max-w-2xl mx-auto">

        <!-- HEADER -->
        <div class="mb-8">

          <nav class="flex items-center gap-2 mb-2 text-[11px] font-semibold text-slate-400 uppercase tracking-widest">
            <span>Workspace</span>
            <span>/</span>
            <span>Trip</span>
            <span>/</span>
            <span class="text-slate-700">
              <%= isRejected ? "Resubmit" : "Edit" %>
            </span>
          </nav>

          <h1 class="text-2xl font-semibold text-slate-800">
            <%= isRejected ? "Resubmit Pengajuan Dinas" : "Edit Pengajuan Dinas" %>
          </h1>

          <p class="text-sm text-slate-500 mt-1">
            <%= isRejected ? "Perbaiki pengajuan yang ditolak lalu ajukan kembali"
              : "Perbarui data pengajuan perjalanan dinas" %>
          </p>

        </div>

        <!-- ALERT -->
        <% if (isRejected) { %>

          <div class="mb-6 bg-red-50 border border-red-200 rounded-2xl p-5">

            <div class="text-sm font-semibold text-red-700">
              Pengajuan Ditolak
            </div>

            <p class="text-sm text-red-600 mt-1">
              Perbaiki data pengajuan sebelum diajukan kembali.
            </p>

            <% if (lastReject?.note) { %>

              <div class="mt-4 bg-white border border-red-100 rounded-xl p-4">

                <div class="text-[11px] font-semibold uppercase tracking-wider text-red-500 mb-2">
                  Catatan Penolakan
                </div>

                <div class="text-sm text-slate-700 leading-relaxed">
                  <%= lastReject.note %>
                </div>

              </div>

              <% } %>

          </div>

          <% } %>

            <!-- CARD -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

              <form action="<%= action %>?_method=<%= method %>" method="POST" class="p-8 space-y-6">

                <!-- TITLE -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Judul Perjalanan
                  </label>

                  <input type="text" name="title" value="<%= trip.title %>" minlength="5" maxlength="100" required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                </div>

                <!-- PURPOSE -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Tujuan Perjalanan
                  </label>

                  <select name="purpose" required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all">

                    <option value="">Pilih tujuan</option>

                    <option value="SALES_VISIT" <%=trip.purpose==="SALES_VISIT" ? "selected" : "" %>
                      >
                      Sales Visit
                    </option>

                    <option value="MEETING" <%=trip.purpose==="MEETING" ? "selected" : "" %>
                      >
                      Meeting
                    </option>

                    <option value="TRAINING" <%=trip.purpose==="TRAINING" ? "selected" : "" %>
                      >
                      Training
                    </option>

                    <option value="SURVEY" <%=trip.purpose==="SURVEY" ? "selected" : "" %>
                      >
                      Survey
                    </option>

                    <option value="OTHER" <%=trip.purpose==="OTHER" ? "selected" : "" %>
                      >
                      Other
                    </option>

                  </select>

                </div>

                <!-- DATE -->
                <div class="grid grid-cols-2 gap-4">

                  <div class="space-y-1.5">

                    <label class="text-[13px] font-semibold text-slate-700">
                      Tanggal Mulai
                    </label>

                    <input type="date" name="startDate"
                      value="<%= trip.startDate ? new Date(trip.startDate).toISOString().split('T')[0] : '' %>" required
                      class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                  </div>

                  <div class="space-y-1.5">

                    <label class="text-[13px] font-semibold text-slate-700">
                      Tanggal Selesai
                    </label>

                    <input type="date" name="endDate"
                      value="<%= trip.endDate ? new Date(trip.endDate).toISOString().split('T')[0] : '' %>" required
                      class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                  </div>

                </div>

                <!-- DESTINATION -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Tujuan / Lokasi
                  </label>

                  <input type="text" name="destination" value="<%= trip.destination %>" minlength="3" maxlength="150"
                    required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                </div>

                <!-- DESCRIPTION -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Deskripsi
                  </label>

                  <textarea name="description" rows="4" minlength="10" maxlength="1000" required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none resize-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all"><%= trip.description %></textarea>

                </div>

                <!-- BUDGET -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Budget
                  </label>

                  <input type="text" id="budget" value="<%= (trip.budget || 0).toLocaleString('id-ID') %>"
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                  <input type="hidden" name="budget" id="budgetRaw" value="<%= trip.budget %>" />

                </div>

                <!-- MEET WITH -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Bertemu Dengan
                  </label>

                  <input type="text" name="meetWith" value="<%= trip.meetWith || '' %>"
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                </div>

                <!-- TIMELINE -->
                <div class="space-y-2">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Timeline Perjalanan
                  </label>

                  <div id="timelineBox" class="space-y-2">

                    <% if (trip.timeline && trip.timeline.length) { %>

                      <% trip.timeline.forEach((t, i)=> { %>

                        <div class="flex gap-2 timeline-item">

                          <input type="text" name="timeline[<%= i %>][address]" value="<%= t.address %>" required
                            class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                          <input type="hidden" name="timeline[<%= i %>][order]" value="<%= i + 1 %>" />

                          <button type="button" onclick="removeTimeline(this)"
                            class="px-3 rounded-xl bg-red-50 text-red-500 hover:bg-red-100 transition">
                            ✕
                          </button>

                        </div>

                        <% }) %>

                          <% } %>

                  </div>

                  <button type="button" onclick="addTimeline()" class="text-sm text-indigo-600 hover:text-indigo-700">
                    + Tambah Timeline
                  </button>

                </div>

                <!-- SUBMIT -->
                <div class="pt-4 border-t border-slate-100">

                  <button type="submit" class="
              w-full
              text-white
              py-3
              rounded-xl
              text-sm
              font-medium
              transition-all

              <%= isRejected
                ? 'bg-red-600 hover:bg-red-700'
                : 'bg-slate-900 hover:bg-slate-800'
              %>
            ">
                    <%= isRejected ? "Ajukan Ulang Pengajuan" : "Simpan Perubahan" %>
                  </button>

                </div>

              </form>

            </div>

      </div>

    </div>

    <script>
      let timelineIndex = <%= trip.timeline ?trip.timeline.length: 0 %>;

      // BUDGET FORMAT
      const budgetInput = document.getElementById("budget");
      const budgetRaw = document.getElementById("budgetRaw");

      budgetInput.addEventListener("input", function (e) {

        let value = e.target.value.replace(/\D/g, "");

        budgetRaw.value = value;

        if (!value) {
          e.target.value = "";
          return;
        }

        e.target.value = Number(value)
          .toLocaleString("id-ID");
      });

      // ADD TIMELINE
      function addTimeline() {

        const box = document.getElementById("timelineBox");

        const div = document.createElement("div");

        div.className = "flex gap-2 timeline-item";

        div.innerHTML = `
      <input
        type="text"
        name="timeline[${timelineIndex}][address]"
        placeholder="Alamat berikutnya"
        required
        class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all"
      />

      <input
        type="hidden"
        name="timeline[${timelineIndex}][order]"
        value="${timelineIndex + 1}"
      />

      <button
        type="button"
        onclick="removeTimeline(this)"
        class="px-3 rounded-xl bg-red-50 text-red-500 hover:bg-red-100 transition"
      >
        ✕
      </button>
    `;

        box.appendChild(div);

        timelineIndex++;
      }

      // REMOVE
      function removeTimeline(btn) {
        btn.parentElement.remove();
      }
    </script>
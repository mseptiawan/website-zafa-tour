<%- layout('layouts/main', { title }) %>

<script>
  function toggleReceiptMode() {
    const noReceipt = document.getElementById("noReceipt").checked;

    const fileSection = document.getElementById("fileSection");
    const reasonSection = document.getElementById("reasonSection");
    const declarationSection = document.getElementById("declarationSection");

    const fileInput = document.getElementById("proofFile");
    const reasonInput = document.getElementById("noReceiptReason");
    const declarationInput = document.getElementById("selfDeclaration");

    if (noReceipt) {
      fileSection.style.opacity = "0.4";
      fileInput.disabled = true;
      fileInput.value = "";

      reasonSection.style.display = "block";
      declarationSection.style.display = "block";
    } else {
      fileSection.style.opacity = "1";
      fileInput.disabled = false;

      reasonSection.style.display = "none";
      declarationSection.style.display = "none";

      reasonInput.value = "";
      declarationInput.checked = false;
    }
  }
</script>

<div class="ml-72 min-h-screen bg-slate-50 p-6">
  <div class="max-w-3xl mx-auto">

    <div class="mb-6">
      <h1 class="text-[24px] font-medium text-slate-800">
        Ajukan Klaim Beban
      </h1>
      <p class="text-[13px] text-slate-500 mt-1">
        Input pengeluaran operasional dan upload bukti transaksi
      </p>
    </div>

    <div class="bg-white border rounded-2xl p-6">

      <form method="POST" enctype="multipart/form-data" class="space-y-5">

        <!-- BASIC INPUTS -->
        <input name="title" placeholder="Judul Pengeluaran" class="input" required />

        <select name="category" class="input">
          <option>TRANSPORT</option>
          <option>MEAL</option>
          <option>PARKING</option>
          <option>HOTEL</option>
          <option>OPERASIONAL</option>
          <option>LAINNYA</option>
        </select>

        <input type="number" name="amount" placeholder="Nominal" class="input" required />

        <input type="date" name="expenseDate" class="input" required />

        <!-- FILE UPLOAD (PRIMARY) -->
        <div id="fileSection" class="space-y-2">
          <label class="text-[12px] text-slate-600">Upload Bukti</label>

          <input
            id="proofFile"
            type="file"
            name="proofFile"
            class="input"
          />

          <p class="text-[10px] text-slate-400">
            Upload struk / invoice / bukti pembayaran
          </p>
        </div>

        <!-- SECONDARY OPTION (UX CORRECT POSITION) -->
        <label class="flex items-center gap-3 bg-slate-50 border p-3 rounded-lg">
          <input
            type="checkbox"
            id="noReceipt"
            name="noReceipt"
            onchange="toggleReceiptMode()"
          />

          <span class="text-[12px] text-slate-600">
            Tidak ada bukti transaksi
          </span>
        </label>

        <!-- REASON -->
        <div id="reasonSection" style="display:none;">
          <label class="text-[12px] text-slate-600">
            Alasan Tidak Ada Bukti
          </label>

          <textarea
            id="noReceiptReason"
            name="noReceiptReason"
            class="input"
            rows="3"
          ></textarea>
        </div>

        <!-- DECLARATION (ONLY WHEN NO RECEIPT) -->
        <div id="declarationSection" style="display:none;">
          <label class="flex items-start gap-3 bg-slate-50 border p-3 rounded-lg">

            <input
              type="checkbox"
              id="selfDeclaration"
              name="selfDeclaration"
            />

            <div>
              <p class="text-[13px] text-slate-700">
                Pernyataan Pengajuan
              </p>

              <p class="text-[11px] text-slate-400">
                Saya menyatakan pengeluaran ini benar dan dapat dipertanggungjawabkan.
              </p>
            </div>

          </label>
        </div>

        <button class="bg-slate-900 text-white px-4 py-2 rounded-lg">
          Submit Klaim
        </button>

      </form>

    </div>
  </div>
</div>

<style>
  .input {
    width: 100%;
    border: 1px solid #e2e8f0;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 13px;
    margin-top: 6px;
  }
</style>
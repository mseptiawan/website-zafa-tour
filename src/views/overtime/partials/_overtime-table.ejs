  
<div class="overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-xs">
  <div class="overflow-x-auto">
    <table class="w-full min-w-[1000px] text-sm text-left border-collapse">
      <thead class="border-b border-slate-100 bg-slate-50 text-[11px] tracking-wider text-slate-400 uppercase font-bold">
        <tr>
          <th class="px-6 py-4.5">Pegawai</th>
          <th class="px-6 py-4.5">Tgl Lembur</th>
          <th class="px-6 py-4.5 text-center">Jam</th>
          <th class="px-6 py-4.5 text-center">Durasi Total</th>
          <th class="px-6 py-4.5 text-center">Status</th>
          <% if (type === 'history') { %>
            <th class="px-6 py-4.5 text-center">Tgl Proses</th>
          <% } %>
          <th class="px-6 py-4.5 text-right pr-8">Aksi</th>
        </tr>
      </thead>
      
      <tbody class="divide-y divide-slate-100 text-[13px]">
        <% if (overtimes.length === 0) { %>
        <tr>
          <td colspan="<%= type === 'active' ? 6 : 7 %>" class="py-16 text-center text-slate-400 font-medium">
            <div class="flex flex-col items-center justify-center space-y-2">
              <i class="fa-solid fa-inbox text-xl text-slate-300"></i>
              <span>Belum ada data <%= type === 'active' ? 'pengajuan' : 'riwayat' %> lembur</span>
            </div>
          </td>
        </tr>
        <% } else { %>
          <% overtimes.forEach(o => { %>
          <tr class="transition-colors hover:bg-slate-50/60 group">
            <td class="px-6 py-4.5 font-semibold text-slate-800">
              <%= o.employeeName %>
            </td>
            
            <td class="px-6 py-4.5 font-medium whitespace-nowrap text-slate-500 tabular-nums">
              <%= new Date(o.date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            </td>
            
            <td class="px-6 py-4.5 text-center font-medium text-slate-500 tabular-nums">
              <span class="inline-flex items-center justify-center px-2 py-1 rounded bg-slate-100 text-[11px]">
                <%= o.startTime %> - <%= o.endTime %>
              </span>
            </td>
            
            <td class="px-6 py-4.5 text-center">
              <span class="font-bold text-slate-900 tabular-nums"><%= o.totalHours %></span>
              <span class="text-[10px] text-slate-400 ml-0.5">Jam</span>
            </td>

            <td class="px-6 py-4.5 align-middle whitespace-nowrap text-center">
              <% 
                const textStyles = { 'Approved': 'text-emerald-700 border-emerald-200/60 bg-emerald-50/50', 'Rejected': 'text-rose-700 border-rose-200/60 bg-rose-50/50', 'Pending Manager': 'text-amber-700 border-amber-200/60 bg-amber-50/50', 'Pending': 'text-amber-700 border-amber-200/60 bg-amber-50/50' }; 
                const dotStyles = { 'Approved': 'bg-emerald-500', 'Rejected': 'bg-rose-500', 'Pending Manager': 'bg-amber-500', 'Pending': 'bg-amber-500' }; 
              %>
              <div class="<%= textStyles[o.status] || 'text-slate-500 border-slate-200 bg-slate-50' %> inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[10px] font-bold tracking-wide shadow-2xs">
                <span class="<%= dotStyles[o.status] || 'bg-slate-400' %> <%= o.status === 'Approved' ? 'animate-pulse' : '' %> h-1.5 w-1.5 rounded-full"></span>
                <span><%= o.status %></span>
              </div>
            </td>

            <% if (type === 'history') { %>
            <td class="px-6 py-4.5 text-center font-medium text-slate-500 tabular-nums text-xs">
              <%= new Date(o.createdAt).toLocaleString("id-ID", {day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit'}) %>
            </td>
            <% } %>

            <td class="px-6 py-4.5 pr-8">
              <div class="flex items-center justify-end gap-2">
                <a href="/overtime/detail/<%= o._id %>" title="Periksa Berkas" class="inline-flex h-8 px-3.5 items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white text-xs font-semibold text-slate-600 shadow-2xs transition-all group-hover:border-blue-500 group-hover:text-blue-600 active:scale-[0.97]">
                  <span>Detail</span>
                  <% if (type === 'active') { %>
                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                  <% } %>
                </a>

                <% if (type === 'active' && o.status === 'Pending Manager') { %>
                <form action="/overtime/approval/<%= o._id %>/manager" method="POST" class="inline-block">
                  <button type="submit" class="inline-flex h-8 px-3.5 items-center justify-center rounded-xl bg-blue-600 text-xs font-semibold text-white shadow-2xs transition-all hover:bg-blue-700 hover:shadow-md active:scale-[0.97] cursor-pointer">
                    Approve
                  </button>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (pagination.totalPages > 1) { %>
<div class="mt-5 flex items-center justify-between text-[11px] font-medium text-slate-500 px-1">
  <span>Menampilkan halaman <span class="font-bold text-slate-800"><%= pagination.page %></span> dari <span class="font-bold text-slate-800"><%= pagination.totalPages %></span></span>
  
  <div class="flex items-center gap-1.5">
    <% if (pagination.page > 1) { %>
    <a href="?tab=<%= type %>&page=<%= pagination.page - 1 %>&search=<%= query.search || '' %>&status=<%= query.status || '' %>&sort=<%= query.sort || '' %>" class="inline-flex items-center justify-center h-8 px-3.5 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 hover:text-slate-900 transition-all shadow-2xs cursor-pointer">
      <i class="fa-solid fa-chevron-left mr-1.5 text-[10px]"></i> Prev
    </a>
    <% } %>
    
    <% if (pagination.page < pagination.totalPages) { %>
    <a href="?tab=<%= type %>&page=<%= pagination.page + 1 %>&search=<%= query.search || '' %>&status=<%= query.status || '' %>&sort=<%= query.sort || '' %>" class="inline-flex items-center justify-center h-8 px-3.5 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 hover:text-slate-900 transition-all shadow-2xs cursor-pointer">
      Next <i class="fa-solid fa-chevron-right ml-1.5 text-[10px]"></i>
    </a>
    <% } %>
  </div>
</div>
<% } %>
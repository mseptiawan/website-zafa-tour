<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased text-slate-900">
  <div class="mx-auto max-w-7xl space-y-6">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <div>
        <a href="#" class="inline-flex items-center gap-1 text-[13px] font-medium text-blue-600 hover:text-blue-700 transition-colors">
          <i class="fa-solid fa-chevron-left text-[11px]"></i> Kembali
        </a>
        <h1 class="text-xl font-bold tracking-tight text-slate-900 mt-1">Komponen Payroll</h1>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">

      <div class="lg:col-span-4 bg-white border border-slate-200/50 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
        <div class="p-3 bg-white border-b border-slate-100">
          <div class="relative">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
            <input type="text" id="searchEmployeeInput" placeholder="Cari nama Pegawai..." class="w-full bg-[#f2f2f7]/60 border-none rounded-lg px-3 py-1.5 pl-8 text-[13px] focus:outline-none focus:ring-1 focus:ring-blue-500/30 transition-shadow">
          </div>
        </div>

        <div class="divide-y divide-slate-100 max-h-[550px] overflow-y-auto">
          <% employees.forEach((emp, index) => { %>
          <% 
            const empAllowances = savedAllowances
              .filter(allow => allow.employeeId.toString() === emp._id.toString() && allow.componentId?.category === 'EARNING')
              .map(allow => ({
                componentName: allow.componentId?.name,
                amount: allow.amount
              }));

            const empDeductions = savedAllowances
              .filter(allow => allow.employeeId.toString() === emp._id.toString() && allow.componentId?.category === 'DEDUCTION')
              .map(allow => ({
                componentName: allow.componentId?.name,
                amount: allow.amount
              }));
          %>

          <div onclick="switchEmployee(this, '<%= emp.fullName %>', '<%= emp.employeeIdNumber %>', '<%= emp.positionId?.name || 'STAFF' %>', '<%= emp.salaryDetail?.basicSalary || 0 %>')" data-id="<%= emp._id %>" data-nik="<%= emp.employeeIdNumber %>" data-allowances='<%= JSON.stringify(empAllowances) %>' data-deductions='<%= JSON.stringify(empDeductions) %>' class="employee-card p-4 <%= index === 0 ? 'bg-blue-50/40' : 'hover:bg-slate-50' %> flex items-center justify-between cursor-pointer transition-colors">
            <div>
              <h4 class="text-[13px] font-<%= index === 0 ? 'semibold text-blue-900' : 'medium text-slate-800' %>"><%= emp.fullName %></h4>
              <p class="text-[11px] text-slate-500 mt-0.5">NIK: <%= emp.employeeIdNumber %> • <%= emp.positionId?.name || 'Staff' %></p>
            </div>
            <span class="text-[11px] font-medium px-2.5 py-0.5 rounded-full bg-slate-100 text-slate-600">Draft</span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-3 gap-6 items-start">

        <div class="md:col-span-2 space-y-6">
          <div class="bg-white border border-slate-200/50 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between bg-white">
              <div>
                <h2 id="empNameTitle" class="text-[14px] font-bold text-slate-900"><%= employees[0]?.fullName %></h2>
                <p id="empMetaTitle" class="text-[11px] text-slate-400">NIK: <%= employees[0]?.employeeIdNumber %> • <%= employees[0]?.positionId?.name || 'Staff' %></p>
              </div>
              <div class="text-right">
                <span class="text-[10px] font-semibold text-slate-400 block uppercase tracking-wide">Periode</span>
                <span class="text-[12px] font-bold text-blue-600">Juni 2026</span>
              </div>
            </div>

            <div class="p-5 space-y-5">
              <div>
                <label class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide mb-1.5 block">Gaji Pokok</label>
                <div class="relative max-w-xs">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[13px] font-medium text-slate-400">Rp</span>
                  <input type="number" id="inputBasicSalary" oninput="calculatePayroll()" value="<%= employees[0]?.salaryDetail?.basicSalary || 0 %>" class="w-full bg-[#f2f2f7]/60 border-none rounded-xl px-3 py-2 pl-9 text-[13px] font-bold text-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all">
                </div>
              </div>

              <div class="pt-4 border-t border-slate-100">
                <h3 class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide mb-2.5">Tunjangan Dinamis</h3>
                <div id="allowanceContainer" class="space-y-2 bg-[#f2f2f7]/40 p-2.5 rounded-xl border border-slate-100"></div>

                <div id="overtimeContainer" class="space-y-2 mt-2"></div>

                <div class="mt-3 flex items-center gap-2">
                  <select id="masterAllowanceSelect" class="bg-white border border-slate-200 rounded-xl px-2.5 py-1.5 text-[12px] font-medium text-slate-600 focus:outline-none">
                    <option value="">-- Pilih Tunjangan --</option>
                    <% components.filter(c => c.category === 'EARNING').forEach(comp => { %>
                    <option value="<%= comp.name %>" data-amount="<%= comp.defaultAmount %>"><%= comp.name %></option>
                    <% }) %>
                  </select>
                  <button type="button" onclick="addAllowanceField()" class="text-[12px] font-semibold text-blue-600 bg-blue-50 px-3 py-1.5 rounded-xl transition-colors">+ Tambah</button>
                </div>
              </div>

              <div class="pt-6 border-t border-slate-100">
                <div class="flex items-center justify-between mb-2.5">
                  <h3 class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide">Potongan / Cicilan</h3>
                  <span class="text-[10px] font-medium text-rose-600 bg-rose-50 px-2 py-0.5 rounded-full">Out / Pengurangan</span>
                </div>

                <div id="deductionContainer" class="space-y-2 bg-[#f2f2f7]/40 p-2.5 rounded-xl border border-slate-100"></div>

                <div class="mt-3 flex items-center gap-2">
                  <select id="masterDeductionSelect" class="bg-white border border-slate-200 rounded-xl px-2.5 py-1.5 text-[12px] font-medium text-slate-600 focus:outline-none">
                    <option value="">-- Pilih Potongan --</option>
                    <% components.filter(c => c.category === 'DEDUCTION').forEach(comp => { %>
                    <option value="<%= comp.name %>" data-amount="<%= comp.defaultAmount %>"><%= comp.name %></option>
                    <% }) %>
                  </select>
                  <button type="button" onclick="addDeductionField()" class="text-[12px] font-semibold text-rose-600 bg-rose-50 px-3 py-1.5 rounded-xl transition-colors">+ Tambah</button>
                </div>
              </div>
            </div>
            <div class="px-5 py-4 bg-slate-50 border-t border-slate-100 flex justify-end">
              <button type="button" onclick="submitPayrollData()" class="px-5 py-2 bg-blue-600 text-white text-[13px] font-semibold rounded-xl transition-colors hover:bg-blue-700">
                Simpan Perubahan
              </button>
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-white border border-slate-200/50 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] p-4 sticky top-6">
            <h3 class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide mb-4">Ringkasan</h3>
            <div class="space-y-3 text-[12px]">
              <div class="flex justify-between"><span>Gaji Pokok</span> <span id="previewBasic" class="font-semibold">Rp 0</span></div>

              <div id="previewOvertimeRow" class="flex justify-between text-blue-600 hidden">
                <span id="previewOvertimeLabel">Uang Lembur</span>
                <span id="previewOvertime" class="font-semibold">+Rp 0</span>
              </div>

              <div id="detailEarningsContainer" class="space-y-1 pl-2 border-l border-emerald-100 hidden text-slate-500 text-[11px]"></div>
              <div class="flex justify-between text-emerald-600"><span>Tunjangan</span> <span id="previewEarnings" class="font-semibold">+Rp 0</span></div>

              <div id="detailDeductionsContainer" class="space-y-1 pl-2 border-l border-rose-100 hidden text-slate-500 text-[11px]"></div>
              <div class="flex justify-between text-rose-600"><span>Potongan</span> <span id="previewDeductions" class="font-semibold">-Rp 0</span></div>

              <div class="border-t pt-3 font-bold flex justify-between"><span>Net Pay</span> <span id="previewNetPay">Rp 0</span></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  // Global State Overtime
  let overtimeSummary = {
    totalHours: 0,
    totalPay: 0
  };

  function calculatePayroll() {
    try {
      const basicInput = document.getElementById('inputBasicSalary');
      const basic = basicInput ? (parseFloat(basicInput.value) || 0) : 0;

      // 1. Hitung Tunjangan Dinamis dari DOM input user
      let allowances = 0;
      let earningsDetailHTML = '';
      document.querySelectorAll('.allowance-row').forEach(row => {
        const nameInput = row.querySelector('input[type="text"]');
        const amountInput = row.querySelector('.amount-input-allowance');
        if (nameInput && amountInput) {
          const val = parseFloat(amountInput.value) || 0;
          allowances += val;
          if (val > 0) {
            earningsDetailHTML += `<div class="flex justify-between"><span>• ${nameInput.value}</span> <span>Rp ${val.toLocaleString('id-ID')}</span></div>`;
          }
        }
      });

      // 2. Ambil Uang Lembur dari State Hasil Fetch API
      let overtime = 0;
      const previewOvertimeRow = document.getElementById('previewOvertimeRow');
      const previewOvertime = document.getElementById('previewOvertime');
      const previewOvertimeLabel = document.getElementById('previewOvertimeLabel');

      if (overtimeSummary && overtimeSummary.totalPay > 0) {
        overtime = overtimeSummary.totalPay;
        if (previewOvertimeLabel) previewOvertimeLabel.innerText = `Uang Lembur (${overtimeSummary.totalHours} jam)`;
        if (previewOvertime) previewOvertime.innerText = '+Rp ' + overtime.toLocaleString('id-ID');
        if (previewOvertimeRow) previewOvertimeRow.classList.remove('hidden');
      } else {
        if (previewOvertimeRow) previewOvertimeRow.classList.add('hidden');
      }

      // 3. Hitung Potongan dari DOM input user
      let deductions = 0;
      let deductionsDetailHTML = '';
      document.querySelectorAll('.deduction-row').forEach(row => {
        const nameInput = row.querySelector('input[type="text"]');
        const amountInput = row.querySelector('.amount-input-deduction');
        if (nameInput && amountInput) {
          const val = parseFloat(amountInput.value) || 0;
          deductions += val;
          if (val > 0) {
            deductionsDetailHTML += `<div class="flex justify-between"><span>• ${nameInput.value}</span> <span>Rp ${val.toLocaleString('id-ID')}</span></div>`;
          }
        }
      });

      // 4. Hitung Akumulasi Akhir secara Presisi
      const netPay = (basic + allowances + overtime) - deductions;

      // Render ke UI Sidebar
      if (document.getElementById('previewBasic')) document.getElementById('previewBasic').innerText = 'Rp ' + basic.toLocaleString('id-ID');

      const earnDetailBox = document.getElementById('detailEarningsContainer');
      if (earnDetailBox) {
        earnDetailBox.innerHTML = earningsDetailHTML;
        if (earningsDetailHTML) earnDetailBox.classList.remove('hidden');
        else earnDetailBox.classList.add('hidden');
      }
      if (document.getElementById('previewEarnings')) document.getElementById('previewEarnings').innerText = '+Rp ' + allowances.toLocaleString('id-ID');

      const dedDetailBox = document.getElementById('detailDeductionsContainer');
      if (dedDetailBox) {
        dedDetailBox.innerHTML = deductionsDetailHTML;
        if (deductionsDetailHTML) dedDetailBox.classList.remove('hidden');
        else dedDetailBox.classList.add('hidden');
      }
      if (document.getElementById('previewDeductions')) document.getElementById('previewDeductions').innerText = '-Rp ' + deductions.toLocaleString('id-ID');

      if (document.getElementById('previewNetPay')) document.getElementById('previewNetPay').innerText = 'Rp ' + netPay.toLocaleString('id-ID');
    } catch (err) {
      console.error(err);
    }
  }

  function renderOvertimeComponent() {
    const container = document.getElementById('overtimeContainer');
    if (!container) return;

    container.innerHTML = '';
    if (!overtimeSummary) return;
    container.innerHTML = `
      <div class="flex items-center gap-2 overtime-row animate-fadeIn">
        <input type="text" value="Lembur (${overtimeSummary.totalHours} jam)" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px] text-blue-700 font-medium" readonly>
        <div class="w-32 relative">
          <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-blue-400">Rp</span>
          <input type="text" value="${overtimeSummary.totalPay.toLocaleString('id-ID')}" class="w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-blue-700 text-right focus:outline-none" readonly>
        </div>
      </div>
    `;
  }

  // BULLETPROOF API EXTRACTION: Mendeteksi struktur flat, .data, camelCase, ataupun snake_case otomatis

  async function loadOvertime(idParam) {
    try {
      const res = await fetch(`/overtime/summary/${idParam}`);
      const data = await res.json();

      console.log("DEBUG RESPONSE LEMBUR:", data);

      const hours = Number(data.totalHours || 0);
      const pay = Number(data.totalPay || 0);

      overtimeSummary = {
        totalHours: hours,
        totalPay: pay
      };

    } catch (err) {
      console.error("Gagal fetch lembur:", err);
      overtimeSummary = {
        totalHours: 0,
        totalPay: 0
      };
    } finally {
      renderOvertimeComponent();
      calculatePayroll();
    }
  }

  function addAllowanceField() {
    const select = document.getElementById('masterAllowanceSelect');
    if (!select || !select.value) return;

    const selectedOption = select.options[select.selectedIndex];
    const defaultAmount = selectedOption.getAttribute('data-amount') || 0;
    const componentName = select.value;

    const template = `
      <div class="flex items-center gap-2 allowance-row animate-fadeIn">
        <input type="text" value="${componentName}" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px]" readonly>
        <div class="w-32 relative">
          <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-slate-400">Rp</span>
          <input type="number" value="${defaultAmount}" oninput="calculatePayroll()" class="amount-input-allowance w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none">
        </div>
        <button type="button" onclick="this.parentElement.remove(); calculatePayroll();" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-rose-600 flex items-center justify-center transition-all text-xs shadow-sm">
          <i class="fa-solid fa-trash-can text-[11px]"></i>
        </button>
      </div>
    `;

    document.getElementById('allowanceContainer').insertAdjacentHTML('beforeend', template);
    select.value = "";
    calculatePayroll();
  }

  function addDeductionField() {
    const select = document.getElementById('masterDeductionSelect');
    if (!select || !select.value) return;

    const selectedOption = select.options[select.selectedIndex];
    const defaultAmount = selectedOption.getAttribute('data-amount') || 0;
    const componentName = select.value;

    const template = `
      <div class="flex items-center gap-2 deduction-row animate-fadeIn">
        <input type="text" value="${componentName}" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px] text-slate-700 focus:outline-none" readonly>
        <div class="w-32 relative">
          <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-slate-400">Rp</span>
          <input type="number" value="${defaultAmount}" oninput="calculatePayroll()" class="amount-input-deduction w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none focus:border-blue-500">
        </div>
        <button type="button" onclick="this.parentElement.remove(); calculatePayroll();" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-rose-600 flex items-center justify-center transition-all text-xs shadow-sm">
          <i class="fa-solid fa-trash-can text-[11px]"></i>
        </button>
      </div>
    `;
    document.getElementById('deductionContainer').insertAdjacentHTML('beforeend', template);
    select.value = "";
    calculatePayroll();
  }

  function switchEmployee(el, name, nik, pos, basicSalary) {
    overtimeSummary = {
      totalHours: 0,
      totalPay: 0
    };

    document.getElementById('empNameTitle').innerText = name;
    document.getElementById('empMetaTitle').innerText = 'NIK: ' + nik + ' • ' + pos;
    document.getElementById('inputBasicSalary').value = parseFloat(basicSalary) || 0;

    const allowanceContainer = document.getElementById('allowanceContainer');
    const deductionContainer = document.getElementById('deductionContainer');
    const overtimeContainer = document.getElementById('overtimeContainer');

    allowanceContainer.innerHTML = '';
    deductionContainer.innerHTML = '';
    if (overtimeContainer) overtimeContainer.innerHTML = '';

    document.querySelectorAll('.employee-card').forEach(card => card.classList.remove('bg-blue-50/40'));
    el.classList.add('bg-blue-50/40');

    const allowances = JSON.parse(el.getAttribute('data-allowances') || '[]');
    if (allowances && allowances.length > 0) {
      allowances.forEach(item => {
        const template = `
          <div class="flex items-center gap-2 allowance-row animate-fadeIn">
            <input type="text" value="${item.componentName}" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px]" readonly>
            <div class="w-32 relative">
              <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-slate-400">Rp</span>
              <input type="number" value="${item.amount}" oninput="calculatePayroll()" class="amount-input-allowance w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none">
            </div>
            <button type="button" onclick="this.parentElement.remove(); calculatePayroll();" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-rose-600 flex items-center justify-center transition-all text-xs shadow-sm">
              <i class="fa-solid fa-trash-can text-[11px]"></i>
            </button>
          </div>
        `;
        allowanceContainer.insertAdjacentHTML('beforeend', template);
      });
    }

    const deductions = JSON.parse(el.getAttribute('data-deductions') || '[]');
    if (deductions && deductions.length > 0) {
      deductions.forEach(item => {
        const template = `
          <div class="flex items-center gap-2 deduction-row animate-fadeIn">
            <input type="text" value="${item.componentName}" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px] text-slate-700 focus:outline-none" readonly>
            <div class="w-32 relative">
              <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-slate-400">Rp</span>
              <input type="number" value="${item.amount}" oninput="calculatePayroll()" class="amount-input-deduction w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none focus:border-blue-500">
            </div>
            <button type="button" onclick="this.parentElement.remove(); calculatePayroll();" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-rose-600 flex items-center justify-center transition-all text-xs shadow-sm">
              <i class="fa-solid fa-trash-can text-[11px]"></i>
            </button>
          </div>
        `;
        deductionContainer.insertAdjacentHTML('beforeend', template);
      });
    }

    console.log("SWITCH EMPLOYEE CALLED");
console.log("DATA-ID:", el.getAttribute('data-id'));
    loadOvertime(el.getAttribute('data-id'));
  }

  function submitPayrollData() {
    const allCards = document.querySelectorAll('.employee-card');
    let activeCard = null;

    allCards.forEach(card => {
      if (card.classList.contains('bg-blue-50/40')) activeCard = card;
    });

    if (!activeCard) {
      alert("Silakan pilih Pegawai terlebih dahulu.");
      return;
    }

    const employeeId = activeCard.getAttribute('data-id');
    const combinedComponents = [];

    document.querySelectorAll('.allowance-row').forEach(row => {
      const nameInput = row.querySelector('input[type="text"]');
      const amountInput = row.querySelector('.amount-input-allowance');
      if (nameInput && amountInput) {
        combinedComponents.push({
          componentName: nameInput.value,
          amount: parseFloat(amountInput.value) || 0
        });
      }
    });

    document.querySelectorAll('.deduction-row').forEach(row => {
      const nameInput = row.querySelector('input[type="text"]');
      const amountInput = row.querySelector('.amount-input-deduction');
      if (nameInput && amountInput) {
        combinedComponents.push({
          componentName: nameInput.value,
          amount: parseFloat(amountInput.value) || 0
        });
      }
    });

    fetch('/payroll/save', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          employeeId,
          allowances: combinedComponents
        })
      })
      .then(res => res.json())
      .then(data => {
        alert(data.success ? " " + data.message : "" + data.message);
      })
      .catch(err => {
        console.error(err);
        alert("Terjadi kesalahan sistem.");
      });
  }

  document.getElementById('searchEmployeeInput').addEventListener('input', function(e) {
    const query = e.target.value.toLowerCase().trim();
    document.querySelectorAll('.employee-card').forEach(card => {
      const name = card.querySelector('h4').innerText.toLowerCase();
      const meta = card.querySelector('p').innerText.toLowerCase();
      card.style.display = (name.includes(query) || meta.includes(query)) ? 'flex' : 'none';
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    const firstCard = document.querySelector('.employee-card');
    if (firstCard) firstCard.click();
    else calculatePayroll();
  });
</script>
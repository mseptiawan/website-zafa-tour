<%
  // Helper Configuration untuk Badge Status Mitigasi/Persetujuan
  const getStatusConfig = (status) => {
    switch(status) {
      case 'PENDING':
        return { label: 'Pending', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500' };
      case 'APPROVED':
        return { label: 'Approved', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500 animate-pulse' };
      case 'REJECTED':
        return { label: 'Rejected', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' };
      case 'CANCELLED':
        return { label: 'Cancelled', badge: 'bg-slate-50 text-slate-500 border-slate-200', dot: 'bg-slate-400' };
      default:
        return { label: status, badge: 'bg-slate-50 text-slate-600 border-slate-200/50', dot: 'bg-slate-500' };
    }
  };
%>

<!-- ========================================================================= -->
<!-- DESKTOP VIEW: TABEL STRUKTURAL (Hidden on Mobile)                         -->
<!-- ========================================================================= -->
<div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse text-[13px]">
      <thead>
        <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
          <% if (type === 'active') { %>
            <th class="py-4 px-6">Tgl Pengajuan</th>
            <th class="py-4 px-6">Nama Pegawai</th>
            <th class="py-4 px-6 text-right">Volume Pinjaman</th>
            <th class="py-4 px-6 text-center">Tenor</th>
            <th class="py-4 px-6 text-right">Amortisasi / Bln</th>
            <th class="py-4 px-6 text-center">Aksi</th>
          <% } else { %>
            <th class="py-4 px-6">Nama Pegawai</th>
            <th class="py-4 px-6 text-right">Total Dana</th>
            <th class="py-4 px-6 text-center">Status Mitigasi</th>
            <th class="py-4 px-6">Otorisasi Catatan</th>
            <th class="py-4 px-6 text-center">Aksi</th>
          <% } %>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
        <% if (loans.length === 0) { %>
          <tr>
            <td colspan="<%= type === 'active' ? 6 : 5 %>" class="py-12 text-center text-slate-400 font-medium">
              Belum ada berkas data aplikasi pinjaman terdaftar.
            </td>
          </tr>
        <% } else { %>
          <% loans.forEach(loan => { %>
            <tr class="hover:bg-slate-50/50 transition-colors">
              <% if (type === 'active') { %>
                <td class="py-4 px-6 text-slate-500 font-medium whitespace-nowrap tabular-nums">
                  <%= new Date(loan.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </td>
                <td class="py-4 px-6 font-semibold text-slate-800">
                  <%= loan.employeeId?.fullName || "Pegawai" %>
                </td>
                <td class="py-4 px-6 text-right font-medium text-slate-700 tabular-nums">
                  Rp <%= loan.amountRequested.toLocaleString('id-ID') %>
                </td>
                <td class="py-4 px-6 text-center whitespace-nowrap">
                  <span class="px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-[11px] font-semibold"><%= loan.tenorMonths %> Bulan</span>
                </td>
                <td class="py-4 px-6 text-right font-semibold text-blue-600 tabular-nums">
                  Rp <%= loan.monthlyDeduction?.toLocaleString('id-ID') || loan.monthlyInstallment?.toLocaleString('id-ID') %>
                  <span class="text-[10px] font-medium text-slate-400 block mt-0.5">Auto-debet</span>
                </td>
                <td class="py-4 px-6">
                  <div class="flex items-center justify-center">
                    <a href="/loans/detail/<%= loan._id %>" title="Periksa Berkas" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                      <i class="fa-solid fa-chevron-right text-[11px]"></i>
                    </a>
                  </div>
                </td>
              <% } else { %>
                <td class="py-4 px-6 font-semibold text-slate-800">
                  <%= loan.employeeId?.fullName || "Pegawai" %>
                </td>
                <td class="py-4 px-6 text-right font-medium text-slate-700 tabular-nums">
                  Rp <%= loan.amountRequested.toLocaleString('id-ID') %>
                </td>
                <td class="py-4 px-6 text-center select-none">
                  <% const config = getStatusConfig(loan.approvalStatus || loan.status); %>
                  <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                    <span><%= config.label.toUpperCase() %></span>
                  </div>
                </td>
                <td class="py-4 px-6 text-slate-400 max-w-xs truncate font-normal">
                  <%= loan.note || loan.reason || '-' %>
                </td>
                <td class="py-4 px-6">
                  <div class="flex items-center justify-center">
                    <a href="/loans/detail/<%= loan._id %>" title="Lihat Riwayat" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                      <i class="fa-solid fa-eye text-[11px]"></i>
                    </a>
                  </div>
                </td>
              <% } %>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- ========================================================================= -->
<!-- MOBILE VIEW: RESPONSIVE CARD STACK (Hidden on Desktop)                     -->
<!-- ========================================================================= -->
<div class="block md:hidden space-y-3.5 w-full">
  <% if (loans.length === 0) { %>
    <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
      <p class="text-[12px] font-medium text-slate-400">Belum ada data aplikasi pinjaman</p>
    </div>
  <% } else { %>
    <% loans.forEach(loan => { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5">
        
        <!-- Header Card Mobile -->
        <div class="flex items-center justify-between gap-2">
          <div>
            <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight">
              <%= loan.employeeId?.fullName || "Pegawai" %>
            </h4>
            <% if (type === 'active') { %>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                Diajukan: <%= new Date(loan.createdAt).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
              </p>
            <% } else { %>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5 truncate max-w-[180px]">
                Memo: <%= loan.note || '-' %>
              </p>
            <% } %>
          </div>

          <!-- Status / Tenor Badge -->
          <% if (type === 'active') { %>
            <div class="inline-flex items-center px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-[10px] font-bold tracking-wide shrink-0">
              <%= loan.tenorMonths %> Bulan
            </div>
          <% } else { %>
            <% const config = getStatusConfig(loan.approvalStatus || loan.status); %>
            <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
              <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
              <span><%= config.label %></span>
            </div>
          <% } %>
        </div>

        <!-- Detail Angka Pokok & Cicilan -->
        <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
          <div>
            <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Volume Pinjaman</p>
            <p class="text-[13px] font-semibold text-slate-800 tabular-nums mt-0.5">Rp <%= loan.amountRequested.toLocaleString('id-ID') %></p>
          </div>
          <div class="text-right">
            <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">
              <%= type === 'active' ? 'Potong / Bulan' : 'Tenor Cicilan' %>
            </p>
            <% if (type === 'active') { %>
              <p class="text-[13px] font-semibold text-blue-600 tabular-nums mt-0.5">
                Rp <%= (loan.monthlyDeduction || loan.monthlyInstallment || 0).toLocaleString('id-ID') %>
              </p>
            <% } else { %>
              <p class="text-[13px] font-semibold text-slate-700 tabular-nums mt-0.5">
                <%= loan.tenorMonths %> Bulan
              </p>
            <% } %>
          </div>
        </div>

        <!-- Footer Aksi Mobile -->
        <div class="flex items-center justify-between gap-2 pt-0.5">
          <span class="text-[11px] font-medium text-slate-400">
            <% if (type === 'active') { %>
              <i class="fa-solid fa-shield-halved mr-1"></i>Butuh Persetujuan
            <% } else { %>
              <i class="fa-solid fa-box-archive mr-1"></i>Arsip Selesai
            <% } %>
          </span>
          
          <a href="/loans/detail/<%= loan._id %>" class="h-8 px-4 bg-slate-100 hover:bg-slate-200/70 text-slate-700 text-[11px] font-semibold border border-slate-200/60 rounded-lg flex items-center justify-center tracking-wide active:scale-95 transition-all">
            <%= type === 'active' ? 'TINJAU' : 'LIHAT' %>
          </a>
        </div>

      </div>
    <% }) %>
  <% } %>
</div>
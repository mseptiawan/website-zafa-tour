<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8">

    <div class="max-w-5xl mx-auto">

      <!-- HEADER -->
      <div class="flex items-start justify-between mb-8">

       <div >
  <div class="mb-3 flex items-center gap-3">
    <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-400 uppercase">
      Area Kerja
    </span>
    <div class="h-3 w-px bg-slate-300"></div>
    <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-800 uppercase">
      Dinas
    </span>
  </div>

  <h1 class="text-3xl font-semibold tracking-tighter text-slate-950">
    Daftar Pengajuan Dinas
  </h1>
  <p class="mt-1.5 text-sm font-medium text-slate-500">
    Kelola seluruh pengajuan perjalanan dinas Pegawai secara efisien.
  </p>
</div>

        <a href="/trip/new" class="bg-blue-600 hover:bg-blue-700 text-white text-sm px-4 py-3 rounded-xl transition">
          + Buat Pengajuan
        </a>

      </div>

      <!-- CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">

        <div class="overflow-x-auto">

          <table class="w-full text-sm min-w-[900px]">

            <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
              <tr>
                <th class="text-left px-6 py-4">Judul</th>
                <th class="text-left px-6 py-4">Tujuan</th>
                <th class="text-left px-6 py-4">Budget</th>
                <th class="text-left px-6 py-4">Status</th>
                <th class="text-left px-6 py-4">Aksi</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-slate-100">

              <% if (trips.length===0) { %>
                <tr>
                  <td colspan="5" class="text-center py-10 text-slate-400">
                    Belum ada data pengajuan
                  </td>
                </tr>
                <% } %>

                  <% trips.forEach(t=> { %>
                    <tr class="hover:bg-slate-50 transition">

                      <td class="px-6 py-4 font-medium text-slate-800">
                        <%= t.title %>
                      </td>

                      <td class="px-6 py-4 text-slate-500">
                        <%= t.destination || '-' %>
                      </td>

                      <td class="px-6 py-4 font-semibold text-slate-700">
                        Rp <%= (t.budget || 0).toLocaleString('id-ID') %>
                      </td>

               <td class="px-6 py-4 whitespace-nowrap align-middle">
  <% 
    // 1. MAPPING WARNA TEKS (Tonalitas Adem/Soft Premium)
    const textStyles = {
      'PENDING': 'text-amber-600',
      'IN_REVIEW': 'text-indigo-600',
      'APPROVED': 'text-emerald-600',
      'REJECTED': 'text-rose-600',
      'PAYMENT_PROCESSING': 'text-purple-600',
      'READY_TO_TRAVEL': 'text-teal-600',
      'PAID': 'text-emerald-700',
      'ON_TRIP': 'text-sky-600',
      'SUBMITTED': 'text-blue-600',
      'CANCELLED': 'text-slate-500'
    };

    // 2. MAPPING BULATAN / DOT INDICATOR (Dengan Ring Transparan)
    const dotStyles = {
      'PENDING': 'bg-amber-500 ring-amber-500/20',
      'IN_REVIEW': 'bg-indigo-500 ring-indigo-500/20',
      'APPROVED': 'bg-emerald-500 ring-emerald-500/20',
      'REJECTED': 'bg-rose-500 ring-rose-500/20',
      'PAYMENT_PROCESSING': 'bg-purple-500 ring-purple-500/20',
      'READY_TO_TRAVEL': 'bg-teal-500 ring-teal-500/20',
      'PAID': 'bg-emerald-600 ring-emerald-600/20',
      'ON_TRIP': 'bg-sky-500 ring-sky-500/20',
      'SUBMITTED': 'bg-blue-500 ring-blue-500/20',
      'CANCELLED': 'bg-slate-400 ring-slate-400/20'
    };

    // 3. MAPPING BACKGROUND TINT SOFT
    const bgStyles = { 
      'PENDING': 'bg-amber-50/70', 
      'IN_REVIEW': 'bg-indigo-50/70',
      'APPROVED': 'bg-emerald-50/70', 
      'REJECTED': 'bg-rose-50/70', 
      'PAYMENT_PROCESSING': 'bg-purple-50/70',
      'READY_TO_TRAVEL': 'bg-teal-50/70',
      'PAID': 'bg-emerald-50/40',
      'ON_TRIP': 'bg-sky-50/70',
      'SUBMITTED': 'bg-blue-50/70',
      'CANCELLED': 'bg-slate-50'
    };

    // 4. MAPPING BORDER TRANSMEDIUM
    const borderStyles = { 
      'PENDING': 'border-amber-200/50', 
      'IN_REVIEW': 'border-indigo-200/50',
      'APPROVED': 'border-emerald-200/50', 
      'REJECTED': 'border-rose-200/50', 
      'PAYMENT_PROCESSING': 'border-purple-200/50',
      'READY_TO_TRAVEL': 'border-teal-200/50',
      'PAID': 'border-emerald-200/60',
      'ON_TRIP': 'border-sky-200/50',
      'SUBMITTED': 'border-blue-200/50',
      'CANCELLED': 'border-slate-200'
    };

    // 5. MAPPING LABEL DISPLAY HUMAN-READABLE
    const statusLabels = {
      'PENDING': 'Pending',
      'IN_REVIEW': 'In Review',
      'APPROVED': 'Approved',
      'REJECTED': 'Rejected',
      'PAYMENT_PROCESSING': 'Payment Processing',
      'READY_TO_TRAVEL': 'Ready to Travel',
      'PAID': 'Paid',
      'ON_TRIP': 'On Trip',
      'SUBMITTED': 'Submitted',
      'CANCELLED': 'Cancelled'
    };
  %>

  <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-medium tracking-wide transition-all duration-200
      <%= textStyles[t.status] || 'text-slate-500' %>
      <%= bgStyles[t.status] || 'bg-slate-50' %>
      <%= borderStyles[t.status] || 'border-slate-200' %>">

    <span class="w-1.5 h-1.5 rounded-full ring-4
      <%= dotStyles[t.status] || 'bg-slate-400 ring-slate-400/20' %> 
      <%= (t.status === 'APPROVED' || t.status === 'ON_TRIP') ? 'animate-pulse' : '' %>">
    </span>

    <span>
      <%= statusLabels[t.status] || t.status %>
    </span>

  </div>
</td>

                      <td class="px-6 py-4 flex items-center gap-2">

                        <!-- DETAIL -->
                        <a href="/trip/<%= t._id %>" title="Detail" class="inline-flex items-center justify-center w-9 h-9 rounded-lg
            border border-slate-200
            text-slate-600
            hover:bg-slate-50 hover:text-slate-800
            transition">

                          <!-- eye icon -->
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 9a3 3 0 100 6 3 3 0 000-6z" />
                          </svg>

                        </a>

                        <!-- EDIT -->
                        <% if (t.status==='PENDING' ) { %>

                          <a href="/trip/<%= t._id %>/edit" title="Edit"
                            class="p-2 rounded-lg bg-amber-400 text-white hover:bg-amber-500 transition">

                            <!-- pencil icon (correct edit icon) -->
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4h3m2.586 2.586a2 2 0 010 2.828l-8.5 8.5
               L5 18l.086-3.086 8.5-8.5a2 2 0 012.828 0z" />
                            </svg>

                          </a>

                          <% } %>

                            <!-- RESUBMIT -->
                            <% if (t.status==='REJECTED' ) { %>

                              <a href="/trip/<%= t._id %>/edit" title="Resubmit"
                                class="p-2 rounded-lg bg-emerald-500 text-white hover:bg-emerald-600 transition">

                                <!-- refresh icon -->
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582M20 20v-5h-.581
             M5.08 13a7 7 0 0113.84 0
             M18.92 11A7 7 0 005.08 11" />
                                </svg>

                              </a>

                              <% } %>

                      </td>

                    </tr>
                    <% }) %>

            </tbody>

          </table>

        </div>

      </div>
      <% if (pagination.totalPages> 1) { %>
        <div
          class="flex items-center justify-between mt-6 px-5 py-4 bg-white border border-slate-200 rounded-2xl shadow-sm text-[13px] antialiased">

          <!-- LEFT INFO -->
          <div class="text-slate-500 font-medium">
            Menampilkan halaman
            <span class="font-bold text-slate-900">
              <%= pagination.page %>
            </span>
            dari
            <span class="font-bold text-slate-900">
              <%= pagination.totalPages %>
            </span>
          </div>

          <!-- RIGHT CONTROLS -->
          <div class="flex items-center gap-2">

            <!-- PREV BUTTON -->
            <a href="?page=<%= pagination.page - 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasPrev
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              Prev
            </a>

            <!-- NEXT BUTTON -->
            <a href="?page=<%= pagination.page + 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasNext
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
              Next
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

          </div>

        </div>
        <% } %>
    </div>

  </div>
<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 p-8 bg-slate-50 min-h-screen">

  <div class="max-w-xl mx-auto bg-white border rounded-xl p-6">

    <h1 class="text-lg font-semibold mb-4">
      Ajukan Koreksi Absensi
    </h1>

    <form method="POST" action="/attendance/correction" class="space-y-4">

      <!-- TANGGAL -->
      <div>
        <label class="text-xs text-slate-500">Tanggal</label>
        <input type="date" name="startDate"
          class="w-full mt-1 border rounded-lg px-3 py-2"
          required>
      </div>

      <!-- JAM MULAI -->
      <div>
        <label class="text-xs text-slate-500">Jam Mulai</label>
        <input type="time" name="startTime"
          class="w-full mt-1 border rounded-lg px-3 py-2"
          required>
      </div>

      <!-- JAM SELESAI -->
      <div>
        <label class="text-xs text-slate-500">Jam Selesai</label>
        <input type="time" name="endTime"
          class="w-full mt-1 border rounded-lg px-3 py-2"
          required>
      </div>

      <!-- ALASAN -->
      <div>
        <label class="text-xs text-slate-500">Alasan</label>
        <select name="reasonType"
          class="w-full mt-1 border rounded-lg px-3 py-2">
          <option value="TIDAK_TERCATAT">Tidak Tercatat Absen</option>
          <option value="LUPA_ABSEN">Lupa Absen</option>
          <option value="ABSEN_TIDAK_SEMPURNA">Absen Tidak Sempurna</option>
          <option value="LAINNYA">Lainnya</option>
        </select>
      </div>

      <!-- PENJELASAN -->
      <div>
        <label class="text-xs text-slate-500">Penjelasan</label>
        <textarea name="reason"
          rows="4"
          class="w-full mt-1 border rounded-lg px-3 py-2"></textarea>
      </div>

      <button class="w-full bg-slate-900 text-white py-2 rounded-lg">
        Kirim Pengajuan
      </button>

    </form>

  </div>

</div>
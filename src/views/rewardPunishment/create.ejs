<%- layout('layouts/main', { title }) %>

<div class=" overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0">

    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Kepegawaian', 
        title: 'Formulir Catatan Reward & Punishment', 
        description: 'Terbitkan berkas formal penghargaan atau sanksi kedisiplinan serta kelola dampak finansialnya.' 
    }) %>

    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl p-4 sm:p-5 md:p-8 overflow-hidden">
      <form action="/reward-punishment" method="POST" enctype="multipart/form-data" class="space-y-5">

        <% if (typeof errors !== 'undefined' && errors?.global) { %>
        <div class="p-3.5 rounded-xl bg-rose-50 text-rose-600 text-[13px] border border-rose-100 font-medium">
          <%= errors.global %>
        </div>
        <% } %>

        <div class="space-y-2 mb-5">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Pilih Pegawai</label>
          <div class="relative w-full">
            <select name="employeeId" class="w-full bg-slate-50/60 border <%= errors?.employeeId ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/70 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] text-slate-800 outline-none focus:bg-white focus:ring-0 transition-all cursor-pointer appearance-none font-medium">
              <option value="" disabled <%= !old?.employeeId ? 'selected' : '' %>>-- Pilih Personel --</option>
              <% employees.forEach(emp => { %>
                <option value="<%= emp._id %>" <%= old?.employeeId === String(emp._id) ? 'selected' : '' %>><%= emp.fullName %></option>
              <% }) %>
            </select>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
              <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </div>
          </div>
          <% if (errors?.employeeId) { %>
          <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors.employeeId %></p>
          <% } %>
        </div>

        <div class="space-y-2 mb-5">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Jenis SK Master</label>
          <div class="relative w-full">
            <select name="typeId" class="w-full bg-slate-50/60 border <%= errors?.typeId ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/70 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] text-slate-800 outline-none focus:bg-white focus:ring-0 transition-all cursor-pointer appearance-none font-medium">
              <option value="" disabled <%= !old?.typeId ? 'selected' : '' %>>-- Pilih Regulasi --</option>
              <% types.forEach(t => { %>
                <option value="<%= t._id %>" <%= old?.typeId === String(t._id) ? 'selected' : '' %>>[<%= t.category %>] <%= t.name %></option>
              <% }) %>
            </select>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
              <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </div>
          </div>
          <% if (errors?.typeId) { %>
          <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors.typeId %></p>
          <% } %>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 p-4 bg-slate-50/60 border border-slate-200/50 rounded-2xl mb-5 select-none items-center">
          <div class="flex flex-col">
            <span class="text-[12px] font-bold text-slate-700 tracking-wide">Dampak Finansial</span>
            <span class="text-[11px] text-slate-400 font-medium mt-0.5">Apakah kasus ini memengaruhi slip gaji/upah?</span>
          </div>
          <div class="flex items-center justify-start sm:justify-end gap-3">
            <span id="toggleLabel" class="text-[11.5px] font-bold text-slate-400 uppercase tracking-wider min-w-[70px] text-right">Tidak Ada</span>
            
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="hasFinancialImpact" name="hasFinancialImpact" class="sr-only peer" onchange="toggleFinancialSection()" <%= (typeof old !== 'undefined' && Number(old?.amount) > 0) ? 'checked' : '' %>>
              <div class="w-11 h-6 bg-slate-200 rounded-full peer peer-focus:ring-0 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
            </label>
          </div>
        </div>

        <div id="financialAmountSection" class="space-y-2 mb-5 hidden transition-all duration-300">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Nominal Dampak Finansial</label>
          <div class="relative flex items-center w-full">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none select-none">
              <span class="text-slate-400 font-semibold text-[13px]">Rp</span>
            </div>
            <input type="text" id="nominalInput" placeholder="0" class="w-full bg-slate-50/60 border <%= errors?.amount ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/70 focus:border-slate-400' %> rounded-xl pl-10 pr-4 py-2.5 text-[13.5px] font-bold text-slate-800 outline-none focus:bg-white transition-all tabular-nums" />
            <input type="hidden" name="amount" id="amountReal" value="<%= old?.amount || '0' %>" />
          </div>
          <% if (errors?.amount) { %>
          <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors.amount %></p>
          <% } %>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Nomor SK Resmi</label>
            <input type="text" name="skNumber" value="<%= old?.skNumber || '' %>" placeholder="SK/REWARD/2026/001"
              class="w-full bg-slate-50/60 border <%= errors?.skNumber ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/70 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 focus:bg-white outline-none transition-all text-slate-800 font-medium" />
            <% if (errors?.skNumber) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors.skNumber %></p>
            <% } %>
          </div>

          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Tanggal Terbit SK</label>
            <input type="date" name="dateIssued" value="<%= old?.dateIssued || today %>"
              class="w-full bg-slate-50/60 border <%= errors?.dateIssued ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/70 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] text-slate-800 outline-none focus:bg-white transition-all cursor-pointer font-medium" />
            <% if (errors?.dateIssued) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors.dateIssued %></p>
            <% } %>
          </div>

          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Tanggal Efektif</label>
            <input type="date" name="effectiveDate" value="<%= old?.effectiveDate || '' %>"
              class="w-full bg-slate-50/60 border <%= errors?.effectiveDate ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/70 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] text-slate-800 outline-none focus:bg-white transition-all cursor-pointer font-medium" />
            <% if (errors?.effectiveDate) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors.effectiveDate %></p>
            <% } %>
          </div>
        </div>

        <div class="space-y-2 mb-5">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Alasan / Justifikasi Kasus</label>
          <textarea name="reason" rows="4" placeholder="Tuliskan justifikasi kronologi detail mengenai diterbitkannya dokumen log ini..." class="w-full bg-slate-50/60 border <%= errors?.reason ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/70 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 focus:bg-white outline-none resize-none transition-all leading-relaxed text-slate-800 font-medium"><%= old?.reason || '' %></textarea>
          <% if (errors?.reason) { %>
          <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors.reason %></p>
          <% } %>
        </div>


          <%- include('../partials/form/file-uploads', {
    label: 'Lampiran SK',
    inputName: 'attachment',
    inputId: 'attachment-reward',
    accept: 'image/*,application/pdf',
    required: false,
    maxText: 'Mendukung format Gambar atau PDF (Maksimal 5MB)',
    error: errors?.attachment,
    oldFile: (typeof old !== 'undefined' && old?.attachment) ? old.attachment : null
}) %>

        <div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-2.5">
          <a href="/reward-punishment" class="w-auto text-center bg-white hover:bg-slate-50 text-slate-600 px-5 py-2.5 rounded-xl text-[12px] font-semibold border border-slate-200 transition-colors">
            Batal
          </a>
          <button type="submit" class="w-auto text-center bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-xl text-[12px] font-semibold transition-colors cursor-pointer">
            Simpan Catatan
          </button>
        </div>

      </form>
    </div>
  </div>
</div>
<script src="/js/file-upload.js"></script>
<script>
  function toggleFinancialSection() {
    const toggleCheckbox = document.getElementById("hasFinancialImpact");
    const amountSection = document.getElementById("financialAmountSection");
    const toggleLabel = document.getElementById("toggleLabel");
    const nominalInput = document.getElementById("nominalInput");
    const amountReal = document.getElementById("amountReal");

    if (toggleCheckbox.checked) {
      amountSection.classList.remove("hidden");
      toggleLabel.textContent = "Ada";
      toggleLabel.className = "text-[11.5px] font-bold text-blue-600 uppercase tracking-wider min-w-[70px] text-right";
      
      if(amountReal.value === "0" || amountReal.value === "") {
        nominalInput.value = "";
        amountReal.value = "0";
      }
    } else {
      amountSection.classList.add("hidden");
      toggleLabel.textContent = "Tidak Ada";
      toggleLabel.className = "text-[11.5px] font-bold text-slate-400 uppercase tracking-wider min-w-[70px] text-right";
      
      nominalInput.value = "";
      amountReal.value = "0";
    }
  }

  

  document.addEventListener("DOMContentLoaded", () => {
    toggleFinancialSection();

    const nominalInput = document.getElementById("nominalInput");
    const amountReal = document.getElementById("amountReal");

    if (nominalInput && amountReal) {
      if (amountReal.value && amountReal.value !== "0") {
        nominalInput.value = formatRupiah(amountReal.value);
      }

      nominalInput.addEventListener("input", function () {
        let value = this.value.replace(/[^0-9]/g, "");
        amountReal.value = value || "0";
        this.value = value ? formatRupiah(value) : "";
      });
    }

    function formatRupiah(angka) {
      return angka.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    }
  });
</script>
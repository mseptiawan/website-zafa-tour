<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50  antialiased selection:bg-slate-100 px-4 sm:p-6 md:p-10 pb-24 md:pb-8 text-slate-800 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 pb-5 mb-6 border-b border-slate-200/60 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header', { 
            section: 'Area Kerja', 
            module: 'Management', 
            title: 'Kunjungan Sales Pegawai', 
            description: 'Pantau dan evaluasi seluruh log riwayat kunjungan sales yang dilakukan oleh staf lapangan.' 
        }) %>
      </div>
    </div>

    <% if (!visits || visits.length === 0) { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl py-16 text-center shadow-3xs px-4">
        <div class="w-10 h-10 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-3.5 text-slate-400">
          <svg class="h-5 w-5 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
        </div>
        <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Riwayat Kunjungan Pegawai</p>
        <p class="text-[11.5px] text-slate-400 max-w-xs mx-auto mt-0.5 leading-relaxed">Seluruh data laporan peninjauan merchant atau klien dari tim sales belum terekam.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 gap-3 md:block md:bg-white md:border md:border-slate-200/60 md:rounded-2xl md:p-1.5 md:shadow-3xs md:divide-y md:divide-slate-100/80">
        <% visits.forEach(v => { %>
          <%- include('./partials/sales-visit-card', { visit: v, showEmployee: true, canEdit: false }) %>
        <% }) %>
      </div>
    <% } %> 

    <%- include('../partials/pagination-nav') %>
  </div>
</div>
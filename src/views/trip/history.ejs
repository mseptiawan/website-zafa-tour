<%- layout('layouts/main', { title }) %>

<% 
  // Memisahkan data dinas berdasarkan status untuk Tab Navigasi seperti contoh referensi
  const activeTrips = trips.filter(t => ['PENDING', 'IN_REVIEW'].includes(t.status));
  const historyTrips = trips.filter(t => ['APPROVED', 'REJECTED', 'CANCELLED'].includes(t.status));

  // Fungsi pembantu untuk memetakan konfigurasi warna status tag agar serasi
  const getStatusConfig = (status) => {
    const maps = {
      'PENDING': { label: 'Pending', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500' },
      'IN_REVIEW': { label: 'In Review', badge: 'bg-indigo-50 text-indigo-600 border-indigo-200/50', dot: 'bg-indigo-500' },
      'APPROVED': { label: 'Approved', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500 animate-pulse' },
      'REJECTED': { label: 'Rejected', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' },
      'PAYMENT_PROCESSING': { label: 'Payment Proc.', badge: 'bg-purple-50 text-purple-600 border-purple-200/50', dot: 'bg-purple-500' },
      'READY_TO_TRAVEL': { label: 'Ready to Travel', badge: 'bg-teal-50 text-teal-600 border-teal-200/50', dot: 'bg-teal-500' },
      'PAID': { label: 'Paid', badge: 'bg-emerald-50/40 text-emerald-700 border-emerald-200/60', dot: 'bg-emerald-600' },
      'ON_TRIP': { label: 'On Trip', badge: 'bg-sky-50 text-sky-600 border-sky-200/50', dot: 'bg-sky-500 animate-pulse' },
      'SUBMITTED': { label: 'Submitted', badge: 'bg-blue-50 text-blue-600 border-blue-200/50', dot: 'bg-blue-500' },
      'CANCELLED': { label: 'Cancelled', badge: 'bg-slate-50 text-slate-500 border-slate-200', dot: 'bg-slate-400' }
    };
    return maps[status] || { label: status, badge: 'bg-slate-50 text-slate-600 border-slate-200/50', dot: 'bg-slate-500' };
  };

  // Kalkulasi sederhana untuk data statistik di atas halaman (menghindari error jika stats dikirim parsial dari controller)
  const totalActiveBudget = activeTrips.reduce((acc, curr) => acc + (curr.budget?.total || 0), 0);
%>

<div>
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

    <div class="border border-slate-200/60 md:border-none md:shadow-none">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Dinas luar', 
          title: 'Daftar Pengajuan Dinas', 
          description: 'Kelola seluruh pengajuan perjalanan dinas luar operasional pegawai secara efisien.' 
      }) %>
    </div>

    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        gridClass: 'grid-cols-2 lg:grid-cols-3', 
        items: [
          { 
            label: 'Total Pengajuan', 
            value: trips.length + ' Berkas', 
            unit: '', 
            icon: 'fa-solid fa-folder-open', 
            labelClass: '!text-[11px] !font-medium text-slate-400 uppercase tracking-wider', 
            valueClass: '!text-base !font-semibold text-slate-800 tracking-tight', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          },
          { 
            label: 'Dinas Berjalan', 
            value: activeTrips.length + ' Agenda', 
            unit: '', 
            icon: 'fa-solid fa-plane-departure', 
            labelClass: '!text-[11px] !font-medium text-blue-600 uppercase tracking-wider', 
            valueClass: '!text-base !font-semibold text-blue-700 tracking-tight', 
            iconBoxClass: 'bg-blue-50 text-blue-500 border border-blue-200/50' 
          },
          { 
            label: 'Estimasi Budget Aktif', 
            value: 'Rp ' + totalActiveBudget.toLocaleString('id-ID'), 
            unit: '', 
            icon: 'fa-solid fa-wallet', 
            labelClass: '!text-[11px] !font-medium text-emerald-600 uppercase tracking-wider', 
            valueClass: '!text-base !font-semibold text-emerald-700 tracking-tight', 
            iconBoxClass: 'bg-emerald-50 text-emerald-500 border border-emerald-200/50' 
          }
        ]
      }) %>
    </div>

    <div class="flex flex-col gap-3.5 w-full bg-white md:bg-transparent border border-slate-200/50 md:border-none p-4 md:p-0 rounded-2xl md:rounded-none md:shadow-none select-none">
      <div class="flex items-center justify-between gap-3 w-full md:hidden">
        <h3 class="text-[14px] font-medium text-slate-800 tracking-tight">Daftar Berkas</h3>
        <a href="/trip/new" class="inline-flex items-center justify-center gap-1.5 h-8.5 px-4 bg-blue-600 text-white text-[11px] font-medium rounded-full transition-all active:scale-95 outline-none cursor-pointer">
          <i class="fa-solid fa-plus text-[9px]"></i>
          <span>Buat Pengajuan</span>
        </a>
      </div>

      <%- include('../partials/_tab-nav', {
        tabs: [
          { 
            id: 'active', 
            label: `Dinas Berjalan (${activeTrips.length})`,
            isActive: true 
          },
          { 
            id: 'history', 
            label: `Riwayat Selesai (${historyTrips.length})`,
            isActive: false 
          }
        ]
      }) %>
    </div>

    <div id="tab-content-active" class="tab-pane space-y-4 block opacity-100 transition-all duration-300 transform translate-y-0">
      
      <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6 w-[35%]">Judul Perjalanan</th>
                <th class="py-4 px-6 w-[25%]">Tujuan / Lokasi</th>
                <th class="py-4 px-6 text-right w-[20%]">Estimasi Anggaran</th>
                <th class="py-4 px-6 text-center w-[12%]">Status</th>
                <th class="py-4 px-6 text-center w-[8%]">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (activeTrips.length === 0) { %>
                <tr>
                  <td colspan="5" class="py-12 text-center text-slate-400 font-medium">Belum ada agenda dinas luar yang sedang berjalan.</td>
                </tr>
              <% } else { %>
                <% activeTrips.forEach(t => { %>
                  <% const config = getStatusConfig(t.status); %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6 font-medium text-slate-800 break-words"><%= t.title %></td>
                    <td class="py-4 px-6 text-slate-500 break-words"><%= t.destination || '-' %></td>
                    <td class="py-4 px-6 text-right font-medium text-slate-900 tabular-nums">
                      Rp <%= (t.budget?.total || 0).toLocaleString('id-ID') %>
                    </td>
                    <td class="py-4 px-6 text-center select-none">
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                        <span><%= config.label.toUpperCase() %></span>
                      </div>
                    </td>
                    <td class="py-4 px-6 text-center">
                      <div class="flex items-center justify-center gap-1.5">
                        <a href="/trip/detail/<%= t._id %>" title="Lihat Berkas" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                          <i class="fa-solid fa-eye text-[11px]"></i>
                        </a>
                        <% if (t.status === 'PENDING') { %>
                          <a href="/trip/edit/<%= t._id %>" title="Ubah Formulir" class="w-8 h-8 rounded-lg bg-amber-400 text-white inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-amber-500">
                            <i class="fa-solid fa-pen-to-square text-[11px]"></i>
                          </a>
                        <% } %>
                        <% if (t.status === 'REJECTED') { %>
                          <a href="/trip/edit/<%= t._id %>" title="Ajukan Kembali" class="w-8 h-8 rounded-lg bg-emerald-500 text-white inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-emerald-600">
                            <i class="fa-solid fa-rotate-left text-[11px]"></i>
                          </a>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-3.5 w-full">
        <% if (activeTrips.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
            <p class="text-[12px] font-medium text-slate-400">Tidak ada dinas luar berjalan</p>
          </div>
        <% } else { %>
          <% activeTrips.forEach(t => { %>
            <% const config = getStatusConfig(t.status); %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight line-clamp-1"><%= t.title %></h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5"><%= t.destination || '-' %></p>
                </div>
                <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
                  <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label %></span>
                </div>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-1 gap-1 text-xs">
                <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Total Estimasi Anggaran</p>
                <p class="text-[13px] font-semibold text-blue-600 tabular-nums mt-0.5">Rp <%= (t.budget?.total || 0).toLocaleString('id-ID') %></p>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-500"><i class="fa-solid fa-briefcase text-slate-400 mr-1.5"></i>Dinas Luar</span>
                <div class="flex items-center gap-1.5">
                  <% if (t.status === 'PENDING' || t.status === 'REJECTED') { %>
                    <a href="/trip/edit/<%= t._id %>" class="h-8 w-8 rounded-lg bg-amber-400 text-white flex items-center justify-center text-xs active:scale-95"><i class="fa-solid fa-marker"></i></a>
                  <% } %>
                  <a href="/trip/detail/<%= t._id %>" class="h-8 px-3.5 bg-blue-50 text-blue-600 text-[11px] font-medium rounded-lg flex items-center justify-center tracking-wide active:scale-95">
                    DETAIL
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane space-y-4 hidden opacity-0 transition-all duration-300 transform translate-y-2">
      
      <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6 w-[35%]">Judul Perjalanan</th>
                <th class="py-4 px-6 w-[25%]">Tujuan / Lokasi</th>
                <th class="py-4 px-6 text-right w-[20%]">Total Budget Reel</th>
                <th class="py-4 px-6 text-center w-[12%]">Status</th>
                <th class="py-4 px-6 text-center w-[8%]">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (historyTrips.length === 0) { %>
                <tr>
                  <td colspan="5" class="py-12 text-center text-slate-400 font-medium">Belum ada arsip riwayat berkas selesai.</td>
                </tr>
              <% } else { %>
                <% historyTrips.forEach(t => { %>
                  <% const config = getStatusConfig(t.status); %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6 font-medium text-slate-800 break-words"><%= t.title %></td>
                    <td class="py-4 px-6 text-slate-500 break-words"><%= t.destination || '-' %></td>
                    <td class="py-4 px-6 text-right font-medium text-slate-900 tabular-nums">
                      Rp <%= (t.budget?.total || 0).toLocaleString('id-ID') %>
                    </td>
                    <td class="py-4 px-6 text-center select-none">
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                        <span><%= config.label.toUpperCase() %></span>
                      </div>
                    </td>
                    <td class="py-4 px-6 text-center">
                      <a href="/trip/detail/<%= t._id %>" title="Lihat Berkas" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                        <i class="fa-solid fa-eye text-[11px]"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-3.5 w-full">
        <% if (historyTrips.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
            <p class="text-[12px] font-medium text-slate-400">Belum ada arsip riwayat selesai</p>
          </div>
        <% } else { %>
          <% historyTrips.forEach(t => { %>
            <% const config = getStatusConfig(t.status); %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight line-clamp-1"><%= t.title %></h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5"><%= t.destination || '-' %></p>
                </div>
                <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
                  <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label %></span>
                </div>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-1 gap-1 text-xs">
                <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Total Anggaran Terpakai</p>
                <p class="text-[13px] font-semibold text-slate-700 tabular-nums mt-0.5">Rp <%= (t.budget?.total || 0).toLocaleString('id-ID') %></p>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-400"><i class="fa-solid fa-box-archive mr-1.5"></i>Arsip Selesai</span>
                <a href="/trip/<%= t._id %>" class="h-8 px-3.5 bg-slate-100 text-slate-700 text-[11px] font-medium border border-slate-200 rounded-lg flex items-center justify-center tracking-wide active:scale-95">
                  LIHAT
                </a>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <% if (pagination && pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between mt-6 px-5 py-4 bg-white border border-slate-200/50 rounded-2xl text-[13px] select-none antialiased shadow-[0_4px_12px_rgba(0,0,0,0.01)]">
        <div class="text-slate-500 font-medium">
          Menampilkan halaman <span class="font-medium text-slate-900"><%= pagination.page %></span> dari <span class="font-medium text-slate-900"><%= pagination.totalPages %></span>
        </div>
        <div class="flex items-center gap-2">
          <a href="?page=<%= pagination.page - 1 %>" class="px-4 py-2 rounded-xl border font-medium transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
            <%= pagination.hasPrev ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900' : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Prev
          </a>
          <a href="?page=<%= pagination.page + 1 %>" class="px-4 py-2 rounded-xl border font-medium transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
            <%= pagination.hasNext ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900' : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
            Next
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    <% } %>

  </div>
</div>

<script>
  function switchTab(tabName) {
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.add('hidden');
      pane.classList.remove('block', 'opacity-100', 'translate-y-0');
    });

    const activeContent = document.getElementById(`tab-content-${tabName}`);
    if (activeContent) {
      activeContent.classList.remove('hidden');
      activeContent.classList.add('block');
      setTimeout(() => {
        activeContent.classList.add('opacity-100', 'translate-y-0');
      }, 10);
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('bg-white', 'font-medium', 'text-slate-900', 'shadow-xs');
      btn.classList.add('font-medium', 'text-slate-500');
    });

    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    if (activeBtn) {
      activeBtn.classList.remove('font-medium', 'text-slate-500');
      activeBtn.classList.add('bg-white', 'font-medium', 'text-slate-900', 'shadow-xs');
    }
  }
</script>
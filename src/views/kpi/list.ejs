<%- layout('layouts/main', { title }) %>

<div class="ml-72 p-8">
  <h2 class="text-2xl font-bold mb-6">Daftar Penilaian KPI</h2>
  <div class="bg-white rounded-xl shadow border border-slate-100">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b">
        <tr class="text-left text-slate-500 uppercase text-xs">
          <th class="p-4">Nama Karyawan</th>
          <th class="p-4">Periode</th>
          <th class="p-4 text-center">Nilai Akhir</th>
          <th class="p-4 text-center">Status</th>
          <th class="p-4">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% kpiList.forEach(kpi => { %>
        <tr>
          <td class="p-4 font-semibold"><%= kpi.employeeId?.fullName %></td>
          <td class="p-4 text-slate-600"><%= kpi.periode %></td>
          <td class="p-4 text-center font-bold text-indigo-600"><%= kpi.totalKpiScore %></td>
          <td class="p-4 text-center">
            <span class="px-2 py-1 bg-green-100 text-green-700 rounded-lg text-xs"><%= kpi.status %></span>
          </td>
          <td class="p-4">
            <a href="/kpi/detail/<%= kpi.employeeId?._id %>/<%= kpi.periode %>" 
               class="text-indigo-600 hover:underline font-medium">Lihat Detail</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
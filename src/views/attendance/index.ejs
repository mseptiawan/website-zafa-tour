<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 p-8 bg-slate-50 min-h-screen">

  <!-- HEADER -->
  <div class="flex justify-between items-end mb-6">

    <div>
      <h1 class="text-xl font-semibold text-slate-800">
        Data Absensi Karyawan
      </h1>
      <p class="text-sm text-slate-500">
        HR Management Absensi
      </p>
    </div>

    <!-- BUTTON MANUAL -->
    <a href="/attendance/create-manual"
      class="bg-slate-900 text-white text-sm px-4 py-2 rounded-lg hover:bg-slate-800 transition">
      + Absen Manual
    </a>

  </div>

  <!-- FILTER -->
  <form class="flex flex-wrap gap-2 mb-4">

    <input type="date" name="from" class="border px-3 py-2 rounded-lg text-sm">
    <input type="date" name="to" class="border px-3 py-2 rounded-lg text-sm">

    <select name="status" class="border px-3 py-2 rounded-lg text-sm">
      <option value="">Status</option>
      <option value="HADIR">Hadir</option>
      <option value="TELAT">Telat</option>
    </select>

    <select name="type" class="border px-3 py-2 rounded-lg text-sm">
      <option value="">Type</option>
      <option value="KANTOR">Kantor</option>
      <option value="LUAR KANTOR">Luar Kantor</option>
    </select>

    <button class="bg-slate-900 text-white px-4 py-2 rounded-lg text-sm">
      Filter
    </button>

  </form>

  <!-- TABLE -->
  <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">

    <div class="overflow-x-auto">
      <table class="w-full text-sm">

        <thead class="bg-slate-100 text-xs text-slate-500">
          <tr>
            <th class="p-3 text-left">User</th>
            <th>Tanggal</th>
            <th>Check In</th>
            <th>Check Out</th>
            <th>Type</th>
            <th>Status</th>
            <th>Foto</th>
            <th>Aksi</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-slate-100">

          <% data.forEach(d => { %>
          <tr class="hover:bg-slate-50">

            <td class="p-3 font-medium text-slate-700">
              <%= d.userId?.username %>
            </td>

            <td><%= new Date(d.createdAt).toLocaleDateString('id-ID') %></td>

            <td><%= d.checkIn ? new Date(d.checkIn).toLocaleTimeString('id-ID') : '-' %></td>

            <td><%= d.checkOut ? new Date(d.checkOut).toLocaleTimeString('id-ID') : '-' %></td>

            <td>
              <span class="text-xs px-2 py-1 rounded bg-slate-100">
                <%= d.type %>
              </span>
            </td>

            <!-- STATUS SIMPLE -->
            <td>
              <span class="text-xs text-slate-600">
                <%= d.status %>
              </span>
            </td>

            <td>
              <% if (d.photo) { %>
                <img src="<%= d.photo %>" class="w-8 h-8 rounded object-cover">
              <% } else { %>
                -
              <% } %>
            </td>

            <td class="space-x-3">

              <a href="/attendance/edit/<%= d._id %>"
                class="text-blue-500 text-sm">
                Edit
              </a>

              <button
                class="openModal text-indigo-500 text-sm"
                data-user="<%= d.userId?.username %>"
                data-date="<%= d.createdAt %>"
                data-checkin="<%= d.checkIn %>"
                data-checkout="<%= d.checkOut %>"
                data-type="<%= d.type %>"
                data-status="<%= d.status %>"
                data-note="<%= d.note || '-' %>"
                data-address="<%= d.location?.address || '-' %>"
                data-photo="<%= d.photo || '' %>"
              >
                Detail
              </button>

            </td>

          </tr>
          <% }) %>

        </tbody>

      </table>
    </div>
  </div>
</div>

<!-- ================= MODAL ================= -->
<div id="modal"
  class="fixed inset-0 hidden bg-black/50 items-center justify-center p-4">

  <div class="bg-white w-full max-w-lg rounded-xl p-5 shadow-xl">

    <h2 class="font-semibold mb-4 text-slate-800">
      Detail Absensi
    </h2>

    <div class="text-sm space-y-1 text-slate-600">

      <p>User: <span id="mUser"></span></p>
      <p>Status: <span id="mStatus"></span></p>
      <p>Type: <span id="mType"></span></p>
      <p>Check In: <span id="mIn"></span></p>
      <p>Check Out: <span id="mOut"></span></p>
      <p>Note: <span id="mNote"></span></p>
      <p>Address: <span id="mAddress"></span></p>

    </div>

    <img id="mPhoto"
      class="mt-4 hidden w-32 h-32 object-cover rounded-lg border">

    <button onclick="closeModal()"
      class="mt-5 bg-slate-900 text-white px-4 py-2 rounded-lg w-full">
      Tutup
    </button>

  </div>
</div>

<!-- ================= SCRIPT ================= -->
<script>
const modal = document.getElementById("modal");

document.querySelectorAll(".openModal").forEach(btn => {
  btn.addEventListener("click", () => {

    document.getElementById("mUser").textContent = btn.dataset.user;
    document.getElementById("mStatus").textContent = btn.dataset.status;
    document.getElementById("mType").textContent = btn.dataset.type;
    document.getElementById("mIn").textContent = btn.dataset.checkin;
    document.getElementById("mOut").textContent = btn.dataset.checkout;
    document.getElementById("mNote").textContent = btn.dataset.note;
    document.getElementById("mAddress").textContent = btn.dataset.address;

    if (btn.dataset.photo) {
      document.getElementById("mPhoto").src = btn.dataset.photo;
      document.getElementById("mPhoto").classList.remove("hidden");
    } else {
      document.getElementById("mPhoto").classList.add("hidden");
    }

    modal.classList.remove("hidden");
    modal.classList.add("flex");
  });
});

function closeModal() {
  modal.classList.add("hidden");
  modal.classList.remove("flex");
}
</script>
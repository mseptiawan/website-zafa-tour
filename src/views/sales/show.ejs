<%- layout('layouts/main', { title }) %>

<div class="ml-72 p-8">

  <div class="bg-white p-6 rounded-xl shadow max-w-2xl">

    <h1 class="text-xl font-bold"><%= visit.customerName %></h1>

    <p class="text-slate-500"><%= visit.address %></p>

    <p class="mt-2">👤 <%= visit.meetWith %></p>

    <p class="mt-2"><%= visit.result %></p>

    <% if (visit.photo) { %>
      <img src="/uploads/<%= visit.photo %>" class="mt-4 rounded-lg" />
    <% } %>

  </div>

</div>
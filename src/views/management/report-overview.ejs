<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50  md:p-10 antialiased selection:bg-slate-100 pb-24 md:pb-8 text-slate-800 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto  md:mt-0 space-y-5">
    

    <form method="GET" class="space-y-3 rounded-2xl border border-slate-200/60 bg-white p-4 shadow-xs">
      <div class="grid grid-cols-2 gap-2">
        <div>
          <label class="mb-1 block text-[9px]   font-medium tracking-wider text-slate-400 uppercase">
            Mulai
          </label>
          <input
            type="date"
            name="startDate"
            value="<%= filters.startDate %>"
            class="w-full rounded-xl border border-slate-200/50 bg-slate-50 p-2.5 text-xs  font-medium text-slate-700 transition-all outline-none focus:border-blue-500"
          />
        </div>
        <div>
          <label class="mb-1 block text-[9px]   font-medium tracking-wider text-slate-400 uppercase">
            Selesai
          </label>
          <input
            type="date"
            name="endDate"
            value="<%= filters.endDate %>"
            class="w-full rounded-xl border border-slate-200/50 bg-slate-50 p-2.5 text-xs  font-medium text-slate-700 transition-all outline-none focus:border-blue-500"
          />
        </div>
      </div>
      
      <div>
        <label class="mb-1 block text-[9px]   font-medium tracking-wider text-slate-400 uppercase">
          Buku Periode Gaji (Payroll)
        </label>
        <input
          type="month"
          name="periodMonth"
          value="<%= filters.periodMonth %>"
          class="w-full rounded-xl border border-slate-200/50 bg-slate-50 p-2.5 text-xs   font-medium text-slate-700 transition-all outline-none focus:border-blue-500"
        />
      </div>

      <button
        type="submit"
        class="flex h-10 w-full items-center justify-center gap-2 rounded-xl bg-blue-600 text-[11px]   font-medium text-white shadow-xs transition-all hover:bg-slate-800 active:scale-95 cursor-pointer"
      >
        <i class="fa-solid fa-arrows-rotate text-[10px]"></i>
        Perbarui Data Laporan
      </button>
    </form>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
      
      <div class="shadow-3xs flex items-center justify-between rounded-2xl border border-slate-200/60 bg-white p-4 transition-colors hover:border-slate-300">
        <div class="flex items-center gap-3.5">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-blue-100/40 bg-blue-50 text-blue-600">
            <i class="fa-solid fa-users text-base"></i>
          </div>
          <div>
            <h4 class="text-xs   font-medium tracking-tight text-slate-800">Laporan Data Pegawai</h4>
            <p class="text-[11px] font-medium text-slate-400">Total internal SDM aktif</p>
          </div>
        </div>
        <div class="text-right">
          <span class="text-lg  font-semibold text-slate-900 tabular-nums">
            <%= summary.employees.total %>
          </span>
          <span class="block text-[9px]   font-medium tracking-wider text-slate-400 uppercase">
            Anggota
          </span>
        </div>
      </div>

      <div class="shadow-3xs flex items-center justify-between rounded-2xl border border-slate-200/60 bg-white p-4 transition-colors hover:border-slate-300">
        <div class="flex items-center gap-3.5">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-emerald-100/40 bg-emerald-50 text-emerald-600">
            <i class="fa-solid fa-calendar-check text-base"></i>
          </div>
          <div>
            <h4 class="text-xs   font-medium tracking-tight text-slate-800">Laporan Rekap Absensi</h4>
            <p class="text-[11px] font-medium text-slate-400">Akumulasi log presensi masuk</p>
          </div>
        </div>
        <div class="text-right">
          <span class="text-lg  font-semibold text-slate-900 tabular-nums">
            <%= summary.attendance.totalHadir %>
          </span>
          <span class="block text-[9px]   font-medium tracking-wider text-slate-400 uppercase">
            Kehadiran
          </span>
        </div>
      </div>

      <div class="shadow-3xs flex items-center justify-between rounded-2xl border border-slate-200/60 bg-white p-4 transition-colors hover:border-slate-300">
        <div class="flex items-center gap-3.5">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-purple-100/40 bg-purple-50 text-purple-600">
            <i class="fa-solid fa-user-clock text-base"></i>
          </div>
          <div>
            <h4 class="text-xs   font-medium tracking-tight text-slate-800">Laporan Rekap Lembur</h4>
            <p class="text-[11px] font-medium text-slate-400">
              Durasi: <b class="  font-medium text-slate-700"><%= summary.overtime.hours %> Jam</b>
            </p>
          </div>
        </div>
        <div class="text-right">
          <span class="text-xs  font-semibold text-purple-600 tabular-nums block">
            Rp <%= new Intl.NumberFormat('id-ID').format(summary.overtime.cost) %>
          </span>
          <span class="block text-[9px]   font-medium tracking-wider text-slate-400 uppercase">
            Beban Lembur
          </span>
        </div>
      </div>

      <div class="shadow-3xs flex items-center justify-between rounded-2xl border border-slate-200/60 bg-white p-4 transition-colors hover:border-slate-300">
        <div class="flex items-center gap-3.5">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-rose-100/40 bg-rose-50 text-rose-600">
            <i class="fa-solid fa-receipt text-base"></i>
          </div>
          <div>
            <h4 class="text-xs   font-medium tracking-tight text-slate-800">Laporan Gaji & Payroll</h4>
            <p class="text-[11px] font-medium text-slate-400">
              Buku tutup: <b class="  font-medium text-slate-700"><%= summary.payroll.count %> Slip</b>
            </p>
          </div>
        </div>
        <div class="text-right">
          <span class="text-xs  font-semibold text-rose-600 tabular-nums block">
            Rp <%= new Intl.NumberFormat('id-ID').format(summary.payroll.totalNet) %>
          </span>
          <span class="block text-[9px]   font-medium tracking-wider text-slate-400 uppercase">
            Total THP
          </span>
        </div>
      </div>

    </div>
  </div>
</div>
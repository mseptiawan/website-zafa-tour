<%- layout('layouts/main', { title }) %>

  <div class="bg-slate-50 min-h-screen antialiased font-sans lg:ml-72 p-4 md:p-8 text-slate-800">
    <div class="max-w-5xl mx-auto space-y-6">

      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-5 bg-white border border-slate-200/80 p-5 rounded-2xl shadow-sm shadow-slate-100/50">
        <div>
          <h1 class="text-xl font-bold text-slate-900 tracking-tight">Daily Activity Log</h1>
          <p class="text-[12px] text-slate-500 mt-1">Selamat bekerja, <%= user.fullName %>! Kelola log aktivitas harian Anda dengan ringkas.</p>
        </div>

        <div class="flex items-center gap-3 w-full sm:w-auto justify-between sm:justify-end border-t sm:border-0 pt-4 sm:pt-0 border-slate-100">
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Tanggal</label>
          <input type="date" id="log-date"
            class="bg-slate-50/80 border border-slate-200 rounded-xl px-4 py-2 text-[13px] font-semibold text-slate-700 outline-none focus:border-slate-400 focus:bg-white focus:ring-4 focus:ring-slate-100 transition transition-all duration-200 cursor-pointer w-full sm:w-auto min-w-[160px] shadow-xs" />
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 bg-white border border-slate-200/80 p-4 rounded-2xl shadow-sm shadow-slate-100/50">
        <div class="flex items-center gap-2.5 pl-1">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          <span id="date-status" class="text-[12.5px] font-semibold text-slate-600">Memuat data lembar kerja...</span>
        </div>

        <button type="button" id="btn-carry-over" onclick="executeCarryOver()"
          class="hidden w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white rounded-xl px-4 py-2.5 text-[12px] font-semibold transition transition-all active:scale-[0.97] shadow-sm shadow-blue-100 cursor-pointer">
          <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l-3 3m3-3l3 3" />
          </svg>
          Salin Tugas Pending Kemarin
        </button>
      </div>

      <div id="container-form-add" class="bg-white border border-slate-200/80 p-5 rounded-2xl shadow-sm shadow-slate-100/50">
        <h2 class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-4 flex items-center gap-2">
          <div class="flex items-center justify-center w-6 h-6 rounded-lg bg-blue-50 text-blue-600">
            <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </div>
          Tambah Aktivitas Baru
        </h2>

        <form id="form-create-activity" onsubmit="submitFormCreate(event)" class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
          <div class="md:col-span-6">
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-1">Judul Aktivitas / Tugas</label>
            <input type="text" id="add-judul" name="judul" placeholder="Contoh: Integrasi API Payment Gateway Sanyru..." required
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-[13px] font-medium text-slate-800 outline-none focus:bg-white focus:border-slate-400 focus:ring-4 focus:ring-slate-100 transition transition-all duration-200" />
          </div>

          <div class="md:col-span-3">
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-1">Kategori</label>
            <div class="relative">
              <select id="add-kategori" name="kategori"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-[13px] font-medium text-slate-700 outline-none focus:bg-white focus:border-slate-400 focus:ring-4 focus:ring-slate-100 transition transition-all duration-200 appearance-none cursor-pointer">
                <option value="Core Task">Core Task</option>
                <option value="Meeting">Meeting</option>
                <option value="Support">Support</option>
              </select>
              <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-slate-400">
                <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </div>
            </div>
          </div>

          <div class="md:col-span-3">
            <button type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-[12.5px] px-5 py-2.5 rounded-xl transition transition-all duration-150 active:scale-[0.97] flex items-center justify-center gap-2 shadow-sm shadow-blue-100 cursor-pointer h-[42px]">
              Simpan Aktivitas
            </button>
          </div>
        </form>
      </div>

      <div class="bg-white border border-slate-200/80 rounded-2xl shadow-sm shadow-slate-100/50 overflow-hidden">
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200 text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                <th class="py-4 px-5 w-36 text-center">Status</th>
                <th class="py-4 px-5 w-32">Kategori</th>
                <th class="py-4 px-5">Judul Aktivitas / Tugas</th>
                <th class="py-4 px-5 w-48">Lampiran Bukti</th>
                <th class="py-4 px-5 w-16 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody id="task-table-body" class="divide-y divide-slate-100">
              </tbody>
          </table>
        </div>

        <div id="task-mobile-list" class="block md:hidden divide-y divide-slate-100">
          </div>

        <div id="empty-state" class="hidden p-12 text-center max-w-sm mx-auto my-4">
          <div class="flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-50 text-slate-400 mx-auto border border-slate-200/60 mb-3">
            <svg class="w-6 h-6 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.03 0 1.9.693 2.166 1.638m-7.377 2.24l-.4 2.055a2.25 2.25 0 001.542 2.58l.107.031" />
            </svg>
          </div>
          <p class="text-[13px] font-bold text-slate-700">Tidak ada aktivitas harian</p>
          <p class="text-[11.5px] text-slate-400 mt-0.5">Silakan tambahkan agenda aktivitas baru melalui kolom form di atas.</p>
        </div>
      </div>

    </div>

    <script>
      const todayStr = new Date().toISOString().split('T')[0];
      const datePicker = document.getElementById('log-date');
      datePicker.value = todayStr;

      // Update Styles: Mengikuti standarisasi Zafa Tour, border transparan tipis + background soft tint
      const statusStyles = {
        "Pending": "bg-amber-50/70 text-amber-600 border-amber-200/50",
        "In Progress": "bg-blue-50/70 text-blue-600 border-blue-200/50",
        "Completed": "bg-emerald-50/70 text-emerald-600 border-emerald-200/50",
        "Canceled": "bg-slate-50 text-slate-400 border-slate-200"
      };

      // 1. FETCH DATA DARI BACKEND
      async function loadDailyLog() {
        const selectedDate = datePicker.value;
        const dateStatus = document.getElementById('date-status');
        const btnCarryOver = document.getElementById('btn-carry-over');
        const containerFormAdd = document.getElementById('container-form-add');

        if (selectedDate === todayStr) {
          dateStatus.innerText = "Lembar Kerja: Hari Ini";
          btnCarryOver.classList.remove('hidden');
          containerFormAdd.classList.remove('hidden');
        } else {
          dateStatus.innerText = `Arsip Riwayat: ${selectedDate}`;
          btnCarryOver.classList.add('hidden');
          containerFormAdd.classList.add('hidden');
        }

        try {
          const response = await fetch(`/daily-log/api/data?tanggal=${selectedDate}`);
          const result = await response.json();

          if (result.success) {
            renderTableData(result.data);
          } else {
            alert(result.message || "Gagal memuat log.");
          }
        } catch (err) {
          console.error(err);
          alert("Terjadi kesalahan koneksi ke server.");
        }
      }

      // 2. RENDER DATA (DESKTOP & MOBILE RESPONSIVE)
      function renderTableData(tasks) {
        const tbody = document.getElementById('task-table-body');
        const mobileList = document.getElementById('task-mobile-list');
        const emptyState = document.getElementById('empty-state');

        tbody.innerHTML = "";
        mobileList.innerHTML = "";

        if (!tasks || tasks.length === 0) {
          emptyState.classList.remove('hidden');
          return;
        }
        emptyState.classList.add('hidden');

        tasks.forEach(task => {
          let titleStyle = "text-[13px] font-semibold text-slate-800 tracking-tight transition-all duration-150";
          if (task.status === "Completed") titleStyle = "text-[13px] text-slate-400 font-normal line-through opacity-80";
          if (task.status === "Canceled") titleStyle = "text-[13px] text-slate-300 font-normal line-through opacity-60";

          // Konten Form Template agar tidak menulis dua kali
          const formInnerHTML = `
          <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
            <div class="sm:col-span-2">
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Judul Tugas</label>
              <input type="text" name="judul" value="${task.judul}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3.5 py-2 text-[12.5px] font-medium text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition" required />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Kategori</label>
              <div class="relative">
                <select name="kategori" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3.5 py-2 text-[12.5px] font-medium text-slate-600 outline-none focus:bg-white focus:border-slate-400 transition appearance-none cursor-pointer">
                  <option value="Core Task" ${task.kategori === 'Core Task' ? 'selected' : ''}>Core Task</option>
                  <option value="Meeting" ${task.kategori === 'Meeting' ? 'selected' : ''}>Meeting</option>
                  <option value="Support" ${task.kategori === 'Support' ? 'selected' : ''}>Support</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
                  <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Status Kerja</label>
              <div class="relative">
                <select name="status" class="w-full border rounded-xl px-3.5 py-2 text-[11px] font-bold ${statusStyles[task.status]} outline-none focus:bg-white focus:border-slate-400 transition appearance-none cursor-pointer">
                  <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                  <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                  <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                  <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none">
                  <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>
            </div>
          </div>

          <div class="pt-1">
            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Penjelasan Hasil / Kendala Kerja</label>
            <textarea name="penjelasanHasil" rows="2" placeholder="Tulis rincian hasil pengerjaan atau kendala lapangan di sini..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3.5 py-2 text-[12.5px] font-medium text-slate-700 outline-none resize-none focus:bg-white focus:border-slate-400 transition">${task.penjelasanHasil || ''}</textarea>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-3 border-t border-slate-100">
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Lampiran Bukti</label>
              ${task.fileLampiran ? `
                <div id="file-status-container-${task._id}" class="flex items-center gap-2">
                  <span class="text-[11px] font-medium text-slate-500 bg-slate-50 border border-slate-200 px-2.5 py-1 rounded-lg truncate max-w-[180px]">📎 ${task.fileLampiran}</span>
                  <button type="button" onclick="switchToEditFile('${task._id}')" class="text-[10px] font-bold text-slate-600 hover:text-slate-900 bg-slate-100/80 hover:bg-slate-200 px-2.5 py-1 rounded-lg border border-slate-200 transition cursor-pointer">Ubah</button>
                </div>
                <input type="file" id="input-file-${task._id}" name="attachment" class="hidden text-[11.5px] text-slate-500 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border file:border-slate-200 file:bg-white file:text-[11px] file:font-semibold cursor-pointer" />
              ` : `
                <input type="file" name="attachment" class="text-[11.5px] text-slate-500 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border file:border-slate-200 file:bg-slate-50 file:text-[11px] file:font-semibold cursor-pointer" />
              `}
            </div>
            <div class="flex gap-2 justify-end">
              <button type="button" onclick="toggleExpandRow('${task._id}')" class="text-[12px] font-semibold text-slate-500 bg-slate-50 hover:bg-slate-100 border border-slate-200 px-4 py-2 rounded-xl transition cursor-pointer active:scale-95">Tutup</button>
              <button type="submit" class="text-[12px] font-semibold text-white bg-blue-600 hover:bg-blue-700 px-5 py-2 rounded-xl transition shadow-sm shadow-blue-100 cursor-pointer active:scale-95">Simpan</button>
            </div>
          </div>
        `;

          // --- DESKTOP VIEW ROW ---
          const rowHTML = `
          <tr class="hover:bg-slate-50/40 transition-colors group border-b border-slate-100 last:border-0" id="row-view-${task._id}">
            <td class="py-3.5 px-5 text-center whitespace-nowrap">
              <div class="relative inline-block w-[115px]">
                <select onchange="quickUpdateStatus('${task._id}', this.value)" class="w-full text-[10px] font-bold rounded-full px-2.5 py-1 outline-none border cursor-pointer transition appearance-none text-center tracking-wide ${statusStyles[task.status]}">
                  <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                  <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                  <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                  <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
                </select>
              </div>
            </td>
            <td class="py-3.5 px-5 whitespace-nowrap">
              <span class="text-[10px] font-bold ${task.kategori === 'Meeting' ? 'text-amber-600 bg-amber-50/60 border-amber-200/40' : task.kategori === 'Support' ? 'text-purple-600 bg-purple-50/60 border-purple-200/40' : 'text-slate-600 bg-slate-50 border-slate-200/60'} px-2.5 py-0.5 rounded-full border tracking-wide">
                ${task.kategori}
              </span>
            </td>
            <td class="py-3.5 px-5">
              <div class="flex flex-col">
                <span class="${titleStyle}">${task.judul}</span>
                <span class="text-[11.5px] text-slate-400 font-normal truncate max-w-md mt-1 italic ${task.penjelasanHasil ? '' : 'hidden'}">
                  Hasil: ${task.penjelasanHasil}
                </span>
              </div>
            </td>
            <td class="py-3.5 px-5">
              ${task.fileLampiran ? `
                <a href="/uploads/files/${task.fileLampiran}" target="_blank" class="inline-flex items-center gap-1.5 text-[11.5px] font-medium text-slate-500 hover:text-blue-600 hover:underline transition truncate max-w-[150px]">
                  <svg class="w-3.5 h-3.5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
                  <span>Lihat Bukti</span>
                </a>
              ` : '<span class="text-slate-300 text-[11px]">—</span>'}
            </td>
            <td class="py-3.5 px-5 text-center">
              <button type="button" onclick="toggleExpandRow('${task._id}')" id="arrow-btn-${task._id}" class="w-7 h-7 inline-flex items-center justify-center text-slate-400 hover:text-slate-700 hover:bg-slate-100 border border-transparent hover:border-slate-200 rounded-lg transition transition-all duration-200 cursor-pointer">
                <svg class="w-4 h-4 stroke-[2] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
            </td>
          </tr>

          <tr class="expanded-form-row hidden bg-slate-50/40 transition-all" id="row-expand-${task._id}">
            <td colspan="5" class="p-5 border-t border-slate-100 bg-slate-50/30 shadow-inner">
              <form id="form-update-${task._id}" onsubmit="submitFormUpdate(event, '${task._id}')" enctype="multipart/form-data" class="max-w-2xl mx-auto space-y-4 bg-white p-5 rounded-2xl border border-slate-200/80 shadow-sm">
                ${formInnerHTML}
              </form>
            </td>
          </tr>
        `;

          // --- MOBILE VIEW CARD ---
          const mobileHTML = `
          <div class="p-4 space-y-3.5 bg-white transition-colors" id="mobile-card-${task._id}">
            <div class="flex items-start justify-between gap-3">
              <div class="space-y-1.5 flex-1 min-w-0">
                <span class="text-[9px] font-bold ${task.kategori === 'Meeting' ? 'text-amber-600 bg-amber-50 border-amber-200/40' : task.kategori === 'Support' ? 'text-purple-600 bg-purple-50 border-purple-200/40' : 'text-slate-600 bg-slate-50 border-slate-200/60'} px-2 py-0.5 rounded-full border tracking-wide">
                  ${task.kategori}
                </span>
                <h3 class="${titleStyle} pt-0.5 break-words">${task.judul}</h3>
                ${task.penjelasanHasil ? `<p class="text-[11.5px] text-slate-400 italic bg-slate-50 p-2 rounded-lg border border-slate-100">Hasil: ${task.penjelasanHasil}</p>` : ''}
              </div>
              <button type="button" onclick="toggleExpandRow('${task._id}')" id="arrow-btn-mob-${task._id}" class="w-8 h-8 flex-shrink-0 inline-flex items-center justify-center text-slate-400 border border-slate-200 rounded-lg bg-slate-50 hover:bg-slate-100 transition">
                <svg class="w-4 h-4 stroke-[2.5] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
            </div>

            <div class="flex items-center justify-between gap-4 pt-2 border-t border-slate-100/80">
              <div class="relative w-[115px]">
                <select onchange="quickUpdateStatus('${task._id}', this.value)" class="w-full text-[10px] font-bold rounded-full px-2.5 py-1.5 outline-none border cursor-pointer text-center tracking-wide appearance-none ${statusStyles[task.status]}">
                  <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                  <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                  <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                  <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
                </select>
              </div>

              ${task.fileLampiran ? `
                <a href="/uploads/files/${task.fileLampiran}" target="_blank" class="text-[11.5px] font-semibold text-blue-600 hover:underline truncate max-w-[140px]">📎 Lihat Bukti</a>
              ` : '<span class="text-slate-300 text-[11px] italic">Tidak ada bukti</span>'}
            </div>

            <div class="hidden mt-4 pt-4 border-t border-slate-200/80" id="row-expand-mob-${task._id}">
              <form id="form-update-mob-${task._id}" onsubmit="submitFormUpdate(event, '${task._id}', true)" enctype="multipart/form-data" class="space-y-4 bg-white">
                ${formInnerHTML}
              </form>
            </div>
          </div>
        `;

          tbody.insertAdjacentHTML('beforeend', rowHTML);
          mobileList.insertAdjacentHTML('beforeend', mobileHTML);
        });
      }

      // 3. LOGIKA INTERAKTIF (EXPAND/COMPACT) - SINKRON DESKTOP & MOBILE
      function toggleExpandRow(id) {
        const expandRowDesktop = document.getElementById(`row-expand-${id}`);
        const expandRowMobile = document.getElementById(`row-expand-mob-${id}`);
        const arrowBtnDesktop = document.getElementById(`arrow-btn-${id}`);
        const arrowBtnMobile = document.getElementById(`arrow-btn-mob-${id}`);
        const mobileCard = document.getElementById(`mobile-card-${id}`);

        // Toggle Desktop Form jika ada
        if (expandRowDesktop) expandRowDesktop.classList.toggle('hidden');
        if (arrowBtnDesktop) arrowBtnDesktop.classList.toggle('rotate-180');

        // Toggle Mobile Form jika ada
        if (expandRowMobile) {
          expandRowMobile.classList.toggle('hidden');
          mobileCard.classList.toggle('bg-slate-50/40');
        }
        if (arrowBtnMobile) arrowBtnMobile.classList.toggle('rotate-180');
      }

      // 4. POST: SUBMIT AKTIVITAS BARU
      async function submitFormCreate(event) {
        event.preventDefault();
        const form = document.getElementById('form-create-activity');
        const formData = {
          judul: document.getElementById('add-judul').value,
          kategori: document.getElementById('add-kategori').value,
          tanggal: document.getElementById('log-date').value
        };

        try {
          const response = await fetch('/daily-log/api/data', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
          });
          const result = await response.json();

          if (result.success) {
            alert("Aktivitas berhasil ditambahkan!");
            form.reset();
            document.getElementById('add-kategori').value = 'Core Task';
            loadDailyLog();
          } else {
            alert(result.message || "Gagal menambahkan aktivitas");
          }
        } catch (err) {
          console.error(err);
          alert("Terjadi kesalahan server");
        }
      }

      // 5. PUT: UPDATE STATUS LANGSUNG VIA DROPDOWN UTAMA
      async function quickUpdateStatus(id, newStatus) {
        try {
          const response = await fetch(`/daily-log/api/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
          });
          const result = await response.json();
          if (result.success) {
            loadDailyLog();
          } else {
            alert(result.message);
          }
        } catch (err) {
          console.error(err);
        }
      }

      // 6. PUT: SUBMIT FORM EDIT LENGKAP
      async function submitFormUpdate(event, id, isMobile = false) {
        event.preventDefault();
        const formId = isMobile ? `form-update-mob-${id}` : `form-update-${id}`;
        const form = document.getElementById(formId);
        const formData = new FormData(form);

        try {
          const response = await fetch(`/daily-log/api/${id}`, {
            method: 'PUT',
            body: formData
          });
          const result = await response.json();

          if (result.success) {
            alert("Aktivitas berhasil diperbarui!");
            loadDailyLog();
          } else {
            alert(result.message);
          }
        } catch (err) {
          console.error(err);
          alert("Gagal menyimpan perubahan.");
        }
      }

      function switchToEditFile(id) {
        const statusContainer = document.getElementById(`file-status-container-${id}`);
        const inputFile = document.getElementById(`input-file-${id}`);

        if (statusContainer && inputFile) {
          statusContainer.classList.add('hidden');
          inputFile.classList.remove('hidden');
        }
      }

      // 7. POST: EKSEKUSI CARRY OVER TUGAS PENDING KEMARIN
      async function executeCarryOver() {
        try {
          const response = await fetch('/daily-log/api/carry-over', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tanggalHariIni: datePicker.value })
          });
          const result = await response.json();

          alert(result.message);
          if (result.success) {
            loadDailyLog();
          }
        } catch (err) {
          console.error(err);
          alert("Gagal menyalin tugas.");
        }
      }

      datePicker.addEventListener('change', loadDailyLog);
      window.onload = function () {
        loadDailyLog();
      };
    </script>
  </div>
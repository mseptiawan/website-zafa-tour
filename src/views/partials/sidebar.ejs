<%- include('./sidebar-config') %>

<aside id="sidebar" class="fixed inset-y-0 left-0 w-64 md:w-16 xl:w-64 bg-white text-black flex flex-col z-[100] border-r border-slate-100 -translate-x-full md:translate-x-0 transition-transform duration-300 xl:transition-all">

  <div class="h-20 flex items-center px-6 md:px-0 xl:px-8 border-b border-slate-100 relative shrink-0 justify-between md:justify-center xl:justify-start">
    <div class="flex items-center gap-4 relative z-10">
      <div class="leading-tight">
        <h1 class="text-lg font-bold tracking-wide text-slate-800 md:hidden xl:block">Zafe Tour</h1>
        <p class="text-[10px] text-slate-500 uppercase tracking-[0.25em] font-medium md:hidden xl:block">PT Zafa Mulia Mandiri</p>
        
        <div class="w-8 h-8 bg-blue-600 rounded-xl flex items-center justify-center text-white font-bold text-xs hidden md:flex xl:hidden shadow-sm">
          ZT
        </div>
      </div>
    </div>
    <button id="mobileCloseBtn" class="flex h-9 w-9 items-center justify-center rounded-xl border border-slate-100 bg-slate-50 text-slate-500 md:hidden active:scale-95">
      <i class="fa-solid fa-xmark text-sm"></i>
    </button>
  </div>

  <nav id="sidebarNav" class="flex-1 overflow-y-auto scrollbar-hide px-4 md:px-2 xl:px-4 py-6 space-y-7 pb-10">
    
    <a href="/dashboard" class="flex items-center justify-start md:justify-center xl:justify-start gap-3 px-4 md:px-0 xl:px-4 py-3 rounded-xl transition-all group border border-transparent" title="Dashboard">
      <svg class="w-5 h-5 text-slate-500 group-hover:text-slate-800 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
      </svg>
      <span class="text-xs font-medium text-slate-600 group-hover:text-slate-800 md:hidden xl:block">Dashboard</span>
    </a>

    <% if (locals.sidebarSections) { %>
    <% locals.sidebarSections.forEach(section => { %>
    <% if (section.show && section.menus.some(m => m.show && m.submenus.some(s => s.show))) { %>
    <section>
      <p class="text-[7px] text-slate-500 font-bold px-4 mb-3 uppercase tracking-[0.2em] md:hidden xl:block"><%= section.title %></p>
      <div class="h-px bg-slate-100 my-4 md:hidden xl:hidden mx-2"></div>
      
      <div class="space-y-1.5">
        <% section.menus.forEach(menu => { %>
        <% if (menu.show && menu.submenus.some(s => s.show)) { %>
        <% 
          const isMenuOpen = menu.submenus.some(sub => 
            (req.originalUrl === sub.path) || 
            (typeof backLink !== 'undefined' && backLink && (backLink === sub.path || (sub.path === '/assignments/' && backLink === '/assignments')))
          );
        %>
        <details class="group outline-none rounded-xl open:bg-slate-50/80 border border-transparent open:border-slate-100 transition-all duration-150" 
                 data-menu="<%= menu.id %>" 
                 title="<%= menu.name %>"
                 <%= isMenuOpen ? 'open' : '' %>>
          
          <summary class="flex items-center justify-between md:justify-center xl:justify-between px-4 md:px-0 xl:px-4 py-3 rounded-xl cursor-pointer list-none transition-all border border-transparent hover:bg-slate-50 group-open:text-slate-900">
            <div class="flex items-center gap-3 min-w-0">
              <svg class="w-5 h-5 text-slate-500 group-hover:text-slate-800 group-open:text-slate-800 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><%- menu.icon %></svg>
              <span class="text-xs font-medium text-slate-600 group-hover:text-slate-800 group-open:text-slate-900 group-open:font-semibold truncate md:hidden xl:block"><%= menu.name %></span>
            </div>
            <svg class="w-4 h-4 text-slate-500 transition-transform group-open:rotate-180 shrink-0 md:hidden xl:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          
          <div class="ml-0 flex flex-col border-t border-slate-200/60 overflow-hidden bg-slate-50/50 md:bg-transparent">
            <% menu.submenus.forEach(sub => { %>
            <% if (sub.show) { %>
            <% 
              const isSubActive = (req.originalUrl === sub.path) || 
                                  (typeof backLink !== 'undefined' && backLink && backLink === sub.path) ||
                                  (sub.path === '/assignments/' && typeof backLink !== 'undefined' && backLink === '/assignments');
            %>

            <a href="<%= sub.path %>" 
               class="sidebar-link py-2.5 px-4 md:px-0 xl:px-4 text-xs transition flex items-center justify-start md:justify-center xl:justify-start gap-3 group/sub <%= isSubActive ? 'bg-blue-50 text-blue-600 font-bold' : 'text-slate-500 hover:text-slate-900 hover:bg-slate-100/60' %>" 
               title="<%= sub.name %>">
           
              <% if (sub.icon) { %>
                <svg class="w-5 h-5 text-slate-400 group-hover/sub:text-slate-700 transition shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <%- sub.icon %>
                </svg>
              <% } else { %>
                <div class="w-5 h-5 flex items-center justify-center shrink-0 md:hidden">
                  <div class="w-1.5 h-1.5 rounded-full bg-slate-400 group-hover/sub:bg-slate-700"></div>
                </div>
              <% } %>
              <span class="font-medium truncate md:hidden xl:block"><%= sub.name %></span>
            </a>
            
            <% } %>
            <% }); %>
          </div>
        </details>
        
        <% } %>
        <% }); %>
      </div>
    </section>
    <% } %>
    <% }); %>
    <% } %>
  </nav>

  <div class="p-4 md:p-2 xl:p-4 border-t border-slate-100 bg-white">
  <% if (typeof user !== 'undefined' && user !== null) { %>
    <div class="flex flex-row md:flex-col xl:flex-row items-center justify-between p-3 md:p-1 xl:p-3 rounded-xl bg-slate-50/70 border border-slate-200/50 hover:bg-slate-100/60 hover:border-slate-300/80 cursor-pointer transition-all duration-200 active:scale-[0.99] group/card gap-3 xl:gap-0">
      
      <a href="/employee/detail/<%= user.employeeId %>" class="flex flex-row md:flex-col xl:flex-row items-center gap-3 min-w-0 flex-1 group/profile decoration-none w-full justify-start md:justify-center xl:justify-start">
        <div class="w-8 h-8 xl:w-10 xl:h-10 rounded-full bg-slate-200 border border-slate-300 overflow-hidden shrink-0 transition-transform duration-200 group-hover/card:scale-105">
          <% 
            let profilePic = user.foto_profile
              ? user.foto_profile
              : (user.gender === "Perempuan"
                ? "https://img.freepik.com/premium-vector/smiling-woman-avatar_937492-6135.jpg"
                : "https://img.freepik.com/vektor-premium/avatar-kartun-pengusaha-mYoung-pria-mengenakan-setelan-jas-dan-dasi_645574-600.jpg");
          %>
          <img src="<%= profilePic %>" class="w-full h-full object-cover" />
        </div>

        <div class="min-w-0 flex-1 leading-normal pr-1 md:hidden xl:block">
          <p class="text-xs font-bold text-slate-800 truncate group-hover/card:text-blue-600 transition-colors">
            <%= user.fullName || 'User' %>
          </p>
          <p class="text-[8px] font-semibold uppercase tracking-[0.15em] text-slate-400 truncate mt-0.5">
            <%= user.role || 'Pegawai' %>
          </p>
        </div>

        <div class="text-slate-300 group-hover/card:text-blue-500 group-hover/card:translate-x-0.5 transition-all duration-200 shrink-0 pr-1 md:hidden xl:block">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </a>

      <form action="/logout" method="POST" class="ml-0 xl:ml-1.5 shrink-0" onsubmit="localStorage.clear();">
        <button type="submit" title="Keluar Aplikasi" class="p-1.5 text-slate-400 hover:text-rose-600 rounded-xl hover:bg-rose-50 transition-all duration-150 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        </button>
      </form>

    </div>
  <% } %>
  </div>
</aside>
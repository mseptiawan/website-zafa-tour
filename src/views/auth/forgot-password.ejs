<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lupa Password - HRIS</title>

  <link rel="stylesheet" href="/css/output.css" />
</head>

<body class="bg-slate-100 h-screen flex items-center justify-center">

  <div class="w-full max-w-md bg-white p-8 rounded-xl shadow">

    <!-- TITLE -->
    <div class="text-center mb-6">
      <h1 class="text-xl font-bold text-slate-900">
        Lupa Password
      </h1>
      <p class="text-sm text-slate-500">
        Masukkan username atau email Anda
      </p>
    </div>

    <!-- ERROR HANDLING -->
    <% if (query?.error === "EMAIL_NOT_FOUND") { %>
      <div class="bg-red-100 text-red-700 text-sm p-3 rounded mb-4">
        Email atau username tidak ditemukan
      </div>
    <% } %>

    <% if (query?.error === "SERVER_ERROR") { %>
      <div class="bg-red-100 text-red-700 text-sm p-3 rounded mb-4">
        Terjadi kesalahan server
      </div>
    <% } %>

    <!-- SUCCESS (opsional kalau mau tambah UX) -->
    <% if (query?.success === "OTP_SENT") { %>
      <div class="bg-green-100 text-green-700 text-sm p-3 rounded mb-4">
        OTP berhasil dikirim ke email
      </div>
    <% } %>

    <!-- FORM -->
    <form action="/forgot-password" method="POST" class="flex flex-col gap-3">

      <input
        type="email"
        name="email"
        placeholder="Email"
        class="border border-slate-300 p-3 rounded-lg focus:outline-none focus:border-blue-500"
        required
        autocomplete="username"
      />

      <button
        type="submit"
        class="bg-slate-800 text-white py-3 rounded-lg hover:bg-slate-900 transition"
      >
        Kirim OTP
      </button>

    </form>

    <!-- BACK -->
    <div class="text-center mt-4 text-sm">
      <a href="/" class="text-blue-600 hover:underline">
        Kembali ke login
      </a>
    </div>

  </div>

</body>
</html>
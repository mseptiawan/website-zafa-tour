<%- layout('layouts/main', { title }) %>

<div >
  <div class="mx-auto max-w-none space-y-6">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-slate-200 pb-5">
      <div class="min-w-0">
        <h1 class="text-xl font-bold tracking-tight text-slate-900">Daftar Data Karyawan</h1>
        <p class="text-xs text-slate-500 mt-1">Halaman pusat kendali administrasi berkas dan sebaran demografi staf.</p>
      </div>

      <div class="shrink-0 w-full sm:w-auto">
        <button onclick="executeDownloadEmployeePdf()" class="w-full sm:w-auto bg-white hover:bg-slate-50 text-slate-700 text-xs font-medium h-9 px-4 rounded-lg border border-slate-200 shadow-xs flex items-center justify-center gap-2 transition-colors cursor-pointer">
          Cetak Berkas (PDF)
        </button>
      </div>
    </div>

    <% 
      let lakiCount = 0; let perempuanCount = 0;
      employees.forEach(emp => {
        if(emp.jenis_kelamin === 'Laki-Laki') lakiCount++;
        if(emp.jenis_kelamin === 'Perempuan') perempuanCount++;
      });
      let totalEmp = employees.length || 1;
      let pctLaki = Math.round((lakiCount / totalEmp) * 100);
      let pctPerempuan = Math.round((perempuanCount / totalEmp) * 100);
    %>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      
      <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-2xs lg:col-span-4">
        <span class="text-xs font-medium text-slate-500 block">Total Staf Aktif</span>
        <div class="mt-2 flex items-baseline gap-2">
          <span class="text-4xl font-semibold tracking-tight text-slate-900 tabular-nums"><%= employees.length %></span>
          <span class="text-xs font-medium text-slate-400">orang terdaftar</span>
        </div>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-2xs lg:col-span-8 flex flex-col justify-between">
        <div>
          <span class="text-xs font-medium text-slate-500 block">Proporsi Gender</span>
        </div>
        
        <div class="my-3 sm:my-0">
          <div class="h-2.5 w-full bg-slate-100 rounded-full overflow-hidden flex">
            <div class="bg-blue-600 h-full transition-all" style="width: <%= pctLaki %>%"></div>
            <div class="bg-slate-400 h-full transition-all" style="width: <%= pctPerempuan %>%"></div>
          </div>
          
          <div class="flex items-center gap-4 mt-3 text-xs">
            <div class="flex items-center gap-1.5 font-medium text-slate-600">
              <span class="w-2 h-2 rounded-full bg-blue-600 block"></span>
              <span>Laki-Laki (<%= lakiCount %> Karyawan — <%= pctLaki %>%)</span>
            </div>
            <div class="flex items-center gap-1.5 font-medium text-slate-600">
              <span class="w-2 h-2 rounded-full bg-slate-400 block"></span>
              <span>Perempuan (<%= perempuanCount %> Karyawan — <%= pctPerempuan %>%)</span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-2xs">
      <div class="p-6 border-b border-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Biodata Lengkap Karyawan</h3>
        <p class="text-xs text-slate-400 mt-0.5">Daftar komparatif data identitas pokok dan status perkawinan personel.</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-xs whitespace-nowrap">
          <thead>
            <tr class="bg-slate-50 text-slate-500 font-semibold border-b border-slate-200">
              <th class="p-4 pl-6">Nama Karyawan</th>
              <th class="p-4">Id</th>
              <th class="p-4">Jenis Kelamin</th>
              <th class="p-4">Tempat Lahir</th>
              <th class="p-4 text-right pr-6">Status Pernikahan</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 text-slate-700 font-medium">
            <% if (employees && employees.length > 0) { %>
              <% employees.forEach((emp) => { %>
                <tr class="hover:bg-slate-50/50 transition-colors">
                  <td class="p-4 pl-6 font-semibold text-slate-900"><%= emp.fullName %></td>
                  <td class="p-4 tabular-nums text-slate-600">
                    <span class="font-mono bg-slate-100 text-slate-700 px-1.5 py-0.5 rounded text-[11px]">
                      <%= emp.employeeIdNumber %>
                    </span>
                  </td>
                  <td class="p-4 text-slate-600"><%= emp.jenis_kelamin %></td>
                  <td class="p-4 text-slate-600"><%= emp.tempat_lahir || '—' %></td>
                  <td class="p-4 text-right pr-6 text-slate-500"><%= emp.status_pernikahan %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="p-8 text-center text-slate-400 font-normal">Tidak ditemukan repositori data karyawan.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script>
  function executeDownloadEmployeePdf() {
    window.location.href = "/report/employees/download-pdf";
  }
</script>
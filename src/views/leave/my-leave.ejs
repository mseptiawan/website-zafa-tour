<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50 p-6">
  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6 text-center">
      <h1 class="text-xl font-medium text-slate-800">
        Riwayat Cuti Saya
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Pantau semua pengajuan cuti kamu
      </p>
    </div>

    <!-- SUMMARY -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-5">

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Total</p>
        <p class="text-lg font-medium text-slate-800 mt-1"><%= summary.total || 0 %></p>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Pending</p>
        <p class="text-lg font-medium text-yellow-600 mt-1"><%= summary.pending || 0 %></p>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Terpakai</p>
        <p class="text-lg font-medium text-green-600 mt-1"><%= summary.used || 0 %></p>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Sisa</p>
        <p class="text-lg font-medium text-indigo-600 mt-1"><%= summary.remaining || 0 %></p>
      </div>

    </div>

    <!-- TABLE CARD -->
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

      <!-- HEADER TABLE -->
      <div class="flex justify-between items-center p-4 border-b border-slate-200">

        <h2 class="text-sm font-medium text-slate-700">
          Riwayat Pengajuan
        </h2>

        <a href="/leave/apply"
          class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-4 py-2 rounded-lg transition"
        >
          + Ajukan
        </a>

      </div>

      <!-- TABLE -->
      <div class="overflow-x-auto">

        <table class="w-full text-sm">

          <thead class="bg-slate-100 border-b border-slate-200">
            <tr class="text-left text-xs text-slate-600">
              <th class="px-3 py-3 font-normal">Jenis</th>
              <th class="px-3 py-3 font-normal">Tanggal</th>
              <th class="px-3 py-3 font-normal">Durasi</th>
              <th class="px-3 py-3 font-normal">Status</th>
              <th class="px-3 py-3 font-normal">Aksi</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">

            <% if (leaves && leaves.length > 0) { %>

              <% leaves.forEach(l => { %>
                <tr class="hover:bg-slate-50 transition">

                  <td class="px-3 py-2 text-slate-700 font-medium">
                    <%= l.type?.name %>
                  </td>

                  <td class="px-3 py-2 text-slate-600">
                    <%= new Date(l.startDate).toLocaleDateString("id-ID") %>
                    -
                    <%= new Date(l.endDate).toLocaleDateString("id-ID") %>
                  </td>

                  <td class="px-3 py-2 text-slate-600">
                    <%= l.totalDays %> hari
                  </td>

                  <!-- STATUS -->
                  <td class="px-3 py-2">
                    <span class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600">
                      <%= l.status %>
                    </span>
                  </td>

                  <td class="px-3 py-2">
                    <a href="/leave/<%= l._id %>"
                      class="text-indigo-600 hover:text-indigo-800 text-sm"
                    >
                      Detail
                    </a>
                  </td>

                </tr>
              <% }) %>

            <% } else { %>

              <tr>
                <td colspan="5" class="px-3 py-10 text-center text-slate-400 text-sm">
                  Belum ada pengajuan cuti
                </td>
              </tr>

            <% } %>

          </tbody>

        </table>

      </div>

    </div>

  </div>
</div>
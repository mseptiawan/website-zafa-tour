<%- layout('layouts/main', { title }) %>
  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold text-slate-900">Riwayat & Status Cuti</h1>
          <p class="text-xs text-slate-500 mt-1">Pantau penggunaan hak cuti kerja tahunan Anda</p>
        </div>
        <a href="/leave/apply"
          class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-sm">+ Ajukan
          Cuti Baru</a>
      </div>

      <div class="grid grid-cols-5 gap-4 mb-8">
        <div class="bg-white p-4 border border-slate-200 rounded-2xl shadow-sm">
          <span class="text-[11px] font-bold text-slate-400 block uppercase">Hak Cuti Awal</span>
          <span class="text-2xl font-black text-slate-800 mt-1 block">
            <%= summary.totalQuota %> Hari
          </span>
        </div>
        <div class="bg-white p-4 border border-slate-200 rounded-2xl shadow-sm">
          <span class="text-[11px] font-bold text-slate-400 block uppercase">Cuti Bersama</span>
          <span class="text-2xl font-black text-slate-800 mt-1 block">
            <%= summary.companyHolidays %> Hari
          </span>
        </div>
        <div class="bg-white p-4 border border-slate-200 rounded-2xl shadow-sm">
          <span class="text-[11px] font-bold text-slate-400 block uppercase">Cuti Mandiri Terpakai</span>
          <span class="text-2xl font-black text-slate-800 mt-1 block">
            <%= summary.usedPrivate %> Hari
          </span>
        </div>
        <div class="bg-white p-4 border border-slate-200 rounded-2xl shadow-sm">
          <span class="text-[11px] font-bold text-slate-400 block uppercase">Pending Approval</span>
          <span class="text-2xl font-black text-amber-600 mt-1 block">
            <%= summary.pending %> Berkas
          </span>
        </div>
        <div class="bg-white p-4 border border-slate-900 bg-slate-900 rounded-2xl shadow-sm">
          <span class="text-[11px] font-bold text-slate-400 block uppercase">Sisa Cuti</span>
          <span class="text-2xl font-black text-white mt-1 block">
            <%= summary.remaining %> Hari
          </span>
        </div>
      </div>

      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr
              class="bg-slate-50 border-b border-slate-200 text-[11px] font-bold text-slate-400 uppercase tracking-wider">
              <th class="py-4 px-6">Kode & Jenis Cuti</th>
              <th class="py-4 px-6">Periode Pelaksanaan</th>
              <th class="py-4 px-6">Durasi</th>
              <th class="py-4 px-6">Handover</th>
              <th class="py-4 px-6">Status Akhir</th>
              <th class="py-4 px-6 text-right">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 text-[13px]">
            <% leaves.forEach(leave=> { %>
              <tr class="hover:bg-slate-50/50">
                <td class="py-4 px-6">
                  <span class="font-bold text-slate-800">
                    <%= leave.leaveTypeId.name %>
                  </span>
                  <span
                    class="text-[10px] font-mono bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded block w-max mt-0.5">
                    <%= leave.leaveTypeId.code %>
                  </span>
                </td>
                <td class="py-4 px-6 font-medium text-slate-600">
                  <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit' , month: 'short' }) %> - <%=
                      new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit' , month: 'short' ,
                      year: 'numeric' }) %>
                </td>
                <td class="py-4 px-6 font-bold text-slate-900">
                  <%= leave.totalDays %> Hari
                </td>
                <td class="py-4 px-6 text-slate-500">
                  <%= (leave.handoverUserId && leave.handoverUserId.employeeData) ?
                    leave.handoverUserId.employeeData.fullName : '-' %>
                </td>
                <td class="py-4 px-6">
                  <span
                    class="px-2.5 py-1 rounded-lg text-[11px] font-bold border 
                  <%= leave.status === 'PENDING' ? 'bg-amber-50 text-amber-600 border-amber-100' : '' %>
                  <%= leave.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : '' %>
                  <%= leave.status === 'REJECTED' ? 'bg-rose-50 text-rose-600 border-rose-100' : '' %>
                  <%= leave.status === 'CANCELLED' ? 'bg-slate-100 text-slate-500 border-slate-200' : '' %>
                  <%= leave.status === 'CANCELLATION_PENDING' ? 'bg-purple-50 text-purple-600 border-purple-100' : '' %>">
                    <%= leave.status %>
                  </span>
                </td>
                <td class="py-4 px-6 text-right space-x-1 whitespace-nowrap">
                  <a href="/leave/detail/<%= leave._id %>"
                    class="bg-white hover:bg-slate-50 text-slate-600 border border-slate-200 rounded-lg px-2.5 py-1.5 font-bold transition shadow-sm">Lihat
                    Progress</a>

                  <% if (leave.status==='PENDING' ) { %>
                    <a href="/leave/edit/<%= leave._id %>"
                      class="bg-amber-50 hover:bg-amber-100 text-amber-700 border border-amber-200 rounded-lg px-2.5 py-1.5 font-bold transition shadow-sm">Edit</a>
                    <form action="/leave/cancel-pending/<%= leave._id %>" method="POST" class="inline">
                      <button
                        class="bg-rose-50 hover:bg-rose-100 text-rose-700 border border-rose-200 rounded-lg px-2.5 py-1.5 font-bold transition shadow-sm cursor-pointer">Batalkan</button>
                    </form>
                    <% } %>

                      <% if (leave.status==='APPROVED' ) { %>
                        <form action="/leave/request-cancel/<%= leave._id %>" method="POST" class="inline">
                          <button
                            class="bg-slate-900 hover:bg-slate-800 text-white rounded-lg px-2.5 py-1.5 font-bold transition shadow-sm cursor-pointer">Ajukan
                            Pembatalan</button>
                        </form>
                        <% } %>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head') %>

  <body class="min-h-dvh overflow-x-hidden bg-slate-50/50 text-slate-800 antialiased">
    <div class="flex min-h-screen w-full">
      <div
        id="sidebarOverlay"
        class="fixed inset-0 z-[90] hidden bg-slate-900/40 backdrop-blur-xs md:hidden"
      ></div>

      <!-- Mobile Header / Top Bar -->
      <div
        class="fixed top-0 right-0 left-0 z-40 flex h-16 items-center justify-between border-b border-slate-200/60 bg-white px-4 md:hidden"
      >
        <div class="flex min-w-0 flex-1 items-center gap-3">
          <button
            id="mobileMenuBtn"
            class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 active:scale-95"
          >
            <i class="fa-solid fa-bars text-sm"></i>
          </button>
          <div class="min-w-0">
            <h1 class="truncate text-[15px] font-semibold text-slate-900">
              <%= typeof title !== 'undefined' ? title : 'Zafa Tour' %>
            </h1>
          </div>
        </div>

        <!-- Tombol Notifikasi Mobile (Dipindahkan ke sini) -->
        <div class="relative shrink-0" id="notificationDropdownMobile">
          <button
            id="notifButtonMobile"
            class="group relative flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200/60 bg-white shadow-xs transition-all duration-200 hover:bg-slate-50 focus:outline-none active:scale-[0.96]"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              class="stroke-[2.2] text-slate-600 transition-colors group-hover:text-slate-900"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"
              ></path>
            </svg>
            <span
              id="notifBadgeMobile"
              class="absolute top-1.5 right-1.5 hidden h-2 w-2 rounded-full bg-rose-500 ring-2 ring-white"
            ></span>
          </button>

          <!-- Dropdown Notifikasi Shared/Mobile Container (Optional, jika ingin dropdown muncul saat diklik di mobile) -->
          <div
            id="notifMenuMobile"
            class="absolute right-0 z-[100] mt-2.5 hidden w-[calc(100vw-2rem)] origin-top-right flex-col rounded-2xl border border-slate-200/50 bg-white shadow-xl shadow-slate-950/[0.05] transition-all duration-200 sm:w-96"
          >
            <div
              class="flex items-center justify-between rounded-t-2xl border-b border-slate-100 bg-white px-5 py-4"
            >
              <h1
                class="flex items-center gap-2 text-[13px] font-bold tracking-tight text-slate-950"
              >
                Notifikasi
                <span
                  id="notifCountTextMobile"
                  class="hidden inline-flex min-w-[18px] items-center justify-center rounded-md bg-blue-600 px-2 py-0.5 text-[10px] font-bold text-white"
                >
                  0
                </span>
              </h1>
              <button
                id="markAllReadBtnMobile"
                class="text-[11px] font-bold text-blue-600 transition-colors hover:text-blue-700"
              >
                Tandai semua dibaca
              </button>
            </div>
            <div
              id="notifContainerMobile"
              class="max-h-[280px] divide-y divide-slate-50 overflow-y-auto"
            >
              <div class="p-6 text-center text-xs text-slate-400">Tidak ada notifikasi baru.</div>
            </div>
          </div>
        </div>
      </div>

      <%- include('../partials/sidebar') %>

      <main
        class="relative flex h-full flex-1 flex-col overflow-visible bg-slate-50/50 px-4 py-5 pt-20 md:px-8 md:pt-20"
      >
        <!-- Tombol Notifikasi Desktop (Tetap ada untuk layar besar) -->
        <div
          class="absolute top-5 right-4 z-[100] hidden md:right-8 md:block"
          id="notificationDropdown"
        >
          <button
            id="notifButton"
            class="group relative flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200/60 bg-white shadow-xs transition-all duration-200 hover:bg-slate-50 focus:outline-none active:scale-[0.96]"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              class="stroke-[2.2] text-slate-600 transition-colors group-hover:text-slate-900"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"
              ></path>
            </svg>
            <span
              id="notifBadge"
              class="absolute top-2 right-2 hidden h-2.5 w-2.5 rounded-full bg-rose-500 ring-2 ring-white"
            ></span>
          </button>

          <div
            id="notifMenu"
            class="absolute right-0 z-[100] mt-2.5 hidden w-[calc(100vw-2rem)] origin-top-right flex-col rounded-2xl border border-slate-200/50 bg-white shadow-xl shadow-slate-950/[0.05] transition-all duration-200 sm:w-96"
          >
            <div
              class="flex items-center justify-between rounded-t-2xl border-b border-slate-100 bg-white px-5 py-4"
            >
              <h1
                class="flex items-center gap-2 text-[13px] font-bold tracking-tight text-slate-950"
              >
                Notifikasi
                <span
                  id="notifCountText"
                  class="hidden inline-flex min-w-[18px] items-center justify-center rounded-md bg-blue-600 px-2 py-0.5 text-[10px] font-bold text-white"
                >
                  0
                </span>
              </h1>
              <button
                id="markAllReadBtn"
                class="text-[11px] font-bold text-blue-600 transition-colors hover:text-blue-700"
              >
                Tandai semua dibaca
              </button>
            </div>
            <div id="notifContainer" class="max-h-[380px] divide-y divide-slate-50 overflow-y-auto">
              <div class="p-6 text-center text-xs text-slate-400">Tidak ada notifikasi baru.</div>
            </div>
          </div>
        </div>

        <div class="ml-0 min-h-screen flex-1 antialiased md:ml-16 md:p-8 xl:ml-64">
          <%- body -%>
        </div>
      </main>
    </div>

    <div
      id="toastContainer"
      class="pointer-events-auto fixed top-5 right-5 z-[99999] flex flex-col gap-3.5"
    ></div>
    <%- include('../partials/modals/confirm-modal') %> <%- include('../partials/scripts') %>
  </body>
</html>

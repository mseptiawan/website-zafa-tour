<%- layout('layouts/main', { title }) %>

<% 
  // =========================================================================
  // LOGIKA PEMISAH DATA (PERBAIKAN: APPROVED MASUK KE RIWAYAT SELESAI)
  // =========================================================================
  const activeLeaves = leaves.filter(l => l.status === 'PENDING' || l.status === 'CANCELLATION_PENDING');
  const historyLeaves = leaves.filter(l => l.status === 'APPROVED' || l.status === 'REJECTED' || l.status === 'CANCELLED');

  // CONFIGURATION UNTUK DESAIN BADGE STATUS
  const getStatusConfig = (status) => {
    switch(status) {
      case 'PENDING':
        return { label: 'Pending', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500' };
      case 'APPROVED':
        return { label: 'Approved', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500' };
      case 'REJECTED':
        return { label: 'Rejected', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' };
      case 'CANCELLED':
        return { label: 'Cancelled', badge: 'bg-slate-50 text-slate-500 border-slate-200', dot: 'bg-slate-400' };
      case 'CANCELLATION_PENDING':
        return { label: 'Cancel Pending', badge: 'bg-purple-50 text-purple-600 border-purple-200/50', dot: 'bg-purple-500' };
      default:
        return { label: status, badge: 'bg-slate-50 text-slate-600 border-slate-200/50', dot: 'bg-slate-500' };
    }
  };
%>

<div>
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

    <!-- PAGE HEADER -->
    <div class="border border-slate-200/60 md:border-none md:shadow-none">
      <%- include('../partials/page-header', {
        section: 'Area Kerja',
        module: 'Kehadiran',
        title: 'Riwayat & Status Cuti',
        description: 'Pantau penggunaan hak cuti kerja tahunan Anda secara berkala.'
      }) %>
    </div>

    <!-- STATS GRID -->
    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        gridClass: 'grid-cols-2 lg:grid-cols-5', 
        items: [
          { 
            label: 'Hak Cuti Awal', 
            value: summary.totalQuota, 
            unit: ' Hari', 
            icon: 'fa-solid fa-calendar-check', 
            labelClass: '!font-medium text-slate-400', 
            valueClass: '!font-medium text-slate-800', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          },
          { 
            label: 'Cuti Bersama', 
            value: summary.companyHolidays, 
            unit: ' Hari', 
            icon: 'fa-solid fa-calendar-days', 
            labelClass: '!font-medium text-indigo-500 group-hover:text-indigo-600', 
            valueClass: '!font-medium text-slate-800', 
            iconBoxClass: 'bg-indigo-50 text-indigo-600 border border-indigo-100/20',
            wrapperClass: 'group cursor-pointer hover:border-indigo-300 hover:shadow-indigo-500/5 transition duration-200',
            attributes: 'onclick="openCompanyHolidayModal()"'
          },
          { 
            label: 'Cuti Terpakai', 
            value: summary.usedPrivate, 
            unit: ' Hari', 
            icon: 'fa-solid fa-user-clock', 
            labelClass: '!font-medium text-slate-400', 
            valueClass: '!font-medium text-slate-800', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          },
          { 
            label: 'Pending Approval', 
            value: summary.pending, 
            unit: ' Berkas', 
            icon: 'fa-solid fa-hourglass-half', 
            labelClass: '!font-medium text-amber-600', 
            valueClass: '!font-medium text-amber-700', 
            iconBoxClass: 'bg-amber-50 text-amber-500 border border-amber-200/50' 
          },
          { 
            label: 'Sisa Saku Cuti', 
            value: summary.remaining, 
            unit: ' Hari', 
            icon: 'fa-solid fa-wallet', 
            labelClass: '!font-medium text-slate-500', 
            valueClass: summary.remaining === 0 ? '!font-medium text-rose-500' : '!font-medium text-slate-900', 
            iconBoxClass: summary.remaining === 0 ? 'bg-rose-50 text-rose-500 border border-rose-200/50' : 'bg-slate-100 text-slate-500 border border-slate-200/50' 
          }
        ]
      }) %>
    </div>

    <!-- TAB NAVIGATION & ACTION BAR -->
<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3.5 w-full bg-white md:bg-transparent border border-slate-200/50 md:border-none p-4 md:p-0 rounded-2xl md:rounded-none md:shadow-none select-none">
  
  <!-- Header & Tombol Aksi (Mobile View Only) -->
  <div class="flex items-center justify-between gap-3 w-full md:hidden">
    <h3 class="text-[14px] font-medium text-slate-800 tracking-tight">Daftar Berkas</h3>
    <div class="flex items-center gap-2">
      <!-- Tombol Cuti Bersama Mobile -->
      <button onclick="openCompanyHolidayModal()" class="inline-flex items-center justify-center gap-1.5 h-8.5 px-3 bg-indigo-50 border border-indigo-200/60 text-indigo-600 text-[11px] font-medium rounded-full active:scale-95 outline-none cursor-pointer">
        <i class="fa-solid fa-calendar-days text-[10px]"></i>
        <span>Libur</span>
      </button>
      <!-- Tombol Ajukan Mobile -->
      <a href="/leave/apply" class="inline-flex items-center justify-center gap-1.5 h-8.5 px-4 bg-blue-600 text-white text-[11px] font-medium rounded-full transition-all active:scale-95 outline-none cursor-pointer">
        <i class="fa-solid fa-plus text-[9px]"></i>
        <span>Ajukan</span>
      </a>
    </div>
  </div>

  <!-- Tab Bar & Tombol Desktop (Flex Container) -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 w-full">
    <!-- Komponen Tab Navigasi bawaan Anda -->
    <div class="flex-1">
      <%- include('../partials/_tab-nav', {
        tabs: [
          { 
            id: 'active', 
            label: `Cuti Berjalan (${activeLeaves.length})`,
            isActive: true 
          },
          { 
            id: 'history', 
            label: `Riwayat Selesai (${historyLeaves.length})`,
            isActive: false 
          }
        ]
      }) %>
    </div>

    <!-- Tombol Cuti Bersama (Desktop View Only) -->
    <button type="button" onclick="openCompanyHolidayModal()" class="hidden md:inline-flex items-center justify-center gap-2 h-10 px-4 bg-white border border-slate-200/80 hover:border-indigo-300 hover:bg-indigo-50/30 text-slate-600 hover:text-indigo-600 text-[12px] font-semibold rounded-xl transition-all  active:scale-98 cursor-pointer group">
      <i class="fa-solid fa-calendar-days text-slate-400 group-hover:text-indigo-500 text-[13px] transition-colors"></i>
      <span>Lihat Cuti Bersama</span>
    </button>
  </div>

</div>
    <!-- =========================================================================
         TAB 1: CUTI BERJALAN / AKTIF
         ========================================================================= -->
    <div id="tab-content-active" class="tab-pane space-y-4 block opacity-100 transition-all duration-300 transform translate-y-0">
      
      <!-- Desktop View Table -->
      <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Kode & Jenis Cuti</th>
                <th class="py-4 px-6">Periode Pelaksanaan</th>
                <th class="py-4 px-6 text-center">Durasi</th>
                <th class="py-4 px-6">Handover Tugas</th>
                <th class="py-4 px-6 text-center">Status</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (activeLeaves.length === 0) { %>
                <tr>
                  <td colspan="6" class="py-12 text-center text-slate-400 font-medium">Belum ada riwayat pengajuan cuti berjalan.</td>
                </tr>
              <% } else { %>
                <% activeLeaves.forEach(leave => { %>
                  <% const config = getStatusConfig(leave.status); %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6">
                      <span class="font-semibold text-slate-800 block text-[13px]"><%= leave.leaveTypeId ? leave.leaveTypeId.name : '-' %></span>
                      <% if (leave.leaveTypeId?.code) { %>
                        <span class="text-[10px] font-mono font-semibold bg-slate-100 border border-slate-200 text-slate-500 px-1.5 py-0.5 rounded-md inline-block mt-1"><%= leave.leaveTypeId.code %></span>
                      <% } %>
                    </td>
                    <td class="py-4 px-6 font-medium text-slate-500">
                      <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                      <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                    </td>
                    <td class="py-4 px-6 text-center text-slate-800 font-semibold"><%= leave.totalDays %> Hari</td>
                    <td class="py-4 px-6 text-slate-600 font-medium">
                      <%= (leave.handoverUserId?.employeeData) ? leave.handoverUserId.employeeData.fullName : '-' %>
                    </td>
                    <td class="py-4 px-6 text-center select-none">
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                        <span><%= config.label.toUpperCase() %></span>
                      </div>
                    </td>
                    <td class="py-4 px-6">
                      <div class="flex items-center justify-center gap-2">
                        <a href="/leave/detail/<%= leave._id %>" title="Lihat Progress" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                          <i class="fa-solid fa-eye text-[11px]"></i>
                        </a>
                        <% if (leave.status === 'PENDING') { %>
                          <a href="/leave/edit/<%= leave._id %>" title="Edit Pengajuan" class="w-8 h-8 rounded-lg bg-amber-400 text-white inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-amber-500">
                            <i class="fa-solid fa-pen-to-square text-[11px]"></i>
                          </a>
                          <form id="form-cancel-pending-desktop-<%= leave._id %>" action="/leave/cancel-pending/<%= leave._id %>" method="POST" class="inline m-0">
                            <button type="button" onclick="openConfirmModal({
                              title: 'Batalkan Pengajuan Cuti',
                              message: 'Pengajuan cuti yang masih menunggu persetujuan akan dibatalkan dan tidak dapat diproses lebih lanjut.',
                              confirmText: 'Batalkan',
                              confirmClass: 'bg-rose-600 hover:bg-rose-700',
                              onConfirm: () => { document.getElementById('form-cancel-pending-desktop-<%= leave._id %>').submit(); }
                            })" class="w-8 h-8 rounded-lg border border-rose-200 bg-rose-50/40 text-rose-600 inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-rose-50 cursor-pointer" title="Batalkan">
                              <i class="fa-solid fa-trash-can text-[11px]"></i>
                            </button>
                          </form>
                        <% } %>
                        <% if (leave.status === 'APPROVED') { %>
                          <form id="form-request-cancel-desktop-<%= leave._id %>" action="/leave/request-cancel/<%= leave._id %>" method="POST" class="inline m-0">
                            <button type="button" onclick="openConfirmModal({
                              title: 'Ajukan Pembatalan Cuti',
                              message: 'Permintaan pembatalan cuti akan dikirim ke atasan untuk ditinjau dan disetujui.',
                              confirmText: 'Ajukan Pembatalan',
                              confirmClass: 'bg-amber-600 hover:bg-amber-700',
                              onConfirm: () => { document.getElementById('form-request-cancel-desktop-<%= leave._id %>').submit(); }
                            })" class="w-8 h-8 rounded-lg border border-slate-200 bg-slate-50 text-slate-500 inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-slate-100 hover:text-slate-800 cursor-pointer" title="Ajukan Pembatalan Cuti">
                              <i class="fa-solid fa-rotate-left text-[11px]"></i>
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Mobile View Responsive -->
      <div class="block md:hidden space-y-3.5 w-full">
        <% if (activeLeaves.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
            <p class="text-[12px] font-medium text-slate-400">Tidak ada pengajuan cuti berjalan</p>
          </div>
        <% } else { %>
          <% activeLeaves.forEach(leave => { %>
            <% const config = getStatusConfig(leave.status); %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight"><%= leave.leaveTypeId ? leave.leaveTypeId.name : '-' %></h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                    <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                  </p>
                </div>
                <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
                  <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label %></span>
                </div>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
                <div>
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Handover Tugas</p>
                  <p class="text-[12px] font-semibold text-slate-700 mt-0.5 truncate">
                    <%= (leave.handoverUserId?.employeeData) ? leave.handoverUserId.employeeData.fullName.split(' ')[0] : '-' %>
                  </p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Durasi Cuti</p>
                  <p class="text-[13px] font-semibold text-blue-600 mt-0.5 tabular-nums"><%= leave.totalDays %> Hari</p>
                </div>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-500">
                  <i class="fa-solid fa-clock text-slate-400 mr-1"></i>Kode: <%= leave.leaveTypeId?.code || '-' %>
                </span>
                <div class="flex items-center gap-1.5">
                  <% if (leave.status === 'PENDING') { %>
                    <a href="/leave/edit/<%= leave._id %>" class="h-8 w-8 rounded-lg bg-amber-400 text-white flex items-center justify-center text-xs active:scale-95"><i class="fa-solid fa-marker"></i></a>
                  <% } %>
                  <a href="/leave/detail/<%= leave._id %>" class="h-8 px-3.5 bg-blue-50 text-blue-600 text-[11px] font-medium rounded-lg flex items-center justify-center tracking-wide active:scale-95">
                    DETAIL
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- =========================================================================
         TAB 2: RIWAYAT SELESAI
         ========================================================================= -->
    <div id="tab-content-history" class="tab-pane space-y-4 hidden opacity-0 transition-all duration-300 transform translate-y-2">
      
      <!-- Desktop View Table -->
      <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Kode & Jenis Cuti</th>
                <th class="py-4 px-6">Periode Pelaksanaan</th>
                <th class="py-4 px-6 text-center">Durasi</th>
                <th class="py-4 px-6">Handover Tugas</th>
                <th class="py-4 px-6 text-center">Status</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (historyLeaves.length === 0) { %>
                <tr>
                  <td colspan="6" class="py-12 text-center text-slate-400 font-medium">Belum ada dokumen riwayat selesai.</td>
                </tr>
              <% } else { %>
                <% historyLeaves.forEach(leave => { %>
                  <% const config = getStatusConfig(leave.status); %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6">
                      <span class="font-semibold text-slate-800 block text-[13px]"><%= leave.leaveTypeId ? leave.leaveTypeId.name : '-' %></span>
                      <% if (leave.leaveTypeId?.code) { %>
                        <span class="text-[10px] font-mono font-semibold bg-slate-100 border border-slate-200 text-slate-500 px-1.5 py-0.5 rounded-md inline-block mt-1"><%= leave.leaveTypeId.code %></span>
                      <% } %>
                    </td>
                    <td class="py-4 px-6 font-medium text-slate-500">
                      <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                      <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                    </td>
                    <td class="py-4 px-6 text-center text-slate-800 font-semibold"><%= leave.totalDays %> Hari</td>
                    <td class="py-4 px-6 text-slate-600 font-medium">
                      <%= (leave.handoverUserId?.employeeData) ? leave.handoverUserId.employeeData.fullName : '-' %>
                    </td>
                    <td class="py-4 px-6 text-center select-none">
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                        <span><%= config.label.toUpperCase() %></span>
                      </div>
                    </td>
                    <td class="py-4 px-6 text-center">
                      <a href="/leave/detail/<%= leave._id %>" title="Lihat Berkas" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                        <i class="fa-solid fa-eye text-[11px]"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Mobile View Responsive -->
      <div class="block md:hidden space-y-3.5 w-full">
        <% if (historyLeaves.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
            <p class="text-[12px] font-medium text-slate-400">Belum ada arsip riwayat selesai</p>
          </div>
        <% } else { %>
          <% historyLeaves.forEach(leave => { %>
            <% const config = getStatusConfig(leave.status); %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight"><%= leave.leaveTypeId ? leave.leaveTypeId.name : '-' %></h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                    <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                  </p>
                </div>
                <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
                  <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label %></span>
                </div>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
                <div>
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Handover Tugas</p>
                  <p class="text-[12px] font-semibold text-slate-700 mt-0.5 truncate">
                    <%= (leave.handoverUserId?.employeeData) ? leave.handoverUserId.employeeData.fullName.split(' ')[0] : '-' %>
                  </p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Durasi Cuti</p>
                  <p class="text-[13px] font-semibold text-slate-700 tabular-nums mt-0.5"><%= leave.totalDays %> Hari</p>
                </div>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-400"><i class="fa-solid fa-box-archive mr-1"></i>Arsip Selesai</span>
                <a href="/leave/detail/<%= leave._id %>" class="h-8 px-3.5 bg-slate-100 text-slate-700 text-[11px] font-medium border border-slate-200 rounded-lg flex items-center justify-center tracking-wide active:scale-95">
                  LIHAT
                </a>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

  </div>
</div>

<!-- COMPANY HOLIDAY MODAL -->
<div id="holiday-modal" class="hidden fixed inset-0 bg-slate-900/40 z-[110] flex items-center justify-center p-4 transition-all">
  <div class="bg-white w-full max-w-md rounded-2xl overflow-hidden transform border border-slate-100">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 bg-indigo-50 text-indigo-600 rounded-md flex items-center justify-center">
          <i class="fa-solid fa-building text-[10px]"></i>
        </div>
        <h2 class="text-xs font-semibold text-slate-800">Kalender Cuti Bersama</h2>
      </div>
      <button onclick="closeHolidayModal()" class="w-6 h-6 flex items-center justify-center rounded-md text-slate-400 hover:bg-slate-100 hover:text-slate-700 transition cursor-pointer text-xs">
        ✕
      </button>
    </div>
    <div id="holiday-modal-content" class="p-5 space-y-3 max-h-[350px] overflow-y-auto"></div>
  </div>
</div>

<script>
  const holidays = <%- JSON.stringify(holidays) %>;

  function openCompanyHolidayModal() {
    const company = holidays.filter(h => h.type === "COMPANY");
    const container = document.getElementById("holiday-modal-content");

    if (!company.length) {
      container.innerHTML = `
        <div class="text-center text-slate-400 text-xs py-10 italic">
          Tidak ada agenda cuti bersama yang terjadwal.
        </div>
      `;
    } else {
      container.innerHTML = company.map(h => `
        <div class="border border-slate-100 rounded-xl p-3.5 bg-slate-50/60 space-y-2">
          <div class="flex justify-between items-start gap-4">
            <div>
              <h4 class="font-semibold text-slate-800 text-[12.5px] leading-tight">${h.name}</h4>
              <p class="text-[10.5px] font-medium text-slate-400 mt-1">
                ${new Date(h.date).toLocaleDateString('id-ID', {
                  weekday: 'long',
                  year: 'numeric',
                  month: 'short',
                  day: '2-digit'
                })}
              </p>
            </div>
            ${h.isDeductLeave
              ? `<span class="shrink-0 text-[9px] px-2 py-0.5 rounded-md bg-rose-50 border border-rose-100 text-rose-600 font-semibold uppercase tracking-wider">Potong Kuota</span>`
              : `<span class="shrink-0 text-[9px] px-2 py-0.5 rounded-md bg-slate-100 border border-slate-200 text-slate-600 font-semibold uppercase tracking-wider">Bebas Potong</span>`
            }
          </div>
          ${h.description ? `<p class="text-[11px] text-slate-500 bg-white border border-slate-100 rounded-lg p-2 mt-2">${h.description}</p>` : ''}
        </div>
      `).join("");
    }
    document.getElementById("holiday-modal").classList.remove("hidden");
  }

  function closeHolidayModal() {
    document.getElementById("holiday-modal").classList.add("hidden");
  }

  function switchTab(tabName) {
    // 1. Sinkronisasi Visibilitas & Animasi Pane Konten
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.add('hidden');
      pane.classList.remove('block', 'opacity-100', 'translate-y-0');
    });

    const activeContent = document.getElementById(`tab-content-${tabName}`);
    if (activeContent) {
      activeContent.classList.remove('hidden');
      activeContent.classList.add('block');
      setTimeout(() => {
        activeContent.classList.add('opacity-100', 'translate-y-0');
      }, 10);
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
      btn.classList.add('font-medium', 'text-slate-500');
    });

    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    if (activeBtn) {
      activeBtn.classList.remove('font-medium', 'text-slate-500');
      activeBtn.classList.add('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
    }
  }

document.addEventListener("DOMContentLoaded", () => {
  const tabButtons = document.querySelectorAll('[id^="tab-btn-"], .tab-btn, button[role="tab"]');
  
  tabButtons.forEach((btn, index) => {
    if (!btn.id) {
      btn.id = index === 0 ? 'tab-btn-active' : 'tab-btn-history';
    }

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const tabName = btn.id.replace('tab-btn-', '');
      switchTab(tabName);
    });
  });
});

</script>
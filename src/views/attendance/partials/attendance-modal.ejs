<div
  id="detailModal"
  class="fixed inset-0 z-[110] hidden items-center justify-center bg-slate-950/40 p-4 backdrop-blur-xs transition-all duration-300"
>
  <div
    class="mx-3 w-full max-w-md transform overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-xl transition-all sm:mx-auto"
  >
    <div class="flex justify-between border-b border-slate-100 bg-white px-5 py-4 select-none">
      <div>
        <h2 class="text-[13.5px] font-semibold tracking-tight text-slate-800">
          Detail Log Kehadiran
        </h2>
        <p class="mt-0.5 text-[10.5px] font-medium text-slate-400">
          Informasi verifikasi absensi harian
        </p>
      </div>
      <button
        onclick="closeModal()"
        class="shadow-3xs flex h-7 w-7 cursor-pointer items-center justify-center rounded-lg border border-slate-200/60 bg-slate-50 text-[10px] text-slate-400 transition-colors outline-none hover:bg-slate-100 hover:text-slate-800"
      >
        ✕
      </button>
    </div>

    <div class="space-y-2.5 p-5 text-[12px] font-semibold text-slate-700">
      <div class="flex items-center justify-between border-b border-slate-50 pb-1.5">
        <span class="font-medium text-slate-400">Tanggal Log</span>
        <span id="mDate" class="font-semibold text-slate-800"></span>
      </div>
      <div class="flex items-center justify-between border-b border-slate-50 pb-1.5">
        <span class="font-medium text-slate-400">Status Kehadiran</span>
        <span id="mStatus" class="font-semibold tracking-wide text-slate-800 uppercase"></span>
      </div>
      <div class="flex items-center justify-between border-b border-slate-50 pb-1.5">
        <span class="font-medium text-slate-400">Tipe Log Sesi</span>
        <span id="mType" class="font-semibold text-slate-800"></span>
      </div>
      <div class="flex items-center justify-between border-b border-slate-50 pb-1.5">
        <span class="font-medium text-slate-400">Waktu Masuk (In)</span>
        <span id="mIn" class="font-semibold text-slate-800 tabular-nums"></span>
      </div>
      <div class="flex items-center justify-between border-b border-slate-50 pb-1.5">
        <span class="font-medium text-slate-400">Waktu Keluar (Out)</span>
        <span id="mOut" class="font-semibold text-slate-800 tabular-nums"></span>
      </div>
      <div class="flex items-center justify-between border-b border-slate-50 pb-1.5">
        <span class="font-medium text-slate-400">Durasi Total Kerja</span>
        <span id="mDuration" class="font-semibold text-slate-800 tabular-nums"></span>
      </div>
      <div class="flex items-center justify-between pb-0.5">
        <span class="font-medium text-slate-400">Durasi Keterlambatan</span>
        <span id="mLate" class="font-semibold text-rose-600 tabular-nums"></span>
      </div>

      <div
        id="photoContainerBox"
        class="grid grid-cols-2 gap-3 border-t border-slate-100 pt-4 select-none"
      >
        <div
          id="inPhotoBox"
          class="shadow-3xs flex flex-col items-center gap-1.5 rounded-xl border border-slate-200/40 bg-slate-50/50 p-2"
        >
          <span class="text-[9.5px] font-bold tracking-wider text-slate-400 uppercase">
            Foto Masuk
          </span>
          <div
            class="shadow-3xs flex h-20 w-20 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-100 sm:h-24 sm:w-24"
          >
            <img
              id="mInPhoto"
              src=""
              class="h-full w-full scale-x-[-1] object-cover"
              onerror="
                this.style.display = 'none';
                document.getElementById('err-in').classList.remove('hidden');
              "
            />
            <span id="err-in" class="hidden p-1 text-center text-[9px] text-slate-400">
              Tidak Ada Foto
            </span>
          </div>
        </div>

        <div
          id="outPhotoBox"
          class="shadow-3xs flex flex-col items-center gap-1.5 rounded-xl border border-slate-200/40 bg-slate-50/50 p-2"
        >
          <span class="text-[9.5px] font-bold tracking-wider text-slate-400 uppercase">
            Foto Pulang
          </span>
          <div
            class="shadow-3xs flex h-20 w-20 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-100 sm:h-24 sm:w-24"
          >
            <img
              id="mOutPhoto"
              src=""
              class="h-full w-full scale-x-[-1] object-cover"
              onerror="
                this.style.display = 'none';
                document.getElementById('err-out').classList.remove('hidden');
              "
            />
            <span id="err-out" class="hidden p-1 text-center text-[9px] text-slate-400">
              Tidak Ada Foto
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  const modal = document.getElementById("detailModal");

  function formatMenit(totalMenit, defaultText = "-") {
    const menitNum = parseInt(totalMenit, 10);
    if (isNaN(menitNum) || menitNum <= 0) return defaultText;

    const jam = Math.floor(menitNum / 60);
    const sisaMenit = menitNum % 60;

    if (jam > 0) {
      return `${jam} jam ${sisaMenit > 0 ? sisaMenit + " menit" : ""}`;
    }
    return `${sisaMenit} menit`;
  }

  function openModalHandler(e) {
    const dataset = e.currentTarget.dataset;

    document.getElementById("mDate").textContent = dataset.date || "-";
    document.getElementById("mStatus").textContent = dataset.status || "-";
    document.getElementById("mType").textContent = dataset.type || "-";
    document.getElementById("mIn").textContent = dataset.checkin || "-";
    document.getElementById("mOut").textContent = dataset.checkout || "-";

    document.getElementById("mDuration").textContent = formatMenit(dataset.duration, "0 menit");
    document.getElementById("mLate").textContent = formatMenit(dataset.lateduration, "-");

    document.getElementById("err-in").classList.add("hidden");
    document.getElementById("err-out").classList.add("hidden");
    document.getElementById("mInPhoto").style.display = "block";
    document.getElementById("mOutPhoto").style.display = "block";

    if (
      dataset.inphoto &&
      dataset.inphoto.trim() !== "" &&
      dataset.inphoto !== "null" &&
      dataset.inphoto !== "undefined"
    ) {
      document.getElementById("inPhotoBox").classList.remove("hidden");
      document.getElementById("mInPhoto").src = decodeURI(dataset.inphoto);
    } else {
      document.getElementById("mInPhoto").style.display = "none";
      document.getElementById("err-in").classList.remove("hidden");
    }

    if (
      dataset.outphoto &&
      dataset.outphoto.trim() !== "" &&
      dataset.outphoto !== "null" &&
      dataset.outphoto !== "undefined"
    ) {
      document.getElementById("outPhotoBox").classList.remove("hidden");
      document.getElementById("mOutPhoto").src = decodeURI(dataset.outphoto);
    } else {
      document.getElementById("mOutPhoto").style.display = "none";
      document.getElementById("err-out").classList.remove("hidden");
    }

    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }

  document.addEventListener("click", (e) => {
    if (e.target.closest(".openModal")) {
      openModalHandler({ currentTarget: e.target.closest(".openModal") });
    }
  });

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
</script>

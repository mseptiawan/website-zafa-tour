<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-2xl mx-auto">

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6">

      <h1 class="text-lg font-medium text-slate-800 mb-4">
        Detail Koreksi Absensi
      </h1>

      <div class="space-y-3 text-sm">

        <div>
          <p class="text-xs text-slate-500">Pegawai</p>
          <p class="text-slate-700 font-medium">
            <%= data.userId?.username %>
          </p>
        </div>

        <div>
          <p class="text-xs text-slate-500">Tanggal</p>
          <p class="text-slate-700">
            <%= new Date(data.date).toLocaleDateString('id-ID') %>
          </p>
        </div>

        <div>
          <p class="text-xs text-slate-500">Alasan</p>
          <p class="text-slate-700">
            <%= data.reasonType %>
          </p>
        </div>

        <div>
          <p class="text-xs text-slate-500">Penjelasan</p>
          <p class="text-slate-700">
            <%= data.reason %>
          </p>
        </div>

        <div>
          <p class="text-xs text-slate-500">Status</p>
          <p class="text-slate-700 font-medium">
            <%= data.status %>
          </p>
        </div>

      </div>

    </div>

  </div>

</div>
<%- layout('layouts/main', { title: 'Riwayat Lembur' }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8">
  <div class="max-w-5xl mx-auto">

    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-semibold text-slate-800">
          Riwayat Lembur
        </h1>
        <p class="text-sm text-slate-500 mt-1">
          Daftar lengkap pengajuan aktivitas lembur
        </p>
      </div>

      <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-xl border border-slate-200 shadow-sm">
        <span class="text-xs font-bold text-slate-400 uppercase">
          Total
        </span>
        <span class="text-sm font-bold text-slate-800">
          <%= overtimes.length %>
        </span>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">

      <% if (overtimes.length > 0) { %>

      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[700px]">

          <thead class="bg-slate-50 text-slate-500 text-[10px] uppercase tracking-wider">
            <tr>
              <th class="px-6 py-4 text-left">Tanggal</th>
              <th class="px-6 py-4 text-left">Jam</th>
              <th class="px-6 py-4 text-left">Total</th>
              <th class="px-6 py-4 text-center">Status</th>
              <th class="px-6 py-4 text-center">Aksi</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">

            <% overtimes.forEach(o=> { %>

            <tr class="hover:bg-slate-50/50 transition">

              <td class="px-6 py-4 font-medium text-slate-700">
                <%= new Date(o.date).toLocaleDateString("id-ID") %>
              </td>

              <td class="px-6 py-4 text-slate-500 font-mono text-xs">
                <%= o.startTime %> - <%= o.endTime %>
              </td>

              <td class="px-6 py-4 text-slate-600">
                <%= o.totalHours %> Jam
              </td>

              <td class="px-6 py-4 text-center">

                <%
                let color='bg-slate-100 text-slate-600 border-slate-200' ;

                if (o.status==='Approved' )
                color='bg-emerald-50 text-emerald-600 border-emerald-100' ;

                if (o.status==='Rejected' )
                color='bg-rose-50 text-rose-600 border-rose-100' ;
                %>

                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-medium <%= color %>">

                  <span class="w-1.5 h-1.5 rounded-full
                    <%= o.status === 'Approved'
                    ? 'bg-emerald-500'
                    : o.status === 'Rejected'
                    ? 'bg-rose-500'
                    : 'bg-slate-400'
                    %>">
                  </span>

                  <%= o.status %>
                </span>

              </td>

              <td class="px-6 py-4 text-center">

                <button
                  class="openModal text-slate-400 hover:text-indigo-600 transition"
                  type="button"

                  data-date="<%= new Date(o.date).toLocaleDateString('id-ID') %>"
                  data-time="<%= o.startTime %> - <%= o.endTime %>"
                  data-total="<%= o.totalHours %> Jam"
                  data-status="<%= o.status %>"
                  data-description="<%= o.workDescription %>"
                  data-result="<%= o.result || '-' %>"
                  data-created="<%= new Date(o.createdAt).toLocaleString('id-ID') %>"
                  data-proof="<%= o.proofFile || '' %>"
                >
                  <i data-lucide="eye" class="w-4 h-4"></i>
                </button>

              </td>

            </tr>

            <% }) %>

          </tbody>
        </table>
      </div>

      <% } else { %>

      <div class="py-16 text-center text-slate-400">
        <i data-lucide="folder-open" class="w-8 h-8 mx-auto mb-2"></i>
        <p>Belum ada riwayat lembur</p>
      </div>

      <% } %>

    </div>
  </div>
</div>


<!-- MODAL -->

<div id="detailModal"
class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50 p-4">

  <div class="bg-white rounded-2xl max-w-lg w-full shadow-xl">

    <div class="px-6 py-4 border-b flex justify-between">

      <h3 class="font-semibold text-slate-800">
        Detail Lembur
      </h3>

      <button id="closeModal">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>

    </div>

    <div class="p-6 space-y-5">

      <div class="grid grid-cols-2 gap-4">

        <div>
          <p class="text-xs text-slate-400 uppercase">Tanggal</p>
          <p id="modalDate"></p>
        </div>

        <div>
          <p class="text-xs text-slate-400 uppercase">Jam</p>
          <p id="modalTime"></p>
        </div>

        <div>
          <p class="text-xs text-slate-400 uppercase">Total</p>
          <p id="modalTotal"></p>
        </div>

        <div>
          <p class="text-xs text-slate-400 uppercase">Status</p>
          <p id="modalStatus"></p>
        </div>

      </div>

      <div>
        <p class="text-xs text-slate-400 uppercase">
          Deskripsi
        </p>
        <p id="modalDescription"></p>
      </div>

      <div>
        <p class="text-xs text-slate-400 uppercase">
          Hasil
        </p>
        <p id="modalResult"></p>
      </div>

      <div>
        <p class="text-xs text-slate-400 uppercase">
          Dibuat
        </p>
        <p id="modalCreated"></p>
      </div>

      <div id="proofWrapper" class="hidden">

        <p class="text-xs text-slate-400 uppercase mb-2">
          Bukti
        </p>

        <img
          id="modalProof"
          class="w-full rounded-lg border"
        >

      </div>

      <div id="proofEmpty" class="hidden text-sm text-slate-400">
        Tidak ada bukti file
      </div>

    </div>

    <div class="px-6 py-4 border-t flex justify-end">
      <button
        id="closeModalFooter"
        class="px-4 py-2 rounded-lg bg-indigo-600 text-white"
      >
        Tutup
      </button>
    </div>

  </div>

</div>

<script src="https://unpkg.com/lucide@latest"></script>
<script>

lucide.createIcons();

const modal = document.getElementById("detailModal");

document.querySelectorAll(".openModal").forEach(btn=>{

    btn.addEventListener("click",()=>{

        modal.classList.remove("hidden");
        modal.classList.add("flex");

        modalDate.textContent = btn.dataset.date;
        modalTime.textContent = btn.dataset.time;
        modalTotal.textContent = btn.dataset.total;
        modalStatus.textContent = btn.dataset.status;
        modalDescription.textContent = btn.dataset.description;
        modalResult.textContent = btn.dataset.result;
        modalCreated.textContent = btn.dataset.created;

        const proof = btn.dataset.proof;

        if(proof){

            modalProof.src=`/uploads/files/${proof}`;

            proofWrapper.classList.remove("hidden");
            proofEmpty.classList.add("hidden");

        }else{

            proofWrapper.classList.add("hidden");
            proofEmpty.classList.remove("hidden");

        }

    });

});


function hideModal(){

    modal.classList.add("hidden");
    modal.classList.remove("flex");

}

closeModal.addEventListener("click",hideModal);

closeModalFooter.addEventListener("click",hideModal);

modal.addEventListener("click",(e)=>{

    if(e.target===modal){

        hideModal();

    }

});

</script>
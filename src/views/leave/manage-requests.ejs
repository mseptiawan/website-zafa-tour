<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50 font-sans text-gray-800">

  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header Dashboard -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Manajemen Administrasi Cuti</h1>
      <p class="text-gray-500 mt-1">Kelola permohonan cuti staff dan konfigurasi hari libur perusahaan secara terpusat.</p>
    </div>

    <!-- TAB NAVIGATION BAR -->
    <div class="border-b border-gray-200 mb-6">
      <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <a href="/leave/manage-requests" class="border-indigo-600 text-indigo-600 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm flex items-center gap-2">
          <i class="fa-solid fa-file-invoice"></i> Permohonan Cuti Karyawan
        </a>
        <a href="/leave/manage-calendar" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm flex items-center gap-2">
          <i class="fa-solid fa-calendar-days"></i> Kelola Kalender & Cuti Bersama
        </a>
      </nav>
    </div>

    <!-- TAB CONTENT: DATA PENGAJUAN -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="p-6 border-b border-gray-100 bg-gray-50/50 flex justify-between items-center">
        <h3 class="font-semibold text-lg text-gray-800">Daftar Pengajuan Masuk</h3>
        <span class="px-2.5 py-1 text-xs font-semibold bg-indigo-50 text-indigo-700 rounded-full">Total: <%= allLeaves.length %> Pengajuan</span>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-100 text-gray-600 uppercase text-xs tracking-wider font-semibold">
              <th class="px-6 py-4">Nama Karyawan</th>
              <th class="px-6 py-4">Tipe Cuti</th>
              <th class="px-6 py-4">Tanggal Pelaksanaan</th>
              <th class="px-6 py-4 text-center">Durasi</th>
              <th class="px-6 py-4">Status Utama</th>
              <th class="px-6 py-4 text-center">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm">
            <% if (allLeaves.length === 0) { %>
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                  <i class="fa-regular fa-folder-open text-4xl mb-3 block"></i>
                  Belum ada riwayat pengajuan cuti yang masuk ke sistem Anda.
                </td>
              </tr>
            <% } else { %>
              <% allLeaves.forEach(leave => { %>
                <tr class="hover:bg-gray-50/70 transition">
                  <td class="px-6 py-4 font-medium text-gray-900">
                    <%= leave.userId && leave.userId.employeeData ? leave.userId.employeeData.fullName : "Karyawan" %>
                  </td>
                  <td class="px-6 py-4">
                    <span class="px-2 py-1 rounded bg-slate-100 text-xs font-medium text-slate-700"><%= leave.leaveTypeId.name %></span>
                  </td>
                  <td class="px-6 py-4 text-gray-600">
                    <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %> 
                    <span class="text-gray-400 mx-1">s/d</span> 
                    <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %>
                  </td>
                  <td class="px-6 py-4 text-center font-semibold text-indigo-600"><%= leave.totalDays %> Hari</td>
                  <td class="px-6 py-4">
                    <% if(leave.status === 'PENDING') { %>
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-800 border border-amber-200"><i class="fa-solid fa-spinner animate-spin"></i> Menunggu Proses</span>
                    <% } else if(leave.status === 'APPROVED') { %>
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-800 border border-emerald-200"><i class="fa-solid fa-circle-check"></i> Disetujui</span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-rose-50 text-rose-800 border border-rose-200"><i class="fa-solid fa-circle-xmark"></i> Ditolak</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-center">
                    <a href="/leave/detail/<%= leave._id %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-gray-300 text-xs font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none shadow-sm transition">
                      <i class="fa-solid fa-eye"></i> Periksa / Aksi
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</body>
</html>
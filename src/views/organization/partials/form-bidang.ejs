<div id="form-panel-bidang" class="block space-y-4">
  <div>
    <h3 class="mb-1 text-[13px] font-bold text-slate-800">Tambah Bidang Baru</h3>
    <p class="text-[11px] text-slate-400">Membuat bidang perusahaan.</p>
  </div>
  <form onsubmit="handleCreateBidang(event)" class="space-y-3">
    <div>
      <input
        type="text"
        id="input-bidang-name"
        placeholder="Contoh: Operasional, IT, HRD..."
        required
        class="w-full rounded-xl border border-slate-200/60 bg-slate-50 px-3.5 py-2.5 text-[12.5px] font-medium transition outline-none focus:border-slate-400 focus:bg-white"
      />
      <p id="error-bidang-name" class="mt-1 hidden text-[11px] font-medium text-red-500"></p>
    </div>

    <button
      type="submit"
      class="w-full cursor-pointer rounded-xl bg-blue-600 py-2.5 text-[12.5px] font-medium text-white transition hover:bg-blue-700"
    >
      Simpan
    </button>
  </form>
</div>

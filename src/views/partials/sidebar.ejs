                  stroke-width="2"
                  d="M12 8c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3zm0-6v2m0 16v2m8-10h2M2 12H4"
                ></path>
              </svg>

              <span
                class="text-xs font-medium text-slate-600 group-hover:text-slate-800"
              >
                Expense Claim
              </span>
            </div>

            <!-- ARROW -->
            <svg
              class="w-4 h-4 text-slate-500 transition-transform group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              ></path>
            </svg>
          </summary>

          <!-- SUBMENU -->
          <div
            class="mt-1 ml-9 flex flex-col border-l border-slate-200 space-y-1"
          >
            <!-- AJUKAN -->
            <a
              href="/expense/create"
              class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
            >
              Ajukan Klaim
            </a>

            <!-- KLAIM SAYA -->
            <a
              href="/expense/my"
              class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
            >
              Klaim Saya
            </a>

            <!-- APPROVAL MANAGER -->
        <% if (
  user.role === 'MANAGER' ||
  user.role === 'GENERAL MANAGER'
) { %>

<a
  href="/expense/approval/manager"
  class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
>
  Approval Manager
</a>

<% } %>
            <!-- VALIDASI FINANCE -->
         <% if (user.role === 'KEUANGAN') { %>

<a
  href="/expense/finance"
  class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
>
  Validasi Finance
</a>

<% } %>

            <!-- SEMUA -->
<% if (
  user.role === 'MANAGER' ||
  user.role === 'HR' ||
  user.role === 'PIMPINAN'
) { %>
            <a
              href="/expense/all"
              class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
            >
              Semua Klaim
            </a>
            <% } %>
          </div>
        </details>
      </div>
    </section>
    <section class="mt-6">
  <p
    class="text-[7px] text-slate-500 font-bold px-4 mb-3 uppercase tracking-[0.2em]"
  >
    Laporan
  </p>

  <div class="space-y-1">

    
    <!-- LAPORAN -->
    <details class="group outline-none" data-menu="report">
      <summary
        class="flex items-center justify-between px-4 py-3 rounded-xl cursor-pointer list-none transition-all border border-transparent hover:border-white/10"
      >
        <div class="flex items-center gap-3">

          <!-- ICON -->
          <svg
            class="w-5 h-5 text-slate-500 group-hover:text-indigo-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 17v-6h6v6m-7 4h8a2 2 0 002-2V7a2 2 0 00-2-2h-3l-2-2h-4L7 5H4a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>

          <span
            class="text-xs font-medium text-slate-600 group-hover:text-slate-800"
          >
            Laporan
          </span>
        </div>

        <!-- ARROW -->
        <svg
          class="w-4 h-4 text-slate-500 transition-transform group-open:rotate-180"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 9l-7 7-7-7"
          ></path>
        </svg>
      </summary>

      <!-- SUB MENU -->
      <div class="mt-1 ml-9 flex flex-col border-l border-slate-200 space-y-1">

        <!-- KPI REPORT -->
        <% if (user.permissions.report_kpi) { %>
        <a
          href="/report/kpi"
          class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
        >
          Laporan KPI
        </a>
        <% } %>

        <!-- CUTI REPORT -->
        <% if (user.permissions.report_leave) { %>
        <a
          href="/report/leave"
          class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
        >
          Laporan Cuti
        </a>
        <% } %>

        <!-- LEMBUR REPORT -->
        <% if (user.permissions.report_overtime) { %>
        <a
          href="/report/overtime"
          class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
        >
          Laporan Lembur
        </a>
        <% } %>

        <!-- ABSENSI REPORT -->
        <% if (user.permissions.report_attendance) { %>
        <a
          href="/report/attendance"
          class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-indigo-400 transition"
        >
          Laporan Absensi
        </a>
        <% } %>

      </div>
    </details>

  </div>
</section>
  </nav>

  <!-- USER FOOTER -->
  <div class="p-4 border-t border-white/10 backdrop- relative">
    <!-- ambient glow -->
    <div
      class="absolute inset-0 from-indigo-500/10 via-cyan-500/5 to-purple-500/10"
    ></div>

    <div
      class="relative flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10 _rgba(99,102,241,0.15)]"
    >
      <!-- AVATAR HOLOGRAM -->
      <div class="relative">
        <div
          class="w-10 h-10 rounded-full flex items-center justify-center bg-slate-200 text-slate-700 font-semibold text-xs border border-slate-300"
        >
          <%= user.username?.charAt(0).toUpperCase() || 'U' %>
        </div>
      </div>

      <!-- USER INFO -->
      <div class="flex-1 overflow-hidden leading-tight">
        <p
          class="text-xs font-semibold text-slate-800 truncate flex items-center gap-2"
        >
          <%= user.fullName || 'User' %>

          <!-- system active dot -->
        </p>

        <p
          class="text-[7px] uppercase tracking-[0.25em] text-slate-500 truncate"
        >
          <%= user.role || 'Karyawan' %>
        </p>
      </div>

      <!-- LOGOUT CONTROL -->
      <a
        href="/logout"
        class="group p-2 rounded-xl transition hover:bg-red-500/10 border border-transparent hover:border-red-400/30"
      >
        <svg
          class="w-5 h-5 text-slate-500 group-hover:text-red-400 transition"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
          />
        </svg>
      </a>
    </div>
  </div>
</aside>

<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6 text-center">
      <h1 class="text-xl font-medium text-slate-800">
        Riwayat Approval Lembur
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Semua data lembur yang sudah diproses
      </p>
    </div>

    <!-- FILTER -->
    <form method="GET"
      class="bg-white border border-slate-200 rounded-xl p-4 mb-5">

      <div class="flex flex-col md:flex-row gap-3">

        <!-- SEARCH -->
        <div class="flex-1">
          <input
            type="text"
            name="search"
            value="<%= query?.search || '' %>"
            placeholder="Cari nama karyawan..."
            class="w-full border border-slate-200 px-3 py-2.5 rounded-lg text-sm
            focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500"
          />
        </div>

        <!-- STATUS -->
        <div class="w-full md:w-48">
          <select
            name="status"
            class="w-full border border-slate-200 px-3 py-2.5 rounded-lg text-sm"
          >
            <option value="">Semua Status</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
          </select>
        </div>

        <!-- SORT -->
        <div class="w-full md:w-40">
          <select
            name="sort"
            class="w-full border border-slate-200 px-3 py-2.5 rounded-lg text-sm"
          >
            <option value="desc">Terbaru</option>
            <option value="asc">Terlama</option>
          </select>
        </div>

        <!-- BUTTON -->
        <div class="flex gap-2">
          <button
            class="bg-indigo-600 text-white px-5 py-2.5 rounded-lg text-sm hover:bg-indigo-700"
          >
            Filter
          </button>

          <a href="/overtime/approval/history"
            class="px-4 py-2.5 text-sm border border-slate-200 rounded-lg text-slate-600 hover:bg-slate-50"
          >
            Reset
          </a>
        </div>

      </div>
    </form>

    <!-- TABLE -->
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

      <div class="overflow-x-auto">

        <table class="w-full text-sm">

          <!-- THEAD (simple clean style) -->
          <thead class="bg-slate-100 border-b border-slate-200">
            <tr class="text-left text-xs text-slate-600">
              <th class="px-3 py-3 font-medium">Karyawan</th>
              <th class="px-3 py-3 font-medium">Tanggal</th>
              <th class="px-3 py-3 font-medium">Jam</th>
              <th class="px-3 py-3 font-medium">Total</th>
              <th class="px-3 py-3 font-medium">Status</th>
              <th class="px-3 py-3 font-medium text-center">Dibuat</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">

            <% if (overtimes.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center py-6 text-slate-400">
                  Tidak ada data
                </td>
              </tr>
            <% } %>

            <% overtimes.forEach(o => { %>
              <tr class="hover:bg-slate-50">

                <td class="px-3 py-3 text-slate-700">
                  <%= o.employeeName %>
                </td>

                <td class="px-3 py-3 text-slate-600">
                  <%= new Date(o.date).toLocaleDateString("id-ID") %>
                </td>

                <td class="px-3 py-3 text-slate-600">
                  <%= o.startTime %> - <%= o.endTime %>
                </td>

                <td class="px-3 py-3 text-slate-600">
                  <%= o.totalHours %> jam
                </td>

                <!-- STATUS SIMPLE (ICON + TEXT, NO WARNA RAMAI) -->
                <td class="px-3 py-3">
                  <div class="flex items-center gap-2 text-xs">

                    <% if (o.status === "Approved") { %>

                      <i data-lucide="check-circle" class="w-4 h-4 text-slate-500"></i>
                      <span class="text-slate-600">Approved</span>

                    <% } else if (o.status === "Rejected") { %>

                      <i data-lucide="x-circle" class="w-4 h-4 text-slate-500"></i>
                      <span class="text-slate-600">Rejected</span>

                    <% } else { %>

                      <i data-lucide="clock" class="w-4 h-4 text-slate-500"></i>
                      <span class="text-slate-600">Pending</span>

                    <% } %>

                  </div>
                </td>

                <td class="px-3 py-3 text-center text-xs text-slate-500">
                  <%= new Date(o.createdAt).toLocaleString("id-ID") %>
                </td>

              </tr>
            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

    <!-- PAGINATION (20 DATA / PAGE UI) -->
    <div class="mt-4 flex items-center justify-between text-sm text-slate-600">

      <div>
        Page <%= pagination.page %> / <%= pagination.totalPages %>
      </div>

      <div class="flex gap-2">

        <% if (pagination.page > 1) { %>
          <a href="?page=<%= pagination.page - 1 %>"
            class="px-3 py-1 border rounded-lg hover:bg-slate-100">
            Prev
          </a>
        <% } %>

        <% if (pagination.page < pagination.totalPages) { %>
          <a href="?page=<%= pagination.page + 1 %>"
            class="px-3 py-1 border rounded-lg hover:bg-slate-100">
            Next
          </a>
        <% } %>

      </div>

    </div>

  </div>
</div>
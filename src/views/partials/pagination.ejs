<% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
<div class="flex items-center justify-between mt-6 px-5 py-4 bg-white border border-slate-200 rounded-2xl shadow-sm text-[13px] antialiased select-none">

  <div class="text-slate-500 font-medium">
    Menampilkan halaman
    <span class="font-bold text-slate-900">
      <%= pagination.page %>
    </span>
    dari
    <span class="font-bold text-slate-900">
      <%= pagination.totalPages %>
    </span>
  </div>

  <div class="flex items-center gap-2">

    <a href="?page=<%= pagination.page - 1 %>" 
       class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5 active:scale-95
       <%= pagination.hasPrev
         ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900 shadow-3xs'
         : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Prev</span>
    </a>

    <a href="?page=<%= pagination.page + 1 %>" 
       class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5 active:scale-95
       <%= pagination.hasNext
         ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900 shadow-3xs'
         : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
      <span>Next</span>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>

  </div>

</div>
<% } %>
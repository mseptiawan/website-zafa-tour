<%- layout('layouts/main', { title }) %>

<div style="
  margin-left:280px;
  min-height:100vh;
  padding:32px;
  background:#f8fafc;
  font-family: system-ui, sans-serif;
  color:#0f172a;
">

  <div style="max-width:640px; margin:auto;">

    <!-- HEADER -->
    <div style="margin-bottom:24px;">
      <h1 style="font-size:20px; font-weight:600;">
        Pengajuan Dinas Luar
      </h1>

      <p style="font-size:13px; color:#64748b; margin-top:4px;">
        Form pengajuan perjalanan dinas
      </p>
    </div>

    <!-- CARD -->
    <div style="background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:22px;">

      <form action="/trip/request" method="POST"
        style="display:flex; flex-direction:column; gap:12px;">

        <!-- TITLE -->
        <input
          type="text"
          name="title"
          placeholder="Judul perjalanan"
          minlength="5"
          maxlength="100"
          required
          style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
        />

        <!-- PURPOSE -->
        <select
          name="purpose"
          required
          style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0; font-size:14px;"
        >
          <option value="">Pilih tujuan perjalanan</option>
          <option value="SALES_VISIT">Sales Visit</option>
          <option value="MEETING">Meeting</option>
          <option value="TRAINING">Training</option>
          <option value="SURVEY">Survey</option>
          <option value="OTHER">Other</option>
        </select>

        <!-- DATE -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
          <input
            type="date"
            name="startDate"
            required
            style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
          />

          <input
            type="date"
            name="endDate"
            required
            style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
          />
        </div>

        <!-- DESTINATION -->
        <input
          type="text"
          name="destination"
          placeholder="Tujuan perjalanan"
          minlength="3"
          maxlength="150"
          required
          style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
        />

        <!-- DESCRIPTION -->
        <textarea
          name="description"
          rows="3"
          minlength="10"
          maxlength="1000"
          required
          placeholder="Deskripsi perjalanan"
          style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0; resize:none;"
        ></textarea>

        <!-- BUDGET -->
        <input
          type="text"
          id="budget"
          placeholder="Budget (Rp)"
          required
          style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
        />

        <!-- hidden REAL budget -->
        <input type="hidden" name="budget" id="budgetRaw" />

        <!-- CONTACT PERSON (FIXED STRUCTURE) -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">

          <input
            type="text"
            name="contactPerson[name]"
            placeholder="Nama orang yang ditemui"
            style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
          />

          <input
            type="text"
            name="contactPerson[phone]"
            placeholder="No HP (opsional)"
            style="padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
          />

        </div>


        <!-- TIMELINE (FIXED STRUCTURE) -->
        <div>
          <label style="font-size:12px; color:#64748b;">
            Timeline Perjalanan
          </label>

          <div id="timelineBox" style="display:flex; flex-direction:column; gap:8px; margin-top:6px;">

            <div class="timeline-item" style="display:flex; gap:8px;">
              <input
                type="text"
                name="timeline[0][address]"
                placeholder="Alamat 1"
                required
                style="flex:1; padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;"
              />

              <input type="hidden" name="timeline[0][order]" value="1" />

              <button type="button" onclick="removeTimeline(this)"
                style="padding:10px; border:none; background:#fee2e2; color:#dc2626; border-radius:8px; cursor:pointer;">
                ✕
              </button>
            </div>

          </div>

          <button type="button"
            onclick="addTimeline()"
            style="margin-top:8px; font-size:12px; color:#4f46e5; background:none; border:none; cursor:pointer;">
            + Tambah Timeline
          </button>

        </div>

        <!-- SUBMIT -->
        <button type="submit"
          style="
            margin-top:6px;
            padding:10px 14px;
            border-radius:8px;
            background:#4f46e5;
            color:#fff;
            border:none;
            font-size:14px;
            font-weight:500;
            cursor:pointer;
          ">
          Ajukan Perjalanan
        </button>

      </form>

    </div>

  </div>
</div>

<script>
let timelineIndex = 1;

// BUDGET FORMAT
const budgetInput = document.getElementById("budget");
const budgetRaw = document.getElementById("budgetRaw");

budgetInput.addEventListener("input", function (e) {
  let value = e.target.value.replace(/\D/g, "");

  budgetRaw.value = value;

  if (!value) {
    e.target.value = "";
    return;
  }

  e.target.value = Number(value).toLocaleString("id-ID");
});

// ADD TIMELINE
function addTimeline() {
  const box = document.getElementById("timelineBox");

  const div = document.createElement("div");
  div.style = "display:flex; gap:8px; margin-top:8px;";

  div.innerHTML = `
    <input type="text"
      name="timeline[${timelineIndex}][address]"
      placeholder="Alamat berikutnya"
      required
      style="flex:1; padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0;" />

    <input type="hidden"
      name="timeline[${timelineIndex}][order]"
      value="${timelineIndex + 1}" />

    <button type="button"
      onclick="removeTimeline(this)"
      style="padding:10px; border:none; background:#fee2e2; color:#dc2626; border-radius:8px; cursor:pointer;">
      ✕
    </button>
  `;

  box.appendChild(div);
  timelineIndex++;
}

// REMOVE
function removeTimeline(btn) {
  btn.parentElement.remove();
}
</script>
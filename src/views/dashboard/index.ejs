<%- layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50 p-10 text-slate-800">

  <!-- HEADER -->
  <div class="mb-8">
    <h1 class="text-2xl font-semibold tracking-tight">Dashboard</h1>
    <p class="text-sm text-slate-500 mt-1">
      Selamat datang, <%= user.fullName %>
    </p>

  </div>

  <!-- SUMMARY -->
  <div class="grid grid-cols-4 gap-6 mb-10">

    <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
      <p class="text-xs text-slate-500">Total Karyawan</p>
      <h2 class="text-2xl font-semibold mt-1"><%= totalEmployee %></h2>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
      <p class="text-xs text-slate-500">Hadir Hari Ini</p>
      <h2 class="text-2xl font-semibold mt-1 text-slate-800"><%= hadir %></h2>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
      <p class="text-xs text-slate-500">Cuti Aktif</p>
      <h2 class="text-2xl font-semibold mt-1"><%= cuti %></h2>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
      <p class="text-xs text-slate-500">Dinas / Trip</p>
      <h2 class="text-2xl font-semibold mt-1"><%= trip %></h2>
    </div>

  </div>

  <!-- TABLE -->
  <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

    <div class="p-4 border-b border-slate-200">
      <h2 class="font-semibold">Absensi Hari Ini</h2>
    </div>

    <table class="w-full text-sm">

      <thead class="bg-slate-50 text-slate-500 text-left">
        <tr>
          <th class="p-3">Nama</th>
          <th class="p-3">Status</th>
          <th class="p-3">Waktu</th>
          <th class="p-3">Tipe</th>
        </tr>
      </thead>

      <tbody>

        <% todayAttendance.forEach(a => { %>
          <tr class="border-t border-slate-100 hover:bg-slate-50">

           <td class="p-3 font-medium">
  <%= a.employee?.fullName || a.userId?.username || '-' %>
</td>

            <td class="p-3">
              <% if (a.status === 'HADIR') { %>
                <span class="px-2 py-1 text-xs rounded-md bg-slate-100 text-slate-700">
                  HADIR
                </span>
              <% } else { %>
                <span class="px-2 py-1 text-xs rounded-md bg-slate-100 text-slate-700">
                  <%= a.status %>
                </span>
              <% } %>
            </td>

            <td class="p-3 text-slate-500">
              <%= new Date(a.checkIn).toLocaleTimeString() %>
            </td>

            <td class="p-3 text-slate-500">
              <%= a.type %>
            </td>

          </tr>
        <% }) %>

      </tbody>

    </table>
    

  </div>
<!-- ANNOUNCEMENT -->
<div class="mt-8 bg-white border border-slate-200 rounded-xl overflow-hidden">

  <!-- HEADER -->
  <div class="p-4 border-b border-slate-200 flex items-center justify-between">

    <div>
      <h2 class="font-semibold">
        Pengumuman Terbaru
      </h2>

      <p class="text-xs text-slate-500 mt-1">
        Informasi internal perusahaan
      </p>
    </div>

    <a
      href="/announcement"
      class="text-xs text-indigo-500 hover:underline"
    >
      Lihat Semua
    </a>

  </div>

  <!-- LIST -->
  <div class="divide-y divide-slate-100">

    <% if(announcements.length === 0) { %>

      <div class="p-6 text-sm text-slate-500">
        Belum ada pengumuman
      </div>

    <% } %>

    <% announcements.forEach(a => { %>

      <a
        href="/announcement/<%= a._id %>"
        class="block p-4 hover:bg-slate-50 transition"
      >

        <div class="flex items-start justify-between gap-4">

          <!-- LEFT -->
          <div>

            <!-- PIN -->
            <% if(a.isPinned) { %>
              <span
                class="text-[10px] bg-amber-100 text-amber-600 px-2 py-1 rounded-full"
              >
                PINNED
              </span>
            <% } %>

            <!-- TITLE -->
            <h3 class="text-sm font-semibold text-slate-800 mt-2">
              <%= a.title %>
            </h3>

            <!-- CONTENT -->
            <p class="text-xs text-slate-500 mt-1 line-clamp-2">
              <%= a.content.substring(0, 120) %>...
            </p>

            <!-- CREATOR -->
            <div class="text-[11px] text-slate-400 mt-2">
              Dibuat oleh:
              <%= a.createdBy?.username || '-' %>
            </div>

          </div>

          <!-- RIGHT -->
          <div class="flex flex-col items-end gap-2">

            <!-- CATEGORY -->
            <% if(a.category === "OFFICIAL") { %>

              <span
                class="text-[10px] bg-red-100 text-red-600 px-2 py-1 rounded-full"
              >
                OFFICIAL
              </span>

            <% } else { %>

              <span
                class="text-[10px] bg-emerald-100 text-emerald-600 px-2 py-1 rounded-full"
              >
                LIGHT
              </span>

            <% } %>

            <!-- ATTACHMENT -->
            <% if(a.attachment) { %>

              <span
                class="text-[10px] bg-indigo-100 text-indigo-600 px-2 py-1 rounded-full"
              >
                SURAT
              </span>

            <% } %>

          </div>

        </div>

      </a>

    <% }) %>

  </div>

</div>
</div>
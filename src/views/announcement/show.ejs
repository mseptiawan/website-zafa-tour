<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] md:p-10 antialiased selection:bg-slate-100 pb-24 md:pb-8 text-slate-800 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto mt-4 md:mt-0">

    <div class="mb-5 hidden md:block">
      <a href="/announcement" class="inline-flex items-center gap-1.5 text-[11.5px] font-semibold text-slate-400 hover:text-slate-800 transition-colors group">
        <svg class="w-3.5 h-3.5 transition-transform group-hover:-translate-x-0.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Kembali ke Pengumuman
      </a>
    </div>

    <div class="bg-white border-0 md:border md:border-slate-200/60 rounded-2xl overflow-hidden ">

      <div class="p-4 sm:p-6 md:p-8 border-b border-slate-100 bg-white">

       <div class="mb-4">
  <% if(announcement.category === "OFFICIAL") { %>
    <span class="inline-flex items-center bg-blue-50 text-blue-600 border border-blue-200/50 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase select-none">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-500 mr-1.5 shrink-0"></span>
      Official Release
    </span>
  <% } else { %>
    <span class="inline-flex items-center bg-slate-50 text-slate-500 border border-slate-200/60 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase select-none">
      <span class="w-1.5 h-1.5 rounded-full bg-slate-400 mr-1.5 shrink-0"></span>
      General Info
    </span>
  <% } %>
</div>

        <h1 class="text-lg sm:text-xl md:text-2xl font-bold text-slate-900 leading-snug tracking-tight break-words mb-4">
          <%= announcement.title %>
        </h1>

        <div class="border-t border-slate-100 my-4"></div>

        <div class="flex items-center gap-3 pt-1">
          <% if (announcement.createdBy?.employeeData?.foto_profile) { %>
          <img src="<%= announcement.createdBy.employeeData.foto_profile %>" alt="Profile" class="w-10 h-10 rounded-full object-cover border border-slate-200/60 shrink-0" />
          <% } else { %>
          <div class="w-10 h-10 rounded-full bg-slate-50 border border-slate-200/60 flex items-center justify-center text-[13px] font-bold text-slate-600 uppercase shrink-0 select-none">
            <%= announcement.createdBy?.employeeData?.fullName?.charAt(0) || '?' %>
          </div>
          <% } %>

          <div class="flex flex-col min-w-0 justify-center">
            <span class="text-[13px] font-semibold text-slate-800 truncate leading-snug">
              <%= announcement.createdBy?.employeeData?.fullName || announcement.createdBy?.username || 'Tidak Diketahui' %>
            </span>

            <span class="text-[11.5px] font-medium text-slate-400 mt-0.5 flex items-center gap-1 leading-relaxed">
              <svg class="w-3 h-3 text-slate-400 stroke-[2] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="truncate">Dipublikasikan pada <%= new Date(announcement.publishDate || announcement.createdAt).toLocaleDateString("id-ID", { day: "2-digit", month: "long", year: "numeric" }) %></span>
            </span>
          </div>
        </div>

      </div>

      <div class="p-4 sm:p-6 md:p-8 pt-5 sm:pt-6">

        <article class="text-[13px] sm:text-[14px] text-slate-600 leading-relaxed whitespace-pre-line tracking-normal wrap-break-words">
          <%= announcement.content ? announcement.content.trim() : '' %>
        </article>

        <% if(announcement.attachment) { %>
        <div class="mt-8 pt-5 border-t border-slate-100 space-y-2.5">

          <div class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-slate-400 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
            </svg>
            <h3 class="text-[10px] font-bold tracking-wider text-slate-400 uppercase">
              Dokumen Lampiran Resmi
            </h3>
          </div>

          <div class="border border-slate-200/60 rounded-xl overflow-hidden bg-slate-50/30 ">

            <% if (announcement.attachment.match(/\.(jpg|jpeg|png|gif|webp)$/i)) { %>
            <div class="p-3 bg-slate-50/50 border-b border-slate-200/40 flex items-center justify-center">
              <div class="overflow-hidden rounded-lg border border-slate-200/60 bg-white max-w-full">
                <img src="/uploads/files/<%= announcement.attachment %>" alt="Lampiran Preview" class="w-full max-h-[260px] sm:max-h-[360px] object-contain select-none pointer-events-none">
              </div>
            </div>
            <% } %>

           <div class="p-4 bg-white border border-slate-100 rounded-xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3.5">
  <div class="flex items-start sm:items-center gap-3 min-w-0">
    <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-200/60 flex items-center justify-center text-slate-400 shrink-0 mt-0.5 sm:mt-0">
      <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    </div>

    <div class="min-w-0 flex-1">
      <p class="text-[12px] font-semibold text-slate-700 truncate">
        Lampiran Pengumuman
      </p>
      <p class="text-[11px] text-slate-400 mt-0.5 leading-normal">
        Klik untuk melihat dokumen lampiran pengumuman.
      </p>
    </div>
  </div>

  <div class="w-full sm:w-auto flex sm:ml-auto">
    <a href="/uploads/files/<%= announcement.attachment %>" 
       target="_blank" 
       class="inline-flex items-center justify-center w-full sm:w-auto h-8.5 bg-blue-50 text-blue-600 rounded-lg px-4 text-[11.5px] font-medium transition-all shrink-0 active:scale-[0.98] decoration-none no-underline">
      Lihat Berkas
    </a>
  </div>
</div>

          </div>
        </div>
        <% } %>

      </div>

    </div>
  </div>
</div>
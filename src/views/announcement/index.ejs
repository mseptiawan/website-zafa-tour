<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD]  md:p-10 antialiased selection:bg-slate-100 pb-24 md:pb-8 text-slate-800 ">
  <div class="w-full max-w-none mx-auto ">

    <div class="mb-6 border-b border-slate-200/60 pb-5">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Informasi', 
          title: 'Pengumuman', 
          description: 'Pantau seluruh informasi internal, kebijakan manajemen, dan rilis berita terbaru perusahaan.' 
      }) %>
    </div>

    <% if(announcements.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 w-full">

      <% announcements.forEach(a => { %>
      <a href="/announcement/<%= a._id %>" class="group bg-white border border-slate-200/60 rounded-xl p-4 sm:p-5 transition-all hover:border-slate-300
hover:-translate-y-0.5 shadow-3xs flex sm:flex-col justify-between min-h-0 sm:min-h-[190px] w-full items-center sm:items-stretch gap-4 sm:gap-0">

        <div class="flex-1 min-w-0 sm:flex-initial space-y-2">

        <div class="flex items-center gap-2 flex-wrap select-none">
  <% if(a.isPinned) { %>
    <span class="inline-flex items-center bg-amber-50 text-amber-700 border border-amber-200/60 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase">
      <i class="fa-solid fa-thumbtack text-[9px] mr-1.5 text-amber-500 shrink-0"></i>
      Pinned
    </span>
  <% } %>

  <% if(a.category === "OFFICIAL") { %>
    <span class="inline-flex items-center bg-blue-50 text-blue-600 border border-blue-200/50 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-500 mr-1.5 shrink-0"></span>
      Official
    </span>
  <% } else { %>
    <span class="inline-flex items-center bg-slate-50 text-slate-500 border border-slate-200/60 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase">
      <span class="w-1.5 h-1.5 rounded-full bg-slate-400 mr-1.5 shrink-0"></span>
      General
    </span>
  <% } %>
</div> 
          <h2 class="text-[13px] sm:text-[13.5px] font-semibold text-slate-800 leading-snug tracking-tight break-words line-clamp-1 sm:line-clamp-2">
            <%= a.title %>
          </h2>

          <p class="hidden sm:block text-[12px] text-slate-400 leading-relaxed line-clamp-2 break-words pt-0.5">
            <%= a.content %>
          </p>

          <div class="block sm:hidden text-[10.5px] text-slate-400 font-medium">
            <%= a.createdBy?.employeeData?.fullName || 'Anonim' %> • <%= new Date(a.createdAt).toLocaleDateString("id-ID", { day: "2-digit", month: "short" }) %>
          </div>
        </div>

        <div class="pt-0 sm:pt-3.5 flex items-center justify-between flex-shrink-0 border-t border-transparent sm:border-slate-100/70 mt-auto">

          <div class="hidden sm:flex items-center gap-2 min-w-0">
            <div class="w-7 h-7 rounded-lg bg-slate-50 border border-slate-200/60 flex-shrink-0 flex items-center justify-center text-[10.5px] font-bold text-slate-600 uppercase select-none">
              <%= a.createdBy?.employeeData?.fullName ? a.createdBy?.employeeData.fullName.charAt(0) : '?' %>
            </div>

            <div class="flex flex-col min-w-0">
              <span class="text-[11.5px] font-semibold text-slate-700 truncate leading-tight">
                <%= a.createdBy?.employeeData?.fullName || 'Tidak Diketahui' %>
              </span>
              <span class="text-[10px] text-slate-400 font-medium leading-none mt-1">
                <%= new Date(a.createdAt).toLocaleDateString("id-ID", { day: "2-digit", month: "short", year: "numeric" }) %>
              </span>
            </div>
          </div>

          <div class="w-6 h-6 rounded-lg bg-slate-50 border border-slate-200/40 flex items-center justify-center transition-colors group-hover:bg-slate-100">
            <svg class="w-3 h-3 text-slate-400 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>

      </a>
      <% }) %>

    </div>
    <% } else { %>
    <div class="bg-white border border-slate-200/60 rounded-2xl py-16 text-center  px-4">
      <div class="w-10 h-10 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-3.5 text-slate-400">
        <svg class="w-5 h-5 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>
      <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Pengumuman</p>
      <p class="text-[11.5px] text-slate-400 max-w-xs mx-auto mt-0.5 leading-relaxed">Seluruh rilis informasi internal penting dari manajemen akan tampil di sini.</p>
    </div>
    <% } %>

    <% if (pagination.totalPages > 1) { %>
    <div class="flex items-center justify-end mt-8 w-full border-t border-slate-200/60 pt-4">
      <div class="flex items-center gap-5">

        <a href="?page=<%= pagination.page - 1 %>" class="py-1 text-[11.5px] font-semibold transition-colors flex items-center gap-1 <%= pagination.hasPrev ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none select-none' %>">
          <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Prev
        </a>

        <a href="?page=<%= pagination.page + 1 %>" class="py-1 text-[11.5px] font-semibold transition-colors flex items-center gap-1 <%= pagination.hasNext ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none select-none' %>">
          Next
          <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>

      </div>
    </div>
    <% } %>

  </div>
</div>
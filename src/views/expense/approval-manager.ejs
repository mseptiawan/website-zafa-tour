<%- layout('layouts/main', { title: 'Approval Klaim Manager' }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-6xl mx-auto">

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-slate-900">Approval Klaim Manager</h1>
      <p class="text-sm text-slate-500 mt-1">Tinjau dan setujui pengajuan klaim beban karyawan</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[1000px]">
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-100">
            <tr>
              <th class="px-6 py-4 text-left">Karyawan</th>
              <th class="px-6 py-4 text-left">Detail Klaim</th>
              <th class="px-6 py-4 text-left">Kategori</th>
              <th class="px-6 py-4 text-left">Nominal</th>
              <th class="px-6 py-4 text-left">Tanggal</th>
              <th class="px-6 py-4 text-left">Bukti</th>
              <th class="px-6 py-4 text-center">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (expenses.length === 0) { %>
              <tr><td colspan="7" class="text-center py-12 text-slate-400">Tidak ada pengajuan menunggu approval</td></tr>
            <% } %>

            <% expenses.forEach(e => { %>
              <tr class="hover:bg-slate-50/50 transition">
                
                <td class="px-6 py-4">
                  <div class="font-semibold text-slate-800"><%= e.employeeId?.fullName %></div>
                  <div class="text-[11px] text-slate-400 font-medium uppercase"><%= e.employeeId?.position || '-' %></div>
                </td>

                <td class="px-6 py-4">
                  <div class="font-medium text-slate-800"><%= e.title %></div>
                  <div class="text-xs text-slate-500 truncate max-w-[200px]"><%= e.description || '-' %></div>
                </td>

                <td class="px-6 py-4">
                  <span class="inline-flex items-center px-2 py-1 rounded-lg bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wide">
                    <%= e.category %>
                  </span>
                </td>

                <td class="px-6 py-4 font-mono font-medium text-slate-700">Rp <%= e.amount.toLocaleString('id-ID') %></td>

                <td class="px-6 py-4 text-slate-500"><%= new Date(e.expenseDate).toLocaleDateString('id-ID') %></td>

                <td class="px-6 py-4">
                  <% if (e.proofFile) { %>
                    <% const isImage = ['jpg','jpeg','png','webp'].includes(e.proofFile.split('.').pop().toLowerCase()); %>
                    <a href="/uploads/<%= e.proofFile %>" target="_blank" class="block group">
                      <% if (isImage) { %>
                        <img src="/uploads/<%= e.proofFile %>" class="w-10 h-10 object-cover rounded-lg border border-slate-200 shadow-sm transition group-hover:scale-105" />
                      <% } else { %>
                        <span class="text-blue-600 underline text-[11px]">Download File</span>
                      <% } %>
                    </a>
                  <% } else { %>
                    <div class="flex flex-col">
                      <span class="text-[10px] bg-amber-50 text-amber-600 px-2 py-0.5 rounded-full w-fit font-bold">SELF DECLARATION</span>
                      <span class="text-[10px] text-slate-400 mt-1 max-w-[150px] truncate"><%= e.noReceiptReason || '-' %></span>
                    </div>
                  <% } %>
                </td>

                <td class="px-6 py-4 text-center">
                  <form action="/expense/<%= e._id %>/approve/manager" method="POST">
                    <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-[11px] font-bold uppercase rounded-lg transition shadow-sm shadow-blue-200">
                      Approve
                    </button>
                  </form>
                </td>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
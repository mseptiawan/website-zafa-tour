<%- layout('layouts/main', { title: "Tambah Pegawai" }) %>
  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-xl font-extrabold text-slate-900 tracking-tight">Edit Profil Karyawan</h1>
        <p class="text-xs text-slate-500 mt-1">Perbarui informasi lengkap berkas dan personal dari PT Zafa Mulia Mandiri.</p>
      </div>
      <a href="/employee" class="text-xs font-semibold text-slate-600 bg-white border border-slate-200 rounded-xl px-4 py-2.5 hover:bg-slate-50 transition-all shadow-sm">
        ← Kembali ke Daftar
      </a>
    </div>

    <% if (error) { %>
      <div class="bg-red-50 border border-red-200 text-red-600 p-4 rounded-xl text-xs mb-6 flex items-start gap-3">
        <span class="font-bold">🚨 Gangguan:</span>
        <span class="flex-1"><%= error %></span>
      </div>
    <% } %>

    <form action="/api/employee/edit/<%= employee._id %>" method="POST" enctype="multipart/form-data" class="space-y-8">
      
      <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm space-y-6">
        <div class="border-b border-slate-100 pb-3">
          <h3 class="text-sm font-bold text-slate-900">1. Identitas Pribadi & Akun</h3>
          <p class="text-[11px] text-slate-400">Informasi dasar kedinasan dan hak akses login sistem HRIS.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nama Lengkap <span class="text-red-500">*</span></label>
            <input type="text" name="fullName" required value="<%= employee.fullName %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
  <label class="text-[13px] font-bold text-slate-700">Email Utama (Akun) <span class="text-slate-400 font-normal">(Tidak dapat diubah)</span></label>
  <input type="email" name="email" value="<%= employee.userId?.email || '' %>" readonly class="w-full bg-slate-100 border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-500 cursor-not-allowed outline-none" />
</div>
          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nomor KTP (NIK) <span class="text-slate-400 font-normal">(Tidak dapat diubah)</span></label>
            <input type="text" name="nomor_ktp" value="<%= employee.nomor_ktp %>" readonly class="w-full bg-slate-100 border border-slate-200 rounded-xl px-4 py-3 text-xs text-slate-500 cursor-not-allowed outline-none" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Hak Akses Sistem <span class="text-red-500">*</span></label>
            <select name="roleId" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all">
              <% roles.forEach(r => { %>
                <option value="<%= r._id %>" <%= employee.userId?.roleId?.toString() === r._id.toString() ? 'selected' : '' %>><%= r.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Tempat Lahir</label>
            <input type="text" name="tempat_lahir" value="<%= employee.tempat_lahir %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Tanggal Lahir</label>
            <input type="date" name="tanggal_lahir" value="<%= employee.tanggal_lahir ? new Date(employee.tanggal_lahir).toISOString().split('T')[0] : '' %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Jenis Kelamin</label>
            <select name="jenis_kelamin" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all">
              <option value="Laki-laki" <%= employee.jenis_kelamin === 'Laki-laki' ? 'selected' : '' %>>Laki-laki</option>
              <option value="Perempuan" <%= employee.jenis_kelamin === 'Perempuan' ? 'selected' : '' %>>Perempuan</option>
            </select>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Agama</label>
            <input type="text" name="agama" value="<%= employee.agama %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Golongan Darah</label>
            <input type="text" name="golongan_darah" value="<%= employee.golongan_darah %>" placeholder="Misal: O / A / B / AB" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Status Pernikahan</label>
            <select name="status_pernikahan" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all">
              <option value="Belum Kawin" <%= employee.status_pernikahan === 'Belum Kawin' ? 'selected' : '' %>>Belum Kawin</option>
              <option value="Kawin" <%= employee.status_pernikahan === 'Kawin' ? 'selected' : '' %>>Kawin</option>
              <option value="Cerai Hidup" <%= employee.status_pernikahan === 'Cerai Hidup' ? 'selected' : '' %>>Cerai Hidup</option>
              <option value="Cerai Mati" <%= employee.status_pernikahan === 'Cerai Mati' ? 'selected' : '' %>>Cerai Mati</option>
            </select>
          </div>
        </div>
      </div>


      <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm space-y-6">
        <div class="border-b border-slate-100 pb-3">
          <h3 class="text-sm font-bold text-slate-900">2. Penempatan Kerja & Karir</h3>
          <p class="text-[11px] text-slate-400">Atur penempatan divisi, cabang unit, jabatan struktural, dan status kontrak.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Jabatan Struktural</label>
            <select name="positionId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all">
              <option value="">-- Pilih Jabatan --</option>
              <% positions.forEach(p => { %>
                <option value="<%= p._id %>" <%= employee.careerData?.positionId?._id?.toString() === p._id.toString() || employee.careerData?.positionId?.toString() === p._id.toString() ? 'selected' : '' %>><%= p.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Unit Kantor</label>
            <select name="unitId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all">
              <option value="">-- Pilih Unit --</option>
              <% units.forEach(u => { %>
                <option value="<%= u._id %>" <%= employee.careerData?.unitId?._id?.toString() === u._id.toString() || employee.careerData?.unitId?.toString() === u._id.toString() ? 'selected' : '' %>><%= u.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Bidang Kerja</label>
            <select name="bidangId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all">
              <option value="">-- Pilih Bidang --</option>
              <% bidang.forEach(b => { %>
                <option value="<%= b._id %>" <%= employee.careerData?.bidangId?._id?.toString() === b._id.toString() || employee.careerData?.bidangId?.toString() === b._id.toString() ? 'selected' : '' %>><%= b.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Status Kepegawaian</label>
            <select name="pegawai" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all">
              <option value="Tetap" <%= employee.careerData?.status_pegawai === 'Tetap' ? 'selected' : '' %>>Pegawai Tetap</option>
              <option value="Kontrak" <%= employee.careerData?.status_pegawai === 'Kontrak' ? 'selected' : '' %>>Pegawai Kontrak</option>
              <option value="Magang" <%= employee.careerData?.status_pegawai === 'Magang' ? 'selected' : '' %>>Magang / Intern</option>
            </select>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Tanggal Mulai Bergabung</label>
            <input type="date" name="tanggal_mulai_bergabung" value="<%= employee.careerData?.tanggal_mulai_bergabung ? new Date(employee.careerData.tanggal_mulai_bergabung).toISOString().split('T')[0] : '' %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Tanggal Berakhir Kontrak</label>
            <input type="date" name="tanggal_berakhir_kontrak" value="<%= employee.careerData?.tanggal_berakhir_kontrak ? new Date(employee.careerData.tanggal_berakhir_kontrak).toISOString().split('T')[0] : '' %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>
        </div>
      </div>


      <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm space-y-6">
        <div class="border-b border-slate-100 pb-3">
          <h3 class="text-sm font-bold text-slate-900">3. Kontak Aktif & Darurat</h3>
          <p class="text-[11px] text-slate-400">Informasi nomor telepon aktif beserta penanggung jawab kondisi darurat.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nomor Telepon Seluler</label>
            <input type="text" name="nomor_telp" value="<%= employee.contactData?.nomor_telp %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5 md:col-span-2">
            <label class="text-[13px] font-bold text-slate-700">Alamat Rumah Tinggal Sesuai KTP</label>
            <textarea name="alamat" rows="2" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all resize-none"><%= employee.contactData?.alamat %></textarea>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nama Kontak Darurat</label>
            <input type="text" name="nama_kontak_darurat" value="<%= employee.contactData?.nama_kontak_darurat %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Hubungan Keluarga</label>
            <input type="text" name="hubungan_kontak_darurat" value="<%= employee.contactData?.hubungan_kontak_darurat %>" placeholder="Contoh: Orang Tua / Istri / Suami" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nomor Telepon Darurat</label>
            <input type="text" name="nomor_kontak_darurat" value="<%= employee.contactData?.nomor_kontak_darurat %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>
        </div>
      </div>


      <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm space-y-6">
        <div class="border-b border-slate-100 pb-3">
          <h3 class="text-sm font-bold text-slate-900">4. Pendidikan Terakhir & Finansial</h3>
          <p class="text-[11px] text-slate-400">Pendidikan terakhir serta akun perbankan untuk payroll gaji bulanan.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Pendidikan Terakhir</label>
            <input type="text" name="pendidikan_terakhir" value="<%= employee.educationData?.pendidikan_terakhir %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nama Institusi / Universitas</label>
            <input type="text" name="institusi_pendidikan" value="<%= employee.educationData?.institusi_pendidikan %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Tahun Kelulusan</label>
            <input type="number" name="tahun_kelulusan" value="<%= employee.educationData?.tahun_kelulusan %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nama Bank Mandat</label>
            <input type="text" name="nama_bank" value="<%= employee.financialData?.nama_bank %>" placeholder="Contoh: BCA / Mandiri / BNI" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nomor Rekening Bank</label>
            <input type="text" name="nomor_rekening" value="<%= employee.financialData?.nomor_rekening %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">Nama Pemilik Rekening</label>
            <input type="text" name="nama_pemilik_rekening" value="<%= employee.financialData?.nama_pemilik_rekening %>" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:bg-white outline-none transition-all" />
          </div>
        </div>
      </div>


      <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-sm space-y-6">
        <div class="border-b border-slate-100 pb-3">
          <h3 class="text-sm font-bold text-slate-900">5. Unggah Berkas Dokumen</h3>
          <p class="text-[11px] text-slate-400">Kosongkan/jangan pilih berkas baru jika Anda tidak berniat mengganti dokumen lama.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-slate-50 border border-slate-200 border-dashed rounded-xl p-4 flex flex-col justify-between">
            <div>
              <label class="text-[13px] font-bold text-slate-700 block mb-1">Update Berkas KTP</label>
              <input type="file" name="file_ktp" class="text-xs file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-200 file:text-slate-700 hover:file:bg-slate-300 cursor-pointer w-full mt-2" />
            </div>
            <% if (employee.documentData?.file_ktp) { %>
              <div class="mt-3 bg-white px-3 py-1.5 border border-slate-200 rounded-lg flex items-center justify-between">
                <span class="text-[11px] text-emerald-600 font-medium truncate">📄 Berkas KTP Tersimpan</span>
                <a href="<%= employee.documentData.file_ktp %>" target="_blank" class="text-[10px] text-slate-500 underline hover:text-slate-900">Lihat File</a>
              </div>
            <% } %>
          </div>

          <div class="bg-slate-50 border border-slate-200 border-dashed rounded-xl p-4 flex flex-col justify-between">
            <div>
              <label class="text-[13px] font-bold text-slate-700 block mb-1">Update Kartu Keluarga (KK)</label>
              <input type="file" name="file_kk" class="text-xs file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-200 file:text-slate-700 hover:file:bg-slate-300 cursor-pointer w-full mt-2" />
            </div>
            <% if (employee.documentData?.file_kk) { %>
              <div class="mt-3 bg-white px-3 py-1.5 border border-slate-200 rounded-lg flex items-center justify-between">
                <span class="text-[11px] text-emerald-600 font-medium truncate">📄 Berkas KK Tersimpan</span>
                <a href="<%= employee.documentData.file_kk %>" target="_blank" class="text-[10px] text-slate-500 underline hover:text-slate-900">Lihat File</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-200">
        <a href="/employee" class="text-xs font-semibold text-slate-600 bg-white border border-slate-200 rounded-xl px-6 py-3 hover:bg-slate-50 transition-all">
          Batal
        </a>
        <button type="submit" class="text-xs font-semibold text-white bg-slate-900 border border-slate-900 rounded-xl px-8 py-3 hover:bg-slate-800 transition-all shadow-sm">
          Simpan Perubahan Data
        </button>
      </div>

    </form>
  </div>

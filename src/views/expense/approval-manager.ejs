<%- layout('layouts/main', { title }) %>

<div class="min-h-screen bg-slate-50/50 p-4 sm:p-8 antialiased">
  <div class="max-w-6xl mx-auto space-y-6 sm:space-y-8">
    
    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Manajemen Klaim', 
        title: 'Approval Klaim Operasional', 
        description: 'Evaluasi substansi pengajuan klaim (reimbursement) pegawai sebelum diteruskan ke bagian keuangan.' 
    }) %>

    <% 
      const activeExpenses = expenses.filter(e => e.status === 'PENDING_MANAGER');
      const historyExpenses = expenses.filter(e => e.status === 'PENDING_FINANCE' || e.status === 'PAID' || e.status === 'REJECTED');
    %>

    <%- include('../partials/_stats-grid', {
      items: [
        { label: 'Perlu Verifikasi', value: activeExpenses.length, unit: 'Berkas', icon: 'fa-solid fa-file-signature', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-amber-50 text-amber-600 border-amber-100' },
        { label: 'Selesai Direview', value: historyExpenses.length, unit: 'Berkas', icon: 'fa-solid fa-check-double', bgClass: 'bg-white border-slate-200/60', iconBoxClass: 'bg-emerald-50 text-emerald-600 border-emerald-100' },
        { label: 'Total Dokumen', value: expenses.length, unit: 'Berkas', icon: 'fa-solid fa-folder-open', bgClass: 'bg-gradient-to-br from-slate-900 to-slate-800 border-slate-800', labelClass: 'text-slate-300', valueClass: 'text-white', unitClass: 'text-slate-400', iconBoxClass: 'bg-white/10 text-white border-transparent' }
      ]
    }) %>

    <%- include('../partials/_tab-nav', {
      tabs: [
        { id: 'active', label: `Antrean Verifikasi (${activeExpenses.length})` },
        { id: 'history', label: `Riwayat Review (${historyExpenses.length})` }
      ]
    }) %>

    <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300">
      
      <div class="hidden lg:block bg-white rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-6 py-4">Pegawai</th>
                <th class="px-6 py-4">Detail Pengajuan</th>
                <th class="px-6 py-4">Tanggal Nota</th>
                <th class="px-6 py-4 text-center">Lampiran</th>
                <th class="px-6 py-4 text-right">Nominal Klaim</th>
                <th class="px-6 py-4 text-center">Aksi Verifikasi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (activeExpenses.length === 0) { %>
                <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400">Belum ada berkas pengajuan baru yang membutuhkan persetujuan.</td></tr>
              <% } else { %>
                <% activeExpenses.forEach(e => { %>
                  <tr class="hover:bg-slate-50/40 transition">
                    <td class="px-6 py-4 font-bold text-slate-900"><%= e.employeeId?.fullName || 'Pegawai' %></td>
                    <td class="px-6 py-4 font-semibold text-slate-800"><%= e.title %></td>
                    <td class="px-6 py-4 text-slate-500 whitespace-nowrap"><%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                    <td class="px-6 py-4 text-center">
                      <% if (!e.proofFile) { %>
                        <span class="inline-flex px-2 py-1 rounded-md text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-200/50 cursor-help" title="Alasan: <%= e.noReceiptReason || 'Tidak ada alasan yang diinput.' %>">
                          Self Declaration ℹ️
                        </span>
                      <% } else { %>
                        <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="group inline-flex items-center gap-1.5 text-[11px] font-medium text-slate-500 hover:text-blue-600 transition-colors">
                          <i class="fa-solid fa-arrow-down-to-bracket text-slate-400 group-hover:text-blue-600 transition-colors"></i>
                          Unduh Nota
                        </a>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></td>
                    <td class="px-6 py-4 text-center">
                      <div class="flex items-center justify-center gap-2">
                        <form action="/expense/<%= e._id %>/approve/manager" method="POST" onsubmit="return confirm('Yakin ingin menyetujui klaim ini?');">
                          <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 hover:bg-blue-600 text-blue-600 hover:text-white text-[11px] font-bold rounded-lg transition-colors cursor-pointer"><i class="fa-solid fa-check"></i> Setujui</button>
                        </form>
                        <form action="/expense/<%= e._id %>/reject/manager" method="POST" onsubmit="return confirm('Yakin ingin MENOLAK klaim ini?');">
                          <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-rose-50 hover:bg-rose-600 text-rose-600 hover:text-white text-[11px] font-bold rounded-lg transition-colors cursor-pointer"><i class="fa-solid fa-xmark"></i> Tolak</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="lg:hidden space-y-4">
        <% if (activeExpenses.length === 0) { %>
          <div class="p-8 text-center text-slate-400 text-xs bg-white border border-dashed border-slate-200 rounded-2xl">
            Belum ada berkas pengajuan baru yang membutuhkan persetujuan.
          </div>
        <% } else { %>
          <% activeExpenses.forEach(e => { %>
            <div class="bg-white rounded-2xl border border-slate-200/70 p-4 shadow-xs space-y-4">
              <div class="flex justify-between items-start gap-3">
                <div class="min-w-0">
                  <span class="text-[9px] uppercase font-bold tracking-wider text-slate-400 block mb-0.5">Pegawai</span>
                  <h3 class="font-bold text-slate-900 text-xs sm:text-sm truncate"><%= e.employeeId?.fullName || 'Pegawai' %></h3>
                </div>
                <div class="text-right shrink-0">
                  <span class="text-[9px] uppercase font-bold tracking-wider text-slate-400 block mb-0.5">Nominal</span>
                  <span class="font-bold text-blue-600 text-xs sm:text-sm tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></span>
                </div>
              </div>
              
              <div class="bg-slate-50/80 rounded-xl p-3 space-y-2.5 border border-slate-100 text-[11px]">
                <div>
                  <span class="text-[9px] uppercase font-bold tracking-wider text-slate-400 block mb-0.5">Detail Pengajuan</span>
                  <p class="font-semibold text-slate-800 leading-normal"><%= e.title %></p>
                </div>
                
                <div class="grid grid-cols-2 gap-3 pt-2 border-t border-slate-200/40">
                  <div>
                    <span class="text-[9px] uppercase font-bold tracking-wider text-slate-400 block mb-0.5">Tanggal Nota</span>
                    <span class="text-slate-600 font-medium"><%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                  </div>
                  <div>
                    <span class="text-[9px] uppercase font-bold tracking-wider text-slate-400 block mb-0.5">Lampiran Berkas</span>
                    <div class="font-medium">
                      <% if (!e.proofFile) { %>
                        <span class="inline-flex px-2 py-0.5 rounded text-[9px] font-bold bg-amber-50 text-amber-700 border border-amber-200/50 cursor-help" title="Alasan: <%= e.noReceiptReason || 'Tidak ada alasan yang diinput.' %>">
                          Self Decl. ℹ️
                        </span>
                      <% } else { %>
                        <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="inline-flex items-center gap-1 text-blue-600 font-bold hover:underline">
                          <i class="fa-solid fa-arrow-down-to-bracket"></i> Unduh
                        </a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-2.5 pt-1">
                <form action="/expense/<%= e._id %>/reject/manager" method="POST" onsubmit="return confirm('Yakin ingin MENOLAK klaim ini?');" class="w-full">
                  <button type="submit" class="w-full inline-flex items-center justify-center gap-1.5 py-2.5 bg-rose-50 hover:bg-rose-600 text-rose-600 hover:text-white text-xs font-bold rounded-xl transition-colors cursor-pointer">
                    <i class="fa-solid fa-xmark"></i> Tolak
                  </button>
                </form>
                <form action="/expense/<%= e._id %>/approve/manager" method="POST" onsubmit="return confirm('Yakin ingin menyetujui klaim ini?');" class="w-full">
                  <button type="submit" class="w-full inline-flex items-center justify-center gap-1.5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold rounded-xl transition-colors cursor-pointer shadow-xs">
                    <i class="fa-solid fa-check"></i> Setujui
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

    </div>

    <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300">
      
      <div class="hidden lg:block bg-white rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/70 text-slate-500 uppercase text-[10px] tracking-wider font-bold border-b border-slate-100">
                <th class="px-6 py-4">Pegawai</th>
                <th class="px-6 py-4">Detail Pengajuan</th>
                <th class="px-6 py-4">Tanggal Nota</th>
                <th class="px-6 py-4 text-center">Lampiran</th>
                <th class="px-6 py-4 text-right">Nominal Klaim</th>
                <th class="px-6 py-4">Status Akhir</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-xs text-slate-700">
              <% if (historyExpenses.length === 0) { %>
                <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400">Belum ada jejak rekam riwayat pemeriksaan klaim dari Anda.</td></tr>
              <% } else { %>
                <% historyExpenses.forEach(e => { %>
                  <tr class="hover:bg-slate-50/40 transition">
                    <td class="px-6 py-4 font-bold text-slate-900"><%= e.employeeId?.fullName %></td>
                    <td class="px-6 py-4 font-semibold text-slate-800"><%= e.title %></td>
                    <td class="px-6 py-4 text-slate-500"><%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                    <td class="px-6 py-4 text-center">
                      <% if (!e.proofFile) { %><span class="text-[11px] text-slate-400 italic">Tanpa Nota</span><% } else { %>
                        <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="group inline-flex items-center gap-1.5 text-[11px] font-medium text-slate-500 hover:text-blue-600 transition-colors"><i class="fa-solid fa-arrow-down-to-bracket text-slate-400 group-hover:text-blue-600 transition-colors"></i> Unduh Nota</a>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></td>
                    <td class="px-6 py-4">
                      <% 
                        const labels = { 'PENDING_FINANCE': 'Diproses Finance', 'PAID': 'Selesai & Lunas', 'REJECTED': 'Ditolak' }; 
                        const texts = { 'PENDING_FINANCE': 'text-blue-600', 'PAID': 'text-emerald-600', 'REJECTED': 'text-rose-600' };
                        const bgs = { 'PENDING_FINANCE': 'bg-blue-50/70', 'PAID': 'bg-emerald-50/70', 'REJECTED': 'bg-rose-50/70' };
                        const borders = { 'PENDING_FINANCE': 'border-blue-200/50', 'PAID': 'border-emerald-200/50', 'REJECTED': 'border-rose-200/50' };
                        const dots = { 'PENDING_FINANCE': 'bg-blue-500', 'PAID': 'bg-emerald-500', 'REJECTED': 'bg-rose-500' };
                      %>
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-medium tracking-wide <%= texts[e.status] %> <%= bgs[e.status] %> <%= borders[e.status] %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= dots[e.status] %> <%= e.status === 'PAID' ? 'animate-pulse' : '' %>"></span>
                        <span><%= labels[e.status] %></span>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="lg:hidden space-y-4">
        <% if (historyExpenses.length === 0) { %>
          <div class="p-8 text-center text-slate-400 text-xs bg-white border border-dashed border-slate-200 rounded-2xl">
            Belum ada jejak rekam riwayat pemeriksaan klaim dari Anda.
          </div>
        <% } else { %>
          <% historyExpenses.forEach(e => { %>
            <div class="bg-white rounded-2xl border border-slate-200/70 p-4 shadow-xs space-y-3.5">
              
              <div class="flex justify-between items-start gap-2">
                <div class="min-w-0">
                  <h3 class="font-bold text-slate-900 text-xs sm:text-sm truncate"><%= e.employeeId?.fullName %></h3>
                  <p class="text-[11px] text-slate-500 font-medium truncate mt-0.5"><%= e.title %></p>
                </div>
                <div class="text-right shrink-0 flex flex-col items-end gap-1.5">
                  <span class="font-bold text-slate-900 text-xs sm:text-sm tabular-nums">Rp <%= e.amount.toLocaleString('id-ID') %></span>
                  
                  <% 
                    const labels = { 'PENDING_FINANCE': 'Diproses Finance', 'PAID': 'Lunas', 'REJECTED': 'Ditolak' }; 
                    const texts = { 'PENDING_FINANCE': 'text-blue-600', 'PAID': 'text-emerald-600', 'REJECTED': 'text-rose-600' };
                    const bgs = { 'PENDING_FINANCE': 'bg-blue-50/70', 'PAID': 'bg-emerald-50/70', 'REJECTED': 'bg-rose-50/70' };
                    const borders = { 'PENDING_FINANCE': 'border-blue-200/50', 'PAID': 'border-emerald-200/50', 'REJECTED': 'border-rose-200/50' };
                    const dots = { 'PENDING_FINANCE': 'bg-blue-500', 'PAID': 'bg-emerald-500', 'REJECTED': 'bg-rose-500' };
                  %>
                  <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[9px] font-bold tracking-wide <%= texts[e.status] %> <%= bgs[e.status] %> <%= borders[e.status] %>">
                    <span class="w-1 h-1 rounded-full <%= dots[e.status] %> <%= e.status === 'PAID' ? 'animate-pulse' : '' %>"></span>
                    <span><%= labels[e.status] %></span>
                  </div>
                </div>
              </div>
              
              <div class="flex items-center justify-between text-[11px] pt-2.5 border-t border-slate-100 text-slate-500 font-medium">
                <span><i class="fa-regular fa-calendar text-slate-400 mr-1"></i> <%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                <div>
                  <% if (!e.proofFile) { %>
                    <span class="italic text-slate-400 text-[10px]">Tanpa Nota</span>
                  <% } else { %>
                    <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="inline-flex items-center gap-1 text-slate-600 hover:text-blue-600 font-bold">
                      <i class="fa-solid fa-arrow-down-to-bracket text-slate-400"></i> Unduh Nota
                    </a>
                  <% } %>
                </div>
              </div>

            </div>
          <% }) %>
        <% } %>
      </div>

    </div>

  </div>
</div>
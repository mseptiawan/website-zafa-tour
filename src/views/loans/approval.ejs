<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] sm:p-6 md:p-10 antialiased pb-24 md:pb-8">
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

    <!-- 1. PAGE HEADER -->
    <div class="border border-slate-200/60 md:border-none md:shadow-none">
      <%- include('../partials/page-header', {
        section: 'Pinjaman',
        module: 'Pinjaman Pegawai',
        title: 'Pusat Administrasi Pinjaman',
        description: 'Pantau pengajuan pinjaman pegawai secara real-time.'
      }) %>
    </div>

    <!-- 2. STATS GRID -->
    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        gridClass: 'grid-cols-2 lg:grid-cols-3',
        items: [
          { 
            label: 'Butuh Persetujuan', 
            value: activeLoans.length + ' Pengajuan', 
            unit: '', 
            icon: 'fa-solid fa-clock-rotate-left', 
            labelClass: '!font-medium text-amber-600', 
            valueClass: '!font-medium text-amber-700', 
            iconBoxClass: 'bg-amber-50 text-amber-500 border border-amber-200/50' 
          },
          { 
            label: 'Selesai Diproses', 
            value: historyLoans.length + ' Pengajuan', 
            unit: '', 
            icon: 'fa-solid fa-circle-check', 
            labelClass: '!font-medium text-slate-400', 
            valueClass: '!font-medium text-slate-800', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          },
          { 
            label: 'Total Transaksi', 
            value: (activeLoans.length + historyLoans.length), 
            unit: 'Berkas', 
            icon: 'fa-solid fa-chart-pie', 
            labelClass: '!font-medium text-slate-500', 
            valueClass: '!font-medium text-slate-900', 
            iconBoxClass: 'bg-slate-100 text-slate-500 border border-slate-200/50' 
          }
        ]
      }) %>
    </div>

    <!-- 3. NAVIGATION TAB STRIP -->
    <div class="flex flex-col gap-3.5 w-full bg-white md:bg-transparent border border-slate-200/50 md:border-none p-4 md:p-0 rounded-2xl md:rounded-none select-none">
      <div class="flex items-center justify-between gap-3 w-full md:hidden">
        <h3 class="text-[14px] font-medium text-slate-800 tracking-tight">Daftar Otorisasi</h3>
      </div>

      <%- include('../partials/_tab-nav', {
        tabs: [
          { id: 'active', label: `Permintaan Aktif (${activeLoans.length})`, isActive: true },
          { id: 'history', label: `Riwayat Persetujuan (${historyLoans.length})`, isActive: false }
        ]
      }) %>
    </div>

    <!-- 4. TAB CONTENTS -->
    <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300 transform translate-y-0">
      <%- include('partials/_loan-table', { loans: activeLoans, type: 'active' }) %>
    </div>

    <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300 transform translate-y-2">
      <%- include('partials/_loan-table', { loans: historyLoans, type: 'history' }) %>
    </div>

  </div>
</div>

<script>
  function switchTab(tabName) {
    // Visibilitas & Animasi Pane Konten
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.add('hidden');
      pane.classList.remove('block', 'opacity-100', 'translate-y-0');
    });

    const activeContent = document.getElementById(`tab-content-${tabName}`);
    if (activeContent) {
      activeContent.classList.remove('hidden');
      activeContent.classList.add('block');
      setTimeout(() => {
        activeContent.classList.add('opacity-100', 'translate-y-0');
      }, 10);
    }

    // Reset Semua Tombol Tab ke Gaya Dasar
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
      btn.classList.add('font-medium', 'text-slate-500');
    });

    // Terapkan Gaya Aktif pada Tab Terpilih
    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    if (activeBtn) {
      activeBtn.classList.remove('font-medium', 'text-slate-500');
      activeBtn.classList.add('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
    }
  }
</script>
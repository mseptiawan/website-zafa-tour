<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">

  <!-- HEADER -->
  <div class="mb-6">

    <h1 class="text-2xl font-semibold">
      Semua Klaim Beban
    </h1>

    <p class="text-sm text-slate-500 mt-1">
      Monitoring seluruh expense claim
    </p>

  </div>

  <!-- TABLE -->
  <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

    <table class="w-full text-sm">

      <thead class="bg-slate-50 text-slate-500">

        <tr>
          <th class="p-3 text-left">Karyawan</th>
          <th class="p-3 text-left">Judul</th>
          <th class="p-3 text-left">Kategori</th>
          <th class="p-3 text-left">Nominal</th>
          <th class="p-3 text-left">Tanggal</th>
          <th class="p-3 text-left">Status</th>
        </tr>

      </thead>

      <tbody>

        <% expenses.forEach(e => { %>

          <tr class="border-t border-slate-100 hover:bg-slate-50">

            <!-- KARYAWAN -->
            <td class="p-3">

              <div class="font-medium">
                <%= e.employeeId?.fullName %>
              </div>


            </td>

            <!-- JUDUL -->
            <td class="p-3">

              <div class="font-medium">
                <%= e.title %>
              </div>

              <div class="text-xs text-slate-400 mt-1">
                <%= e.description || '-' %>
              </div>

            </td>

            <!-- KATEGORI -->
            <td class="p-3">

              <span
                class="px-2 py-1 text-xs rounded-md bg-slate-100 text-slate-700"
              >
                <%= e.category %>
              </span>

            </td>

            <!-- NOMINAL -->
            <td class="p-3 font-semibold">
              Rp <%= e.amount.toLocaleString() %>
            </td>

            <!-- TANGGAL -->
            <td class="p-3 text-slate-500">
              <%= new Date(e.expenseDate).toLocaleDateString() %>
            </td>

            <!-- STATUS -->
            <td class="p-3">

              <% if(e.status === 'PAID') { %>

                <span
                  class="px-2 py-1 text-xs rounded-md bg-emerald-100 text-emerald-700"
                >
                  PAID
                </span>

              <% } else if(e.status === 'PENDING_MANAGER') { %>

                <span
                  class="px-2 py-1 text-xs rounded-md bg-amber-100 text-amber-700"
                >
                  PENDING MANAGER
                </span>

              <% } else { %>

                <span
                  class="px-2 py-1 text-xs rounded-md bg-slate-100 text-slate-700"
                >
                  <%= e.status %>
                </span>

              <% } %>

            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>

</div>
<%- layout('layouts/main', { title }) %>
  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-xl font-bold text-slate-900 mb-6">Persetujuan Berkas Cuti (Role: <%= user.role %>)</h1>

      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden space-y-6 p-6">
        <% if (pendingApprovals.length===0) { %>
          <p class="text-center text-slate-400 py-6 text-xs italic">Antrean persetujuan Anda bersih / kosong</p>
          <% } %>

            <% pendingApprovals.forEach(app=> { %>
              <div class="border border-slate-200 rounded-xl p-4 bg-slate-50/40 grid grid-cols-3 gap-4">
                <div class="space-y-1">
                  <span class="text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-bold">
                    <%= app.leaveId.userId.role %>
                  </span>
                  <h3 class="text-sm font-bold text-slate-800 mt-1">
                    <%= app.leaveId.userId.name %>
                  </h3>
                  <span class="text-xs font-medium text-slate-500 block">
                    <%= app.leaveId.leaveTypeId.name %> (<%= app.leaveId.totalDays %> Hari)
                  </span>
                  <span class="text-[11px] text-slate-400 block">
                    <%= new Date(app.leaveId.startDate).toLocaleDateString('id-ID') %> s/d <%= new
                        Date(app.leaveId.endDate).toLocaleDateString('id-ID') %>
                  </span>
                </div>

                <div class="text-xs text-slate-600 bg-white p-3 rounded-xl border border-slate-100">
                  <strong class="text-[10px] text-slate-400 block uppercase mb-0.5">Alasan Cuti:</strong>
                  "<%= app.leaveId.reason %>"
                </div>

                <form action="/leave/approvals/process/<%= app._id %>" method="POST"
                  class="space-y-2 text-right my-auto">
                  <input type="text" name="note" placeholder="Tulis catatan di sini..."
                    class="w-full border border-slate-200 rounded-lg p-1.5 text-xs focus:outline-blue-600 mb-1">
                  <div class="space-x-1">
                    <button type="submit" name="status" value="APPROVED"
                      class="bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg px-4 py-1.5 text-xs font-bold cursor-pointer">Setujui</button>
                    <button type="submit" name="status" value="REJECTED"
                      class="bg-rose-600 hover:bg-rose-700 text-white rounded-lg px-4 py-1.5 text-xs font-bold cursor-pointer">Tolak</button>
                  </div>
                </form>
              </div>
              <% }) %>
      </div>
    </div>
  </div>
<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">

  <div class="max-w-3xl mx-auto">

    <div class="mb-6">
      <h1 class="text-2xl font-bold text-slate-800">
        Input Sales Visit
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Catat kunjungan toko / pelanggan / prospek
      </p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow border">

      <form action="/sales/visit" method="POST" enctype="multipart/form-data" class="space-y-5">

        <!-- Nama Toko / Customer -->
        <div>
          <label class="text-sm font-medium text-slate-600">Nama Toko / Customer</label>
          <input
            type="text"
            name="customerName"
            class="w-full mt-1 p-3 border rounded-lg"
            required
          />
        </div>

        <!-- Alamat -->
        <div>
          <label class="text-sm font-medium text-slate-600">Alamat</label>
          <input
            type="text"
            name="address"
            class="w-full mt-1 p-3 border rounded-lg"
            required
          />
        </div>

        <!-- Orang yang ditemui -->
        <div>
          <label class="text-sm font-medium text-slate-600">Bertemu Dengan</label>
          <input
            type="text"
            name="meetWith"
            class="w-full mt-1 p-3 border rounded-lg"
            placeholder="Nama owner / staff toko"
            required
          />
        </div>

        <!-- Hasil kunjungan -->
        <div>
          <label class="text-sm font-medium text-slate-600">Hasil Kunjungan</label>
          <textarea
            name="result"
            rows="4"
            class="w-full mt-1 p-3 border rounded-lg"
            placeholder="Contoh: nego harga, presentasi produk, dll"
          ></textarea>
        </div>

        <!-- Foto -->
        <div>
          <label class="text-sm font-medium text-slate-600">Foto Bukti</label>
          <input type="file" name="photo" class="w-full mt-1" />
        </div>

        <!-- Lokasi -->
        <div>
          <label class="text-sm font-medium text-slate-600">Lokasi GPS</label>
          <input type="text" name="location" placeholder="lat,lng (auto nanti bisa GPS)" class="w-full mt-1 p-3 border rounded-lg" />
        </div>

        <!-- BUTTON -->
        <button
          type="submit"
          class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-lg"
        >
          Simpan Kunjungan
        </button>

      </form>

    </div>

  </div>
</div>
<%- layout('layouts/main') -%>

<div class="min-h-screen p-6 lg:p-10 ml-72">

  <!-- HEADER -->
  <div class="mb-8">
    <h1 class="text-2xl font-semibold tracking-tight text-slate-800">
      Tambah Karyawan
    </h1>
    <p class="text-sm text-slate-500 mt-1">
      Isi data karyawan baru dengan lengkap
    </p>
  </div>

  <!-- FORM CARD -->
  <div class="max-w-3xl bg-white border border-slate-200 rounded-2xl shadow-sm p-6 lg:p-8">

    <form method="POST" class="space-y-5">

      <!-- FULL NAME -->
      <div>
        <label class="text-xs text-slate-500">Nama Lengkap</label>
        <input
          name="fullName"
          placeholder="Contoh: Budi Santoso"
          class="mt-1 w-full border border-slate-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 p-3 rounded-xl outline-none transition"
          required
        />
      </div>

      <!-- POSITION -->
      <div>
        <label class="text-xs text-slate-500">Position</label>
        <select
          name="positionId"
          class="mt-1 w-full border border-slate-200 p-3 rounded-xl focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition"
          required
        >
          <option value="">Pilih Position</option>
          <% positions.forEach(p => { %>
            <option value="<%= p._id %>"><%= p.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- UNIT + BIDANG -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

        <div>
          <label class="text-xs text-slate-500">Unit</label>
          <select
            name="unitId"
            class="mt-1 w-full border border-slate-200 p-3 rounded-xl"
          >
            <option value="">Pilih Unit</option>
            <% units.forEach(u => { %>
              <option value="<%= u._id %>"><%= u.name %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="text-xs text-slate-500">Bidang</label>
          <select
            name="bidangId"
            class="mt-1 w-full border border-slate-200 p-3 rounded-xl"
          >
            <option value="">Pilih Bidang</option>
            <% bidang.forEach(b => { %>
              <option value="<%= b._id %>"><%= b.name %></option>
            <% }) %>
          </select>
        </div>

      </div>

      <!-- STATUS -->
      <div>
        <label class="text-xs text-slate-500">Status Karyawan</label>
        <select
          name="employmentStatus"
          class="mt-1 w-full border border-slate-200 p-3 rounded-xl"
          required
        >
          <option value="">Status Karyawan</option>
          <option value="Tetap">Tetap</option>
          <option value="Kontrak">Kontrak</option>
          <option value="Magang">Magang</option>
        </select>
      </div>

      <!-- GENDER -->
      <div>
        <label class="text-xs text-slate-500">Jenis Kelamin</label>
        <div class="mt-2 flex gap-6 text-sm">
          <label class="flex items-center gap-2">
            <input type="radio" name="gender" value="Laki-Laki" required />
            Laki-Laki
          </label>

          <label class="flex items-center gap-2">
            <input type="radio" name="gender" value="Perempuan" />
            Perempuan
          </label>
        </div>
      </div>

      <!-- PHONE -->
      <div>
        <label class="text-xs text-slate-500">No HP</label>
        <input
          name="phoneNumber"
          placeholder="08xxxxxxxxxx"
          class="mt-1 w-full border border-slate-200 p-3 rounded-xl"
        />
      </div>

      <!-- ADDRESS -->
      <div>
        <label class="text-xs text-slate-500">Alamat</label>
        <textarea
          name="address"
          rows="3"
          placeholder="Alamat lengkap"
          class="mt-1 w-full border border-slate-200 p-3 rounded-xl"
        ></textarea>
      </div>

      <!-- BUTTON -->
      <div class="pt-2">
        <button
          class="w-full lg:w-auto px-6 py-3 bg-slate-900 hover:bg-slate-500 text-white rounded-xl transition font-medium"
        >
          Simpan Karyawan
        </button>
      </div>

    </form>

  </div>

</div>
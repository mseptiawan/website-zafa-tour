<% layout('layouts/main') -%>

<div class="max-w-3xl mx-auto p-6">
  <div class="bg-white p-8 rounded-2xl shadow">
    <h1 class="text-2xl font-bold mb-6">Ajukan Lembur</h1>

    <form
      action="/overtime/apply"
      method="POST"
      enctype="multipart/form-data"
      class="space-y-5"
    >
      <input
        type="date"
        name="date"
        class="w-full border p-3 rounded-xl"
        required
      />

      <div class="grid grid-cols-2 gap-4">
        <input
          type="time"
          name="startTime"
          class="w-full border p-3 rounded-xl"
          required
        />

        <input
          type="time"
          name="endTime"
          class="w-full border p-3 rounded-xl"
          required
        />
      </div>

      <textarea
        name="workDescription"
        placeholder="Pekerjaan yang dilakukan"
        class="w-full border p-3 rounded-xl"
        required
      ></textarea>

      <textarea
        name="result"
        placeholder="Hasil pekerjaan"
        class="w-full border p-3 rounded-xl"
      ></textarea>

      <input
        type="file"
        name="proofFile"
        class="w-full border p-3 rounded-xl"
      />

      <button
        class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl"
      >
        Kirim Pengajuan
      </button>
    </form>
  </div>
</div>

<!-- LEAVE MENU -->
<div id="leaveMenuMobile" class="fixed inset-0 z-[9999] hidden bg-slate-950/30 md:hidden transition-opacity duration-200" onclick="toggleLeaveMenuMobile()">
  <div class="absolute bottom-0 inset-x-0 bg-white rounded-t-3xl p-6 shadow-2xl space-y-4 transform translate-y-full transition-transform duration-200" onclick="event.stopPropagation()">
    <div class="w-12 h-1 bg-slate-200 rounded-full mx-auto mb-2" onclick="toggleLeaveMenuMobile()"></div>
    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Menu Pengajuan Cuti</h3>
    <div class="grid grid-cols-2 gap-3 pt-2">
      <% if (typeof user !== 'undefined' && user?.permissions?.leave_new) { %>
      <a href="/leave/apply" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-indigo-50 border border-slate-100 text-center gap-2 transition-colors"><div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center"><i class="fa-solid fa-calendar-plus text-sm"></i></div><span class="text-xs font-bold text-slate-700">Ajukan Cuti</span></a>
      <% } %>
      <% if (typeof user !== 'undefined' && user?.permissions?.leave_my) { %>
      <a href="/leave/me" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-indigo-50 border border-slate-100 text-center gap-2 transition-colors"><div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center"><i class="fa-solid fa-clock-rotate-left text-sm"></i></div><span class="text-xs font-bold text-slate-700">Riwayat Saya</span></a>
      <% } %>
      <% if (typeof user !== 'undefined' && user?.permissions?.leave_delegation) { %>
      <a href="/leave/my-delegations" class="col-span-2 flex items-center gap-3 p-4 rounded-2xl bg-slate-50 hover:bg-indigo-50 border border-slate-100 text-left transition-colors">
        <div class="w-10 h-10 rounded-xl bg-indigo-100/50 text-indigo-700 flex items-center justify-center shrink-0"><i class="fa-solid fa-hands-sharing text-sm"></i></div>
        <div>
          <span class="text-xs font-bold text-slate-800 block">Permintaan Delegasi</span>
          <span class="text-[10.5px] text-slate-500 font-medium leading-none">Konfirmasi pengalihan tugas dari rekan kerja</span>
        </div>
      </a>
      <% } %>
      <% if (typeof user !== 'undefined' && user?.permissions?.leave_manage) { %>
      <a href="/leave/manage-requests" class="col-span-2 flex items-center gap-3 p-4 rounded-2xl bg-amber-50/60 hover:bg-amber-50 border border-amber-100 text-left transition-colors">
        <div class="w-10 h-10 rounded-xl bg-amber-500 text-white flex items-center justify-center shrink-0 shadow-sm"><i class="fa-solid fa-user-shield text-sm"></i></div>
        <div>
          <span class="text-xs font-bold text-slate-800 block">Manajemen & Persetujuan Cuti</span>
          <span class="text-[10.5px] text-slate-500 font-medium leading-none">Validasi kuota harian dan verifikasi dokumen pengajuan staf</span>
        </div>
      </a>
      <% } %>
    </div>
  </div>
</div>

<!-- PERMIT MENU -->
<div id="permitMenuMobile" class="fixed inset-0 z-[9999] hidden bg-slate-950/30 md:hidden transition-opacity duration-200 opacity-0" onclick="togglePermitMenuMobile()">
  <div class="absolute bottom-0 inset-x-0 bg-white rounded-t-3xl p-6 shadow-2xl space-y-4 transform translate-y-full transition-transform duration-200" onclick="event.stopPropagation()">
    <div class="w-12 h-1 bg-slate-200 rounded-full mx-auto mb-2" onclick="togglePermitMenuMobile()"></div>
    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Menu Administrasi Izin</h3>
    <div class="grid grid-cols-2 gap-3 pt-2">
      <% if (typeof user !== 'undefined' && user?.permissions?.permit_new) { %>
      <a href="/permit/new" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-indigo-50 border border-slate-100 text-center gap-2 transition-colors"><div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center"><i class="fa-solid fa-file-circle-plus text-sm"></i></div><span class="text-xs font-bold text-slate-700">Buat Pengajuan</span></a>
      <% } %>
      <% if (typeof user !== 'undefined' && user?.permissions?.permit_my) { %>
      <a href="/permit/history" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-indigo-50 border border-slate-100 text-center gap-2 transition-colors"><div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center"><i class="fa-solid fa-clock-rotate-left text-sm"></i></div><span class="text-xs font-bold text-slate-700">Riwayat Pengajuan</span></a>
      <% } %>
      <% if (typeof user !== 'undefined' && user?.role === 'WAKIL_DIREKTUR') { %>
      <a href="/permit/incoming" class="col-span-2 flex items-center gap-3 p-4 rounded-2xl bg-amber-50/60 hover:bg-amber-50 border border-amber-100 text-left transition-colors">
        <div class="w-10 h-10 rounded-xl bg-amber-500 text-white flex items-center justify-center shrink-0 shadow-sm"><i class="fa-solid fa-user-shield text-sm"></i></div>
        <div>
          <span class="text-xs font-bold text-slate-800 block">Persidangan & Persetujuan Izin</span>
          <span class="text-[10.5px] text-slate-500 font-medium leading-tight block mt-0.5">Otorisasi dokumen dinas luar, penugasan, dan verifikasi berkas staf.</span>
        </div>
      </a>
      <% } %>
    </div>
  </div>
</div>
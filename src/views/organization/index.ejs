<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] md:p-10 antialiased selection:bg-slate-100 pb-24 md:pb-8 text-slate-800 rounded-2xl overflow-hidden">
  
  <div class="w-full max-w-none mx-auto">

    <div class="mb-6 border-b border-slate-200/60 pb-5">
      <%- include('../partials/page-header', {
        section: 'Area Kerja',
        module: 'Bidang & Unit',
        title: 'Bidang & Unit',
        description: 'Kelola master data Bidang, Sub-Unit Kerja, dan Jabatan secara efisien dalam satu halaman.'
      }) %>

    <div class="w-full">
        <%- include('../partials/_stats-grid', {
          items: [
            {
              label: 'Total Bidang Induk',
              value: '0',
              valueId: 'stat-total-bidang', 
              unit: 'Bidang',
              icon: 'fa-solid fa-sitemap',
              bgClass: 'bg-white border-slate-200/60',
              iconBoxClass: 'bg-blue-50 text-blue-600 border border-blue-100',
              labelClass: 'text-slate-400' 
            },
            {
              label: 'Total Sub-Unit Kerja',
              value: '0',
              valueId: 'stat-total-unit', 
              unit: 'Tersebar',
              icon: 'fa-solid fa-cubes',
              bgClass: 'bg-white border-slate-200/60',
              iconBoxClass: 'bg-indigo-50 text-indigo-600 border border-indigo-100',
              labelClass: 'text-slate-400'
            },
          {
              label: 'Jabatan',
              value: '0',
              valueId: 'stat-total-jabatan',
              unit: 'Level Karier',
              icon: 'fa-solid fa-briefcase',
              bgClass: 'bg-white border-slate-200/60', 
              labelClass: 'text-slate-400',
              valueClass: 'text-slate-900',
              unitClass: 'text-slate-500',
              iconBoxClass: 'bg-emerald-50 text-emerald-600 border border-emerald-100' 
            }
          ]
        }) %>
      </div>
   <div class="mb-5 mt-10">
        <%- include('../partials/_tab-nav', {
          tabs: [
            { id: 'bidang', label: 'Bidang Induk' },
            { id: 'unit', label: 'Sub-Unit Kerja' },
            { id: 'jabatan', label: 'Jabatan' }
          ]
        }) %>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        
        <div class="lg:col-span-5">
          <div class="bg-white border border-slate-200/60 p-5 rounded-xl">
            <%- include('./partials/form-bidang') %>
            <%- include('./partials/form-unit') %>
            <%- include('./partials/form-jabatan') %>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="bg-white border border-slate-200/60 rounded-xl overflow-hidden">
            <%- include('./partials/table-bidang') %>
            <%- include('./partials/table-unit') %>
            <%- include('./partials/table-jabatan') %>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<script>
  window.listBidang = <%- JSON.stringify(listBidang) %>;
  window.listUnit = <%- JSON.stringify(listUnit) %>;
  window.listJabatan = <%- JSON.stringify(listPosition) %>; 
  
  window.flashMessage = {
    success: '<%= (typeof success !== "undefined" && success.length > 0) ? success[0] : "" %>',
    error: '<%= (typeof error !== "undefined" && error.length > 0) ? error[0] : "" %>'
  };
</script>

<script src="/js/organization.js"></script>
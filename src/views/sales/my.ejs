<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50 md:bg-[#FCFCFD]  antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 pb-5 mb-6 border-b border-slate-200/60 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header', { 
            section: 'Area Kerja', 
            module: 'Sales', 
            title: 'Riwayat Kunjungan', 
            description: 'Daftar pelacakan dan laporan kunjungan klien yang telah Anda lakukan.' 
        }) %>
      </div>
      
    <div class="shrink-0 flex items-center justify-end gap-2">
  <% if (visits && visits.length > 0) { %>
    <a href="/sales/my/export-pdf" title="Export PDF" class="inline-flex items-center justify-center bg-white hover:bg-slate-50 border border-slate-200 text-slate-700 h-9 w-9 sm:w-auto sm:px-4 rounded-xl text-[11px] font-semibold transition-all shadow-3xs active:scale-[0.98] decoration-none flex-shrink-0">
      <svg class="w-3.5 h-3.5 text-slate-400 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <span class="hidden sm:inline ml-1.5">Export PDF</span>
    </a>
  <% } %>

  <a href="/sales/new" class="inline-flex items-center justify-center gap-1 bg-blue-600 hover:bg-blue-700 text-white h-9 px-4 rounded-xl text-[11px] font-semibold transition-all shadow-3xs active:scale-[0.98] decoration-none flex-shrink-0">
    <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    <span class="hidden sm:inline">Catat Kunjungan</span>
    <span class="sm:hidden">Baru</span>
  </a>
</div>
    </div>

    <% if (!visits || visits.length === 0) { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl py-12 text-center shadow-3xs px-4">
        <div class="w-10 h-10 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-3.5 text-slate-400">
          <svg class="h-5 w-5 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Data Kunjungan</p>
        <p class="text-[11.5px] text-slate-400 max-w-xs mx-auto mt-0.5 leading-relaxed">Semua log riwayat kunjungan sales ke merchant atau klien akan tercatat di sini.</p>
      </div>
    <% } else { %>

      <div class="grid grid-cols-1 gap-3 md:block md:bg-white md:border md:border-slate-200/60 md:rounded-2xl md:p-1.5 md:shadow-3xs md:divide-y md:divide-slate-100/80">
        <% visits.forEach(v => { %>
          
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 md:bg-transparent md:border-none md:rounded-none md:p-5 flex flex-col gap-3.5 shadow-3xs md:shadow-none">
            
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1 space-y-1">
                <h2 class="text-[14px] font-bold tracking-tight text-slate-800 break-words">
                  <%= v.title %>
                </h2>
                
                <div class="flex items-start gap-1.5 text-slate-400 font-medium">
                  <svg class="w-3.5 h-3.5 text-slate-400 flex-shrink-0 mt-0.5 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <p class="text-[12px] leading-relaxed text-slate-400 font-medium line-clamp-1 pr-4">
                    <%= v.address %>
                  </p>
                </div>
              </div>

              <div class="flex-shrink-0 pt-0.5">
                <% const diffHours = (new Date() - new Date(v.createdAt)) / (1000 * 60 * 60); %>
                <% if (diffHours <= 24) { %>
                  <a href="/sales/<%= v._id %>/edit" title="Ubah data kunjungan" class="w-7 h-7 rounded-lg bg-slate-50 hover:bg-slate-100 border border-slate-200/40 text-slate-400 hover:text-slate-700 flex items-center justify-center transition-all shadow-3xs active:scale-95 decoration-none">
                    <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                    </svg>
                  </a>
                <% } else { %>
                  <div class="w-7 h-7 flex items-center justify-center text-slate-300" title="Akses edit telah terkunci (>24 jam)">
                    <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                  </div>
                <% } %>
              </div>
            </div>

            <% if (v.result) { %>
              <div class="bg-slate-50/60 border border-slate-100 p-2.5 rounded-xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Hasil Kunjungan</p>
                <p class="text-[12px] text-slate-600 leading-relaxed break-words whitespace-pre-line"><%= v.result %></p>
              </div>
            <% } %>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 pt-3.5 border-t border-slate-100/80">
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[11.5px] font-semibold text-slate-400">
                <div>
                  PIC: <span class="text-slate-600 font-bold"><%= v.meetWith %></span>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="h-1 w-1 rounded-full bg-slate-200 hidden sm:block"></span>
                  Waktu: <span class="text-slate-600 font-bold">
                    <%= new Date(v.visitTime).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" }) %>
                  </span>
                </div>
              </div>

              <div class="flex items-center gap-2 justify-end">
                <% if (v.attachments && v.attachments.length > 0 && v.attachments[0].filename) { %>
                  <a href="/uploads/files/<%= v.attachments[0].filename %>" target="_blank" class="inline-flex items-center gap-1 bg-blue-50 hover:bg-blue-100 text-blue-600 rounded-lg px-2 py-1 text-[11px] font-bold transition-colors decoration-none">
                    <svg class="w-3 h-3 stroke-[2.5] text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.414a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                    </svg>
                    <span>Lampiran</span>
                  </a>
                <% } %>
              </div>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %> 

    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-end mt-8 w-full border-t border-slate-200/60 pt-4 select-none">
        <div class="flex items-center gap-4">
          <a href="?page=<%= pagination.page - 1 %>" class="py-1 text-[11.5px] font-bold transition-colors flex items-center gap-1 decoration-none <%= pagination.hasPrev ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %>">
            <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Prev
          </a>

          <a href="?page=<%= pagination.page + 1 %>" class="py-1 text-[11.5px] font-bold transition-colors flex items-center gap-1 decoration-none <%= pagination.hasNext ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %>">
            Next
            <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    <% } %>
  </div>
</div>
<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] antialiased selection:bg-slate-100 px-4 sm:p-6 md:p-10 pb-24 md:pb-8 text-slate-800 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 pb-5 mb-6 border-b border-slate-200/60 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header', { 
            section: 'Area Kerja', 
            module: 'Management', 
            title: 'Kunjungan Sales Pegawai', 
            description: 'Pantau dan evaluasi seluruh log riwayat kunjungan sales yang dilakukan oleh staf lapangan.' 
        }) %>
      </div>
    </div>

    <% if (!visits || visits.length === 0) { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl py-16 text-center shadow-3xs px-4">
        <div class="w-10 h-10 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-3.5 text-slate-400">
          <svg class="h-5 w-5 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
        </div>
        <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Riwayat Kunjungan Pegawai</p>
        <p class="text-[11.5px] text-slate-400 max-w-xs mx-auto mt-0.5 leading-relaxed">Seluruh data laporan peninjauan merchant atau klien dari tim sales belum terekam.</p>
      </div>
    <% } else { %>

      <div class="space-y-4 w-full">
        <% visits.forEach(v => { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 sm:p-5 flex flex-col gap-4 shadow-3xs hover:border-slate-300/80 transition-all duration-150">
            
            <div class="flex items-center gap-2 pb-1.5 border-b border-slate-100/70 select-none">
              <div class="w-6 h-6 rounded-md bg-blue-50 border border-blue-100 flex items-center justify-center text-[10px] font-bold text-blue-600 uppercase">
                <%= v.userId?.employeeData?.fullName ? v.userId.employeeData.fullName.charAt(0) : '?' %>
              </div>
              <span class="text-[11.5px] font-semibold text-slate-400">
                Oleh Sales: <span class="text-blue-600 font-bold"><%= v.userId?.employeeData?.fullName || 'Anonim / User Seeder' %></span>
              </span>
            </div>

            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1 space-y-1.5">
                <h2 class="text-[13.5px] sm:text-[14px] font-bold tracking-tight text-slate-800 break-words leading-snug">
                  <%= v.title %>
                </h2>
                
                <div class="flex items-start gap-1.5 text-slate-400">
                  <svg class="w-3.5 h-3.5 text-slate-400 flex-shrink-0 mt-0.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  <p class="text-[12px] leading-relaxed text-slate-500 font-medium break-words">
                    <%= v.address %>
                  </p>
                </div>
              </div>
            </div>

            <% if (v.result) { %>
              <div class="bg-slate-50/70 border border-slate-200/40 p-3 rounded-xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Hasil Kunjungan</p>
                <p class="text-[12px] text-slate-600 leading-relaxed break-words whitespace-pre-line"><%= v.result %></p>
              </div>
            <% } %>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 pt-3.5 border-t border-slate-100">
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[11.5px] font-semibold text-slate-400">
                <div class="text-slate-500">
                  PIC Klien: <span class="text-slate-700 font-bold"><%= v.meetWith %></span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="h-1 w-1 rounded-full bg-slate-300 hidden sm:block"></span>
                  Waktu Kunjungan: <span class="text-slate-700 font-bold">
                    <%= new Date(v.visitTime).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" }) %>
                  </span>
                </div>
              </div>

              <div class="flex items-center gap-2 justify-end select-none">
                <% if (v.attachments && v.attachments.length > 0 && v.attachments[0].filename) { %>
                  <a href="/uploads/files/<%= v.attachments[0].filename %>" target="_blank" class="inline-flex items-center gap-1.5 bg-blue-50/70 hover:bg-blue-100 text-blue-600 rounded-lg px-2.5 py-1 text-[11px] font-bold transition-colors decoration-none border border-blue-100/40">
                    <svg class="w-3 h-3 stroke-[2.5] text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.414a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                    </svg>
                    <span>Lihat Lampiran</span>
                  </a>
                <% } %>
              </div>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %> 

    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-end mt-8 w-full border-t border-slate-200/60 pt-4 select-none">
        <div class="flex items-center gap-5">
          <a href="?page=<%= pagination.page - 1 %>" class="py-1 text-[11.5px] font-bold transition-colors flex items-center gap-1 decoration-none <%= pagination.hasPrev ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %>">
            <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Prev
          </a>

          <a href="?page=<%= pagination.page + 1 %>" class="py-1 text-[11.5px] font-bold transition-colors flex items-center gap-1 decoration-none <%= pagination.hasNext ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %>">
            Next
            <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    <% } %>
  </div>
</div>


<%- layout('layouts/main', { title }) %>

<style>
  #invoice-print-zone { display: none; }
  @media print {
    html, body, body * { visibility: hidden !important; background: transparent !important; }
    #invoice-print-zone, #invoice-print-zone * { visibility: visible !important; }
    #invoice-print-zone {
      display: block !important; position: absolute !important;
      left: 0 !important; top: 0 !important; width: 100% !important;
      max-width: 100% !important; margin: 0 !important; padding: 0 !important;
      border: none !important; box-shadow: none !important; color: black !important;
    }
    .yellow-header-badge {
      background-color: #facc15 !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color: black !important;
    }
  }
  .yellow-header-badge { background-color: #facc15; color: black; }
</style>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50 md:bg-[#FCFCFD] md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 pb-5 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header', { 
            section: 'Area Kerja', 
            module: 'Keuangan', 
            title: 'Riwayat Slip Gaji', 
            description: 'Daftar dokumen slip pendapatan resmi Anda di PT Zafa Mulia Mandiri' 
        }) %>
      </div>
    </div>

    <% if (!payrolls || payrolls.length === 0) { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl py-16 text-center shadow-3xs px-4 no-print">
        <div class="w-10 h-10 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-3.5 text-slate-400">
          <i class="fa-solid fa-receipt text-lg"></i>
        </div>
        <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Riwayat Slip Gaji</p>
        <p class="text-[11.5px] text-slate-400 max-w-xs mx-auto mt-0.5 leading-relaxed">Belum ada riwayat dokumen slip gaji yang diterbitkan untuk akun Anda saat ini.</p>
      </div>
    <% } else { %>

      <div class="no-print grid grid-cols-1 gap-3 md:block md:bg-white md:border md:border-slate-200/60 md:rounded-2xl md:p-1.5 md:shadow-3xs md:divide-y md:divide-slate-100/80">
        <% payrolls.forEach((pay, index) => { %>
          
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 md:bg-transparent md:border-none md:rounded-none md:p-4 hover:bg-slate-50/60 transition-all flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 select-none shadow-3xs md:shadow-none">
            
            <div class="flex items-center gap-3.5 min-w-0">
              <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-400 shrink-0 shadow-3xs">
                <i class="fa-solid fa-file-invoice-dollar text-[14px]"></i>
              </div>
              
              <div class="space-y-0.5 min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-[13px] font-bold text-slate-800 tracking-tight">Periode <%= pay.periodMonth %></span>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-emerald-50 text-emerald-600 border border-emerald-100/50">
                    <span class="h-1 w-1 rounded-full bg-emerald-500"></span> PAID
                  </span>
                </div>
                <div class="text-[12px] text-slate-400 font-medium">
                  Take Home Pay: <span class="font-bold text-slate-700">Rp <%= pay.netTakeHomePay.toLocaleString('id-ID') %></span>
                </div>
              </div>
            </div>
            
            <div class="flex items-center justify-end gap-2 shrink-0 pt-2 sm:pt-0">
              <% if (pay.status === 'PAID' && pay.mutationFile) { %>
                <a href="<%= pay.mutationFile %>" target="_blank" 
                   class="bg-slate-100 hover:bg-slate-200 text-slate-600 text-[11px] font-bold h-8.5 px-3 rounded-xl transition-all border-none flex-1 sm:flex-none inline-flex items-center justify-center gap-1.5 active:scale-[0.98] decoration-none">
                  <i class="fa-solid fa-cloud-download text-[10px] text-slate-400"></i> Bukti TF
                </a>
              <% } else if (pay.status === 'PAID') { %>
                <span class="text-[11px] text-slate-400 font-medium px-2 hidden sm:inline-block">Processed by Bank</span>
              <% } %>

              <button type="button" onclick="executePrintSlip(<%= index %>)" 
                      class="bg-blue-50 hover:bg-blue-100 text-blue-600 text-[11px] font-bold h-8.5 px-4 rounded-xl transition-all cursor-pointer flex items-center justify-center gap-1.5 border-none flex-1 sm:flex-none active:scale-[0.98] outline-none">
                <i class="fa-solid fa-print text-[10px] text-blue-500"></i> Cetak Slip
              </button>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>

    <div id="invoice-print-zone" class="bg-white p-2 space-y-6 text-black"></div>

  </div>
</div>


<script>
  const payrollsList = <%- JSON.stringify(payrolls) %>;
  const employeeProfile = <%- JSON.stringify(employee) %>;

  function executePrintSlip(index) {
    const payroll = payrollsList[index];
    if (!payroll) return;

    const overtimePay = payroll.overtime?.amount || 0;

    let allowancesRowsHTML = '';
    payroll.allowances.forEach(allow => {
      allowancesRowsHTML += `
        <tr class="h-7">
          <td class="p-1.5 font-normal">${allow.componentName}</td>
          <td class="p-1.5 text-right border-l border-black font-normal">Rp ${Number(allow.amount).toLocaleString('id-ID')}</td>
        </tr>`;
    });
    if (payroll.allowances.length < 1) {
      allowancesRowsHTML += `<tr class="h-7"><td>&nbsp;</td><td class="border-l border-black"></td></tr>`;
    }

    let deductionsRowsHTML = '';
    payroll.deductions.forEach(ded => {
      deductionsRowsHTML += `
        <tr class="h-7">
          <td class="p-1.5 font-normal">${ded.componentName}</td>
          <td class="p-1.5 text-right border-l border-black font-normal">Rp ${Number(ded.amount).toLocaleString('id-ID')}</td>
        </tr>`;
    });
    if (payroll.loanDeduction && payroll.loanDeduction.amount > 0) {
      deductionsRowsHTML += `
        <tr class="h-7">
          <td class="p-1.5 font-normal">Cicilan Pinjaman</td>
          <td class="p-1.5 text-right border-l border-black font-normal">Rp ${Number(payroll.loanDeduction.amount).toLocaleString('id-ID')}</td>
        </tr>`;
    }
    const totalDedCount = payroll.deductions.length + (payroll.loanDeduction?.amount > 0 ? 1 : 0);
    for (let i = totalDedCount; i < 2; i++) {
      deductionsRowsHTML += `<tr class="h-7"><td>&nbsp;</td><td class="border-l border-black"></td></tr>`;
    }

    const joinDateRaw = employeeProfile.careerData?.tanggal_mulai_bergabung ? new Date(employeeProfile.careerData.tanggal_mulai_bergabung).toLocaleDateString('id-ID', {day: '2-digit', month: 'long', year: 'numeric'}) : '-';

    const finalPrintTemplate = `
      <div class="flex justify-between items-start">
        <div class="border border-black px-6 py-1 mt-2">
          <span class="text-xs font-normal tracking-wide" style="color: #f43f5e;">Pribadi & Rahasia</span>
        </div>
        <div class="text-center space-y-0.5">
          <div class="inline-flex flex-col items-center justify-center">
            <span class="text-2xl font-normal tracking-tighter" style="font-family: 'Times New Roman', Times, serif;">ZM</span>
            <span class="text-[8px] font-normal tracking-widest uppercase -mt-1">ZAFA TOUR</span>
          </div>
          <div class="text-[10px] font-normal uppercase tracking-tight">Zafa Mulia Mandiri</div>
        </div>
      </div>

      <div class="pt-1">
        <h2 class="text-xs font-normal">PT Zafa Mulia Mandiri</h2>
      </div>

      <div class="space-y-0.5">
        <h3 class="text-xs font-normal">Slip Gaji</h3>
        <p class="text-xs font-normal">Periode : ${payroll.periodMonth}</p>
      </div>

      <div class="grid grid-cols-2 gap-x-12 text-xs pt-2">
        <table class="w-full border-none">
          <tr class="h-5">
            <td class="w-28 font-normal">Nama</td>
            <td class="w-3">:</td>
            <td class="font-normal">${employeeProfile.fullName}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">ID Pegawai</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.employeeIdNumber}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Bagian</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.careerData?.bidangId?.name || 'BOD'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Job Title</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.careerData?.positionId?.name || 'Staff'}</td>
          </tr>
        </table>

        <table class="w-full border-none">
          <tr class="h-5">
            <td class="w-32 font-normal">Golongan</td>
            <td class="w-3">:</td>
            <td class="font-normal">${employeeProfile.careerData?.unitId?.name || 'Marketing'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Status Pegawai</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.careerData?.status_pegawai || 'Pegawai Tetap'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Status PTKP</td>
            <td>:</td>
            <td class="font-normal">TK0</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Tanggal Bergabung</td>
            <td>:</td>
            <td class="font-normal">${joinDateRaw}</td>
          </tr>
        </table>
      </div>

      <div class="grid grid-cols-2 gap-6 items-start pt-4">
        <div class="border border-black">
          <table class="w-full text-xs text-left border-collapse">
            <thead>
              <tr class="yellow-header-badge border-b border-black">
                <th class="p-1.5 font-normal">Komponen Pendapatan</th>
                <th class="p-1.5 text-center border-l border-black font-normal w-28">Jumlah</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black">
              <tr class="h-7">
                <td class="p-1.5 font-normal">Upah Pokok</td>
                <td class="p-1.5 text-right border-l border-black font-normal">Rp ${Number(payroll.basicSalary).toLocaleString('id-ID')}</td>
              </tr>
              ${overtimePay > 0 ? `
                <tr class="h-7">
                  <td class="p-1.5 font-normal">Upah Kerja Lembur</td>
                  <td class="p-1.5 text-right border-l border-black font-normal">Rp ${Number(overtimePay).toLocaleString('id-ID')}</td>
                </tr>` : ''
              }
              ${allowancesRowsHTML}
              <tr class="h-7 border-t border-black bg-slate-50/20">
                <td class="p-1.5 font-semibold">Total Pendapatan</td>
                <td class="p-1.5 text-right border-l border-black font-semibold">Rp ${Number(payroll.totalEarnings + overtimePay).toLocaleString('id-ID')}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="border border-black">
          <table class="w-full text-xs text-left border-collapse">
            <thead>
              <tr class="yellow-header-badge border-b border-black">
                <th class="p-1.5 font-normal">Komponen Potongan</th>
                <th class="p-1.5 text-center border-l border-black font-normal w-28">Jumlah</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black">
              ${deductionsRowsHTML}
              <tr class="h-7 border-t border-black bg-slate-50/20">
                <td class="p-1.5 font-semibold">Total Potongan</td>
                <td class="p-1.5 text-right border-l border-black font-semibold">Rp ${Number(payroll.totalDeductions).toLocaleString('id-ID')}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="pt-4 flex justify-between items-start text-xs">
        <table class="w-auto border-none">
          <tr class="h-5">
            <td class="w-36 font-normal">Nama Bank</td>
            <td class="w-3">:</td>
            <td class="font-normal">${employeeProfile.financialData?.nama_bank || 'BCA'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Nomor Rekening</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.financialData?.nomor_rekening || '-'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Nama Pemilik Rekening</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.financialData?.nama_pemilik_rekening || '-'}</td>
          </tr>
        </table>

        <div class="flex items-center gap-4 pr-6">
          <span class="font-bold">Take Home Pay</span>
          <span>:</span>
          <span class="font-bold text-sm">Rp ${Number(payroll.netTakeHomePay).toLocaleString('id-ID')}</span>
        </div>
      </div>

      <div class="border-b border-black pt-6"></div>

      <div class="flex items-center gap-1.5 text-[9px] font-normal pt-1.5">
        <span style="font-family: 'Times New Roman', Times, serif;">ZM</span>
        <span>PT Zafa Mulia Mandiri</span>
      </div>
    `;

    const printZone = document.getElementById('invoice-print-zone');
    if (printZone) {
      printZone.innerHTML = finalPrintTemplate;
      window.print();
    }
  }
</script>

<%- layout('layouts/main', { title }) %>

<div>
  <div class="mx-auto max-w-none space-y-6">

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white border border-slate-200/60 rounded-2xl p-5 shadow-[0_4px_12px_rgba(0,0,0,0.02)] mb-6">

      <div>
        <h1 class="text-base font-bold tracking-tight text-slate-900">Komponen Payroll</h1>
        <p class="text-[11px] text-slate-400 mt-0.5">Kelola kalkulasi gaji, tunjangan, dan potongan Pegawai aktif</p>
      </div>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 shrink-0">

        <form id="form-tutup-buku" onsubmit="triggerTutupBuku(event)" class="flex items-center gap-3.5 bg-slate-50/50 border border-slate-200/80 p-1.5 pl-3.5 rounded-xl max-w-sm w-full sm:w-auto">
          <div class="text-[10px] text-slate-400 leading-tight hidden sm:block font-medium whitespace-nowrap">
            Kunci transaksi & update pinjaman <br />periode <span class="font-bold text-blue-600"><%= currentPeriod %></span>
          </div>

          <button type="submit" class="bg-slate-950 hover:bg-slate-800 text-white font-bold text-[11px] h-8.5 px-3.5 rounded-xl  transition-all active:scale-[0.98] flex items-center gap-1.5 whitespace-nowrap cursor-pointer">
            <i class="fa-solid fa-lock text-[9px] text-slate-400"></i> Tutup Buku
          </button>
        </form>

        <div class="relative min-w-[140px] sm:w-36">
          <i class="fa-solid fa-calendar-days absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[11px] pointer-events-none"></i>
          <select id="filterPeriod" class="w-full bg-white border border-slate-200 text-[11px] font-bold text-slate-700 rounded-xl pl-8 pr-7 h-11 appearance-none cursor-pointer focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all">
            <% availablePeriods.forEach(p => { %>
            <option value="<%= p %>" <%= p === currentPeriod ? 'selected' : '' %>><%= p %></option>
            <% }) %>
          </select>
          <i class="fa-solid fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-[9px] pointer-events-none"></i>
        </div>

      </div>

    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
      <div class="lg:col-span-3 bg-white border border-slate-200/50 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
        <div class="p-3 bg-white border-b border-slate-100">
          <div class="relative">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
            <input type="text" id="searchEmployeeInput" placeholder="Cari nama Pegawai..." class="w-full bg-[#f2f2f7]/60 border-none rounded-lg px-3 py-1.5 pl-8 text-[13px] focus:outline-none focus:ring-1 focus:ring-blue-500/30 transition-shadow">
          </div>
        </div>

        <div class="divide-y divide-slate-100 max-h-[550px] overflow-y-auto">
          <% employees.forEach((emp, index) => { %>
          <% 
            const empAllowances = savedAllowances
              .filter(allow => allow.employeeId.toString() === emp._id.toString() && allow.componentId?.category === 'EARNING')
              .map(allow => ({
                componentName: allow.componentId?.name,
                amount: allow.amount
              }));

            const empDeductions = savedAllowances
              .filter(allow => allow.employeeId.toString() === emp._id.toString() && allow.componentId?.category === 'DEDUCTION')
              .map(allow => ({
                componentName: allow.componentId?.name,
                amount: allow.amount
              }));
          %>
          <div onclick="switchEmployee(this)" data-id="<%= emp._id %>" data-name="<%= emp.fullName %>" data-nik="<%= emp.employeeIdNumber %>" data-pos="<%= emp.positionId?.name || 'STAFF' %>" data-allowances='<%= JSON.stringify(empAllowances) %>' data-deductions='<%= JSON.stringify(empDeductions) %>' class="employee-card p-4 <%= index === 0 ? 'bg-blue-50/40' : 'hover:bg-slate-50' %> flex items-center justify-between cursor-pointer transition-colors">
            <div>
              <h4 class="text-[13px] font-<%= index === 0 ? 'semibold text-blue-900' : 'medium text-slate-800' %>"><%= emp.fullName %></h4>
              <p class="text-[11px] text-slate-500 mt-0.5">NIK: <%= emp.employeeIdNumber %> • <%= emp.positionId?.name || 'Staff' %></p>
            </div>
            <span class="status-badge text-[11px] font-medium px-2.5 py-0.5 rounded-full bg-slate-100 text-slate-600 transition-colors">
              Draft
            </span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="lg:col-span-9 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        <div class="lg:col-span-7 space-y-6">
          <div class="bg-white border border-slate-200/50 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.03)] overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between bg-white">
              <div>
                <h2 id="empNameTitle" class="text-[14px] font-bold text-slate-900"><%= employees[0]?.fullName %></h2>
                <p id="empMetaTitle" class="text-[11px] text-slate-400">NIK: <%= employees[0]?.employeeIdNumber %> • <%= employees[0]?.positionId?.name || 'Staff' %></p>
              </div>
              <div class="text-right">
                <span class="text-[10px] font-semibold text-slate-400 block uppercase tracking-wide">Periode</span>
                <span id="labelPeriodSummary" class="text-[12px] font-bold text-blue-600"><%= currentPeriod %></span>
              </div>
            </div>

            <div class="p-5 space-y-5">
              <div>
                <label class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide mb-1.5 block">Gaji Pokok</label>
                <div class="relative max-w-xs">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[13px] font-medium text-slate-400">Rp</span>
                  <input type="text" id="inputBasicSalary" oninput="formatRupiahInput(this)" value="0" class="w-full bg-[#f2f2f7]/60 border-none rounded-xl px-3 py-2 pl-9 text-[13px] font-bold text-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all" readonly>
                </div>
              </div>

              <div class="pt-4 border-t border-slate-100">
                <h3 class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide mb-2.5">Tunjangan Dinamis</h3>

                <div id="allowanceWrapper" class="space-y-2 rounded-xl border border-transparent">
                  <div id="overtimeContainer" class="space-y-2"></div>
                  <div id="attendanceAllowanceContainer" class="space-y-2"></div>
                  <div id="allowanceContainer" class="space-y-2"></div>
                </div>

                <div class="mt-4 flex items-center gap-2 w-full max-w-md">
                  <select id="masterAllowanceSelect" class="flex-1 bg-white border border-slate-200 rounded-xl px-3 py-2 text-[12px] font-medium text-slate-600 focus:outline-none focus:border-blue-500 min-h-[38px]">
                    <option value="">-- Pilih Tunjangan --</option>
                    <% dropdownComponents.filter(c => c.category === 'EARNING' && c.name !== 'Tunjangan Konsumsi' ).forEach(comp => { %>
                    <option value="<%= comp.name %>" data-amount="<%= comp.defaultAmount %>"><%= comp.name %></option>
                    <% }) %>
                  </select>
                  <button type="button" onclick="addAllowanceField()" class="text-[12px] font-semibold text-blue-600 bg-blue-50 px-4 py-2 rounded-xl transition-colors hover:bg-blue-100/70 min-h-[38px] whitespace-nowrap">+ Tambah</button>
                </div>
              </div>

              <div class="pt-6 border-t border-slate-100">
                <div class="flex items-center justify-between mb-2.5">
                  <h3 class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide">Potongan / Cicilan</h3>
                  <span class="text-[10px] font-medium text-rose-600 bg-rose-50 px-2 py-0.5 rounded-full">Out / Pengurangan</span>
                </div>

                <div id="deductionContainer" class="space-y-2 rounded-xl border border-transparent"></div>

                <div class="mt-4 flex items-center gap-2 w-full max-w-md">
                  <select id="masterDeductionSelect" class="flex-1 bg-white border border-slate-200 rounded-xl px-3 py-2 text-[12px] font-medium text-slate-600 focus:outline-none focus:border-rose-500 min-h-[38px]">
                    <option value="">-- Pilih Potongan --</option>
                    <% dropdownComponents.filter(c => c.category === 'DEDUCTION').forEach(comp => { %>
                    <option value="<%= comp.name %>" data-amount="<%= comp.defaultAmount %>"><%= comp.name %></option>
                    <% }) %>
                  </select>
                  <button type="button" onclick="addDeductionField()" class="text-[12px] font-semibold text-rose-600 bg-rose-50 px-4 py-2 rounded-xl transition-colors hover:bg-rose-100/70 min-h-[38px] whitespace-nowrap">+ Tambah</button>
                </div>
              </div>
            </div>

            <div class="px-5 py-4 bg-slate-50 border-t border-slate-100 flex justify-end">
              <button id="btnSavePayroll" type="button" onclick="submitPayrollData()" class="px-5 py-2 bg-blue-600 text-white text-[13px] font-semibold rounded-xl transition-colors hover:bg-blue-700">
                Simpan Perubahan
              </button>
            </div>
          </div>
        </div>

        <div class="lg:col-span-5 space-y-6">
          <div class="bg-white border border-slate-200/60 rounded-2xl shadow-[0_8px_20px_rgba(0,0,0,0.03)] p-6 sticky top-6 w-full">
            <h3 class="text-[11px] font-medium text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-3">
              Ringkasan Gaji
            </h3>
            <div class="space-y-3.5 text-[12px]">
              <div class="flex justify-between items-center text-slate-600">
                <span>Gaji Pokok</span>
                <span id="previewBasic" class="font-medium text-slate-800 tracking-tight">Rp 0</span>
              </div>
              <div id="previewOvertimeRow" class="flex justify-between items-center text-blue-600 hidden">
                <span id="previewOvertimeLabel">Uang Lembur</span>
                <span id="previewOvertime" class="font-medium tracking-tight">+Rp 0</span>
              </div>
              <div class="flex flex-col gap-1.5">
                <div class="flex justify-between items-center text-emerald-600">
                  <span>Total Tunjangan</span>
                  <span id="previewEarnings" class="font-medium tracking-tight">+Rp 0</span>
                </div>
                <div id="detailEarningsContainer" class="hidden pl-3 border-l-2 border-emerald-100 space-y-1.5 mt-0.5 w-full"></div>
              </div>
              <div class="flex flex-col gap-1.5">
                <div class="flex justify-between items-center text-rose-500">
                  <span>Total Potongan</span>
                  <span id="previewDeductions" class="font-medium tracking-tight">-Rp 0</span>
                </div>
                <div id="detailDeductionsContainer" class="hidden pl-3 border-l-2 border-rose-100 space-y-1.5 mt-0.5 w-full"></div>
              </div>
              <div class="pt-4 mt-2 border-t border-slate-200/80">
                <div class="flex justify-between items-end">
                  <span class="font-medium text-slate-600 text-[13px]">Take Home Pay</span>
                  <span id="previewNetPay" class="font-bold text-blue-600 text-[15px] tracking-tight">Rp 0</span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  let overtimeSummary = {
    totalHours: 0,
    totalPay: 0
  };
  let attendanceSummary = {
    totalDays: 0,
    ratePerDay: 0,
    totalPay: 0
  };
  let isReadOnlyMode = false;

  function parseIDR(str) {
    if (!str) return 0;
    return parseFloat(str.toString().replace(/\./g, '')) || 0;
  }

  function formatIDRValue(number) {
    return new Intl.NumberFormat('id-ID').format(number || 0);
  }

  function formatRupiahInput(el) {
    let angka = el.value.replace(/[^,\d]/g, '').toString();
    let split = angka.split(',');
    let sisa = split[0].length % 3;
    let rupiah = split[0].substr(0, sisa);
    let ribuan = split[0].substr(sisa).match(/\d{3}/gi);
    if (ribuan) {
      let separator = sisa ? '.' : '';
      rupiah += separator + ribuan.join('.');
    }
    el.value = split[1] != undefined ? rupiah + ',' + split[1] : rupiah;
    calculatePayroll();
  }

  function updateContainerBackgrounds() {
    const allowanceWrapper = document.getElementById('allowanceWrapper');
    const allowanceContainer = document.getElementById('allowanceContainer');
    const overtimeContainer = document.getElementById('overtimeContainer');
    const attendanceAllowanceContainer = document.getElementById('attendanceAllowanceContainer');
    if (allowanceWrapper && allowanceContainer && overtimeContainer && attendanceAllowanceContainer) {
      if (allowanceContainer.children.length > 0 || overtimeContainer.children.length > 0 || attendanceAllowanceContainer.children.length > 0) {
        allowanceWrapper.className = "space-y-2 bg-[#f2f2f7]/40 p-2.5 rounded-xl border border-slate-100";
      } else {
        allowanceWrapper.className = "space-y-2 rounded-xl border border-transparent";
      }
    }
    const deductionContainer = document.getElementById('deductionContainer');
    if (deductionContainer) {
      if (deductionContainer.children.length > 0) {
        deductionContainer.className = "space-y-2 bg-[#f2f2f7]/40 p-2.5 rounded-xl border border-slate-100";
      } else {
        deductionContainer.className = "space-y-2 rounded-xl border border-transparent";
      }
    }
  }

  function calculatePayroll() {
    try {
      const basicInput = document.getElementById('inputBasicSalary');
      const basic = basicInput ? parseIDR(basicInput.value) : 0;

      let allowances = 0;
      let earningsDetailHTML = '';

      document.querySelectorAll('.allowance-row').forEach(row => {
        const nameInput = row.querySelector('input[type="text"]');
        const amountInput = row.querySelector('.amount-input-allowance');
        if (nameInput && amountInput) {
          const val = parseIDR(amountInput.value);
          allowances += val;
          if (val > 0) {
            earningsDetailHTML += `<div class="flex justify-between items-center text-[11px] text-slate-500"><span>${nameInput.value}</span><span class="font-medium text-slate-600">Rp ${val.toLocaleString('id-ID')}</span></div>`;
          }
        }
      });

      let overtime = 0;
      const previewOvertimeRow = document.getElementById('previewOvertimeRow');
      const previewOvertime = document.getElementById('previewOvertime');
      const previewOvertimeLabel = document.getElementById('previewOvertimeLabel');
      if (typeof overtimeSummary !== 'undefined' && overtimeSummary && overtimeSummary.totalPay > 0) {
        overtime = overtimeSummary.totalPay;
        if (previewOvertimeLabel) previewOvertimeLabel.innerText = `Uang Lembur (${overtimeSummary.totalHours} jam)`;
        if (previewOvertime) previewOvertime.innerText = '+Rp ' + overtime.toLocaleString('id-ID');
        if (previewOvertimeRow) {
          previewOvertimeRow.classList.remove('hidden');
          previewOvertimeRow.classList.add('flex');
        }
      } else {
        if (previewOvertimeRow) {
          previewOvertimeRow.classList.add('hidden');
          previewOvertimeRow.classList.remove('flex');
        }
      }

      let deductions = 0;
      let deductionsDetailHTML = '';

      document.querySelectorAll('.deduction-row').forEach(row => {
        const nameInput = row.querySelector('input[type="text"]');
        const amountInput = row.querySelector('.amount-input-deduction');
        const container = row.querySelector('.w-32 relative');
        const unitSpan = container ? container.querySelector('span') : null;

        if (nameInput && amountInput) {
          let inputVal = parseIDR(amountInput.value);
          let finalAmount = inputVal;
          let displayLabel = nameInput.value;

          // HANYA hitung rumus persen jika unit di UI saat itu terdeteksi '%' (Artinya sedang di mode DRAFT)
          const isPercentageUnit = unitSpan && unitSpan.innerText === '%';

          if (isPercentageUnit && (nameInput.value.toUpperCase().includes('BPJS') || nameInput.value.toUpperCase().includes('PPH') || nameInput.value.toUpperCase().includes('PAJAK'))) {
            finalAmount = (inputVal / 100) * basic;
            displayLabel = `${nameInput.value} (${inputVal}%)`;
          }

          deductions += finalAmount;
          if (finalAmount > 0) {
            deductionsDetailHTML += `<div class="flex justify-between items-center text-[11px] text-slate-500"><span>${displayLabel}</span><span class="font-medium text-slate-600">Rp ${finalAmount.toLocaleString('id-ID')}</span></div>`;
          }
        }
      });

      const netPay = (basic + allowances + overtime) - deductions;

      if (document.getElementById('previewBasic')) document.getElementById('previewBasic').innerText = 'Rp ' + basic.toLocaleString('id-ID');

      const earnDetailBox = document.getElementById('detailEarningsContainer');
      if (earnDetailBox) {
        earnDetailBox.innerHTML = earningsDetailHTML;
        earnDetailBox.classList.toggle('hidden', earningsDetailHTML === '');
      }
      if (document.getElementById('previewEarnings')) document.getElementById('previewEarnings').innerText = '+Rp ' + allowances.toLocaleString('id-ID');

      const dedDetailBox = document.getElementById('detailDeductionsContainer');
      if (dedDetailBox) {
        dedDetailBox.innerHTML = deductionsDetailHTML;
        dedDetailBox.classList.toggle('hidden', deductionsDetailHTML === '');
      }

      if (document.getElementById('previewDeductions')) document.getElementById('previewDeductions').innerText = '-Rp ' + deductions.toLocaleString('id-ID');
      if (document.getElementById('previewNetPay')) document.getElementById('previewNetPay').innerText = 'Rp ' + netPay.toLocaleString('id-ID');
    } catch (err) {}
  }

  async function loadOvertime(idParam) {
    if (isReadOnlyMode) return;
    try {
      const res = await fetch(`/overtime/summary/${idParam}`);
      const data = await res.json();
      overtimeSummary = {
        totalHours: Number(data.totalHours || 0),
        totalPay: Number(data.totalPay || 0)
      };
    } catch (err) {
      overtimeSummary = {
        totalHours: 0,
        totalPay: 0
      };
    } finally {
      renderOvertimeComponent();
      calculatePayroll();
    }
  }

  function renderOvertimeComponent() {
    const container = document.getElementById('overtimeContainer');
    if (!container) return;
    container.innerHTML = '';
    if (overtimeSummary.totalHours === 0) return;
    container.innerHTML = `<div class="flex items-center gap-2 overtime-row animate-fadeIn"><input type="text" value="Lembur (${overtimeSummary.totalHours} jam)" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px] text-slate-800 font-medium" readonly><div class="w-32 relative"><span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-slate-400">Rp</span><input type="text" value="${formatIDRValue(overtimeSummary.totalPay)}" class="amount-input-allowance w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none" readonly></div><div class="w-8 h-8 flex items-center justify-center opacity-0 pointer-events-none"></div></div>`;
    updateContainerBackgrounds();
  }

  async function loadAttendance(idParam) {
    if (isReadOnlyMode) return;
    try {
      const res = await fetch(`/payroll/attendance-summary/${idParam}`);
      const data = await res.json();
      if (data.success) {
        attendanceSummary.totalDays = Number(data.totalDays || 0);
        const activeCard = document.querySelector(`.employee-card[data-id="${idParam}"]`);
        const savedAllowances = JSON.parse(activeCard.getAttribute('data-allowances') || '[]');
        const existingKonsumsi = savedAllowances.find(a => a.componentName === 'Tunjangan Konsumsi');
        if (existingKonsumsi && attendanceSummary.totalDays > 0) {
          attendanceSummary.totalPay = existingKonsumsi.amount;
          attendanceSummary.ratePerDay = existingKonsumsi.amount / attendanceSummary.totalDays;
        } else {
          attendanceSummary.ratePerDay = 0;
          attendanceSummary.totalPay = 0;
        }
      }
    } catch (err) {
      attendanceSummary.totalDays = 0;
    } finally {
      renderAttendanceComponent();
      const rateInput = document.getElementById('inputRateKonsumsi');
      const totalOutput = document.getElementById('totalPayKonsumsi');
      if (rateInput && totalOutput && attendanceSummary.ratePerDay > 0) {
        rateInput.value = formatIDRValue(attendanceSummary.ratePerDay);
        totalOutput.value = attendanceSummary.totalPay;
      }
      calculatePayroll();
    }
  }

  function renderAttendanceComponent() {
    const container = document.getElementById('attendanceAllowanceContainer');
    if (!container) return;
    if (attendanceSummary.totalDays === 0) {
      container.innerHTML = '';
      return;
    }
    const readOnlyAttr = isReadOnlyMode ? 'readonly' : '';
    container.innerHTML = `<div class="flex items-center gap-2 allowance-row animate-fadeIn"><input type="text" value="Tunjangan Konsumsi (${attendanceSummary.totalDays} Hari)" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px] text-slate-800 font-medium" readonly><div class="w-32 relative"><span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-slate-400">Rp</span><input type="text" id="inputRateKonsumsi" placeholder="0" oninput="formatRupiahInput(this); calculateAttendancePay()" class="w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none focus:ring-2 focus:ring-blue-500/20" ${readOnlyAttr}></div><input type="hidden" id="totalPayKonsumsi" value="0" class="amount-input-allowance"><div class="w-8 h-8 flex items-center justify-center opacity-0 pointer-events-none"></div></div>`;
    updateContainerBackgrounds();
  }

  function calculateAttendancePay() {
    const rateInput = document.getElementById('inputRateKonsumsi');
    const totalHiddenInput = document.getElementById('totalPayKonsumsi');
    if (rateInput && totalHiddenInput) {
      const rate = parseIDR(rateInput.value);
      const total = rate * attendanceSummary.totalDays;
      totalHiddenInput.value = total;
      calculatePayroll();
    }
  }

  // --- REVISI UTAMA FIX 404 & FIX RIBAUAN PERSEN DI HISTORY MODE ---
  function generateRowHTML(name, amount, isFixed, type) {
    const colorClass = type === 'allowance' ? 'blue' : 'rose';

    const isReadOnly = isFixed || isReadOnlyMode;
    const readOnlyAttr = isReadOnly ? 'readonly' : '';

    const trashButton = isReadOnly ?
      `<div class="w-8 h-8"></div>` :
      `<button type="button"
        onclick="this.parentElement.remove(); updateContainerBackgrounds(); calculatePayroll();"
        class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-${colorClass}-600 flex items-center justify-center transition-all text-xs">
        <i class="fa-solid fa-trash-can text-[11px]"></i>
      </button>`;

    const numericAmount = parseFloat(amount || 0);
    const formattedAmount = formatIDRValue(numericAmount);

    return `
    <div class="flex items-center gap-2 ${type}-row animate-fadeIn">

      <input type="text"
        value="${name}"
        class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px]"
        readonly
      >

      <div class="w-32 relative">
        <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] text-slate-400">
          Rp
        </span>

        <input type="text"
          value="${formattedAmount}"
          oninput="formatRupiahInput(this); calculatePayroll();"
          class="amount-input-${type} w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none focus:ring-2 focus:ring-${colorClass}-500/20"
          ${readOnlyAttr}
        >
      </div>

      ${trashButton}

    </div>
  `;
  }

  function addAllowanceField() {
    const select = document.getElementById('masterAllowanceSelect');
    if (!select || !select.value) return;

    const selectedOption = select.options[select.selectedIndex];
    const componentName = select.value;
    const defaultAmount = selectedOption.getAttribute('data-amount') || 0;

    let isDuplicate = false;
    document.querySelectorAll('.allowance-row input[type="text"]').forEach(input => {
      const existingName = input.value.split('(')[0].trim();
      if (existingName === componentName.trim()) isDuplicate = true;
    });

    if (isDuplicate) {
      alert(`❌ Komponen "${componentName}" sudah ada di daftar tunjangan!`);
      select.value = "";
      return;
    }

    document.getElementById('allowanceContainer').insertAdjacentHTML('beforeend', generateRowHTML(componentName, defaultAmount, false, 'allowance'));
    select.value = "";
    updateContainerBackgrounds();
    calculatePayroll();
  }

  function addDeductionField() {
    const select = document.getElementById('masterDeductionSelect');
    if (!select || !select.value) return;

    const selectedOption = select.options[select.selectedIndex];
    const componentName = select.value;
    const defaultAmount = selectedOption.getAttribute('data-amount') || 0;

    let isDuplicate = false;
    document.querySelectorAll('.deduction-row input[type="text"]').forEach(input => {
      const existingName = input.value.split('(')[0].trim();
      if (existingName === componentName.trim() || (componentName.trim() === 'Potongan Pajak PPh 21' && existingName.includes('Pajak'))) {
        isDuplicate = true;
      }
    });

    if (isDuplicate) {
      alert(`❌ Komponen "${componentName}" sudah ada di daftar potongan!`);
      select.value = "";
      return;
    }

    document.getElementById('deductionContainer').insertAdjacentHTML('beforeend', generateRowHTML(componentName, defaultAmount, false, 'deduction'));
    select.value = "";
    updateContainerBackgrounds();
    calculatePayroll();
  }

  function switchEmployee(el) {
    document.querySelectorAll('.employee-card').forEach(card => card.classList.remove('bg-blue-50/40'));
    el.classList.add('bg-blue-50/40');

    const employeeId = el.getAttribute('data-id');
    const name = el.getAttribute('data-name');
    const nik = el.getAttribute('data-nik');
    const pos = el.getAttribute('data-pos');

    sessionStorage.setItem('selectedEmployeeId', employeeId);

    document.getElementById('empNameTitle').innerText = name;
    document.getElementById('empMetaTitle').innerText = 'NIK: ' + nik + ' • ' + pos;

    fetchAndRenderPayrollData(employeeId);
  }

  function fetchAndRenderPayrollData(employeeId) {
    const period = document.getElementById('filterPeriod').value;
    document.getElementById('labelPeriodSummary').innerText = period;
    const activeCard = document.querySelector(`.employee-card[data-id="${employeeId}"]`);
    if (!activeCard) return;

    overtimeSummary = {
      totalHours: 0,
      totalPay: 0
    };
    attendanceSummary = {
      totalDays: 0,
      ratePerDay: 0,
      totalPay: 0
    };

    const allowanceContainer = document.getElementById('allowanceContainer');
    const deductionContainer = document.getElementById('deductionContainer');
    const overtimeContainer = document.getElementById('overtimeContainer');
    const attendanceAllowanceContainer = document.getElementById('attendanceAllowanceContainer');

    allowanceContainer.innerHTML = '';
    deductionContainer.innerHTML = '';
    if (overtimeContainer) overtimeContainer.innerHTML = '';
    if (attendanceAllowanceContainer) attendanceAllowanceContainer.innerHTML = '';

    fetch(`/payroll/calculate/${employeeId}?period=${period}`)
      .then(res => res.json())
      .then(resData => {
        isReadOnlyMode = resData.isHistory;
        const data = resData.data;

        const badge = activeCard.querySelector('.status-badge');
        if (badge) {
          if (isReadOnlyMode) {
            badge.innerText = "Closed";
            badge.className = "status-badge text-[11px] font-semibold px-2.5 py-0.5 rounded-full bg-rose-50 text-rose-600 border border-rose-100 animate-fadeIn";
          } else {
            badge.innerText = "Draft";
            badge.className = "status-badge text-[11px] font-medium px-2.5 py-0.5 rounded-full bg-slate-100 text-slate-600";
          }
        }
        document.getElementById('inputBasicSalary').value = formatIDRValue(data.basicSalary || 0);

        const actionInputsA = document.getElementById('masterAllowanceSelect').parentElement;
        const actionInputsD = document.getElementById('masterDeductionSelect').parentElement;
        const btnSave = document.getElementById('btnSavePayroll');

        if (isReadOnlyMode) {
          actionInputsA.classList.add('hidden');
          actionInputsD.classList.add('hidden');
          btnSave.classList.add('hidden');

          const arrAllow = data.allowances || [];
          arrAllow.forEach(item => {
            const cName = item.componentName || item.name;
            if (cName.includes('Konsumsi') || cName.includes('Lembur')) return;
            allowanceContainer.insertAdjacentHTML('beforeend', generateRowHTML(cName, item.amount, true, 'allowance'));
          });

          const konsumsiItem = arrAllow.find(a => (a.componentName || a.name).includes('Konsumsi'));
          if (konsumsiItem) {
            attendanceSummary.totalDays = 1;
            attendanceAllowanceContainer.innerHTML = `<div class="flex items-center gap-2 allowance-row animate-fadeIn"><input type="text" value="${konsumsiItem.componentName || konsumsiItem.name}" class="flex-1 bg-white border border-slate-200/60 rounded-lg px-2.5 py-1.5 text-[12px] text-slate-800 font-medium" readonly><div class="w-32 relative"><span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[11px] font-medium text-slate-400">Rp</span><input type="text" value="${formatIDRValue(konsumsiItem.amount)}" class="amount-input-allowance w-full bg-white border border-slate-200/60 rounded-lg pl-7 pr-2 py-1.5 text-[12px] font-bold text-slate-800 text-right focus:outline-none" readonly></div><div class="w-8 h-8"></div></div>`;
          }

          if (data.overtime && data.overtime.amount > 0) {
            overtimeSummary = {
              totalHours: data.overtime.hours,
              totalPay: data.overtime.amount
            };
            renderOvertimeComponent();
          }

          const arrDed = data.deductions || [];
          arrDed.forEach(item => {
            const cName = item.componentName || item.name;
            // Force true (Fixed) saat History agar generateRowHTML memicu mode Rupiah
            deductionContainer.insertAdjacentHTML('beforeend', generateRowHTML(cName, item.amount, true, 'deduction'));
          });

          if (data.loanDeduction && data.loanDeduction.length > 0) {
            data.loanDeduction.forEach(loan => {
              deductionContainer.insertAdjacentHTML(
                'beforeend',
                generateRowHTML(
                  'Cicilan Pinjaman',
                  loan.amount,
                  true,
                  'deduction'
                )
              );
            });
          }

          updateContainerBackgrounds();
          calculatePayroll();

        } else {
          actionInputsA.classList.remove('hidden');
          actionInputsD.classList.remove('hidden');
          btnSave.classList.remove('hidden');

          const allowances = JSON.parse(activeCard.getAttribute('data-allowances') || '[]');
          allowances.forEach(item => {
            if (item.componentName === 'Tunjangan Konsumsi') return;
            allowanceContainer.insertAdjacentHTML('beforeend', generateRowHTML(item.componentName, item.amount, false, 'allowance'));
          });

          const deductions = JSON.parse(activeCard.getAttribute('data-deductions') || '[]');
          deductions.forEach(item => {
            deductionContainer.insertAdjacentHTML('beforeend', generateRowHTML(item.componentName, item.amount, false, 'deduction'));
          });

          if (data.loanDeduction && data.loanDeduction.length > 0) {
            data.loanDeduction.forEach(loan => {
              deductionContainer.insertAdjacentHTML(
                'beforeend',
                generateRowHTML(
                  'Cicilan Pinjaman',
                  loan.amount,
                  true,
                  'deduction'
                )
              );
            });
          }

          updateContainerBackgrounds();
          loadOvertime(employeeId);
          loadAttendance(employeeId);
        }
      });
  }

  async function triggerTutupBuku(event) {
    event.preventDefault();

    const currentPeriod = document.getElementById('filterPeriod').value;

    // 1. Sesuaikan teks alert konfirmasi menjadi 5 pegawai target
    if (!confirm(`Apakah Anda yakin ingin melakukan Tutup Buku periode ${currentPeriod} untuk 5 pegawai target? Data yang dikunci tidak dapat diubah kembali.`)) {
      return;
    }

    const allCards = document.querySelectorAll('.employee-card');

    // 2. TAMBAHKAN USERNAME BARU DI SINI 👈
    const targetUsernames = ["fajarjaniko", "adindarismayani", "abdulaziz", "meltisundari", "basoherman"];
    const matchedEmployeeIds = [];

    allCards.forEach(card => {
      const nameText = card.querySelector('h4').innerText.toLowerCase().replace(/\s/g, "");
      const empId = card.getAttribute('data-id');

      const isTarget = targetUsernames.some(target => nameText.includes(target));
      if (isTarget && empId) {
        matchedEmployeeIds.push(empId);
      }
    });

    if (matchedEmployeeIds.length === 0) {
      alert("❌ Gagal memetakan ID Pegawai. Pastikan profil 5 pegawai target ada di database.");
      return;
    }

    try {
      const response = await fetch('/payroll/close-book', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          employeeIds: matchedEmployeeIds,
          periodMonth: currentPeriod
        })
      });

      const result = await response.json();

      if (result.success) {
        alert(`🔒 Sukses! ${result.message}`);
        window.location.reload();
      } else {
        alert(`❌ Gagal: ${result.message}`);
      }
    } catch (error) {
      console.error(error);
      alert("Terjadi kesalahan koneksi sistem.");
    }
  }

  function submitPayrollData() {
    const allCards = document.querySelectorAll('.employee-card');
    let activeCard = null;
    allCards.forEach(card => {
      if (card.classList.contains('bg-blue-50/40')) activeCard = card;
    });
    if (!activeCard) return;

    const employeeId = activeCard.getAttribute('data-id');
    const combinedComponents = [];

    document.querySelectorAll('.allowance-row').forEach(row => {
      const nameInput = row.querySelector('input[type="text"]');
      const amountInput = row.querySelector('.amount-input-allowance');
      if (nameInput && amountInput) {
        let nameValue = nameInput.value;
        if (nameValue.includes('Tunjangan Konsumsi')) nameValue = 'Tunjangan Konsumsi';
        combinedComponents.push({
          componentName: nameValue,
          amount: parseIDR(amountInput.value) || 0
        });
      }
    });

    document.querySelectorAll('.deduction-row').forEach(row => {
      const nameInput = row.querySelector('input[type="text"]');
      const amountInput = row.querySelector('.amount-input-deduction');
      if (nameInput && amountInput) {
        combinedComponents.push({
          componentName: nameInput.value,
          amount: parseIDR(amountInput.value) || 0
        });
      }
    });

    fetch('/payroll/save', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          employeeId,
          allowances: combinedComponents
        })
      })
      .then(res => res.json())
      .then(data => {
        alert(data.success ? " " + data.message : "" + data.message);
      })
      .catch(err => {
        alert("Terjadi kesalahan sistem.");
      });
  }

  document.getElementById('filterPeriod').addEventListener('change', function() {
    const activeCard = document.querySelector('.employee-card.bg-blue-50\\/40');
    if (activeCard) {
      fetchAndRenderPayrollData(activeCard.getAttribute('data-id'));
    }
  });

  document.getElementById('searchEmployeeInput').addEventListener('input', function(e) {
    const query = e.target.value.toLowerCase().trim();
    document.querySelectorAll('.employee-card').forEach(card => {
      const name = card.querySelector('h4').innerText.toLowerCase();
      const meta = card.querySelector('p').innerText.toLowerCase();
      card.style.display = (name.includes(query) || meta.includes(query)) ? 'flex' : 'none';
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    const savedEmployeeId = sessionStorage.getItem('selectedEmployeeId');
    let targetCard = null;
    if (savedEmployeeId) {
      targetCard = document.querySelector(`.employee-card[data-id="${savedEmployeeId}"]`);
    }
    if (targetCard) {
      setTimeout(() => {
        targetCard.click();
        targetCard.scrollIntoView({
          block: 'nearest',
          behavior: 'smooth'
        });
      }, 100);
    } else {
      const firstCard = document.querySelector('.employee-card');
      if (firstCard) firstCard.click();
    }
  });
</script>
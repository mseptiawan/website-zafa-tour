<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50 p-6">
  <div class="max-w-2xl mx-auto">
    <!-- HEADER -->
    <div class="mb-6 text-center">
      <h1 class="text-xl font-medium text-slate-800">Ajukan Lembur</h1>
      <p class="text-sm text-slate-500 mt-1">Isi detail lembur yang dilakukan</p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-xl p-6">
      <form action="/overtime/apply" method="POST" enctype="multipart/form-data" class="space-y-4">
        <!-- TANGGAL -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">Tanggal Lembur</label>
          <input
            type="date"
            name="date"
            required
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
          />
        </div>

        <!-- JAM -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-slate-500 mb-1">Jam Mulai</label>
            <input
              type="time"
              name="startTime"
              required
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
            />
          </div>

          <div>
            <label class="block text-xs text-slate-500 mb-1">Jam Selesai</label>
            <input
              type="time"
              name="endTime"
              required
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
            />
          </div>
        </div>

        <!-- DESKRIPSI -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">Pekerjaan</label>
          <textarea
            name="workDescription"
            rows="3"
            minlength="10"
            maxlength="500"
            required
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
            placeholder="Jelaskan pekerjaan lembur..."
          ></textarea>
        </div>

        <!-- HASIL -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">Hasil (opsional)</label>
          <textarea
            name="result"
            rows="2"
            minlength="10"
            maxlength="500"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
            placeholder="Hasil pekerjaan..."
          ></textarea>
        </div>

        <!-- FILE -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">Bukti (opsional)</label>

          <input
            type="file"
            name="proofFile"
            class="w-full text-sm border border-slate-200 rounded-lg p-2 bg-slate-50"
          />
        </div>

        <!-- BUTTON -->
        <button
          type="submit"
          class="w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium py-2.5 rounded-lg transition"
        >
          Kirim Pengajuan
        </button>
      </form>
    </div>
  </div>
</div>

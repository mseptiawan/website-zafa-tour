<%- layout('layouts/main', { title: "Data Pegawai" }) %>
<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD]  sm:p-6 md:p-10 antialiased pb-24 md:pb-8 text-slate-800">
  <div class="w-full max-w-none mx-auto space-y-6">

    
    <%- include('../partials/page-header', {
    section: 'Area Kerja',
    module: 'SDM',
    title: 'Data Pegawai',
    description: 'Kelola informasi, peran, dan lacak status keanggotaan seluruh organisasi.'
  }) %>

    <% 
    const totalPegawai = employees ? employees.length : 0;
    const pegawaiAktif = employees ? employees.filter(e => (e.userId && e.userId.status === 'Active') && !(e.terminationInfo && e.terminationInfo.statusPHK === 'Waiting')).length : 0;
    const pegawaiPhk = totalPegawai - employees.filter(e => e.userId && e.userId.status === 'Active').length;
  %>
    <div class="mb-6">
      <%- include('../partials/_stats-grid', {
      items: [
        { 
          label: 'Total Pegawai', 
          value: totalPegawai, 
          unit: 'Orang', 
          icon: 'fa-solid fa-users', 
          bgClass: 'bg-white border-slate-200/60', 
          iconBoxClass: 'bg-blue-50 text-blue-600 border-blue-100' 
        },
        { 
          label: 'Pegawai Aktif', 
          value: pegawaiAktif, 
          unit: 'Aktif', 
          icon: 'fa-solid fa-user-check', 
          bgClass: 'bg-white border-slate-200/60', 
          iconBoxClass: 'bg-emerald-50 text-emerald-600 border-emerald-100' 
        },
        { 
          label: 'Arsip Nonaktif / PHK', 
          value: pegawaiPhk, 
          unit: 'Berkas', 
          icon: 'fa-solid fa-user-minus', 
          bgClass: 'bg-gradient-to-br from-slate-900 to-slate-800 border-slate-800', 
          labelClass: 'text-slate-300', 
          valueClass: 'text-white', 
          unitClass: 'text-slate-400',
          iconBoxClass: 'bg-white/10 text-white border-transparent' 
        }
      ]
    }) %>
    </div>

  <div class="bg-transparent md:bg-white md:border md:border-slate-200 md:rounded-2xl md:shadow-xs overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse block md:table">
        <thead class="bg-slate-50/50 border-b border-slate-200 hidden md:table-header-group">
          <tr>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Pegawai</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Posisi / Bidang</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Unit Kerja</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Info Finansial</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Status / Aksi</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-slate-100 block md:table-row-group space-y-4 md:space-y-0">
          <% if (employees && employees.length > 0) { %>
          <% employees.forEach(e => { %>
          <% 
            // 💡 VALIDASI TIGA KONDISI VISUAL TABEL
            const isApprovedPHK = e.userId && e.userId.status === 'Inactive'; 
            const isWaitingPHK = e.terminationInfo && e.terminationInfo.statusPHK === 'Waiting';
            const currentStatus = e.userId?.status || 'Active';

            // 💡 ATUR KELAS WARNA BARIS TABEL SECARA DINAMIS
            let rowClass = 'hover:bg-slate-50/80 group';
            if (isApprovedPHK) {
              rowClass = 'bg-red-50/30 opacity-85 hover:bg-red-50/50';
            } else if (isWaitingPHK) {
              rowClass = 'bg-amber-50/45 border-l-4 border-l-amber-500 hover:bg-amber-50/70';
            }
          %>
          <tr class="transition-all duration-200 <%= rowClass %> block md:table-row bg-white border border-slate-200/70 md:border-none rounded-2xl p-4 md:p-0 shadow-xs md:shadow-none">

            <td class="px-2 md:px-6 py-2 md:py-4 block md:table-cell border-b border-slate-100 md:border-none pb-3 md:pb-4">
              <div class="flex items-center gap-3">
                <div>
                  <div class="font-semibold text-sm <%= isApprovedPHK ? 'text-slate-500 line-through decoration-slate-400' : 'text-slate-800' %> flex flex-wrap items-center gap-2">
                    <%= e.fullName %>
                    <% if (isWaitingPHK) { %>
                    <span class="inline-flex items-center text-[10px] font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-md border border-amber-200 shadow-2xs">Proses PHK</span>
                    <% } %>
                  </div>
                  <div class="text-[11px] text-slate-400 mt-0.5">
                    ID: <%= e.employeeIdNumber %>
                  </div>
                </div>
              </div>
            </td>

            <td class="px-2 md:px-6 py-2.5 md:py-4 flex justify-between items-start md:table-cell border-b border-slate-100 md:border-none">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider md:hidden pt-0.5">Posisi</span>
              <div class="text-right md:text-left">
                <div class="text-sm font-medium <%= isApprovedPHK ? 'text-slate-400' : 'text-slate-700' %>">
                  <%= e.careerData?.positionId?.name || '-' %>
                </div>
                <div class="text-[10px] text-slate-400 uppercase tracking-widest mt-0.5">
                  Bidang: <%= e.careerData?.bidangId?.name || '-' %>
                </div>
              </div>
            </td>

            <td class="px-2 md:px-6 py-2.5 md:py-4 flex justify-between items-center md:table-cell border-b border-slate-100 md:border-none">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider md:hidden">Unit Kerja</span>
              <div class="text-right md:text-left">
                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold text-slate-600 bg-slate-50 border border-slate-100">
                  <%= e.careerData?.unitId?.name || '-' %>
                </span>
                <div class="text-[11px] text-slate-400 font-medium mt-1">
                  <%= e.careerData?.status_pegawai || '-' %>
                </div>
              </div>
            </td>

            <td class="px-2 md:px-6 py-2.5 md:py-4 flex justify-between items-start md:table-cell border-b border-slate-100 md:border-none">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider md:hidden pt-0.5">Finansial</span>
              <div class="text-right md:text-left">
                <div class="text-sm font-bold text-slate-800">
                  Rp <%= (e.salaryDetail?.basicSalary || 0).toLocaleString('id-ID') %>
                </div>
                <div class="text-[10px] text-slate-400 mt-0.5">
                  Lembur: Rp <%= (e.financialData?.overtimeRate || 0).toLocaleString('id-ID') %>/jam
                </div>
              </div>
            </td>

            <td class="px-2 md:px-6 py-3 md:py-4 flex justify-between items-center md:table-cell text-right pt-3">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider md:hidden">Status & Aksi</span>
              <div class="flex items-center justify-end gap-3">

                <div>
                  <% if (isWaitingPHK) { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-500 text-white border border-amber-600 shadow-xs animate-pulse">Waiting Approval</span>
                  <% } else if (currentStatus === 'Active') { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-600 border border-emerald-100">Active</span>
                  <% } else if (currentStatus === 'Suspended') { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-600 border border-amber-100">Suspended</span>
                  <% } else { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-rose-50 text-rose-600 border border-rose-100">Inactive</span>
                  <% } %>
                </div>

                <div>
                  <% if (isApprovedPHK) { %>
                  <button type="button" onclick="showHistoryModal('<%= e.fullName %>', '<%= e.terminationInfo?.reason || 'Tidak ada alasan' %>', '<%= e.terminationInfo?.approvedBy || 'Pimpinan' %>', '<%= e.terminationInfo?.date || '-' %>')" class="inline-flex items-center gap-1.5 text-xs font-semibold text-red-600 bg-white hover:bg-red-50 px-3 py-1.5 rounded-lg border border-red-200 shadow-sm transition-all cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Arsip PHK
                  </button>
                  <% } else { %>
                  <div class="flex items-center gap-1.5">

                    <a href="/employee/detail/<%= e._id %>" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition active:scale-[0.95] cursor-pointer shadow-sm" title="Lihat Detail Profil">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    </a>

                    <% if (user && user.role === 'WAKIL_DIREKTUR') { %>
                    <a href="/employee/edit/<%= e._id %>" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-amber-400 text-white hover:bg-amber-500 transition active:scale-[0.95] cursor-pointer shadow-sm" title="Edit Data">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                    </a>

                    <% if (isWaitingPHK) { %>
                    <button type="button" disabled class="w-8 h-8 flex items-center justify-center bg-amber-50 border border-amber-200 rounded-lg text-amber-600 cursor-not-allowed" title="Pengajuan sedang ditinjau Direktur Utama">
                      <svg class="animate-spin h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                      </svg>
                    </button>
                    <% } else { %>
                    <button type="button" onclick="openPhkModal('<%= e._id %>', '<%= e.fullName %>')" class="w-8 h-8 flex items-center justify-center bg-white border border-slate-200 rounded-lg text-slate-500 hover:text-red-600 hover:border-red-200 hover:bg-red-50/50 shadow-sm transition-all cursor-pointer" title="Ajukan PHK Pegawai">
                      <svg xmlns="http://www.w3.org/2000/xl" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                      </svg>
                    </button>
                    <% } %>
                    <% } %>
                  </div>
                  <% } %>
                </div>
              </div>
            </td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr class="block md:table-row">
            <td colspan="5" class="px-6 py-12 text-center text-sm font-medium text-slate-400 bg-slate-50/30 block md:table-cell">
              Tidak ada data Pegawai yang ditemukan.
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/30 hidden md:block">
      <p class="text-xs text-slate-500">Menampilkan <%= employees ? employees.length : 0 %> Pegawai</p>
    </div>
  </div>
</div>
  </div>

<div id="phkModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
  <form id="phkForm" action="/api/employee/phk" method="POST" enctype="multipart/form-data" class="bg-white p-6 rounded-2xl w-full max-w-md shadow-xl border border-slate-100">
    <h3 class="font-bold text-base text-slate-800 mb-2">Ajukan Pemutusan Hubungan Kerja</h3>
    <p class="text-xs text-slate-400 mb-4">Pengajuan ini akan dikirim ke Pusat Otorisasi Pimpinan untuk divalidasi.</p>

    <div class="mb-4 bg-slate-50 p-2.5 rounded-xl border border-slate-200/60 text-xs font-semibold text-slate-700">
      Pegawai: <span id="empName" class="text-indigo-600 font-bold"></span>
    </div>

    <input type="hidden" name="employeeId" id="employeeId">

    <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Alasan Pengajuan</label>
    <textarea name="reason" required placeholder="Tuliskan alasan penghentian hak kerja secara detail..." class="w-full border border-slate-200 rounded-xl p-3 text-xs mb-4 focus:outline-none focus:border-indigo-500 min-h-[80px]"></textarea>

    <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Berkas Pendukung (.pdf, .jpg, .png)</label>
    <input type="file" name="document" accept=".pdf,.jpg,.png" required class="w-full border border-slate-100 bg-slate-50 rounded-lg p-2 text-xs mb-5">

    <div class="flex justify-end gap-2 pt-2 border-t border-slate-100">
      <button type="button" onclick="closePhkModal()" class="px-4 py-2 text-xs font-semibold text-slate-500 hover:text-slate-800 transition-colors">Batal</button>
      <button type="submit" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-xs font-semibold rounded-xl shadow-sm transition-colors">Kirim Pengajuan</button>
    </div>
  </form>
</div>

<div id="historyModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
  <div class="bg-white p-6 rounded-2xl w-full max-w-md shadow-xl border border-slate-100">
    <div class="flex items-center gap-2 text-slate-800 mb-3">
      <div class="h-7 w-7 rounded-lg bg-red-50 flex items-center justify-center text-red-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <h3 class="font-bold text-sm">Detail Dokumen Arsip Keluar</h3>
    </div>

    <div class="space-y-3 my-4 bg-slate-50 p-4 rounded-xl border border-slate-200/40 text-xs">
      <div>
        <span class="block text-[10px] text-slate-400 font-bold uppercase">Nama Mantan Pegawai</span>
        <span id="histName" class="font-bold text-slate-700"></span>
      </div>
      <div>
        <span class="block text-[10px] text-slate-400 font-bold uppercase">Disahkan Oleh</span>
        <span id="histAdmin" class="font-bold text-slate-800"></span>
      </div>
      <div>
        <span class="block text-[10px] text-slate-400 font-bold uppercase">Tanggal Penonaktifan</span>
        <span id="histDate" class="font-medium text-slate-600"></span>
      </div>
      <div class="pt-2 border-t border-slate-200/60">
        <span class="block text-[10px] text-slate-400 font-bold uppercase mb-0.5">Alasan Resmi PHK</span>
        <p id="histReason" class="text-slate-600 leading-relaxed italic bg-white p-2 rounded border border-slate-200/40 break-words"></p>
      </div>
    </div>

    <div class="flex justify-end pt-2">
      <button type="button" onclick="closeHistoryModal()" class="px-4 py-2 bg-blue-500 hover:bg-blue-700 text-white text-xs font-semibold rounded-xl shadow-sm transition-all">Tutup Dokumen</button>
    </div>
  </div>
</div>

<script>
  function openPhkModal(id, name) {
    document.getElementById('employeeId').value = id;
    document.getElementById('empName').innerText = name;
    document.getElementById('phkModal').classList.remove('hidden');
  }

  function showHistoryModal(name, reason, approvedBy, date) {
    document.getElementById('histName').innerText = name;
    document.getElementById('histReason').innerText = reason;
    document.getElementById('histAdmin').innerText = approvedBy.startsWith('@') ? approvedBy : `@${approvedBy}`;
    document.getElementById('histDate').innerText = date;
    document.getElementById('historyModal').classList.remove('hidden');
  }

  function closePhkModal() {
    document.getElementById('phkModal').classList.add('hidden');
  }

  function closeHistoryModal() {
    document.getElementById('historyModal').classList.add('hidden');
  }
</script>
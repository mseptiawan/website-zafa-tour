<%- layout('layouts/main', { title }) %>

  <div style="margin-left:280px; padding:32px; background:#f1f5f9; min-height:100vh; font-family:'Inter',sans-serif;">

    <div style="margin-bottom:24px;">
      <h2 style="font-size:24px; font-weight:700; margin:0;">
        Persetujuan Dinas Luar
      </h2>

      <p style="margin-top:6px; color:#64748b;">
        Kelola dan tinjau semua pengajuan perjalanan dinas tim Anda.
      </p>
    </div>

    <div style="background:#fff; border-radius:16px; overflow:hidden;">

      <table style="width:100%; border-collapse:collapse; min-width:900px;">

        <thead style="background:#f8fafc;">
          <tr>

            <th style="padding:16px; text-align:left;">Pengaju</th>
            <th style="padding:16px; text-align:left;">Judul</th>
            <th style="padding:16px; text-align:left;">Tujuan</th>

            <% if (user.role==="HR" ) { %>
              <th style="padding:16px; text-align:left;">Delegasi</th>
              <% } %>

                <th style="padding:16px; text-align:left;">Budget</th>
                <th style="padding:16px; text-align:left;">Status</th>
                <th style="padding:16px; text-align:center;">Aksi</th>

          </tr>
        </thead>

        <tbody>

          <% trips.forEach(t=> { %>

            <tr style="border-top:1px solid #e2e8f0;">

              <td style="padding:16px;">
                <%= t.userId?.username || '-' %>
              </td>

              <td style="padding:16px;">
                <%= t.title %>
              </td>

              <td style="padding:16px;">
                <%= t.destination || '-' %>
              </td>

              <% if (user.role==="HR" ) { %>

                <td style="padding:16px;">

                  <% if (t.delegation?.active) { %>

                    <span style="
                    background:#fef3c7;
                    color:#92400e;
                    padding:6px 10px;
                    border-radius:999px;
                    font-size:12px;
                    font-weight:600;
                  ">
                      Pimpinan → HR
                    </span>

                    <% } else { %>

                      -

                      <% } %>

                </td>

                <% } %>

                  <td style="padding:16px;">
                    Rp <%= (t.budget || 0).toLocaleString('id-ID') %>
                  </td>

                  <td style="padding:16px;">
                    <%= t.status %>
                  </td>

                  <td style="padding:16px; text-align:center;">

                    <a href="/trip/approval/<%= t._id %>" style="
                  display:inline-block;
                  padding:10px 16px;
                  background:#4f46e5;
                  color:#fff;
                  text-decoration:none;
                  border-radius:10px;
                  font-size:13px;
                  font-weight:600;
                ">
                      Tinjau
                    </a>

                  </td>

            </tr>

            <% }) %>

        </tbody>

      </table>

    </div>

  </div>
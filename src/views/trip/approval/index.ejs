<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8">

  <div class="mb-8">
  <div class="mb-3 flex items-center gap-3">
    <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-400 uppercase">
      Area Kerja
    </span>
    <div class="h-3 w-px bg-slate-300"></div>
    <span class="text-[10px] font-semibold tracking-[0.2em] text-slate-800 uppercase">
      Dinas
    </span>
  </div>

  <h1 class="text-3xl font-semibold tracking-tighter text-slate-950">
    Persetujuan Dinas Luar
  </h1>
  <p class="mt-1.5 text-sm font-medium text-slate-500">
    Kelola dan tinjau semua pengajuan perjalanan dinas tim Anda secara terpusat.
  </p>
</div>

    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">

      <div class="overflow-x-auto">

        <table class="w-full min-w-[900px] text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
            <tr>
              <th class="px-6 py-4 text-left">Pengaju</th>
              <th class="px-6 py-4 text-left">Judul</th>
              <th class="px-6 py-4 text-left">Tujuan</th>

              <% if (user.role==="HR" ) { %>
                <th class="px-6 py-4 text-left">Delegasi</th>
                <% } %>

                  <th class="px-6 py-4 text-left">Budget</th>
                  <th class="px-6 py-4 text-left">Status</th>
                  <th class="px-6 py-4 text-center">Aksi</th>
            </tr>
          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (trips.length===0) { %>
              <tr>
                <td colspan="10" class="text-center py-10 text-slate-400">
                  Tidak ada pengajuan
                </td>
              </tr>
              <% } %>

                <% trips.forEach(t=> { %>
                  <tr class="hover:bg-slate-50 transition">

                    <!-- PENGAJU -->
                    <td class="px-6 py-4 font-medium text-slate-700">
                      <%= t.userId?.username || '-' %>
                    </td>

                    <!-- JUDUL -->
                    <td class="px-6 py-4 text-slate-600">
                      <%= t.title %>
                    </td>

                    <!-- TUJUAN -->
                    <td class="px-6 py-4 text-slate-500">
                      <%= t.destination || '-' %>
                    </td>

                    <!-- DELEGASI -->
                    <% if (user.role==="HR" ) { %>
                      <td class="px-6 py-4">
                        <% if (t.delegation?.active) { %>
                          <span
                            class="text-xs px-3 py-1 rounded-full bg-amber-50 text-amber-700 border border-amber-200">
                            Pimpinan → HR
                          </span>
                          <% } else { %>
                            <span class="text-slate-400">-</span>
                            <% } %>
                      </td>
                      <% } %>

                        <!-- BUDGET -->
                        <td class="px-6 py-4 font-medium text-slate-700">
                          Rp <%= (t.budget || 0).toLocaleString('id-ID') %>
                        </td>

                        <!-- STATUS -->
                        <td class="px-6 py-4">
                          <span class="text-[11px] px-2.5 py-1 rounded-md font-bold uppercase tracking-wider border
    <%= t.status === 'APPROVED'
      ? 'bg-emerald-50/50 text-emerald-700 border-emerald-200/60'
      : t.status === 'REJECTED'
        ? 'bg-red-50/50 text-red-700 border-red-200/60'
        : 'bg-slate-50 text-slate-600 border-slate-200'
    %>">
                            <%= t.status %>
                          </span>
                        </td>

                        <!-- AKSI -->
                        <td class="px-6 py-4 text-center">

                          <a href="/trip/approval/<%= t._id %>" title="Tinjau"
                            class="inline-flex items-center text-blue-600 hover:text-blue-800">

                            <!-- eye icon -->
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" />
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 9a3 3 0 100 6 3 3 0 000-6z" />
                            </svg>

                          </a>

                        </td>

                  </tr>
                  <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </div>
<% if (activeApproval) { %>
<div class="w-full">
  <!-- Judul Section -->
  <h3 class="text-[11px] md:text-xs font-bold text-slate-400 uppercase tracking-wider mb-3.5 flex items-center gap-2 select-none">
    <div class="w-1.5 h-3 bg-blue-500 rounded-xs md:hidden"></div>
    <span><%= (user.role || '').toUpperCase() === 'MANAGER_KEUANGAN' ? 'Proses Pencairan Dana' : 'Evaluasi Pengajuan Pinjaman' %></span>
  </h3>

  <% if ((user.role || '').toUpperCase() === 'MANAGER_KEUANGAN') { %>
  <form action="/loans/approval/disburse/<%= activeApproval._id %>" method="POST" enctype="multipart/form-data" onsubmit="return validateForm()" class="m-0 space-y-3.5">
    <div>
      <label class="text-[9px] md:text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 block select-none">
        Upload Bukti Transfer Resmi <span class="text-rose-500">*</span>
      </label>

      <div id="error-message" class="text-[10px] text-rose-500 mb-2 hidden font-bold select-none">
        <i class="fa-solid fa-circle-exclamation mr-1"></i> Harap pilih file bukti transfer terlebih dahulu!
      </div>

      <input type="file" name="paymentProof" id="file-input" class="hidden" accept="image/*,application/pdf" onchange="handleFilePreview(this)">

      <div id="file-preview-area" class="hidden flex items-center justify-between border border-slate-200 rounded-xl p-2.5 bg-slate-50/50">
        <div class="flex items-center gap-2 overflow-hidden min-w-0 flex-1 pr-2">
          <div class="w-7 h-7 rounded-lg bg-blue-50 border border-blue-100 flex items-center justify-center text-blue-600 shrink-0">
            <i id="file-icon" class="fa-solid fa-file-lines text-xs"></i>
          </div>
          <span id="file-name" class="text-[11.5px] font-bold text-slate-700 truncate">file.pdf</span>
        </div>
        <div class="flex items-center gap-0.5 shrink-0 select-none">
          <button type="button" id="btn-view" onclick="viewFile()" class="text-[10px] font-bold text-blue-600 hover:text-blue-700 px-2 py-1 uppercase tracking-wider">View</button>
          <button type="button" onclick="resetFile()" class="text-[10px] font-bold text-rose-600 hover:text-rose-700 px-2 py-1 uppercase tracking-wider">Hapus</button>
        </div>
      </div>

      <button type="button" id="btn-select-file" onclick="document.getElementById('file-input').click()" class="w-full h-11 border border-dashed border-slate-300 rounded-xl text-[11.5px] font-bold text-slate-500 hover:border-blue-400 hover:text-blue-600 transition-all bg-slate-50/20 active:scale-[0.99] cursor-pointer">
        <i class="fa-solid fa-cloud-arrow-up mr-2 text-slate-400"></i> Pilih Bukti Transfer (JPG/PDF)
      </button>
    </div>

    <button type="submit" class="w-full h-11 bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold rounded-xl tracking-wider transition-all active:scale-[0.97] cursor-pointer shadow-sm">
      MARK AS PAID
    </button>
  </form>

  <script>
    let currentFileUrl = null;
    function validateForm() {
      const fileInput = document.getElementById('file-input');
      const errorMessage = document.getElementById('error-message');
      if (!fileInput.files || fileInput.files.length === 0) {
        errorMessage.classList.remove('hidden');
        return false;
      }
      return true;
    }
    function handleFilePreview(input) {
      if (input.files && input.files[0]) {
        const file = input.files[0];
        document.getElementById('error-message').classList.add('hidden');
        document.getElementById('file-name').textContent = file.name;
        const icon = document.getElementById('file-icon');
        icon.className = file.type === 'application/pdf' ? 'fa-solid fa-file-pdf text-xs' : 'fa-solid fa-file-image text-xs';
        if (currentFileUrl) URL.revokeObjectURL(currentFileUrl);
        currentFileUrl = URL.createObjectURL(file);
        document.getElementById('file-preview-area').classList.replace('hidden', 'flex');
        document.getElementById('btn-select-file').classList.add('hidden');
      }
    }
    function viewFile() { if (currentFileUrl) window.open(currentFileUrl, '_blank'); }
    function resetFile() {
      document.getElementById('file-input').value = "";
      document.getElementById('file-preview-area').classList.replace('flex', 'hidden');
      document.getElementById('btn-select-file').classList.remove('hidden');
      if (currentFileUrl) { URL.revokeObjectURL(currentFileUrl); currentFileUrl = null; }
    }
  </script>

  <% } else { %>
  <div class="space-y-3.5">
    <textarea 
      id="evaluation-note" 
      rows="3" 
      class="w-full text-xs text-slate-700 bg-slate-50/50 border border-slate-200/80 rounded-xl p-3 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 outline-none transition-all placeholder:text-slate-400 resize-none" 
      placeholder="Masukkan catatan keputusan pemeriksaan berkas di sini..."></textarea>

    <div class="flex items-center gap-2.5 w-full justify-stretch">
      <form action="/loans/approval/reject/<%= activeApproval._id %>" method="POST" onsubmit="appendNoteBeforeSubmit(this)" class="flex-1 m-0">
        <input type="hidden" name="note" class="hidden-note-field">
        <button type="submit" class="w-full h-11 rounded-xl border border-rose-200 bg-rose-50/50 text-rose-600 text-xs font-bold hover:bg-rose-50 hover:text-rose-700 transition-all active:scale-[0.96] cursor-pointer tracking-wide">
          Tolak
        </button>
      </form>

      <form action="/loans/approval/approve/<%= activeApproval._id %>" method="POST" onsubmit="appendNoteBeforeSubmit(this)" class="flex-1 m-0">
        <input type="hidden" name="note" class="hidden-note-field">
        <button type="submit" class="w-full h-11 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold transition-all active:scale-[0.96] cursor-pointer tracking-wide shadow-sm">
          Setujui
        </button>
      </form>
    </div>
  </div>
  <% } %>
</div>
<% } %>


<% if (activeApproval && (user.role || '').toUpperCase() !== 'MANAGER_KEUANGAN') { %>
<script>
  function appendNoteBeforeSubmit(formElement) {
    const textSource = document.getElementById('evaluation-note');
    
    const hiddenField = formElement.querySelector('.hidden-note-field');
    
    if (textSource && hiddenField) {
      hiddenField.value = textSource.value.trim();
    }
  }
</script>
<% } %>


<%- layout('layouts/main') -%>

<div class="ml-72 p-8 bg-slate-50 min-h-screen">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Data Karyawan</h1>
      <p class="text-sm text-slate-500 mt-1">Kelola informasi dan peran seluruh anggota organisasi.</p>
    </div>

    <a href="/employee/create"
       class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-all duration-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Tambah Karyawan
    </a>
  </div>

  <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead class="bg-slate-50/50 border-b border-slate-200">
          <tr>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Karyawan</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Posisi / Bidang</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Unit Kerja</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Aksi</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-slate-100">
          <% employees.forEach(e => { %>
            <tr class="hover:bg-slate-50/80 transition-colors group">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-sm border border-indigo-200">
                    <%= e.fullName.charAt(0) %>
                  </div>
                  <div>
                    <div class="font-semibold text-slate-800"><%= e.fullName %></div>
                    <div class="text-xs text-slate-500 font-medium tracking-tight">
                      @<%= e.userId?.username || 'user' %>
                    </div>
                  </div>    
                </div>
              </td>

              <td class="px-6 py-4">
                <div class="text-sm text-slate-700 font-medium"><%= e.positionId?.name || '-' %></div>
                <div class="text-[10px] text-slate-400 uppercase tracking-widest mt-0.5">Bidang: <%= e.bidangId?.name || '-' %></div>
              </td>

              <td class="px-6 py-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-100">
                  <%= e.unitId?.name || 'Unassigned' %>
                </span>
              </td>

              <td class="px-6 py-4 text-right">
                <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                   <a href="/employee/edit/<%= e._id %>" class="p-2 text-slate-400 hover:text-indigo-600 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                   </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    
    <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/30">
      <p class="text-xs text-slate-500">Menampilkan <%= employees.length %> karyawan</p>
    </div>
  </div>
</div>
<%- layout('layouts/main', { title }) %>
<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD]  md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto mt-4 md:mt-0 space-y-4 md:space-y-6">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 pb-5 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header', { 
            section: 'Area Kerja', 
            module: 'Jurnal', 
            title: 'Daily Activity Log', 
            description: 'Kelola log aktivitas harian Anda dengan ringkas.' 
        }) %>
      </div>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full md:w-auto shrink-0">
        <div class="w-full sm:w-44">
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Tanggal Log</label>
          <input type="date" id="log-date" 
                 class="w-full bg-white border border-slate-200/80 rounded-xl px-3 py-2 text-[12px] font-semibold text-slate-700 outline-none focus:border-slate-400 transition shadow-3xs cursor-pointer" />
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 pb-4 select-none">
      <div class="flex items-center gap-2 pl-0.5">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-slate-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-slate-900"></span>
        </span>
        <span id="date-status" class="text-[12px] font-semibold text-slate-600">Memuat lembar kerja...</span>
      </div>

      <button type="button" id="btn-carry-over" onclick="executeCarryOver()" 
              class="hidden h-[34px] px-3.5 inline-flex items-center justify-center gap-1.5 bg-white hover:bg-slate-50 border border-slate-200/80 text-slate-700 text-[11px] font-bold rounded-xl transition-all active:scale-[0.98] shadow-3xs cursor-pointer outline-none w-full sm:w-auto">
        <i class="fa-solid fa-rotate text-[10px] text-slate-400"></i>
        <span>Salin Tugas Pending</span>
      </button>
    </div>

    <div id="container-form-add" class="bg-white border border-slate-200/60 p-4 rounded-xl md:rounded-2xl shadow-3xs">
      <h2 class="text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-3.5 flex items-center gap-1.5 select-none">
        <div class="flex items-center justify-center w-5 h-5 rounded-md bg-slate-50 border border-slate-200/60 text-slate-800 shadow-3xs">
          <i class="fa-solid fa-plus text-[9px]"></i>
        </div>
        Aktivitas Baru
      </h2>

      <form id="form-create-activity" onsubmit="submitFormCreate(event)" class="grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-4 items-end">
        <div class="md:col-span-6">
          <label class="block text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1 ml-0.5">Judul Aktivitas</label>
          <!-- Atribut name diganti menjadi title -->
          <input type="text" id="add-title" name="title" placeholder="Contoh: Rekap data bulanan penjualan" required class="w-full h-9 md:h-10 bg-slate-50 border border-slate-200/80 rounded-xl px-3 text-[12px] md:text-[12.5px] font-semibold text-slate-800 placeholder-slate-400/70 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs" />
        </div>

        <div class="md:col-span-3">
          <label class="block text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1 ml-0.5">Target KPI</label>
          <div class="relative">
            <select id="add-kpiTemplateId" name="kpiTemplateId" required class="w-full h-9 md:h-10 bg-slate-50 border border-slate-200/80 rounded-xl pl-3 pr-8 text-[12px] md:text-[12.5px] font-semibold text-slate-700 outline-none focus:bg-white focus:border-slate-400 transition-colors appearance-none cursor-pointer shadow-3xs">
              <% initialKpis.forEach(kpi => { %>
              <option value="<%= kpi._id %>"><%= kpi.indikator %></option>
              <% }) %>
              <option value="lainnya">Lainnya (Non-KPI)</option>
            </select>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-slate-400">
              <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </div>
          </div>
        </div>

        <div class="md:col-span-3 w-full">
          <button type="submit" class="w-full h-9 md:h-10 bg-blue-600 hover:bg-blue-700 text-white font-medium text-[11px] md:text-[11.5px] rounded-xl transition-all active:scale-[0.99] flex items-center justify-center gap-1.5 shadow-3xs cursor-pointer outline-none">
            <i class="fa-solid fa-floppy-disk text-[10px]"></i>
            Simpan Aktivitas
          </button>
        </div>
      </form>
    </div>

    <div class="bg-white border border-slate-200/60 rounded-xl md:rounded-2xl shadow-3xs overflow-hidden w-full">
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200/60 text-[10.5px] font-medium text-slate-400 uppercase tracking-wider select-none">
              <th class="py-3.5 px-5 w-36 text-center">Status</th>
              <th class="py-3.5 px-5 w-52">Target KPI</th>
              <th class="py-3.5 px-5">Judul Aktivitas / Tugas</th>
              <th class="py-3.5 px-5 w-56">Lampiran Bukti</th>
              <th class="py-3.5 px-5 w-16 text-center">Aksi</th>
            </tr>
          </thead>
          <tbody id="task-table-body" class="divide-y divide-slate-100"></tbody>
        </table>
      </div>

      <div id="task-mobile-list" class="block md:hidden divide-y divide-slate-100"></div>

      <div id="empty-state" class="hidden py-14 text-center max-w-sm mx-auto px-4">
        <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-slate-50 border border-slate-200/60 text-slate-400 mx-auto mb-2.5 shadow-3xs">
          <i class="fa-solid fa-list-check text-xs"></i>
        </div>
        <p class="text-[12px] font-semibold text-slate-700">Tidak ada aktivitas harian</p>
        <p class="text-[11px] text-slate-400 mt-0.5 leading-relaxed">Silakan tambahkan agenda aktivitas baru melalui kolom form di atas.</p>
      </div>
    </div>

  </div>
</div>

<script>
  const todayStr = new Date().toISOString().split('T')[0];
  const datePicker = document.getElementById('log-date');
  datePicker.value = todayStr;

  const availableKpis = <%- JSON.stringify(initialKpis) %>;

  const statusStyles = {
    "Pending": "bg-amber-50/70 text-amber-600 border-amber-200/50",
    "In Progress": "bg-blue-50/70 text-blue-600 border-blue-200/50",
    "Completed": "bg-emerald-50/70 text-emerald-600 border-emerald-200/50",
    "Canceled": "bg-slate-50 text-slate-400 border-slate-200"
  };

  async function loadDailyLog() {
    const selectedDate = datePicker.value;
    const dateStatus = document.getElementById('date-status');
    const btnCarryOver = document.getElementById('btn-carry-over');
    const containerFormAdd = document.getElementById('container-form-add');

    if (selectedDate === todayStr) {
      dateStatus.innerText = "Lembar Kerja: Hari Ini";
      btnCarryOver.classList.remove('hidden');
      containerFormAdd.classList.remove('hidden');
    } else {
      dateStatus.innerText = `Arsip Riwayat: ${selectedDate}`;
      btnCarryOver.classList.add('hidden');
      containerFormAdd.classList.add('hidden');
    }

    try {
      // Endpoint disesuaikan dengan skema RESTful Controller sebelumnya
      const response = await fetch(`/daily-activities/api?tanggal=${selectedDate}`);
      const result = await response.json();

      if (result.success) {
        renderTableData(result.data);
      }
    } catch (err) {
      console.error(err);
    }
  }

  function renderTableData(tasks) {
    const tbody = document.getElementById('task-table-body');
    const mobileList = document.getElementById('task-mobile-list');
    const emptyState = document.getElementById('empty-state');

    tbody.innerHTML = "";
    mobileList.innerHTML = "";

    if (!tasks || tasks.length === 0) {
      emptyState.classList.remove('hidden');
      return;
    }
    emptyState.classList.add('hidden');

    tasks.forEach(task => {
      let titleStyle = "text-[13px] font-semibold text-slate-800 tracking-tight transition-all duration-150";
      if (task.status === "Completed") titleStyle = "text-[13px] text-slate-400 font-normal line-through opacity-80";
      if (task.status === "Canceled") titleStyle = "text-[13px] text-slate-300 font-normal line-through opacity-60";

      const currentKpiId = task.kpiTemplateId?._id || task.kpiTemplateId || "";
      const currentKpiName = task.kpiTemplateId?.indikator || "KPI Tidak Diketahui";

      let kpiOptionsHTML = "";
      availableKpis.forEach(kpi => {
        const isSelected = String(kpi._id) === String(currentKpiId) ? 'selected' : '';
        kpiOptionsHTML += `<option value="${kpi._id}" ${isSelected}>${kpi.indikator}</option>`;
      });
      kpiOptionsHTML += `<option value="lainnya" ${!currentKpiId ? 'selected' : ''}>Lainnya (Aktivitas Non-KPI)</option>`;
      
      // Sinkronisasi data dinamis inner HTML form update (Bahasa Inggris)
      const formInnerHTML = `
          <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
            <div class="sm:col-span-2">
              <label class="block text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Judul Tugas</label>
              <input type="text" name="title" value="${task.title}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3.5 py-2 text-[12.5px] font-medium text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition" required />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Target KPI</label>
              <div class="relative">
                <select name="kpiTemplateId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3.5 py-2 text-[12.5px] font-medium text-slate-600 outline-none focus:bg-white focus:border-slate-400 transition appearance-none cursor-pointer" required>
                  ${kpiOptionsHTML}
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
                  <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Status Kerja</label>
              <div class="relative">
                <select name="status" class="w-full border rounded-xl px-3.5 py-2 text-[11px] font-medium ${statusStyles[task.status]} outline-none focus:bg-white focus:border-slate-400 transition appearance-none cursor-pointer">
                  <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                  <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                  <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                  <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none">
                  <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>
            </div>
          </div>
          <div class="pt-1">
            <label class="block text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Penjelasan Hasil / Kendala Kerja</label>
            <textarea name="resultDescription" rows="2" placeholder="Tulis rincian hasil pengerjaan atau kendala lapangan di sini..." class="w-full bg-slate-50 border border-slate-200 placeholder:text-[11.5px] rounded-xl px-3.5 py-2 text-[12.5px] font-medium text-slate-700 outline-none resize-none focus:bg-white focus:border-slate-400 transition">${task.resultDescription || ''}</textarea>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pt-3 border-t border-slate-100">
            <div>
              <label class="block text-[10px] font-medium text-slate-400 uppercase tracking-wider mb-1.5 ml-0.5">Lampiran Bukti</label>
              ${task.attachmentFile ? `
                <div id="file-status-container-${task._id}" class="flex items-center gap-2">
                  <span class="text-[11px] font-medium text-slate-500 bg-slate-50 border border-slate-200 px-2.5 py-1 rounded-lg truncate max-w-[180px]">📎 ${task.attachmentFile}</span>
                  <button type="button" onclick="switchToEditFile('${task._id}')" class="text-[10px] font-medium text-slate-600 hover:text-slate-900 bg-slate-100/80 hover:bg-slate-200 px-2.5 py-1 rounded-lg border border-slate-200 transition cursor-pointer">Ubah</button>
                </div>
                <input type="file" id="input-file-${task._id}" name="attachment" class="hidden text-[11.5px] text-slate-500 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border file:border-slate-200 file:bg-white file:text-[11px] file:font-semibold cursor-pointer" />
              ` : `
                <input type="file" name="attachment" class="text-[11.5px] text-slate-500 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border file:border-slate-200 file:bg-slate-50 file:text-[11px] file:font-semibold cursor-pointer" />
              `}
            </div>
            <div class="flex gap-2 justify-end">
              <button type="button" onclick="toggleExpandRow('${task._id}')" class="text-[12px] font-semibold text-slate-500 bg-slate-50 hover:bg-slate-100 border border-slate-200 px-4 py-2 rounded-xl transition cursor-pointer active:scale-95">Tutup</button>
              <button type="submit" class="text-[12px] font-semibold text-white bg-blue-600 hover:bg-blue-700 px-5 py-2 rounded-xl transition shadow-sm shadow-blue-100 cursor-pointer active:scale-95">Simpan</button>
            </div>
          </div>
        `;

      const rowHTML = `
          <tr class="hover:bg-slate-50/40 transition-colors group border-b border-slate-100 last:border-0" id="row-view-${task._id}">
            <td class="py-3.5 px-5 text-center whitespace-nowrap">
              <div class="relative inline-block w-[115px]">
                <select onchange="quickUpdateStatus('${task._id}', this.value)" class="w-full text-[10px] font-medium rounded-full px-2.5 py-1 outline-none border cursor-pointer transition appearance-none text-center tracking-wide ${statusStyles[task.status]}">
                  <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                  <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                  <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                  <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
                </select>
              </div>
            </td>
            <td class="py-3.5 px-5">
              <span class="text-[10px] font-medium text-blue-600 bg-blue-50/60 border-blue-200/40 px-2.5 py-0.5 rounded-full border tracking-wide block truncate max-w-[180px]" title="${currentKpiName}">
                ${currentKpiName}
              </span>
            </td>
            <td class="py-3.5 px-5">
              <div class="flex flex-col">
                <span class="${titleStyle}">${task.title}</span>
                <span class="text-[11.5px] text-slate-400 font-normal truncate max-w-md mt-1 italic ${task.resultDescription ? '' : 'hidden'}">
                  Hasil: ${task.resultDescription}
                </span>
              </div>
            </td>
            <td class="py-3.5 px-5">
              ${task.attachmentFile ? `
                <a href="/uploads/files/${task.attachmentFile}" target="_blank" class="inline-flex items-center gap-1.5 text-[11.5px] font-medium text-slate-500 hover:text-blue-600 hover:underline transition truncate max-w-[150px]">
                  <svg class="w-3.5 h-3.5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
                  <span>Lihat Bukti</span>
                </a>
              ` : '<span class="text-slate-300 text-[11px]">—</span>'}
            </td>
            <td class="py-3.5 px-5 text-center">
              <button type="button" onclick="toggleExpandRow('${task._id}')" id="arrow-btn-${task._id}" class="w-7 h-7 inline-flex items-center justify-center text-slate-400 hover:text-slate-700 hover:bg-slate-100 border border-transparent hover:border-slate-200 rounded-lg transition-all duration-200 cursor-pointer">
                <svg class="w-4 h-4 stroke-[2] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
            </td>
          </tr>
          <tr class="expanded-form-row hidden bg-slate-50/40 transition-all" id="row-expand-${task._id}">
            <td colspan="5" class="p-5 border-t border-slate-100 bg-slate-50/30 shadow-inner">
              <form id="form-update-${task._id}" onsubmit="submitFormUpdate(event, '${task._id}')" enctype="multipart/form-data" class="max-w-2xl mx-auto space-y-4 bg-white p-5 rounded-2xl border border-slate-200/80 shadow-sm">
                ${formInnerHTML}
              </form>
            </td>
          </tr>
        `;

      const mobileHTML = `
          <div class="p-4 space-y-3.5 bg-white transition-colors" id="mobile-card-${task._id}">
            <div class="flex items-start justify-between gap-3">
              <div class="space-y-1.5 flex-1 min-w-0">
                <span class="text-[9px] font-medium text-blue-600 bg-blue-50 border-blue-200/40 px-2 py-0.5 rounded-full border tracking-wide inline-block truncate max-w-[200px]" title="${currentKpiName}">
                  ${currentKpiName}
                </span>
                <h3 class="${titleStyle} pt-0.5 break-words">${task.title}</h3>
                ${task.resultDescription ? `<p class="text-[11.5px] text-slate-400 italic bg-slate-50 p-2 rounded-lg border border-slate-100">Hasil: ${task.resultDescription}</p>` : ''}
              </div>
              <button type="button" onclick="toggleExpandRow('${task._id}')" id="arrow-btn-mob-${task._id}" class="w-8 h-8 flex-shrink-0 inline-flex items-center justify-center text-slate-400 border border-slate-200 rounded-lg bg-slate-50 hover:bg-slate-100 transition">
                <svg class="w-4 h-4 stroke-[2.5] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </button>
            </div>
            <div class="flex items-center justify-between gap-4 pt-2 border-t border-slate-100/80">
              <div class="relative w-[115px]">
                <select onchange="quickUpdateStatus('${task._id}', this.value)" class="w-full text-[10px] font-medium rounded-full px-2.5 py-1.5 outline-none border cursor-pointer text-center tracking-wide appearance-none ${statusStyles[task.status]}">
                  <option value="Pending" ${task.status === 'Pending' ? 'selected' : ''}>Pending</option>
                  <option value="In Progress" ${task.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                  <option value="Completed" ${task.status === 'Completed' ? 'selected' : ''}>Completed</option>
                  <option value="Canceled" ${task.status === 'Canceled' ? 'selected' : ''}>Canceled</option>
                </select>
              </div>
              ${task.attachmentFile ? `
                <a href="/uploads/files/${task.attachmentFile}" target="_blank" class="text-[11.5px] font-semibold text-blue-600 hover:underline truncate max-w-[140px]">📎 Lihat Bukti</a>
              ` : '<span class="text-slate-300 text-[11px] italic">Tidak ada bukti</span>'}
            </div>
            <div class="hidden mt-4 pt-4 border-t border-slate-200/80" id="row-expand-mob-${task._id}">
              <form id="form-update-mob-${task._id}" onsubmit="submitFormUpdate(event, '${task._id}', true)" enctype="multipart/form-data" class="space-y-4 bg-white">
                ${formInnerHTML}
              </form>
            </div>
          </div>
        `;

      tbody.insertAdjacentHTML('beforeend', rowHTML);
      mobileList.insertAdjacentHTML('beforeend', mobileHTML);
    });
  }

  function toggleExpandRow(id) {
    const expandRowDesktop = document.getElementById(`row-expand-${id}`);
    const expandRowMobile = document.getElementById(`row-expand-mob-${id}`);
    const arrowBtnDesktop = document.getElementById(`arrow-btn-${id}`);
    const arrowBtnMobile = document.getElementById(`arrow-btn-mob-${id}`);
    const mobileCard = document.getElementById(`mobile-card-${id}`);

    if (expandRowDesktop) expandRowDesktop.classList.toggle('hidden');
    if (arrowBtnDesktop) arrowBtnDesktop.classList.toggle('rotate-180');

    if (expandRowMobile) {
      expandRowMobile.classList.toggle('hidden');
      mobileCard.classList.toggle('bg-slate-50/40');
    }
    if (arrowBtnMobile) arrowBtnMobile.classList.toggle('rotate-180');
  }

  async function submitFormCreate(event) {
    event.preventDefault();
    const form = document.getElementById('form-create-activity');
    
    // Properti payload disesuaikan penuh dengan ekspektasi backend (activityDate & title)
    const formData = {
      title: document.getElementById('add-title').value,
      kpiTemplateId: document.getElementById('add-kpiTemplateId').value,
      activityDate: datePicker.value
    };

    try {
      const response = await fetch('/daily-activities/api', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
      });
      const result = await response.json();
      if (result.success) {
        form.reset();
        if (availableKpis.length > 0) {
          document.getElementById('add-kpiTemplateId').value = availableKpis[0]._id;
        }
        loadDailyLog();
      }
    } catch (err) {
      console.error(err);
    }
  }

  async function quickUpdateStatus(id, newStatus) {
    try {
      const response = await fetch(`/daily-activities/api/${id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          status: newStatus
        })
      });
      const result = await response.json();
      if (result.success) {
        loadDailyLog();
      }
    } catch (err) {
      console.error(err);
    }
  }

  async function submitFormUpdate(event, id, isMobile = false) {
    event.preventDefault();
    const formId = isMobile ? `form-update-mob-${id}` : `form-update-${id}`;
    const form = document.getElementById(formId);
    const formData = new FormData(form);

    try {
      const response = await fetch(`/daily-activities/api/${id}`, {
        method: 'PUT',
        body: formData
      });
      const result = await response.json();
      if (result.success) {
        loadDailyLog();
      }
    } catch (err) {
      console.error(err);
    }
  }

  function switchToEditFile(id) {
    const statusContainer = document.getElementById(`file-status-container-${id}`);
    const inputFile = document.getElementById(`input-file-${id}`);
    if (statusContainer && inputFile) {
      statusContainer.classList.add('hidden');
      inputFile.classList.remove('hidden');
    }
  }

  async function executeCarryOver() {
    try {
      const response = await fetch('/daily-activities/api/carry-over', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          tanggalHariIni: datePicker.value
        })
      });
      const result = await response.json();
      if (result.success) {
        loadDailyLog();
      }
    } catch (err) {
      console.error(err);
    }
  }

  datePicker.addEventListener('change', loadDailyLog);
  window.onload = function() {
    loadDailyLog();
  };
</script>
<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 sm:p-6 md:p-10 antialiased pb-24 text-slate-800">
  <div class="w-full max-w-2xl mx-auto space-y-6">
    
    <div class="bg-white rounded-2xl p-6 border border-slate-200/60 shadow-xs">
      <div class="flex items-center gap-3 border-b border-slate-100 pb-4 mb-6">
        <a href="/reward-punishment" class="w-8 h-8 rounded-xl border border-slate-200 flex items-center justify-center text-slate-400 hover:text-slate-600"><i class="fa-solid fa-arrow-left text-xs"></i></a>
        <div>
          <h2 class="text-base font-bold text-slate-900">Formulir Pencatatan Baru</h2>
          <p class="text-xs text-slate-400">Terbitkan lembar sanksi kedisiplinan atau penghargaan pegawai.</p>
        </div>
      </div>

      <form action="/reward-punishment" method="POST" class="space-y-5">
        
        <div>
          <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Pilih Pegawai</label>
          <select name="employeeId" required class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:border-blue-500">
            <option value="" disabled selected>-- Pilih Personel --</option>
            <% employees.forEach(emp => { %>
              <option value="<%= emp._id %>" <%= (typeof old !== 'undefined' && old.employeeId == emp._id.toString()) ? 'selected' : '' %>><%= emp.fullName %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Jenis Reward / Punishment</label>
          <select name="typeId" required class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:border-blue-500">
            <option value="" disabled selected>-- Pilih Jenis SK Master --</option>
            <% types.forEach(t => { %>
              <option value="<%= t._id %>" <%= (typeof old !== 'undefined' && old.typeId == t._id.toString()) ? 'selected' : '' %>>
                [<%= t.category %>] <%= t.name %> (<%= t.financialImpact >= 0 ? '+' : '' %><%= t.financialImpact %>)
              </option>
            <% }) %>
          </select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Nomor Surat Keputusan (SK)</label>
            <input type="text" name="skNumber" value="<%= typeof old !== 'undefined' ? old.skNumber : '' %>" placeholder="Contoh: SK/REWARD/2026/001" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:border-blue-500">
          </div>
          <div>
            <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Tanggal Berlaku</label>
            <input type="date" name="dateIssued" value="<%= typeof old !== 'undefined' ? old.dateIssued : today %>" required class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:border-blue-500">
          </div>
        </div>

        <div>
          <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Deskripsi / Alasan</label>
          <textarea name="reason" required rows="4" placeholder="Tuliskan justifikasi detail mengenai dikeluarkannya dokumen ini..." class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:border-blue-500"><%= typeof old !== 'undefined' ? old.reason : '' %></textarea>
        </div>

        <div class="flex items-center justify-end gap-3 pt-3 border-t border-slate-100">
          <a href="/reward-punishment" class="h-10 px-4 border border-slate-200 text-slate-600 text-xs font-semibold rounded-xl hover:bg-slate-50 flex items-center justify-center">Batal</a>
          <button type="submit" class="h-10 px-5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-xl shadow-sm cursor-pointer">Simpan Log Catatan</button>
        </div>
      </form>
    </div>

  </div>
</div>
<div class="flex items-center gap-2 flex-wrap select-none">
  <% if(typeof isPinned !== 'undefined' && isPinned) { %>
    <span class="inline-flex items-center bg-amber-50 text-amber-700 border border-amber-200/60 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase">
      <i class="fa-solid fa-thumbtack text-[9px] mr-1.5 text-amber-500 shrink-0"></i>
      Pinned
    </span>
  <% } %>

  <% if(category === "OFFICIAL") { %>
    <span class="inline-flex items-center bg-blue-50 text-blue-600 border border-blue-200/50 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-500 mr-1.5 shrink-0"></span>
      Official
    </span>
  <% } else { %>
    <span class="inline-flex items-center bg-slate-50 text-slate-500 border border-slate-200/60 px-2.5 py-1 rounded-lg text-[10px] font-medium tracking-wide uppercase">
      <span class="w-1.5 h-1.5 rounded-full bg-slate-400 mr-1.5 shrink-0"></span>
      General
    </span>
  <% } %>
</div>
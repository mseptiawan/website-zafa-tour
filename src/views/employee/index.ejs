<%- layout('layouts/main', { title: "Data Pegawai" }) %>

<% 
  // =========================================================================
  // LOGIKA STATISTIK & FORMATTING KILAT
  // =========================================================================
  const totalPegawai = employees ? employees.length : 0;
  const pegawaiAktif = employees ? employees.filter(e => (e.userId && e.userId.status === 'Active') && !(e.terminationInfo && e.terminationInfo.statusPHK === 'Waiting')).length : 0;
  const pegawaiPhk = totalPegawai - employees.filter(e => e.userId && e.userId.status === 'Active').length;

  function getStatusConfig(status, isWaitingPHK) {
    if (isWaitingPHK) {
      return { label: 'Waiting Approval', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500 animate-pulse' };
    }
    switch(status) {
      case 'Active': return { label: 'Active', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500' };
      case 'Suspended': return { label: 'Suspended', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500' };
      case 'Inactive': return { label: 'Inactive', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' };
      default: return { label: status, badge: 'bg-slate-50 text-slate-600 border-slate-200/50', dot: 'bg-slate-500' };
    }
  }
%>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 sm:p-6 md:p-10 antialiased pb-24 md:pb-8 text-slate-800">
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

    <div class="border border-slate-200/60 md:border-none md:shadow-none">
      <%- include('../partials/page-header', {
        section: 'Area Kerja',
        module: 'SDM',
        title: 'Data Pegawai',
        description: 'Kelola informasi, peran, dan lacak status keanggotaan seluruh organisasi.'
      }) %>
    </div>

    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        gridClass: 'grid-cols-1 sm:grid-cols-3',
        items: [
          { 
            label: 'Total Pegawai', 
            value: totalPegawai, 
            unit: ' Orang', 
            icon: 'fa-solid fa-users', 
            labelClass: '!font-medium text-slate-400', 
            valueClass: '!font-medium text-slate-800', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          },
          { 
            label: 'Pegawai Aktif', 
            value: pegawaiAktif, 
            unit: ' Aktif', 
            icon: 'fa-solid fa-user-check', 
            labelClass: '!font-medium text-emerald-600', 
            valueClass: '!font-medium text-emerald-700', 
            iconBoxClass: 'bg-emerald-50 text-emerald-500 border border-emerald-200/50' 
          },
          { 
            label: 'Arsip Nonaktif', 
            value: pegawaiPhk, 
            unit: ' Berkas', 
            icon: 'fa-solid fa-user-minus', 
            labelClass: '!font-medium text-rose-600', 
            valueClass: '!font-medium text-rose-700', 
            iconBoxClass: 'bg-rose-50 text-rose-500 border border-rose-200/50' 
          }
        ]
      }) %>
    </div>

    <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50 shadow-2xs">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-[13px] table-fixed">
          <thead>
            <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
              <th class="py-4 px-6 w-[22%]">Pegawai</th>
              <th class="py-4 px-6 w-[20%]">Posisi & Bidang</th>
              <th class="py-4 px-6 w-[18%]">Unit Kerja</th>
              <th class="py-4 px-6 w-[16%]">Info Finansial</th>
              <th class="py-4 px-6 w-[12%] text-center">Status</th>
              <th class="py-4 px-6 w-[12%] text-center">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
            <% if (employees && employees.length > 0) { %>
              <% employees.forEach(e => { %>
                <% 
                  const isApprovedPHK = e.userId && e.userId.status === 'Inactive'; 
                  const isWaitingPHK = e.terminationInfo && e.terminationInfo.statusPHK === 'Waiting';
                  const config = getStatusConfig(e.userId?.status || 'Active', isWaitingPHK);
                %>
                <tr class="hover:bg-slate-50/40 transition-colors <%= isApprovedPHK ? 'bg-rose-50/10' : '' %> <%= isWaitingPHK ? 'bg-amber-50/10' : '' %>">
                  
                  <td class="py-4 px-6">
                    <span class="font-bold text-slate-800 block truncate <%= isApprovedPHK ? 'line-through text-slate-400 decoration-slate-300' : '' %>">
                      <%= e.fullName %>
                    </span>
                    <span class="text-[10.5px] text-slate-400 font-medium block mt-0.5">🪪 ID: <%= e.employeeIdNumber %></span>
                  </td>

                  <td class="py-4 px-6">
                    <span class="text-slate-700 block truncate"><%= e.careerData?.positionId?.name || '-' %></span>
                    <span class="text-[10.5px] text-slate-400 font-medium block mt-0.5">🏢 Bidang: <%= e.careerData?.bidangId?.name || '-' %></span>
                  </td>

                  <td class="py-4 px-6">
                    <span class="inline-flex items-center px-2 py-0.5 bg-slate-50 border border-slate-200/80 rounded-md text-[11px] text-slate-700 font-semibold mb-0.5">
                      <%= e.careerData?.unitId?.name || '-' %>
                    </span>
                    <span class="text-[10.5px] text-slate-400 font-medium block"><%= e.careerData?.status_pegawai || '-' %></span>
                  </td>

                  <td class="py-4 px-6 tabular-nums">
                    <span class="font-bold text-slate-800 block">Rp <%= (e.financialData?.basicSalary || 0).toLocaleString('id-ID') %></span>
                    <span class="text-[10.5px] text-slate-400 font-medium block mt-0.5">⏱️ Lembur: Rp <%= (e.financialData?.overtimeRate || 0).toLocaleString('id-ID') %>/jam</span>
                  </td>

                  <td class="py-4 px-6 text-center select-none">
                    <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-bold border tracking-wide uppercase <%= config.badge %>">
                      <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                      <span><%= config.label.toUpperCase() %></span>
                    </div>
                  </td>

                  <td class="py-4 px-6 text-center">
                    <div class="flex items-center justify-center gap-1.5">
                      <% if (isApprovedPHK) { %>
                        <button type="button" data-action="show-history" data-name="<%= e.fullName %>" data-reason="<%= e.terminationInfo?.reason || 'Tidak ada alasan' %>" data-approved="<%= e.terminationInfo?.approvedBy || 'Pimpinan' %>" data-date="<%= e.terminationInfo?.date || '-' %>" class="h-7 px-2.5 bg-white border border-rose-200 text-rose-600 hover:bg-rose-50 text-[11px] font-semibold rounded-lg transition-all cursor-pointer inline-flex items-center gap-1">
                          <i class="fa-solid fa-folder-open text-[10px]"></i> Arsip
                        </button>
                      <% } else { %>
                        <a href="/employee/detail/<%= e._id %>" title="Detail Profil" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-500 inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-slate-50">
                          <i class="fa-solid fa-eye text-[11px]"></i>
                        </a>

                        <% if (user && user.role === 'WAKIL_DIREKTUR') { %>
                          <a href="/employee/edit/<%= e._id %>" title="Ubah Data" class="w-8 h-8 rounded-lg bg-amber-400 text-white inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-amber-500">
                            <i class="fa-solid fa-pen-to-square text-[11px]"></i>
                          </a>

                          <% if (isWaitingPHK) { %>
                            <button type="button" disabled class="w-8 h-8 flex items-center justify-center bg-amber-50 border border-amber-200 rounded-lg text-amber-500 cursor-not-allowed">
                              <i class="fa-solid fa-spinner animate-spin text-[11px]"></i>
                            </button>
                          <% } else { %>
                            <button type="button" data-action="open-phk" data-id="<%= e._id %>" data-name="<%= e.fullName %>" title="Ajukan PHK" class="w-8 h-8 rounded-lg border border-rose-200 bg-rose-50/40 text-rose-600 inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-rose-50 cursor-pointer">
                              <i class="fa-solid fa-user-xmark text-[11px]"></i>
                            </button>
                          <% } %>
                        <% } %>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="py-12 text-center text-slate-400 font-medium">Tidak ada data pegawai ditemukan.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <div class="px-6 py-3.5 border-t border-slate-100 bg-slate-50/40 text-[11px] text-slate-400 font-medium select-none">
        Menampilkan <%= employees ? employees.length : 0 %> Pegawai
      </div>
    </div>

    <div class="block md:hidden space-y-3.5 w-full">
      <% if (!employees || employees.length === 0) { %>
        <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4"><p class="text-[12px] font-medium text-slate-400">Tidak ada data pegawai</p></div>
      <% } else { %>
        <% employees.forEach(e => { %>
          <% 
            const isApprovedPHK = e.userId && e.userId.status === 'Inactive'; 
            const isWaitingPHK = e.terminationInfo && e.terminationInfo.statusPHK === 'Waiting';
            const config = getStatusConfig(e.userId?.status || 'Active', isWaitingPHK);
          %>
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5 shadow-2xs">
            
            <div class="flex items-start justify-between gap-2">
              <div>
                <h4 class="text-[13px] font-bold text-slate-800 tracking-tight <%= isApprovedPHK ? 'line-through text-slate-400 decoration-slate-300' : '' %>">
                  <%= e.fullName %>
                </h4>
                <p class="text-[11px] text-slate-400 font-medium mt-0.5">🪪 ID: <%= e.employeeIdNumber %></p>
              </div>
              <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-bold tracking-wider border shrink-0 uppercase <%= config.badge %>">
                <span><%= config.label %></span>
              </div>
            </div>

            <div class="bg-slate-50 p-3 rounded-xl border border-slate-200/30 text-xs space-y-1.5">
              <div>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Posisi & Unit</p>
                <p class="text-slate-700 font-semibold mt-0.5"><%= e.careerData?.positionId?.name || '-' %> (<%= e.careerData?.unitId?.name || '-' %>)</p>
              </div>
              <div class="pt-1.5 border-t border-slate-200/60 flex justify-between items-center">
                <div>
                  <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Gaji Pokok</p>
                  <p class="text-slate-800 font-bold">Rp <%= (e.financialData?.basicSalary || 0).toLocaleString('id-ID') %></p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Status Kerja</p>
                  <p class="text-slate-500 font-medium"><%= e.careerData?.status_pegawai || '-' %></p>
                </div>
              </div>
            </div>

            <div class="flex items-center justify-between gap-2 pt-0.5">
              <span class="text-[10.5px] text-slate-400 font-medium">Bidang: <%= e.careerData?.bidangId?.name || '-' %></span>
              
              <div class="flex items-center gap-1.5">
                <% if (isApprovedPHK) { %>
                  <button type="button" data-action="show-history" data-name="<%= e.fullName %>" data-reason="<%= e.terminationInfo?.reason || 'Tidak ada alasan' %>" data-approved="<%= e.terminationInfo?.approvedBy || 'Pimpinan' %>" data-date="<%= e.terminationInfo?.date || '-' %>" class="h-7 px-3 bg-white border border-rose-200 text-rose-600 font-semibold text-[11px] rounded-md inline-flex items-center gap-1">
                    <i class="fa-solid fa-folder-open"></i> Arsip PHK
                  </button>
                <% } else { %>
                  <a href="/employee/detail/<%= e._id %>" class="h-7 w-7 bg-white border border-slate-200 text-slate-500 flex items-center justify-center text-xs rounded-md shadow-xs" title="Detail">
                    <i class="fa-solid fa-eye"></i>
                  </a>
                  <% if (user && user.role === 'WAKIL_DIREKTUR') { %>
                    <a href="/employee/edit/<%= e._id %>" class="h-7 w-7 bg-amber-400 text-white flex items-center justify-center text-xs rounded-md shadow-xs" title="Ubah Data">
                      <i class="fa-solid fa-marker"></i>
                    </a>
                    <% if (!isWaitingPHK) { %>
                      <button type="button" data-action="open-phk" data-id="<%= e._id %>" data-name="<%= e.fullName %>" class="h-7 w-7 bg-white border border-rose-200 text-rose-600 flex items-center justify-center text-xs rounded-md shadow-xs">
                        <i class="fa-solid fa-user-xmark"></i>
                      </button>
                    <% } %>
                  <% } %>
                <% } %>
              </div>
            </div>

          </div>
        <% }) %>
      <% } %>
    </div>

  </div>
</div>

<div id="phkModal" class="fixed inset-0 z-[120] hidden bg-slate-900/40 backdrop-blur-xs flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl max-w-md w-full border border-slate-100 shadow-2xl overflow-hidden transform scale-95 transition-all duration-200">
    <div class="p-5 space-y-4">
      <div class="flex items-center gap-2.5 text-rose-600">
        <div class="w-7 h-7 rounded-lg bg-rose-50 flex items-center justify-center text-xs"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <h3 class="text-sm font-bold text-slate-800">Ajukan Pemutusan Hubungan Kerja</h3>
      </div>
      <p class="text-xs text-slate-500 leading-relaxed">Pengajuan ini akan dikirim ke Pusat Otorisasi Pimpinan untuk divalidasi secara bertahap.</p>
      
      <div class="bg-slate-50 p-3 rounded-xl border border-slate-200/50 text-xs font-semibold text-slate-600 flex items-center gap-1.5 select-none">
        <span>Pegawai:</span>
        <span id="empName" class="text-blue-600 font-bold"></span>
      </div>

      <form id="phkForm" action="/api/employee/phk" method="POST" enctype="multipart/form-data" class="space-y-4">
        <input type="hidden" name="employeeId" id="employeeId">
        
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Alasan Pengajuan</label>
          <textarea name="reason" required rows="3" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 transition-all" placeholder="Tuliskan alasan penghentian hak kerja secara detail..."></textarea>
        </div>

        <div>
          <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Berkas Pendukung (.pdf, .jpg, .png)</label>
          <input type="file" name="document" accept=".pdf,.jpg,.png" required class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-2.5 focus:outline-none focus:border-blue-500 transition-all file:mr-3 file:py-1 file:px-2.5 file:rounded-md file:border-0 file:text-[11px] file:font-semibold file:bg-blue-50 file:text-blue-600 hover:file:bg-blue-100">
        </div>

        <div class="flex items-center justify-end gap-2 pt-1 border-t border-slate-100">
          <button type="button" id="btn-close-phk" class="h-8.5 px-3.5 border border-slate-200 text-slate-600 text-xs font-semibold rounded-xl hover:bg-slate-50 cursor-pointer">Batal</button>
          <button type="submit" class="h-8.5 px-4 bg-rose-600 hover:bg-rose-700 text-white text-xs font-semibold rounded-xl shadow-sm cursor-pointer">Kirim Pengajuan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="historyModal" class="fixed inset-0 z-[120] hidden bg-slate-900/40 backdrop-blur-xs flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl max-w-md w-full border border-slate-100 shadow-2xl overflow-hidden transform scale-95 transition-all duration-200">
    <div class="p-5 space-y-4">
      <div class="flex items-center gap-2.5 text-slate-800">
        <div class="w-7 h-7 rounded-lg bg-slate-50 flex items-center justify-center text-xs text-slate-500"><i class="fa-solid fa-folder-closed"></i></div>
        <h3 class="text-sm font-bold text-slate-800">Detail Dokumen Arsip Keluar</h3>
      </div>
      
      <div class="space-y-3 bg-slate-50 p-4 rounded-xl border border-slate-200/40 text-xs">
        <div>
          <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wide">Nama Mantan Pegawai</span>
          <span id="histName" class="font-bold text-slate-700 text-[13px]"></span>
        </div>
        <div class="grid grid-cols-2 gap-2 pt-1">
          <div>
            <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wide">Disahkan Oleh</span>
            <span id="histAdmin" class="font-semibold text-slate-600"></span>
          </div>
          <div>
            <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wide">Tanggal Keluar</span>
            <span id="histDate" class="font-semibold text-slate-600 tabular-nums"></span>
          </div>
        </div>
        <div class="pt-2.5 border-t border-slate-200/60">
          <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-wide mb-1">Alasan Resmi PHK</span>
          <p id="histReason" class="text-slate-600 font-normal leading-relaxed italic bg-white p-2.5 rounded-lg border border-slate-200/50 break-words"></p>
        </div>
      </div>

      <div class="flex items-center justify-end pt-1">
        <button type="button" id="btn-close-history" class="h-8.5 px-4 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-xl shadow-sm cursor-pointer">Tutup Dokumen</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/employee-list.js" defer></script>
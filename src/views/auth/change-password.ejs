<%- layout('layouts/main', { title: 'Ubah Password' }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50 md:bg-[#FCFCFD] p-4 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-xl mx-auto">

    <div class="pb-5 select-none">
      <%- include('../partials/page-header', {
        section: 'Pengaturan Akun',
        module: 'Keamanan',
        title: 'Ubah Password',
        description: 'Amankan akun Anda dengan memperbarui kata sandi secara berkala.'
      }) %>
    </div>

    <% if (query?.error === "WRONG_CURRENT_PASSWORD") { %>
      <div class="mb-5 p-4 bg-red-50 border border-red-100 text-red-700 text-[12.5px] font-bold rounded-xl flex items-start gap-2.5">
        <i class="fa-solid fa-circle-exclamation w-4 h-4 shrink-0 mt-0.5 text-red-500"></i>
        <span>Password lama yang Anda masukkan salah.</span>
      </div>
    <% } %>

    <% if (query?.error === "PASSWORD_MISMATCH") { %>
      <div class="mb-5 p-4 bg-red-50 border border-red-100 text-red-700 text-[12.5px] font-bold rounded-xl flex items-start gap-2.5">
        <i class="fa-solid fa-circle-exclamation w-4 h-4 shrink-0 mt-0.5 text-red-500"></i>
        <span>Konfirmasi password baru tidak cocok.</span>
      </div>
    <% } %>

    <% if (query?.error === "WEAK_PASSWORD") { %>
      <div class="mb-5 p-4 bg-red-50 border border-red-100 text-red-700 text-[12.5px] font-bold rounded-xl flex items-start gap-2.5">
        <i class="fa-solid fa-circle-exclamation w-4 h-4 shrink-0 mt-0.5 text-red-500"></i>
        <span>Password baru terlalu lemah. Minimal wajib 6 karakter.</span>
      </div>
    <% } %>

    <% if (query?.success === "PASSWORD_CHANGED") { %>
      <div class="mb-5 p-4 bg-emerald-50 border border-emerald-100 text-emerald-700 text-[12.5px] font-bold rounded-xl flex items-start gap-2.5">
        <i class="fa-solid fa-circle-check w-4 h-4 shrink-0 mt-0.5 text-emerald-500"></i>
        <span>Kata sandi Anda berhasil diperbarui.</span>
      </div>
    <% } %>

    <div class="bg-white border border-slate-200/60 rounded-2xl shadow-3xs overflow-hidden">
      <form id="change-password-form" method="POST" class="p-6 md:p-8 space-y-5" action="/change-password">

        <div class="space-y-1.5">
          <label class="text-[12px] font-bold text-slate-500">Password Saat Ini <span class="text-red-500">*</span></label>
          <input 
            type="password" 
            name="currentPassword" 
            required 
            placeholder="Ketik password yang digunakan sekarang..."
            class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-2.5 text-[13px] font-semibold text-slate-700 placeholder-slate-400/80 outline-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all" 
          />
        </div>

        <hr class="border-t border-slate-100/80 my-2" />

        <div class="space-y-1.5">
          <label class="text-[12px] font-bold text-slate-500">Password Baru <span class="text-red-500">*</span></label>
          <input 
            type="password" 
            id="newPassword"
            name="password" 
            required 
            placeholder="Minimal 6 karakter kombinasi huruf & angka..."
            class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-2.5 text-[13px] font-semibold text-slate-700 placeholder-slate-400/80 outline-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all" 
          />
        </div>

        <div class="space-y-1.5">
          <label class="text-[12px] font-bold text-slate-500">Konfirmasi Password Baru <span class="text-red-500">*</span></label>
          <input 
            type="password" 
            id="confirmPassword"
            name="confirmPassword" 
            required 
            placeholder="Ulangi ketik password baru Anda..."
            class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-2.5 text-[13px] font-semibold text-slate-700 placeholder-slate-400/80 outline-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all" 
          />
        </div>

        <div class="pt-5 border-t border-slate-100/80 flex items-center justify-end gap-2.5 select-none">
          <a href="/dashboard" class="inline-flex items-center justify-center bg-slate-100 hover:bg-slate-200 text-slate-600 h-9.5 px-4 text-[12px] font-bold rounded-xl transition-all active:scale-[0.98] decoration-none">
            Batal
          </a>
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white h-9.5 px-5 text-[12px] font-bold rounded-xl transition-all border-none shadow-xs active:scale-[0.98] cursor-pointer">
            Perbarui Password
          </button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  // Validasi Sisi Klien untuk kecocokan konfirmasi password
  document.getElementById('change-password-form').addEventListener('submit', function(e) {
    const password = document.getElementById('newPassword').value;
    const confirm = document.getElementById('confirmPassword').value;

    if (password.length < 6) {
      e.preventDefault();
      alert('Password baru minimal harus terdiri dari 6 karakter!');
      return false;
    }

    if (password !== confirm) {
      e.preventDefault();
      alert('Konfirmasi password baru tidak cocok dengan yang Anda ketik!');
      return false;
    }
  });
</script>
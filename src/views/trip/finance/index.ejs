<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8">

    <div class="max-w-5xl mx-auto">

      <!-- HEADER -->
      <div class="mb-8">
        <h1 class="text-2xl font-semibold text-slate-800">
          Permintaan Pembayaran Dinas Luar
        </h1>
        <p class="text-sm text-slate-500 mt-1">
          Daftar pengajuan yang menunggu atau sudah diproses pembayaran
        </p>
      </div>

      <!-- CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">

        <div class="overflow-x-auto">

          <table class="w-full text-sm min-w-[900px]">

            <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
              <tr>
                <th class="text-left px-6 py-4">Nama Pengaju</th>
                <th class="text-left px-6 py-4">Judul</th>
                <th class="text-left px-6 py-4">Tanggal</th>
                <th class="text-left px-6 py-4">Budget</th>
                <th class="text-left px-6 py-4">Status Pembayaran</th>
                <th class="text-left px-6 py-4">Aksi</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-slate-100">

              <% if (trips.length===0) { %>
                <tr>
                  <td colspan="6" class="text-center py-10 text-slate-400">
                    Tidak ada data pembayaran
                  </td>
                </tr>
                <% } %>

                  <% trips.forEach(t=> { %>
                    <tr class="hover:bg-slate-50 transition">

                      <!-- PENGAJU -->
                      <td class="px-6 py-4 font-medium text-slate-800">
                        <%= t.userId?.username || '-' %>
                      </td>

                      <!-- JUDUL -->
                      <td class="px-6 py-4 text-slate-600">
                        <%= t.title %>
                      </td>

                      <!-- TANGGAL -->
                      <td class="px-6 py-4 text-slate-500">
                        <%= t.createdAt ? new Date(t.createdAt).toLocaleDateString('id-ID') : '-' %>
                      </td>

                      <!-- BUDGET -->
                      <td class="px-6 py-4 font-semibold text-slate-700">
                        Rp <%= (t.budget || 0).toLocaleString('id-ID') %>
                      </td>

                      <!-- STATUS -->
                      <!-- STATUS (PAYMENT STATUS) -->
                      <td class="px-6 py-4">
                        <span class="text-xs px-3 py-1 rounded-md font-medium border
    <%= t.payment?.status === 'PAID'
      ? 'bg-emerald-50 text-emerald-600 border-emerald-200'
      : t.payment?.status === 'PROCESSING'
        ? 'bg-amber-50 text-amber-600 border-amber-200'
        : t.payment?.status === 'FAILED'
          ? 'bg-red-50 text-red-600 border-red-200'
          : 'bg-blue-50 text-blue-600 border-blue-200'
    %>
  ">
                          <%= t.payment?.status || 'PENDING' %>
                        </span>
                      </td>

                      <!-- AKSI -->
                      <td class="px-6 py-4">

                        <a href="/finance/<%= t._id %>"
                          class="p-2 inline-flex rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50 hover:text-slate-700 transition"
                          title="Detail">

                          <!-- eye icon -->
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                          </svg>

                        </a>

                      </td>

                    </tr>
                    <% }) %>

            </tbody>

          </table>

        </div>

      </div>

    </div>
  </div>
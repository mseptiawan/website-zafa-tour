<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-[#FCFCFD] p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
    <div class="max-w-6xl mx-auto">

      <!-- HEADER INTERFACE -->
      <div class="flex items-center justify-between mb-8 pb-5 border-b border-slate-100">
        <div class="space-y-1">
          <h1 class="text-2xl font-bold text-slate-900 tracking-tight">
            Pengumuman
          </h1>
          <p class="text-slate-500 text-[13px] flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Informasi internal dan manajemen terbaru
          </p>
        </div>

        <a href="/announcement/new"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2.5 rounded-xl text-[13px] font-medium transition-all duration-200 border border-blue-700/30 shadow-sm shadow-blue-100/50 active:scale-[0.98]">
          <svg class="w-4 h-4 text-white/90 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Buat Baru
        </a>
      </div>

      <!-- 3-COLUMN COMPACT GRID -->
      <% if(announcements.length> 0) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4.5">

          <% announcements.forEach(a=> { %>
            <a href="/announcement/<%= a._id %>"
              class="group relative flex flex-col justify-between bg-white border border-slate-200/70 rounded-xl p-4.5 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50/50 shadow-sm hover:shadow-md hover:shadow-slate-100/60 min-h-[210px]">

              <div>
                <!-- MIX STATUS BADGES -->
                <div class="flex items-center gap-1.5 mb-3 flex-wrap">
                  <% if(a.isPinned) { %>
                    <span
                      class="inline-flex items-center bg-amber-50 text-amber-700 border border-amber-200/60 px-2 py-0.5 rounded-md text-[10px] font-bold tracking-wide uppercase">
                      📌 Pinned
                    </span>
                    <% } %>

                      <% if(a.category==="OFFICIAL" ) { %>
                        <span
                          class="inline-flex items-center bg-blue-50 text-blue-700 border border-blue-200/50 px-2 py-0.5 rounded-md text-[10px] font-bold tracking-wide uppercase">
                          Official
                        </span>
                        <% } %>
                </div>

                <!-- TITLE (COMPACT SIZE) -->
                <h2
                  class="text-[15px] font-bold text-slate-800 leading-snug break-words mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">
                  <%= a.title %>
                </h2>

                <!-- CONTENT WITH LINE CLAMP (Maksimal 3 Baris agar rapi) -->
                <p class="text-[12.5px] text-slate-500 leading-relaxed break-words line-clamp-3 mb-4">
                  <%= a.content %>
                </p>
              </div>

              <!-- CARD COMPACT FOOTER -->
              <div class="pt-3.5 border-t border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-2.5 min-w-0">
                  <!-- Avatar Initial -->
                  <div
                    class="w-7 h-7 rounded-lg bg-slate-100 border border-slate-200 flex-shrink-0 flex items-center justify-center text-[11px] font-semibold text-slate-600 uppercase">
                    <%= a.createdBy?.username ? a.createdBy.username.charAt(0) : '?' %>
                  </div>

                  <div class="flex flex-col min-w-0">
                    <span class="text-[11.5px] font-semibold text-slate-700 truncate">
                      <%= a.createdBy?.username || 'Unknown' %>
                    </span>
                    <span class="text-[10.5px] text-slate-400 font-medium">
                      <%= new Date(a.createdAt).toLocaleDateString("id-ID", { day: "2-digit" , month: "short" ,
                        year: "numeric" }) %>
                    </span>
                  </div>
                </div>

                <!-- Hover Arrow Action Indicator -->
                <svg
                  class="w-3.5 h-3.5 text-slate-400 opacity-0 transform -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200 stroke-[2.5]"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>

            </a>
            <% }) %>

        </div>

        <% } else { %>
          <!-- EMPTY STATE INTERFACE -->
          <div class="bg-white border border-slate-200/60 rounded-2xl py-16 text-center shadow-sm">
            <div
              class="w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-3 text-slate-400">
              <svg class="w-6 h-6 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold text-slate-700">Belum Ada Pengumuman</h3>
            <p class="text-slate-400 text-[12px] mt-1">Seluruh rilis informasi internal penting akan tampil di halaman
              ini.</p>
          </div>
          <% } %>

            <!-- PAGINATION CONTROL CONTROLLER -->
            <% if (pagination.totalPages> 1) { %>
              <div
                class="flex items-center justify-between mt-8 px-5 py-3.5 bg-white border border-slate-200/60 rounded-xl shadow-sm text-[13px]">
                <div class="text-slate-500 font-medium">
                  Halaman <span class="font-bold text-slate-900">
                    <%= pagination.page %>
                  </span> dari <span class="font-bold text-slate-900">
                    <%= pagination.totalPages %>
                  </span>
                </div>

                <div class="flex items-center gap-2">
                  <!-- PREV PAGE -->
                  <a href="?page=<%= pagination.page - 1 %>"
                    class="px-3.5 py-2 rounded-lg border text-[12px] font-bold transition-all flex items-center gap-1.5
            <%= pagination.hasPrev ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50' : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
                    <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                    Prev
                  </a>

                  <!-- NEXT PAGE -->
                  <a href="?page=<%= pagination.page + 1 %>"
                    class="px-3.5 py-2 rounded-lg border text-[12px] font-bold transition-all flex items-center gap-1.5
            <%= pagination.hasNext ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50' : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
                    Next
                    <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
              <% } %>

    </div>
  </div>
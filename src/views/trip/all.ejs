<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">

  <div class="max-w-7xl mx-auto">

    <!-- HEADER -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-800">
        Pengajuan Dinas Luar
      </h1>
      <p class="text-sm text-slate-500 mt-2">
        Semua pengajuan perjalanan dinas karyawan
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

      <div class="overflow-x-auto">
        <table class="w-full text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wider">
            <tr>
              <th class="p-4 text-left">Karyawan</th>
              <th class="text-left">Tujuan</th>
              <th class="text-left">Tanggal</th>
              <th class="text-left">Budget</th>
              <th class="text-left">Status</th>
              <th class="text-left">Aksi</th>
            </tr>
          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (trips.length === 0) { %>
              <tr>
                <td colspan="6" class="p-10 text-center text-slate-400">
                  Tidak ada data pengajuan
                </td>
              </tr>
            <% } %>

            <% trips.forEach(trip => { %>
              <tr class="hover:bg-slate-50 transition">

                <!-- USER -->
                <td class="p-4 font-semibold text-slate-800">
                  <%= trip.userId?.username || "Unknown" %>
                </td>

                <!-- TUJUAN -->
                <td class="text-slate-600">
                  <%= trip.destination %>
                </td>

                <!-- TANGGAL -->
                <td class="text-slate-600">
                  <%= new Date(trip.startDate).toLocaleDateString('id-ID') %>
                  -
                  <%= new Date(trip.endDate).toLocaleDateString('id-ID') %>
                </td>

                <!-- BUDGET -->
                <td class="text-slate-600 font-medium">
                  Rp <%= Number(trip.budget).toLocaleString('id-ID') %>
                </td>

                <!-- STATUS -->
                <td>
                  <% if (trip.status === 'PENDING') { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-yellow-50 text-yellow-700 font-medium">
                      Menunggu Manager
                    </span>

                  <% } else if (trip.status === 'APPROVED_MANAGER') { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-blue-50 text-blue-600 font-medium">
                      Menunggu HR / Direktur
                    </span>

                  <% } else if (trip.status === 'APPROVED_DIRECTOR') { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-emerald-50 text-emerald-600 font-medium">
                      Disetujui
                    </span>

                  <% } else { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-red-50 text-red-600 font-medium">
                      Ditolak
                    </span>
                  <% } %>
                </td>

                <!-- ACTION -->
                <td class="flex items-center gap-3 p-4">

                  <!-- DETAIL -->
                  <a href="/trip/detail/<%= trip._id %>"
                     class="text-indigo-600 hover:text-indigo-700 font-medium text-sm">
                    Detail
                  </a>

                  <!-- APPROVE MANAGER -->
                  <% if (trip.status === 'PENDING' && user.role === 'MANAGER') { %>
                    <form method="POST" action="/trip/<%= trip._id %>/approve/manager">
                      <button class="px-3 py-1 text-xs rounded-lg bg-emerald-50 text-emerald-600 font-medium hover:bg-emerald-100 transition">
                        Approve
                      </button>
                    </form>
                  <% } %>

                  <!-- APPROVE FINAL -->
                  <% if (trip.status === 'APPROVED_MANAGER' && (user.role === 'HR' || user.role === 'PIMPINAN')) { %>
                 <form method="POST" action="/trip/<%= trip._id %>/approve/director">
                <button class="px-3 py-1 text-xs rounded-lg bg-blue-50 text-blue-600 font-medium hover:bg-blue-100 transition">
                    Final Approve
                </button>
                </form>
                  <% } %>

                </td>

              </tr>
            <% }) %>

          </tbody>

        </table>
      </div>

    </div>

  </div>

</div>
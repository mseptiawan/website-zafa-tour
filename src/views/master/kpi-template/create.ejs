<%- layout('layouts/main', { title }) %>

<div class="max-w-xl mx-auto py-4 md:py-8">
  <div class="bg-white rounded-2xl border border-slate-200/60  overflow-hidden transform transition-all duration-200">
    
    <div class="p-5 space-y-4 border-b border-slate-100">
      <div class="flex items-center gap-2.5 text-blue-600">
        <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center text-xs">
          <i class="fa-solid fa-folder-plus"></i>
        </div>
        <h3 class="text-sm font-bold text-slate-800">Tambah KPI Template</h3>
      </div>
      <p class="text-xs text-slate-500 leading-relaxed">
        Buat draf template target penilaian standar indikator baru untuk posisi struktural maupun fungsional manajemen.
      </p>
    </div>

    <div class="p-6">
      <form action="/master/kpi-template" method="POST" class="space-y-4">
        
        <div>
          <label for="name" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Nama Template</label>
          <input type="text" id="name" name="name" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" placeholder="Contoh: Staff Call Center / Divisi IT" required>
        </div>

        <div>
          <label for="description" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Deskripsi Singkat</label>
          <textarea id="description" name="description" rows="3" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" placeholder="Tulis rincian peruntukan berkas rancangan template ini..."></textarea>
        </div>

        <div>
          <label for="isActive" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">Status Aktivasi Sistem</label>
          <select id="isActive" name="isActive" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700 bg-white cursor-pointer">
            <option value="true" selected>Aktif (Dapat Digunakan Langsung)</option>
            <option value="false">Non-Aktif (Simpan Sebagai Arsip Draf)</option>
          </select>
          <p class="mt-1.5 text-[11px] text-slate-400 italic">Template non-aktif tidak akan dimuat saat proses penarikan form penilaian KPI berkas pegawai.</p>
        </div>

        <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
          <a href="/master/kpi-template" class="inline-flex items-center justify-center h-8.5 px-3.5 border border-slate-200 text-slate-600 text-xs font-semibold rounded-xl hover:bg-slate-50 transition-colors">
            Batal
          </a>
          <button type="submit" class="inline-flex items-center justify-center h-8.5 px-4 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-xl  transition-all cursor-pointer">
            Simpan Template
          </button>
        </div>

      </form>
    </div>
  </div>
</div>
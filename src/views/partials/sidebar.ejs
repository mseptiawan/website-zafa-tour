                            <svg class="w-5 h-5 text-slate-500 group-hover:text-indigo-400" fill="none"
                              stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M11 5l-7 7h4v7h6v-4h2v4h6v-7h4l-7-7z"></path>
                            </svg>

                            <span class="text-xs font-medium text-slate-600 group-hover:text-slate-800">
                              Pengumuman
                            </span>

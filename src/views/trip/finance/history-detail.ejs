<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
    <div class="max-w-5xl mx-auto">

      <!-- BACK TO DASHBOARD -->
      <a href="javascript:history.back()"
        class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-400 hover:text-slate-800 mb-6 tracking-wide transition-colors group">
        <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none"
          stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Kembali
      </a>

      <!-- MAIN CARD -->
      <div class="bg-white border border-slate-200/60 rounded-2xl shadow-sm overflow-hidden">

        <!-- HEADER -->
        <div
          class="p-8 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-gradient-to-b from-slate-50/30 to-transparent">
          <div>
            <h1 class="text-xl font-semibold text-slate-900 tracking-tight">
              Payment Detail
            </h1>
            <p class="text-[13px] text-slate-400 mt-1">
              Detail transaksi dan pelacakan dana perjalanan dinas
            </p>
          </div>

          <!-- PAYMENT STATUS BADGE -->
          <div>
            <span class="inline-flex items-center px-3 py-1 text-[12px] rounded-full border font-medium tracking-wide
          <%= trip.payment?.status === 'PAID'
            ? 'bg-emerald-50/60 text-emerald-600 border-emerald-100'
            : trip.payment?.status === 'PROCESSING'
              ? 'bg-amber-50/60 text-amber-600 border-amber-100'
              : 'bg-rose-50/60 text-rose-600 border-rose-100'
          %>">
              <span class="w-1.5 h-1.5 rounded-full mr-1.5
            <%= trip.payment?.status === 'PAID'
              ? 'bg-emerald-500'
              : trip.payment?.status === 'PROCESSING'
                ? 'bg-amber-500'
                : 'bg-rose-500'
            %>"></span>
              <%= trip.payment?.status || 'UNPAID' %>
            </span>
          </div>
        </div>

        <!-- BODY CONTENT -->
        <div class="p-8 space-y-6">

          <!-- CORE INFORMATION GRID -->
          <div
            class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 bg-slate-50/70 p-5 rounded-xl border border-slate-200/50">
            <div class="space-y-1">
              <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Nama Pengaju</div>
              <div class="text-[13px] font-semibold text-slate-700">
                <%= trip.userId?.username || '-' %>
              </div>
            </div>
            <div class="space-y-1">
              <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Destinasi</div>
              <div class="text-[13px] font-semibold text-slate-700">
                <%= trip.destination || '-' %>
              </div>
            </div>
            <div class="space-y-2">
  <div class="space-y-1">
    <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Budget Dinas</div>
    <div class="text-[13px] font-semibold text-slate-800">
      Rp <%= (typeof trip.budget === 'number' ? trip.budget : (trip.budget?.total || 0)).toLocaleString('id-ID') %>
    </div>
  </div>

  <% if (trip.budget && typeof trip.budget === 'object' && trip.budget.items && trip.budget.items.length > 0) { %>
    <div class="border-t border-slate-100 pt-1.5 space-y-1.5">
      <% trip.budget.items.forEach(function(item) { %>
        <div class="flex justify-between items-start text-[11px] bg-slate-50/60 border border-slate-200/20 rounded-lg p-2">
          <div class="pr-3 leading-tight">
            <span class="font-medium text-slate-600 block"><%= item.title %></span>
            <% if (item.description) { %>
              <span class="text-[10px] text-slate-400 block mt-0.5"><%= item.description %></span>
            <% } %>
          </div>
          <span class="font-semibold text-slate-700 whitespace-nowrap">
            Rp <%= (item.allocatedAmount || 0).toLocaleString('id-ID') %>
          </span>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
            <div class="space-y-1">
              <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Status Approval</div>
              <div class="text-[13px] font-semibold text-slate-700">
                <%= trip.status==='APPROVED' ? 'Disetujui Pimpinan' : trip.status %>
              </div>
            </div>
          </div>

          <!-- TRIP TITLE & DESCRIPTION -->
          <div class="space-y-5">
            <div class="space-y-1">
              <label class="text-[11px] font-medium text-slate-400 uppercase tracking-wider block">Judul
                Perjalanan</label>
              <div class="text-[15px] font-semibold text-slate-800 tracking-tight">
                <%= trip.title || '-' %>
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-[13px] font-medium text-slate-500 block">Deskripsi / Keperluan</label>
              <div
                class="w-full bg-white border border-slate-200/60 rounded-xl px-4 py-3 text-[13px] text-slate-600 leading-relaxed shadow-inner shadow-slate-50">
                <%= trip.description || '-' %>
              </div>
            </div>
          </div>

          <!-- TIMELINE -->
          <div class="space-y-3">
            <label class="text-[13px] font-medium text-slate-500 block">Rute / Timeline Kunjungan</label>
            <% if (!trip.timeline || trip.timeline.length===0) { %>
              <div
                class="p-5 rounded-xl bg-slate-50/50 text-slate-400 text-[13px] border border-slate-200/60 text-center">
                Tidak ada data rute perjalanan
              </div>
              <% } else { %>
                <div class="space-y-0 pl-1.5">
                  <% trip.timeline.forEach(t=> { %>
                    <div class="relative border-l border-slate-200/80 pl-5 pb-4 last:pb-1">
                      <div
                        class="absolute -left-[4.5px] top-1.5 w-2 h-2 rounded-full border border-white bg-slate-300 ring-2 ring-slate-50">
                      </div>
                      <p class="text-[13px] text-slate-600 font-medium leading-none">
                        <%= t.address %>
                      </p>
                    </div>
                    <% }) %>
                </div>
                <% } %>
          </div>

          <!-- PAYMENT PROOF & META SECTION -->
          <div class="pt-6 border-t border-slate-100 grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- LEFT: PROOF DOWNLOAD -->
            <div class="space-y-2">
              <label class="text-[13px] font-medium text-slate-500 block">Lampiran Bukti Transfer</label>

              <% if (trip.payment?.proof?.url) { %>
                <div
                  class="p-4 border border-slate-200/60 rounded-xl bg-white flex items-center justify-between gap-4 shadow-sm hover:border-slate-300 transition-colors duration-200">
                  <div class="flex items-center gap-3 overflow-hidden">
                    <div
                      class="w-10 h-10 rounded-lg border border-slate-200 bg-slate-50 flex items-center justify-center text-slate-400 font-semibold text-[10px] tracking-wider flex-shrink-0">
                      FILE
                    </div>
                    <div class="overflow-hidden">
                      <div class="text-[13px] font-medium text-slate-700 truncate max-w-[180px] sm:max-w-[240px]">
                        <%= trip.payment.proof.filename || 'Bukti_Pembayaran.file' %>
                      </div>
                      <div class="text-[11px] text-slate-400 mt-0.5">Klik berkas untuk meninjau</div>
                    </div>
                  </div>

                  <a href="<%= trip.payment.proof.url %>" target="_blank"
                    class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white rounded-xl text-[12px] font-medium transition-colors shadow-sm flex-shrink-0 active:scale-[0.98]">
                    View File
                  </a>
                </div>
                <% } else { %>
                  <div
                    class="p-5 rounded-xl bg-slate-50/50 text-slate-400 text-[13px] border border-slate-200/60 border-dashed text-center">
                    Belum ada bukti pembayaran yang diunggah
                  </div>
                  <% } %>
            </div>

            <!-- RIGHT: TRANSACTION METADATA -->
            <div
              class="space-y-3 bg-slate-50/50 p-4 border border-slate-200/50 rounded-xl flex flex-col justify-center">
              <label class="text-[11px] font-medium text-slate-400 uppercase tracking-wider block">Informasi
                Pemrosesan</label>

              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Diproses Oleh</div>
                  <div class="text-[13px] font-semibold text-slate-700">
                    <%= trip.payment?.paidBy?.username || '-' %>
                  </div>
                </div>

                <div class="space-y-1">
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Waktu Pembayaran</div>
                  <div class="text-[12px] font-semibold text-slate-700">
                    <%= trip.payment?.paidAt ? new Date(trip.payment.paidAt).toLocaleString('id-ID') : '-' %> WIB
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
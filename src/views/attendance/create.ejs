<%- layout('layouts/main', { title: title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] px-4 py-5 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-xl mx-auto mt-4 md:mt-0">

    <div class="mb-5 border-b border-slate-200/60 pb-5">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Kehadiran', 
          title: 'Pencatatan Kehadiran', 
          description: 'Lakukan absensi harian dengan verifikasi wajah dan lokasi GPS terkunci.' 
      }) %>
      
      <% if (!(already && hasCheckedOut)) { %>
        <p class="text-[11.5px] font-medium text-slate-400/90 flex items-center gap-1.5 mt-2" id="camera-instruction">
          <i class="fa-solid fa-face-viewfinder text-slate-400"></i> Posisikan wajah Anda tepat pada area kamera
        </p>
      <% } %>
    </div>

    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl p-4 sm:p-5 md:p-8 shadow-2xs md:shadow-sm overflow-hidden">
      
      <% if (already && hasCheckedOut) { %>
        <div class="text-center py-8 px-2 flex flex-col items-center justify-center">
          <div class="relative flex h-12 w-12 items-center justify-center rounded-xl bg-slate-50 text-slate-800 border border-slate-200/60 shadow-3xs mb-4">
            <i class="fa-solid fa-calendar-check text-lg"></i>
            <span class="absolute -top-0.5 -right-0.5 flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-slate-400 opacity-75"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-slate-900"></span>
            </span>
          </div>

          <div class="space-y-1 mb-5">
            <h2 class="text-[13.5px] font-semibold text-slate-800 tracking-tight">Sesi Kehadiran Selesai</h2>
            <p class="text-[11.5px] text-slate-400 max-w-xs mx-auto leading-relaxed">
              Anda telah melengkapi pencatatan <span class="text-slate-700 font-semibold">Check-In</span> dan <span class="text-slate-700 font-semibold">Check-Out</span> untuk hari ini.
            </p>
          </div>

          <a href="/attendance/history" 
             class="inline-flex items-center gap-2 h-9 px-4 text-[11px] font-semibold text-slate-700 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 shadow-3xs transition-all active:scale-[0.98]">
            <i class="fa-solid fa-clock-rotate-left text-slate-400 text-[10px]"></i> 
            Buka Riwayat Kehadiran
          </a>
        </div>

      <% } else { %>
        <div class="space-y-5">
          
        <div class="relative bg-slate-950 rounded-2xl overflow-hidden aspect-[3/4] sm:aspect-video border border-slate-200/80 shadow-2xs w-full">
            <video id="video" autoplay playsinline muted class="w-full h-full object-cover scale-x-[-1]"></video>
            <canvas id="canvas" class="hidden"></canvas>
            
            <div class="absolute inset-0 border border-white/10 rounded-2xl pointer-events-none m-3 flex items-center justify-center">
              <div class="w-48 h-48 sm:w-40 sm:h-40 rounded-full border-2 border-dashed border-white/20 bg-white/5 backdrop-blur-[0.3px] flex items-center justify-center">
                <div class="w-1.5 h-1.5 rounded-full bg-white/25"></div>
              </div>
            </div>
          </div>

          <div class="pt-1  mx-auto  border-t border-slate-100 flex items-center justify-end">
            <% if (!already) { %>
              <button type="button" onclick="submitAttendance(event, 'checkin')" id="btn-submit"
                class="w-full  h-10 text-[12px] font-semibold bg-blue-500 text-white rounded-xl transition-colors shadow-3xs outline-none cursor-pointer">
                 Check-In 
              </button>
            <% } else { %>
              <button type="button" onclick="submitAttendance(event, 'checkout')" id="btn-submit"
                class="w-full  h-10 text-[12px] font-semibold bg-rose-600 hover:bg-rose-700 text-white rounded-xl transition-colors shadow-3xs outline-none cursor-pointer">
                Check-Out 
              </button>
            <% } %>
          </div>

        </div>
      <% } %>

    </div>
  </div>
</div>

<script>
let stream = null, lat = null, lng = null;
const video = document.getElementById("video");
const canvas = document.getElementById("canvas");

const isAlreadyCheckIn = <%- already %>;
const isAlreadyCheckOut = <%- hasCheckedOut %>;

function showMessage(type, message) {
  if (type === "success") {
    triggerGlobalToast({
      title: "Berhasil",
      message: message,
      type: "success"
    });
  } else {
    triggerGlobalToast({
      title: "Gagal",
      message: message,
      type: "error"
    });
  }
}

async function submitAttendance(event, actionType) {
  const btn = event.currentTarget;
  const originalText = btn.innerText;

  btn.disabled = true;
  btn.innerText = "Mengunci lokasi & foto...";

  try {
    const pos = await getLocation();
    lat = pos.lat;
    lng = pos.lng;

    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext("2d").drawImage(video, 0, 0, canvas.width, canvas.height);

    const blob = await new Promise(resolve =>
      canvas.toBlob(resolve, "image/jpeg", 0.8)
    );

    const formData = new FormData();
    formData.append("photo", blob, `${actionType}_selfie.jpg`);
    formData.append("lat", lat);
    formData.append("lng", lng);

    if (actionType === "checkin") {
      const noteInput = document.getElementById("note");
      formData.append("note", noteInput ? noteInput.value : "");
    }

    const targetUrl = actionType === "checkin" ? "/attendance/checkin" : "/attendance/checkout";

    const res = await fetch(targetUrl, { method: "POST", body: formData });
    const data = await res.json();

    if (data.success) {
      showMessage("success", data.message);
      stopCamera();
      setTimeout(() => {
        window.location.href = "/attendance/history";
      }, 1500);
    } else {
      showMessage("error", data.message);
      btn.disabled = false;
      btn.innerText = originalText;
    }

  } catch (e) {
    console.error(e);
    showMessage("error", "Gagal memproses absensi. Pastikan GPS aktif.");
    btn.disabled = false;
    btn.innerText = originalText;
  }
}

function getLocation() {
  return new Promise((resolve, reject) => {
    if (!navigator.geolocation) return reject(new Error("GPS tidak didukung browser"));
    navigator.geolocation.getCurrentPosition(
      p => resolve({ lat: p.coords.latitude, lng: p.coords.longitude }),
      err => reject(err),
      { enableHighAccuracy: true, timeout: 10000 }
    );
  });
}

async function startCamera() {
  if (isAlreadyCheckIn && isAlreadyCheckOut) return;
  if (!video) return;

  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { width: 640, height: 480, facingMode: "user" }
    });
    video.srcObject = stream;
  } catch (err) {
    const inst = document.getElementById("camera-instruction");
    if(inst) {
      inst.innerText = "Gagal memuat kamera. Harap aktifkan izin kamera perangkat Anda.";
      inst.className = "text-[11.5px] font-semibold text-rose-500 mt-2";
    }
  }
}

function stopCamera() {
  if (!stream) return;
  stream.getTracks().forEach(track => track.stop());
}

startCamera();

document.addEventListener("visibilitychange", () => {
  document.hidden ? stopCamera() : startCamera();
});
</script>
<%- layout('layouts/main', { title: title }) %>

<% 
  // ==========================================
  // COMPONENT-LEVEL UTILITIES (STATUS MAPPER)
  // ==========================================
  const getStatusConfig = (status) => {
    switch(status) {
      case 'PENDING_MANAGER':
        return { 
          label: 'PENDING', 
          badge: 'bg-amber-50 text-amber-700 border-amber-200/50', 
          dot: 'bg-amber-500' 
        };
      case 'PENDING_FINANCE':
        return { 
          label: 'PENDING', 
          badge: 'bg-blue-50 text-blue-700 border-blue-200/50', 
          dot: 'bg-blue-500' 
        };
      case 'PAID':
        return { 
          label: 'APPROVED', 
          badge: 'bg-emerald-50 text-emerald-700 border-emerald-200/50', 
          dot: 'bg-emerald-500' 
        };
      case 'REJECTED':
        return { 
          label: 'DITOLAK', 
          badge: 'bg-rose-50 text-rose-700 border-rose-200/50', 
          dot: 'bg-rose-500' 
        };
      default:
        return { 
          label: 'PENDING', 
          badge: 'bg-slate-50 text-slate-700 border-slate-200', 
          dot: 'bg-slate-400' 
        };
    }
  };

  const activeExpenses = expenses.filter(e => e.status === 'PENDING_MANAGER' || e.status === 'PENDING_FINANCE');
  const historyExpenses = expenses.filter(e => e.status === 'PAID' || e.status === 'REJECTED');
%>

<div>
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-6">

    <div class="hidden md:block">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Reimbursement', 
          title: 'Riwayat Reimbursement', 
          description: 'Pantau status persetujuan reimbursement dan rekam jejak pencairan dana reimbursement Anda.' 
      }) %>
    </div>

    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        items: [
          { 
            label: 'Sedang Diproses', 
            value: activeExpenses.length, 
            unit: 'Berkas', 
            icon: 'fa-solid fa-spinner', 
            bgClass: 'bg-white border-slate-200/60', 
            iconBoxClass: 'bg-blue-50 text-blue-600 border border-blue-100' 
          },
          { 
            label: 'Selesai Pencairan', 
            value: historyExpenses.filter(e => e.status === 'PAID').length, 
            unit: 'Berkas', 
            icon: 'fa-solid fa-check-to-slot', 
            bgClass: 'bg-white border-slate-200/60', 
            iconBoxClass: 'bg-emerald-50 text-emerald-600 border border-emerald-100' 
          },
         { 
  label: 'Total Diajukan', 
  value: pagination.totalItems || pagination.total || expenses.length, 
  unit: 'Berkas', 
  icon: 'fa-solid fa-wallet', 
  bgClass: 'bg-white border-slate-200/60',
  labelClass: 'text-slate-400', 
  valueClass: 'text-slate-800', 
  unitClass: 'text-slate-400',
  iconBoxClass: 'bg-indigo-50 text-indigo-600 border border-indigo-100' 
}
        ]
      }) %>
    </div>

    <div class="flex flex-col gap-3.5 w-full bg-white md:bg-transparent border border-slate-200/60 md:border-none p-4 md:p-0 rounded-2xl md:rounded-none select-none">
      <div class="flex items-center justify-between gap-3 w-full md:hidden">
        <div>
          <h3 class="text-[14px] font-bold text-slate-900 tracking-tight">Daftar Pengajuan Reimbursement</h3>
        </div>
        <a href="/expense/create" class="inline-flex items-center justify-center gap-1.5 h-8.5 px-4 bg-blue-600 hover:bg-blue-700 text-white text-[11px] font-bold rounded-full transition-all active:scale-95 cursor-pointer decoration-none">
          <i class="fa-solid fa-plus text-[9px] text-blue-100"></i>
          <span>Buat</span>
        </a>
      </div>

      <%- include('../partials/_tab-nav', {
        tabs: [
          { id: 'active', label: `Dalam Proses (${activeExpenses.length})` },
          { id: 'history', label: `Riwayat (${historyExpenses.length})` }
        ]
      }) %>
    </div>

    <div id="tab-content-active" class="tab-pane space-y-5 block opacity-100 transition-all duration-300">

      <div class="hidden md:block bg-white border border-slate-200/60 rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-[13px] border-collapse">
            <thead class="bg-slate-50/70 text-[10px] uppercase text-slate-400 font-bold tracking-wider border-b border-slate-100">
              <tr>
                <th class="py-4 px-6 w-56">Tanggal Pengajuan</th>
                <th class="py-4 px-6 w-32">Kategori</th>
                <th class="py-4 px-6 text-right w-56">Nominal</th>
                <th class="py-4 px-6 text-center w-40">Status</th>
                <th class="py-4 px-6 text-center w-24">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50 font-medium text-slate-600 bg-white">
              <% if (activeExpenses.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center py-12 text-slate-400 font-medium">
                  Tidak ada pengajuan reimbursement yang sedang diproses.
                </td>
              </tr>
              <% } else { %>
              <% activeExpenses.forEach(e => { %>
              <% const config = getStatusConfig(e.status); %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="py-4 px-6 font-bold text-slate-900">
                  <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                </td>
                <td class="py-4 px-6 text-slate-700">
                  <span class="bg-slate-100 text-slate-700 text-[12px] px-3 py-1 rounded-md font-semibold inline-block whitespace-nowrap">
                    <%= e.category?.name || 'Umum' %>
                  </span>
                </td>
                <td class="py-4 px-6 text-right tabular-nums font-bold text-slate-900">
                  Rp <%= e.amount.toLocaleString('id-ID') %>
                </td>
                <td class="py-4 px-6 text-center select-none">
                  <span class="px-2.5 py-0.5 rounded-full font-medium text-[9.5px] uppercase tracking-wider border inline-flex items-center gap-1.5 <%= config.badge %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                    <%= config.label %>
                  </span>
                </td>
                <td class="py-4 px-6 select-none text-center">
                  <a href="/expense/detail/<%= e._id %>" title="Lihat Detail" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 inline-flex items-center justify-center transition-all hover:bg-slate-50 active:scale-95 mx-auto">
                    <i class="fa-solid fa-eye text-[11px]"></i>
                  </a>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-4 w-full">
        <% if (activeExpenses.length === 0) { %>
        <div class="bg-white border border-slate-200/60 rounded-2xl py-12 text-center px-4">
          <p class="text-[11px] font-semibold text-slate-400">Tidak ada pengajuan aktif</p>
        </div>
        <% } else { %>
        <% activeExpenses.forEach(e => { %>
        <% const config = getStatusConfig(e.status); %>
        <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-4">
          <div class="flex items-start justify-between gap-3 border-b border-slate-100 pb-3">
            <div>
              <div class="text-[13px] font-bold text-slate-900 tracking-tight">
                <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
              </div>
              <div class="flex items-center gap-2 mt-1.5">
                <span class="text-[11px] bg-slate-100 text-slate-600 px-2.5 py-0.5 rounded font-bold uppercase tracking-wide"><%= e.category?.name || 'Umum' %></span>
              </div>
            </div>
            <span class="px-2 py-0.5 rounded-full font-bold text-[9px] uppercase tracking-wider border shrink-0 select-none <%= config.badge %>">
              <%= config.label %>
            </span>
          </div>

          <div class="bg-slate-50/60 rounded-xl px-4 py-3 border border-slate-200/40 flex items-center justify-between">
            <div>
              <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wide">Nominal</p>
              <p class="text-[14px] font-bold text-slate-900 tabular-nums mt-0.5">Rp <%= e.amount.toLocaleString('id-ID') %></p>
            </div>

            <div class="flex items-center gap-1.5 select-none">
              <a href="/expense/detail/<%= e._id %>" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-500 flex items-center justify-center text-xs active:scale-95" title="Detail"><i class="fa-solid fa-eye"></i></a>
            </div>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane space-y-5 hidden opacity-0 transition-all duration-300 transform translate-y-2">

      <div class="hidden md:block bg-white border border-slate-200/60 rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-[13px] border-collapse">
            <thead class="bg-slate-50/70 text-[10px] uppercase text-slate-400 font-bold tracking-wider border-b border-slate-100">
              <tr>
                <th class="py-4 px-6 w-56">Tanggal Pengajuan</th>
                <th class="py-4 px-6 w-32">Kategori</th>
                <th class="py-4 px-6 text-right w-56">Nominal</th>
                <th class="py-4 px-6 text-center w-40">Status Akhir</th>
                <th class="py-4 px-6 text-center w-24">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50 font-medium text-slate-600 bg-white">
              <% if (historyExpenses.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center py-12 text-slate-400 font-medium">
                  Belum ada riwayat pengajuan berkas reimbursement.
                </td>
              </tr>
              <% } else { %>
              <% historyExpenses.forEach(e => { %>
              <% const config = getStatusConfig(e.status); %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="py-4 px-6 font-bold text-slate-900">
                  <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                </td>
                <td class="py-4 px-6 text-slate-700">
                  <span class="bg-slate-100 text-slate-700 text-[12px] px-3 py-1 rounded-md font-semibold inline-block whitespace-nowrap">
                    <%= e.category?.name || 'Umum' %>
                  </span>
                </td>
                <td class="py-4 px-6 text-right tabular-nums font-bold text-slate-900">
                  Rp <%= e.amount.toLocaleString('id-ID') %>
                </td>
                <td class="py-4 px-6 text-center select-none">
                  <span class="px-2.5 py-0.5 rounded-full font-medium text-[9.5px] uppercase tracking-wider border inline-flex items-center gap-1.5 <%= config.badge %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                    <%= config.label %>
                  </span>
                </td>
                <td class="py-4 px-6 select-none text-center">
                  <a href="/expense/detail/<%= e._id %>" title="Lihat Berkas" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-400 hover:text-slate-700 inline-flex items-center justify-center transition-all hover:bg-slate-50 active:scale-95 mx-auto">
                    <i class="fa-solid fa-eye text-[11px]"></i>
                  </a>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-4 w-full">
        <% if (historyExpenses.length === 0) { %>
        <div class="bg-white border border-slate-200/60 rounded-2xl py-12 text-center px-4">
          <p class="text-[11px] font-semibold text-slate-400">Belum ada riwayat dokumen</p>
        </div>
        <% } else { %>
        <% historyExpenses.forEach(e => { %>
        <% const config = getStatusConfig(e.status); %>
        <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-4">
          <div class="flex items-start justify-between gap-3 border-b border-slate-100 pb-3">
            <div>
              <div class="text-[13px] font-bold text-slate-900 tracking-tight">
                <%= new Date(e.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
              </div>
              <div class="flex items-center gap-2 mt-1.5">
                <span class="text-[11px] bg-slate-100 text-slate-600 px-2.5 py-0.5 rounded font-bold uppercase tracking-wide"><%= e.category?.name || 'Umum' %></span>
              </div>
            </div>
            <span class="px-2 py-0.5 rounded-full font-bold text-[9px] uppercase tracking-wider border shrink-0 select-none <%= config.badge %>">
              <%= config.label %>
            </span>
          </div>

          <div class="bg-slate-50/60 rounded-xl px-4 py-3 border border-slate-200/40 flex items-center justify-between">
            <div>
              <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wide">Nominal Akhir</p>
              <p class="text-[14px] font-bold text-slate-900 tabular-nums mt-0.5">Rp <%= e.amount.toLocaleString('id-ID') %></p>
            </div>
            <div class="flex items-center gap-1.5 select-none">
              <a href="/expense/detail/<%= e._id %>" class="w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-500 flex items-center justify-center text-xs active:scale-95" title="Lihat"><i class="fa-solid fa-eye"></i></a>
            </div>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>
    </div>

    <% if (pagination.totalPages > 1) { %>
    <div class="flex items-center justify-end mt-8 w-full border-t border-slate-200/60 pt-4">
      <div class="flex items-center gap-5">
        <a href="?page=<%= pagination.page - 1 %>" class="py-1 text-[11.5px] font-semibold transition-colors flex items-center gap-1 <%= pagination.hasPrev ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none select-none' %>">
          <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Prev
        </a>
        <a href="?page=<%= pagination.page + 1 %>" class="py-1 text-[11.5px] font-semibold transition-colors flex items-center gap-1 <%= pagination.hasNext ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none select-none' %>">
          Next
          <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
    <% } %>

  </div>
</div>
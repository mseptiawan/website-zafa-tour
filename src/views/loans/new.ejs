<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

    <div class="max-w-2xl mx-auto">
<div class="mb-12"> <div class="flex items-center gap-3 mb-4">
    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em]">Area Kerja</span>
    <div class="w-px h-3 bg-slate-200"></div> <span class="text-[10px] font-bold text-slate-900 uppercase tracking-[0.2em]">Finance</span>
  </div>

  <h1 class="text-3xl font-extrabold text-slate-950 tracking-tighter">
    <%= typeof loan !== 'undefined' && loan ? 'Ubah Pengajuan Pinjaman' : 'Pengajuan Pinjaman' %>
  </h1>

  <p class="text-slate-400 mt-2 text-sm font-medium">
    <%= typeof loan !== 'undefined' && loan ? 'Update data permohonan pinjaman internal Anda.' : 'Ajukan pinjaman internal atau modal kerja Anda di sini.' %>
  </p>
</div>

      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

        <form action="<%= typeof loan !== 'undefined' && loan ? '/loans/update/' + loan._id : '/loans' %>" method="POST" class="p-8 space-y-6">

          <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
            <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm border border-red-100">
              <%= errorMessage %>
            </div>
          <% } else if (typeof error !== 'undefined' && error) { %>
            <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm border border-red-100">
              <%= error %>
            </div>
          <% } %>

          <div class="space-y-1.5">

            <label class="text-[13px] font-bold text-slate-700">
              Jumlah Pinjaman (IDR)
            </label>

            <% 
              let amountValue = '';
              if (typeof loan !== 'undefined' && loan) {
                amountValue = loan.amountRequested || '';
              } else if (typeof old !== 'undefined' && old) {
                amountValue = old.amount || '';
              }
            %>
            <input type="number" name="amountRequested" required value="<%= amountValue %>"
              placeholder="Contoh: 5000000" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
        focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
        outline-none transition-all" />

          </div>

          <div class="space-y-2">

            <label class="text-[13px] font-bold text-slate-700 block">
              Tenor Pinjaman
            </label>

            <div class="grid grid-cols-2 gap-4">
              
              <% 
                let currentTenor = '';
                if (typeof loan !== 'undefined' && loan) {
                  currentTenor = String(loan.tenorMonths);
                } else if (typeof old !== 'undefined' && old) {
                  currentTenor = String(old.tenor);
                }
              %>
              
              <label class="relative flex items-center justify-between border border-slate-200 rounded-xl p-4 bg-slate-50/50 hover:bg-slate-50 cursor-pointer transition select-none has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50/20">
                <div class="flex items-center gap-3">
                  <input type="radio" name="tenorMonths" value="3" required <%= currentTenor === '3' ? 'checked' : '' %>
                    class="w-4 h-4 text-blue-600 border-slate-300 focus:ring-blue-500/20 focus:ring-2" />
                  <span class="text-xs font-semibold text-slate-800">3 Bulan</span>
                </div>
              </label>

              <label class="relative flex items-center justify-between border border-slate-200 rounded-xl p-4 bg-slate-50/50 hover:bg-slate-50 cursor-pointer transition select-none has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50/20">
                <div class="flex items-center gap-3">
                  <input type="radio" name="tenorMonths" value="6" required <%= currentTenor === '6' ? 'checked' : '' %>
                    class="w-4 h-4 text-blue-600 border-slate-300 focus:ring-blue-500/20 focus:ring-2" />
                  <span class="text-xs font-semibold text-slate-800">6 Bulan</span>
                </div>
              </label>

            </div>

          </div>

          <div class="space-y-1.5">

            <label class="text-[13px] font-bold text-slate-700">
              Alasan Peminjaman
            </label>

            <% 
              let reasonValue = '';
              if (typeof loan !== 'undefined' && loan) {
                reasonValue = loan.reason || '';
              } else if (typeof old !== 'undefined' && old) {
                reasonValue = old.reason || '';
              }
            %>
            <textarea name="reason" rows="5" maxlength="500" required placeholder="Jelaskan tujuan dan alasan pengajuan pinjaman secara detail" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
        focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
        outline-none resize-none transition-all"><%= reasonValue %></textarea>

          </div>

          <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">

            <a href="/loans/my"
              class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
              Batal
            </a>

            <button type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
              <%= typeof loan !== 'undefined' && loan ? 'Simpan Perubahan' : 'Ajukan Loan' %>
            </button>

          </div>

        </form>

      </div>

    </div>

  </div>
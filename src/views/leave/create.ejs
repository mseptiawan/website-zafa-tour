<%- layout('layouts/main', { title }) %>
  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    <div class="max-w-3xl mx-auto">
      <div class="mb-6">
        <a href="/leave/my" class="text-xs font-bold text-blue-600 hover:underline">← Batal dan Kembali</a>
        <h1 class="text-xl font-bold text-slate-900 mt-2">
          <%= title %>
        </h1>
      </div>

      <% if (typeof rejectNote !=='undefined' && rejectNote) { %>
        <div class="bg-rose-50 border border-rose-200 rounded-2xl p-4 mb-6">
          <h4 class="text-xs font-bold text-rose-800 uppercase tracking-wider">Alasan Penolakan Sebelumnya:</h4>
          <p class="text-xs text-rose-700 mt-1 italic">"<%= rejectNote %>"</p>
        </div>
        <% } %>

          <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6">
            <form id="leaveForm" enctype="multipart/form-data" class="space-y-4">
              <div>
                <label class="text-[11px] font-bold text-slate-400 uppercase">Pilih Kategori Cuti</label>
                <select name="leaveTypeId" required
                  class="w-full mt-1 border border-slate-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-blue-600">
                  <% leaveTypes.forEach(type=> { %>
                    <option value="<%= type._id %>" <%=(typeof oldData !=='undefined' &&
                      oldData.leaveTypeId.toString()===type._id.toString()) ? 'selected' : '' %>><%= type.name %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="text-[11px] font-bold text-slate-400 uppercase">Tanggal Mulai</label>
                  <input type="date" name="startDate" required
                    value="<%= typeof oldData !== 'undefined' ? oldData.startDate.toISOString().split('T')[0] : '' %>"
                    class="w-full mt-1 border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-blue-600">
                </div>
                <div>
                  <label class="text-[11px] font-bold text-slate-400 uppercase">Tanggal Selesai</label>
                  <input type="date" name="endDate" required
                    value="<%= typeof oldData !== 'undefined' ? oldData.endDate.toISOString().split('T')[0] : '' %>"
                    class="w-full mt-1 border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-blue-600">
                </div>
              </div>

              <div>
                <label class="text-[11px] font-bold text-slate-400 uppercase">Alasan Pengajuan</label>
                <textarea name="reason" rows="3" required
                  class="w-full mt-1 border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-blue-600"><%= typeof oldData !== 'undefined' ? oldData.reason : '' %></textarea>
              </div>

              <div>
                <label class="text-[11px] font-bold text-slate-400 uppercase">Personel Handover (Delegasi Tugas)</label>
                <select name="handoverUserId" required
                  class="w-full mt-1 border border-slate-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-blue-600">
                  <% employees.forEach(emp=> { %>
                    <option value="<%= emp._id %>" <%=(typeof oldData !=='undefined' && oldData.handoverUserId &&
                      oldData.handoverUserId.toString()===emp._id.toString()) ? 'selected' : '' %>><%= emp.name %> (@<%=
                          emp.username %>)</option>
                    <% }) %>
                </select>
              </div>

              <div>
                <label class="text-[11px] font-bold text-slate-400 uppercase">Dokumen Lampiran (Opsional)</label>
                <input type="file" name="file"
                  class="w-full mt-1 text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
              </div>

              <button type="submit"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white rounded-xl py-2.5 font-bold text-sm transition shadow-sm cursor-pointer">Kirim
                Berkas Pengajuan</button>
            </form>
          </div>
    </div>
  </div>

  <script>
    document.getElementById('leaveForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const isEdit = '<%= typeof oldData !== "undefined" && oldData && title !== "Resubmit Pengajuan Cuti" %>' === 'true';
      const url = isEdit ? '/leave/edit/<%= typeof oldData !== "undefined" && oldData ? oldData._id : "" %>' : '/leave/apply';

      const res = await fetch(url, { method: 'POST', body: formData });
      const data = await res.json();
      if (data.success) {
        alert(data.message);
        window.location.href = '/leave/my';
      } else {
        alert(data.message);
      }
    });
  </script>
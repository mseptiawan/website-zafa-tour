<%- layout('layouts/main', { title }) %>
  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-xl font-bold text-slate-900 mb-2">Permintaan Delegasi Pekerjaan</h1>
      <p class="text-xs text-slate-500 mb-6">Konfirmasi kesediaan Anda untuk mem-backup tugas rekan kerja yang cuti</p>

      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                <th class="py-4 px-6">Rekan Kerja</th>
                <th class="py-4 px-6">Jenis Cuti</th>
                <th class="py-4 px-6">Durasi & Tanggal</th>
                <th class="py-4 px-6">Status Anda</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-sm">
              <% if (delegations.length === 0) { %>
                <tr>
                  <td colspan="5" class="py-12 text-center text-slate-400 italic text-xs">
                    Tidak ada permintaan delegasi aktif saat ini
                  </td>
                </tr>
              <% } %>
              
              <% delegations.forEach(del => { %>
                <tr class="hover:bg-slate-50/50 transition-colors">
                  <!-- Kolom Rekan Kerja -->
                  <td class="py-4 px-6 text-slate-900 font-medium">
                    <%= (del.leaveId && del.leaveId.userId && del.leaveId.userId.employeeData) ? del.leaveId.userId.employeeData.fullName : '-' %>
                  </td>
                  
                  <!-- Kolom Jenis Cuti -->
                  <td class="py-4 px-6 font-medium text-slate-600">
                    <%= (del.leaveId && del.leaveId.leaveTypeId) ? del.leaveId.leaveTypeId.name : '-' %>
                  </td>
                  
                  <!-- Kolom Durasi & Tanggal -->
                  <td class="py-4 px-6 text-xs text-slate-500">
                    <span class="font-semibold text-slate-700 block mb-0.5">
                      <%= del.leaveId ? del.leaveId.totalDays : 0 %> Hari Kerja
                    </span>
                    <% if (del.leaveId && del.leaveId.startDate && del.leaveId.endDate) { %>
                      <%= new Date(del.leaveId.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %>
                      s.d 
                      <%= new Date(del.leaveId.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  
                  <!-- Kolom Status Badge -->
            <td class="py-4 px-6 whitespace-nowrap">
  <% 
    const textStyles = {
      'APPROVED': 'text-emerald-700',
      'REJECTED': 'text-rose-700',
      'PENDING': 'text-amber-700'
    };

    const dotStyles = {
      'APPROVED': 'bg-emerald-500 ring-emerald-500/20',
      'REJECTED': 'bg-rose-500 ring-rose-500/20',
      'PENDING': 'bg-amber-500 ring-amber-500/20'
    };
  %>

  <div class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-wider <%= textStyles[del.status] || 'text-slate-600' %>">
    <span class="w-1.5 h-1.5 rounded-full ring-4 <%= dotStyles[del.status] || 'bg-slate-400 ring-slate-400/20' %>"></span>
    <span><%= del.status %></span>
  </div>
</td>
                  
                  <!-- Kolom Aksi (Hanya Icon Tinjau / Mata) -->
                  <td class="py-4 px-6 text-center whitespace-nowrap">
                    <% if (del.leaveId) { %>
                      <a href="/leave/detail/<%= del.leaveId._id %>" 
                         title="Tinjau Permintaan"
                         class="inline-flex items-center justify-center p-2 rounded-xl border border-slate-200 bg-white text-slate-600 hover:text-blue-600 hover:border-blue-200 hover:bg-blue-50/50 transition shadow-sm group">
                        <!-- Icon Eye / Tinjau -->
                        <svg class="w-4 h-4 transition-transform group-hover:scale-105" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                      </a>
                    <% } else { %>
                      <span class="text-xs text-slate-400">-</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-3xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-[24px] font-medium text-slate-800 tracking-tight">
        Ajukan Klaim Beban
      </h1>

      <p class="text-[13px] text-slate-500 mt-1">
        Input pengeluaran operasional dan upload bukti transaksi
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">

      <form
        method="POST"
        enctype="multipart/form-data"
        class="space-y-5"
      >

        <!-- TITLE -->
        <div class="space-y-1.5">
          <label class="text-[12px] text-slate-600">
            Judul Pengeluaran
          </label>

          <input
            type="text"
            name="title"
            required
            placeholder="Contoh: Biaya makan client"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-700 placeholder:text-[12px] placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900/10 focus:border-slate-300 transition"
          />
        </div>

        <!-- CATEGORY -->
        <div class="space-y-1.5">
          <label class="text-[12px] text-slate-600">
            Kategori
          </label>

          <select
            name="category"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-slate-900/10 focus:border-slate-300 transition"
          >
            <option>TRANSPORT</option>
            <option>MEAL</option>
            <option>PARKING</option>
            <option>HOTEL</option>
            <option>OPERASIONAL</option>
            <option>LAINNYA</option>
          </select>
        </div>

        <!-- AMOUNT -->
        <div class="space-y-1.5">
          <label class="text-[12px] text-slate-600">
            Nominal
          </label>

          <input
            type="number"
            name="amount"
            required
            placeholder="Contoh: 50000"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-700 placeholder:text-[12px] placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900/10 focus:border-slate-300 transition"
          />
        </div>

        <!-- DATE -->
        <div class="space-y-1.5">
          <label class="text-[12px] text-slate-600">
            Tanggal Pengeluaran
          </label>

          <input
            type="date"
            name="expenseDate"
            required
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-900/10 focus:border-slate-300 transition"
          />
        </div>

        <!-- DESCRIPTION -->
        <div class="space-y-1.5">
          <label class="text-[12px] text-slate-600">
            Deskripsi
          </label>

          <textarea
            name="description"
            rows="4"
            placeholder="Jelaskan detail pengeluaran..."
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-700 placeholder:text-[12px] placeholder:text-slate-400 resize-none focus:outline-none focus:ring-2 focus:ring-slate-900/10 focus:border-slate-300 transition"
          ></textarea>
        </div>

        <!-- FILE -->
        <div class="space-y-1.5">
          <label class="text-[12px] text-slate-600">
            Upload Bukti
          </label>

          <div
            class="border border-slate-200 rounded-lg overflow-hidden bg-white hover:border-slate-300 transition"
          >
            <input
              type="file"
              name="proofFile"
              class="w-full text-[12px] text-slate-500
              file:border-0
              file:bg-slate-900
              file:text-white
              file:px-4
              file:py-2
              file:mr-4
              file:text-[12px]
              file:font-normal
              hover:file:bg-slate-800
              cursor-pointer"
            />
          </div>

          <p class="text-[10px] text-slate-400">
            Upload struk, nota, atau bukti pembayaran
          </p>
        </div>

        <!-- NO RECEIPT -->
        <div class="space-y-1.5">
          <label class="text-[12px] text-slate-600">
            Alasan Tidak Ada Bukti
          </label>

          <textarea
            name="noReceiptReason"
            rows="3"
            placeholder="Contoh: parkir tidak menyediakan struk"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-700 placeholder:text-[12px] placeholder:text-slate-400 resize-none focus:outline-none focus:ring-2 focus:ring-slate-900/10 focus:border-slate-300 transition"
          ></textarea>
        </div>

        <!-- DECLARATION -->
        <label
          class="flex items-start gap-3 border border-slate-200 rounded-xl px-4 py-3 bg-slate-50"
        >

          <input
            type="checkbox"
            name="selfDeclaration"
            class="mt-0.5 w-4 h-4 accent-slate-900"
          />

          <div>
            <p class="text-[13px] text-slate-700">
              Pernyataan Pengajuan
            </p>

            <p class="text-[11px] text-slate-400 leading-relaxed">
              Saya menyatakan bahwa pengeluaran ini benar
              dan dapat dipertanggungjawabkan.
            </p>
          </div>

        </label>

        <!-- BUTTON -->
        <div class="pt-1">
          <button
            class="bg-slate-900 hover:bg-slate-800 text-white px-5 py-2 rounded-lg text-[13px] transition"
          >
            Submit Klaim
          </button>
        </div>

      </form>

    </div>

  </div>

</div>
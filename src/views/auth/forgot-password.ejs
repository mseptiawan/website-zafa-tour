<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lupa Password - HRIS</title>

  <link rel="stylesheet" href="/css/output.css" />

  <style>
    body {
      margin: 0;
      font-family: system-ui, sans-serif;
      background: #f1f5f9;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }
  </style>
</head>

<body>

  <div style="
    width: 360px;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  ">

    <!-- TITLE -->
    <div style="text-align:center; margin-bottom:18px;">
      <h1 style="font-size:18px; font-weight:700; color:#0f172a;">
        Lupa Password
      </h1>
      <p style="font-size:12px; color:#64748b;">
        Masukkan username atau email Anda
      </p>
    </div>

    <!-- ERROR -->
    <% if (query?.error) { %>
      <div style="
        background:#fef2f2;
        border:1px solid #fecaca;
        color:#b91c1c;
        padding:10px;
        border-radius:8px;
        font-size:12px;
        margin-bottom:12px;
      ">
        Data tidak ditemukan atau terjadi kesalahan
      </div>
    <% } %>

    <!-- FORM -->
    <form action="/forgot-password" method="POST" style="display:flex; flex-direction:column; gap:12px;">

      <input
        type="text"
        name="identifier"
        placeholder="Username atau Email"
        style="
          padding:10px 12px;
          border:1px solid #cbd5e1;
          border-radius:8px;
          font-size:14px;
          outline:none;
        "
      />

      <button
        type="submit"
        style="
          margin-top:6px;
          padding:10px;
          border-radius:8px;
          border:1px solid #2563eb;
          background:#2563eb;
          color:white;
          font-weight:500;
          cursor:pointer;
          font-size:14px;
        "
      >
        Reset Password
      </button>

    </form>

    <!-- BACK TO LOGIN -->
    <div style="text-align:center; margin-top:12px; font-size:12px;">
      <a href="/" style="color:#2563eb; text-decoration:none;">
        Kembali ke login
      </a>
    </div>

  </div>

</body>
</html>
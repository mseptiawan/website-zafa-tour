<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    <div class="max-w-2xl mx-auto">

      <!-- Header -->
      <div class="mb-8">
        <nav class="flex items-center gap-2 mb-2 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
          <span>Workspace</span>
          <span class="text-slate-300">/</span>
          <span class="text-slate-900">Announcements</span>
        </nav>
        <h1 class="text-2xl font-bold text-slate-900">Buat Pengumuman</h1>
        <p class="text-[14px] text-slate-500 mt-1">Publikasikan informasi internal untuk tim Anda.</p>
      </div>

      <!-- Main Form Cards-->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">
        <form method="POST" action="/announcement/" enctype="multipart/form-data" class="p-8 space-y-6">

          <% if (error) { %>
            <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm border border-red-100 flex items-center gap-3">
              <%= error %>
            </div>
            <% } %>

              <!-- Row 1: Judul -->
              <div class="space-y-2">
                <label class="text-[13px] font-medium text-slate-500 block">Judul Pengumuman</label>
                <input type="text" name="title" placeholder="Ketik judul di sini..." required
                  value="<%= old?.title || '' %>"
                  class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-3 text-[13px] font-medium text-slate-700 placeholder-slate-400 outline-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all duration-200 shadow-sm shadow-slate-100/50" />
              </div>

              <!-- Row 2: Kategori (Full Width) -->
              <div class="space-y-1.5">
                <label class="text-[13px] font-medium text-slate-500 block">Kategori</label>

                <!-- DROPDOWN CONTAINER -->
                <div class="relative w-full" id="category-dropdown">

                  <!-- HIDDEN INPUT (Untuk menampung value form backend) -->
                  <input type="hidden" name="category" id="category-value" value="LIGHT" required>

                  <!-- SELECT TRIGGER BUTTON -->
                  <button type="button" onclick="toggleCategoryDropdown()"
                    class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-3 text-[13px] font-medium text-slate-700 text-left flex items-center justify-between outline-none hover:bg-slate-50 hover:border-slate-300 focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all duration-200 cursor-pointer shadow-sm shadow-slate-100/50">
                    <span id="category-label" class="flex items-center gap-2 text-slate-700">
                      <span>🍃</span> Pengumuman Ringan
                    </span>
                    <svg id="category-arrow" class="w-4 h-4 text-slate-400 stroke-[2] transition-transform duration-200"
                      fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>

                  <!-- OPTIONS MENU PANEL -->
                  <div id="category-menu"
                    class="hidden absolute z-30 w-full mt-2 bg-white border border-slate-200/50 rounded-xl shadow-xl shadow-slate-100/80 p-1.5 space-y-0.5 origin-top transform opacity-0 scale-95 transition-all duration-150 backdrop-blur-sm">

                    <!-- OPTION: LIGHT -->
                    <button type="button" onclick="selectCategory('LIGHT', '🍃 Pengumuman Ringan')"
                      class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                      <div class="flex items-center gap-2">
                        <span>🍃</span>
                        <span>Pengumuman Ringan</span>
                      </div>
                      <span
                        class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                    </button>

                    <!-- OPTION: OFFICIAL (EJS Conditional Check) -->
                    <% if (user.role==="PIMPINAN" ) { %>
                      <button type="button" onclick="selectCategory('OFFICIAL', '⚖️ Pengumuman Resmi')"
                        class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                        <div class="flex items-center gap-2">
                          <span>⚖️</span>
                          <span>Pengumuman Resmi</span>
                        </div>
                        <span
                          class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                      </button>
                      <% } %>

                  </div>
                </div>
              </div>

              <!-- Row 3: Detail Informasi -->
              <div class="space-y-2">
                <label class="text-[13px] font-medium text-slate-500 block">Isi Pengumuman</label>
                <textarea name="content" rows="6" placeholder="Tulis detail informasi di sini..." required
                  class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-3 text-[13px] font-medium text-slate-700 placeholder-slate-400 outline-none resize-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all duration-200 shadow-inner shadow-slate-50"><%= old?.content || '' %></textarea>
              </div>
              <!-- Row 4: Attachment (Upload Area Modern) -->
              <div class="space-y-1.5">
                <label class="text-[13px] font-bold text-slate-700">
                  Lampiran
                  <span class="text-slate-400 font-normal">(Opsional)</span>
                </label>

                <div class="relative group">
                  <input type="file" name="attachment" id="file-input"
                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                    onchange="handleFileSelect(this)" />

                  <!-- Empty State -->
                  <div id="dropzone-empty"
                    class="border-2 border-dashed border-slate-200 rounded-xl py-8 flex flex-col items-center justify-center bg-slate-50 group-hover:bg-slate-100 group-hover:border-slate-300 transition-all">

                    <svg class="w-8 h-8 text-slate-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
                        stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>

                    <p class="text-sm text-slate-600 font-medium">
                      Klik untuk upload file
                    </p>

                    <p class="text-xs text-slate-400 mt-1">
                      PNG, JPG, PDF (Maks. 5MB)
                    </p>
                  </div>

                  <!-- Filled State -->
                  <div id="dropzone-filled"
                    class="hidden border border-slate-200 rounded-xl p-4 bg-white flex items-center justify-between shadow-sm">

                    <div class="flex items-center gap-3 overflow-hidden">
                      <div id="preview-box"
                        class="w-12 h-12 rounded-lg bg-slate-100 flex items-center justify-center overflow-hidden border border-slate-200 flex-shrink-0">

                        <img id="img-preview" class="hidden w-full h-full object-cover" />

                        <svg id="doc-icon" class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor"
                          viewBox="0 0 24 24">

                          <path
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                            stroke-width="1.5" />
                        </svg>
                      </div>

                      <div class="overflow-hidden">
                        <p id="name-preview" class="text-sm font-bold text-slate-800 truncate max-w-[200px]">
                          file.pdf
                        </p>

                        <p id="size-preview" class="text-xs text-slate-400">
                          1.2 MB
                        </p>
                      </div>
                    </div>

                    <div class="flex items-center gap-2 ml-4">
                      <a id="view-file-btn" href="#"
                        class="text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100/70 px-3 py-2 rounded-lg transition">
                        View
                      </a>

                      <button type="button" onclick="changeFile()"
                        class="text-xs font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 px-3 py-2 rounded-lg transition">
                        Ganti File
                      </button>


                    </div>
                  </div>
                </div>
              </div>
              <!-- Footer Actions -->
              <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">

                <!-- BUTTON BATAL -->
                <a href="/announcement"
                  class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
                  Batal
                </a>

                <!-- BUTTON PUBLISH -->
                <button type="submit"
                  class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
                  Publish
                </button>

              </div>
        </form>
      </div>
    </div>
  </div>

  <script>

    function handleFileSelect(input) {
      if (input.files && input.files.length > 0) {

        document.getElementById("file-input").style.pointerEvents = "none";

        const file = input.files[0];

        document.getElementById("name-preview").textContent = file.name;

        document.getElementById("size-preview").textContent =
          (file.size / (1024 * 1024)).toFixed(2) + " MB";

        const imgPreview = document.getElementById("img-preview");
        const docIcon = document.getElementById("doc-icon");

        const fileUrl = URL.createObjectURL(file);

        document.getElementById("view-file-btn").href = fileUrl;

        if (file.type.startsWith("image/")) {

          const reader = new FileReader();

          reader.onload = (e) => {
            imgPreview.src = e.target.result;

            imgPreview.classList.remove("hidden");
            docIcon.classList.add("hidden");
          };

          reader.readAsDataURL(file);

        } else {

          imgPreview.classList.add("hidden");
          docIcon.classList.remove("hidden");
        }

        document.getElementById("dropzone-empty")
          .classList.add("hidden");

        document.getElementById("dropzone-filled")
          .classList.remove("hidden");
      }
    }

    function changeFile() {
      document.getElementById("file-input").style.pointerEvents = "auto";
      document.getElementById("file-input").click();
    }

    function toggleCategoryDropdown() {
      const menu = document.getElementById('category-menu');
      const arrow = document.getElementById('category-arrow');

      if (menu.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        setTimeout(() => {
          menu.classList.remove('opacity-0', 'scale-95');
          menu.classList.add('opacity-100', 'scale-100');
        }, 10);
        arrow.classList.add('rotate-180');
      } else {
        closeCategoryDropdown();
      }
    }

    function closeCategoryDropdown() {
      const menu = document.getElementById('category-menu');
      const arrow = document.getElementById('category-arrow');

      menu.classList.remove('opacity-100', 'scale-100');
      menu.classList.add('opacity-0', 'scale-95');
      arrow.classList.remove('rotate-180');

      setTimeout(() => {
        menu.classList.add('hidden');
      }, 150);
    }

    function selectCategory(value, labelWithEmoji) {
      // Masukkan value ke hidden input form
      document.getElementById('category-value').value = value;

      // Perbarui teks di tombol trigger utama
      const labelEl = document.getElementById('category-label');
      labelEl.innerHTML = labelWithEmoji;

      closeCategoryDropdown();
    }

    // Otomatis menutup menu jika user mengklik di luar area dropdown kategori
    window.addEventListener('click', function (e) {
      const dropdown = document.getElementById('category-dropdown');
      if (dropdown && !dropdown.contains(e.target)) {
        closeCategoryDropdown();
      }
    });


  </script>
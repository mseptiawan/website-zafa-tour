<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-2xl mx-auto">

    <div class="mb-8">
      <nav class="flex items-center gap-2 mb-2 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
        <span>Area Kerja</span>
        <span class="text-slate-300">/</span>
        <span class="text-slate-900">Announcements</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900">Buat Pengumuman</h1>
      <p class="text-[14px] text-slate-500 mt-1">Publikasikan informasi internal untuk tim Anda.</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">
      <form method="POST" action="/announcement/" enctype="multipart/form-data" class="p-8 space-y-6">

      

        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">Judul Pengumuman</label>
          <input type="text" name="title" placeholder="Ketik judul di sini..." required value="<%= old?.title || '' %>"
            class="w-full bg-slate-50 border <%= (typeof errors !== 'undefined' && errors?.title) ? 'border-rose-400 focus:ring-rose-100 focus:border-rose-500' : 'border-slate-200 focus:ring-slate-100 focus:border-slate-400' %> rounded-xl px-4 py-3 text-[14px] focus:bg-white outline-none transition-all focus:ring-4" />
          
          <% if (typeof errors !== 'undefined' && errors?.title) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1"><%= errors.title %></p>
          <% } %>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">Kategori</label>
          <div class="relative w-full" id="category-dropdown">
            <% 
              let currentCatValue = old?.category || 'LIGHT';
              let currentCatLabel = '🍃 Pengumuman Ringan';
              if (currentCatValue === 'OFFICIAL') {
                currentCatLabel = '⚖️ Pengumuman Resmi';
              }
            %>
            <input type="hidden" name="category" id="category-value" value="<%= currentCatValue %>" required>
            <button type="button" onclick="toggleCategoryDropdown()"
              class="w-full bg-slate-50 border <%= (typeof errors !== 'undefined' && errors?.category) ? 'border-rose-400 focus:ring-rose-100 focus:border-rose-500' : 'border-slate-200 focus:ring-slate-100 focus:border-slate-400' %> rounded-xl px-4 py-3 text-[14px] text-slate-700 text-left flex items-center justify-between outline-none focus:bg-white focus:ring-4 transition-all">
              <span id="category-label" class="flex items-center gap-2">
                <%= currentCatLabel %>
              </span>
              <svg id="category-arrow" class="w-4 h-4 text-slate-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="category-menu" class="hidden absolute z-30 w-full mt-2 bg-white border border-slate-200 rounded-xl shadow-lg p-1.5 space-y-0.5">
              <button type="button" onclick="selectCategory('LIGHT', '🍃 Pengumuman Ringan')"
                class="w-full text-left px-3 py-2 text-[13px] font-medium text-slate-600 hover:bg-slate-50 rounded-lg flex items-center gap-2">
                <span>🍃</span> Pengumuman Ringan
              </button>
              <% if (user.role === "DIREKTUR_UTAMA") { %>
              <button type="button" onclick="selectCategory('OFFICIAL', '⚖️ Pengumuman Resmi')"
                class="w-full text-left px-3 py-2 text-[13px] font-medium text-slate-600 hover:bg-slate-50 rounded-lg flex items-center gap-2">
                <span>⚖️</span> Pengumuman Resmi
              </button>
              <% } %>
            </div>
          </div>
          <% if (typeof errors !== 'undefined' && errors?.category) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1"><%= errors.category %></p>
          <% } %>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">Isi Pengumuman</label>
          <textarea name="content" rows="6" placeholder="Tulis detail informasi di sini..." required
            class="w-full bg-slate-50 border <%= (typeof errors !== 'undefined' && errors?.content) ? 'border-rose-400 focus:ring-rose-100 focus:border-rose-500' : 'border-slate-200 focus:ring-slate-100 focus:border-slate-400' %> rounded-xl px-4 py-3 text-[14px] focus:bg-white outline-none resize-none transition-all focus:ring-4"><%= old?.content || '' %></textarea>
          
          <% if (typeof errors !== 'undefined' && errors?.content) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1"><%= errors.content %></p>
          <% } %>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">Lampiran <span class="text-slate-400 font-normal">(Opsional)</span></label>
          <div class="relative">
            <input type="file" name="attachment" id="file-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="handleFileSelect(this)" />
            <div id="dropzone-empty" class="w-full border border-slate-200 border-dashed rounded-xl p-6 bg-white hover:bg-slate-50/50 transition flex flex-col items-center text-center">
              <svg class="w-5 h-5 text-slate-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"/></svg>
              <span class="text-[13px] font-medium text-slate-600">Pilih Berkas atau Drop File Disini</span>
              <span class="text-xs text-slate-400 mt-0.5">PNG, JPG, PDF (maks 5MB)</span>
            </div>
            <div id="dropzone-filled" class="hidden flex items-center justify-between border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-sm">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-slate-50 border border-slate-200 flex items-center justify-center">
                   <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div>
                  <div id="name-preview" class="text-[13px] font-medium text-slate-700">file.pdf</div>
                  <div id="size-preview" class="text-xs text-slate-400 mt-0.5">0 KB</div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <a id="view-file-btn" href="#" target="_blank" class="text-xs font-medium text-blue-600 bg-blue-50 px-2.5 py-1.5 rounded-lg">View</a>
                <button type="button" onclick="document.getElementById('file-input').click()" class="text-xs font-medium text-slate-600 bg-slate-50 px-2.5 py-1.5 rounded-lg">Ganti</button>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
          <a href="/announcement" class="bg-white hover:bg-slate-50 text-slate-600 border border-slate-200 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all">Batal</a>
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50">Publish</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function handleFileSelect(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];
      document.getElementById("name-preview").textContent = file.name;
      document.getElementById("size-preview").textContent = (file.size / 1024).toFixed(1) + " KB";
      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
      document.getElementById("view-file-btn").href = URL.createObjectURL(file);
    }
  }

  function toggleCategoryDropdown() {
    const menu = document.getElementById('category-menu');
    menu.classList.toggle('hidden');
    document.getElementById('category-arrow').classList.toggle('rotate-180');
  }

  function selectCategory(value, label) {
    document.getElementById('category-value').value = value;
    document.getElementById('category-label').innerHTML = label;
    toggleCategoryDropdown();
  }
</script>
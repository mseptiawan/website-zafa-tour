<% layout('layouts/main') -%>

<!-- 
  Penjelasan Class:
  - ml-72: Memberi ruang untuk sidebar (18rem/288px).
  - min-h-screen: Memastikan background abu-abu memenuhi tinggi layar.
  - p-8: Padding agar konten tidak menempel ke pinggir.
-->
<div class=" min-h-screen bg-slate-50 p-8 ml-72">
  
  <!-- Container Utama dengan Max Width agar tidak terlalu melar di layar Ultra Wide -->
  <div class="max-w-6xl mx-auto">
    
    <!-- Header Section -->
    <div class="flex justify-between items-end mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Input KPI Karyawan</h1>
        <p class="text-slate-500 mt-1">Manajemen penilaian kinerja karyawan Zafa Mulia Mandiri.</p>
      </div>
      <div class="text-sm text-slate-400">
        Total: <span class="font-bold text-slate-700"><%= employees.length %> Karyawan</span>
      </div>
    </div>

    <!-- Table Card Container -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50/50 border-b border-slate-200">
              <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Data Karyawan</th>
              <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Unit Kerja</th>
              <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Bidang</th>
              <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider text-center">Aksi</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">
            <% if (employees.length > 0) { %>
              <% employees.forEach(emp => { %>
                <tr class="hover:bg-indigo-50/30 transition-colors duration-150">
                  <td class="px-6 py-5">
                    <div class="flex items-center">
                      <div class="h-10 w-10 flex-shrink-0 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold">
                        <%= emp.fullName.charAt(0) %>
                      </div>
                      <div class="ml-4">
                        <div class="text-sm font-semibold text-slate-900"><%= emp.fullName %></div>
                        <div class="text-xs text-slate-400">ID: <%= emp._id.toString().substring(18) %></div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-5">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-blue-50 text-blue-700 border border-blue-100">
                      <%= emp.unitId?.name || 'N/A' %>
                    </span>
                  </td>
                  <td class="px-6 py-5 text-sm text-slate-600">
                    <%= emp.bidangId?.name || '-' %>
                  </td>
                  <td class="px-6 py-5 text-center">
                    <a href="/kpi/input/<%= emp._id %>" 
                       class="inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-all shadow-sm hover:shadow-indigo-200 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-1">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Nilai Kinerja
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="px-6 py-12 text-center text-slate-400 italic">
                  Belum ada data karyawan untuk dinilai.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Footer Information -->
    <p class="mt-4 text-xs text-slate-400 text-center">
      © 2026 HRIS System • Pastikan data sudah sesuai sebelum melakukan submit penilaian.
    </p>
  </div>
</div>
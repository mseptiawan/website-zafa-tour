<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/60 p-8 antialiased">
    <div class="max-w-6xl mx-auto"> <!-- Diperlebar ke max-w-6xl agar layout 2 kolom lebih leluasa -->

  <% 
  // Cek apakah user saat ini adalah orang yang harus memproses persetujuan (approver / delegasi)
  const isApproverView = approvals.some(app => {
    if (app.status !== 'PENDING') return false;
    if (app.step === 'HANDOVER') {
      return leave.handoverUserId && leave.handoverUserId._id && leave.handoverUserId._id.toString() === user._id.toString();
    }
    return (app.step || '').toUpperCase() === (user.role || '').toUpperCase();
  });

  // Tentukan arah link kembali secara dinamis
  // Jaga-jaga jika diakses dari halaman Pusat Manajemen Cuti (HR/Manager/Pimpinan)
  const APPROVER_ROLES = ["MANAGER", "HR", "PIMPINAN", "GENERAL_MANAGER"];
  const isManagement = APPROVER_ROLES.includes((user.role || '').toUpperCase());
  const backLink = isManagement ? '/leave/manage-requests' : (isApproverView ? '/leave/my-delegations' : '/leave/my-history');
%>

<a href="<%= backLink %>"
  class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 mb-6 transition-colors group">
  <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none"
    stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
  </svg>
  Kembali
</a>
      <!-- RESUBMIT ACTION AREA (IF REJECTED) - Tetap Full Width di Atas -->
      <% if ((leave.status === 'REJECTED' || leave.status === 'CANCELED') && leave.userId && leave.userId._id.toString() === user._id.toString()) { %>
        <div class="border border-blue-100 bg-blue-50/30 rounded-xl p-5 flex items-center justify-between mb-6 shadow-[0_1px_3px_rgba(15,23,42,0.03)]">
          <div>
            <h2 class="text-sm font-semibold text-blue-900">Pengajuan Dihentikan</h2>
            <p class="text-[13px] text-blue-700/90 mt-0.5">
              Anda dapat melakukan penyesuaian data dan mengirim ulang berkas ini kembali.
            </p>
          </div>
          <a href="/leave/resubmit/<%= leave._id %>"
             class="px-4 py-2 bg-blue-600 text-white text-[13px] font-medium rounded-lg hover:bg-blue-700 transition shadow-sm focus:ring-4 focus:ring-blue-50">
            Resubmit Pengajuan
          </a>
        </div>
      <% } %>

      <!-- TWO-COLUMN LAYOUT GRID -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
        
        <!-- ===================================== -->
        <!-- LEFT COLUMN: CORE INFO & DESCRIPTION  -->
        <!-- ===================================== -->
        <div class="lg:col-span-2 space-y-6">
          
          <!-- MAIN CARD: INFORMATION -->
          <div class="bg-white border border-slate-200/60 rounded-xl shadow-[0_1px_3px_rgba(15,23,42,0.03)] overflow-hidden">
            <!-- HEADER CARD -->
<div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-white">
  <div class="flex items-center gap-3">
    <!-- Avatar Icon -->
    <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200/60 flex items-center justify-center text-slate-500 shrink-0">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
    </div>
    <div>
  <h1 class="text-sm font-bold text-slate-900 tracking-tight leading-none mb-1.5">
    <%= (leave.userId && leave.userId.employeeData) ? leave.userId.employeeData.fullName : 'Detail Pengajuan Cuti' %>
  </h1>
  
  <p class="text-[11px] text-slate-400 font-medium mb-1.5">
    Tujuan Dokumen: 
    <span class="font-bold <%= leave.status === 'CANCELLATION_PENDING' ? 'text-amber-600' : 'text-blue-600' %>">
      <%= leave.status === 'CANCELLATION_PENDING' ? 'Permohonan Pembatalan Cuti' : 'Permohonan Cuti Baru' %>
    </span>
  </p>

  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] font-medium">
    <span class="text-slate-500 flex items-center gap-1">
  <i class="fa-solid fa-briefcase text-slate-400 text-[10px]"></i>
  Unit: 
  <span class="text-slate-700 font-semibold">
    <%= (leave.userId && leave.userId.employeeData && leave.userId.employeeData.unitId) ? leave.userId.employeeData.unitId.name : 'Tidak Ada' %>
  </span>
</span>

    <span class="text-slate-300 hidden sm:inline">•</span>

    <span class="text-slate-500 flex items-center gap-1">
      <i class="fa-solid fa-clock-rotate-left text-slate-400 text-[10px]"></i>
      Sisa Kuota: 
     <span class="px-1.5 py-0.5 rounded font-bold bg-slate-100 text-slate-700 tabular-nums">
  <%= (leave.userId && leave.userId.leaveBalanceData) ? leave.userId.leaveBalanceData.remaining : '0' %> Hari
</span>
    </span>
  </div>
</div>
  </div>

  <!-- STATUS BADGE -->
  <div>
    <span class="text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-wider border
      <%= leave.status === 'PENDING' ? 'bg-amber-50 text-amber-700 border-amber-200/50'
        : leave.status === 'CANCELLATION_PENDING' ? 'bg-orange-50 text-orange-700 border-orange-200/50'
        : leave.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50'
        : leave.status === 'REJECTED' ? 'bg-rose-50 text-rose-700 border-rose-200/50'
        : leave.status === 'CANCELLED' || leave.status === 'CANCELED' ? 'bg-slate-100 text-slate-600 border-slate-300'
        : 'bg-purple-50 text-purple-700 border-purple-200/50'
      %>">
      <%= leave.status === 'CANCELLATION_PENDING' ? 'MINTA BATAL' : leave.status %>
    </span>
  </div>
</div>

            <!-- CARD BODY -->
            <div class="p-6 space-y-6">
              
              <!-- GRID DATA -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Tipe / Jenis Cuti</div>
                  <div class="text-[13px] font-semibold text-slate-800 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80">
                    <%= leave.leaveTypeId.name %> 
                  </div>
                </div>

                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Total Durasi</div>
                  <div class="text-[13px] font-bold text-slate-900 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80">
                    <%= leave.totalDays %> Hari Kerja
                  </div>
                </div>

                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Tanggal Mulai Cuti</div>
                  <div class="text-[13px] font-medium text-slate-800 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80">
                    <%= leave.startDate ? new Date(leave.startDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %>
                  </div>
                </div>

                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Tanggal Selesai Cuti</div>
                  <div class="text-[13px] font-medium text-slate-800 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80">
                    <%= leave.endDate ? new Date(leave.endDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %>
                  </div>
                </div>

                <div class="sm:col-span-2">
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Delegasi Tugas (Handover To)</div>
                  <div class="text-[13px] font-medium text-slate-800 flex items-center gap-2 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80">
                    <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <span class="truncate">
                      <%= (leave.handoverUserId && leave.handoverUserId.employeeData) ? leave.handoverUserId.employeeData.fullName : 'Tidak ada delegasi tugas' %>
                    </span>
                  </div>
                </div>
              </div>

              <!-- ALASAN CUTI -->
              <div class="pt-4 border-t border-slate-100">
                <div class="text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-2">Alasan / Kepentingan Cuti</div>
                <div class="text-[13px] text-slate-600 leading-relaxed bg-slate-50/50 border border-slate-100 p-4 rounded-xl whitespace-pre-line">
                  <%= leave.reason || '-' %>
                </div>
              </div>

              <!-- LAMPIRAN DOKUMEN -->
              <div class="pt-4 border-t border-slate-100">
                <div class="text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-2.5">Lampiran Dokumen Pendukung</div>
                <% if (leave.documentPath) { %>
                  <div class="flex items-center justify-between border border-slate-100 rounded-xl p-3 bg-white hover:border-slate-300 transition-colors">
                    <div class="flex items-center gap-3 min-w-0">
                      <div class="w-10 h-10 rounded-lg border border-slate-100 bg-slate-50 flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                      </div>
                      <div class="min-w-0">
                        <div class="text-[13px] font-medium text-slate-700 truncate">Berkas_Lampiran_Cuti.pdf</div>
                        <div class="text-[10px] text-slate-400 uppercase mt-0.5">Dokumen Fisik</div>
                      </div>
                    </div>
                    <a href="<%= leave.documentPath %>" target="_blank"
                      class="text-xs font-semibold text-blue-600 bg-blue-50/50 hover:bg-blue-100/80 px-3 py-1.5 rounded-lg transition shrink-0">
                      View File
                    </a>
                  </div>
                <% } else { %>
                  <div class="text-xs text-slate-400 bg-slate-50/50 p-4 rounded-xl border border-dashed border-slate-200 text-center">
                    Tidak ada berkas dokumen pendukung yang diunggah.
                  </div>
                <% } %>
              </div>

            </div>
          </div>

          <!-- EVALUATION FORM (IF ACTIVE APPROVER) -->
          <% 
            const activeApproval = approvals.find(app => {
              if (app.status !== 'PENDING') return false;
              if (app.step === 'HANDOVER') {
                return (
                  leave.handoverUserId &&
                  leave.handoverUserId._id &&
                  leave.handoverUserId._id.toString() === user._id.toString()
                );
              }
              return (app.step || '').toUpperCase() === (user.role || '').toUpperCase();
            });
          %>

          <% if (activeApproval) { %>
            <div class="bg-white border border-slate-200 rounded-xl shadow-[0_1px_3px_rgba(15,23,42,0.03)] p-6">
              <div class="flex items-center gap-2 mb-4">
                <div class="p-1.5 <%= leave.status === 'CANCELLATION_PENDING' ? 'bg-amber-50 text-amber-600' : 'bg-blue-50 text-blue-600' %> rounded-lg">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-slate-900">
                    <%= leave.status === 'CANCELLATION_PENDING' ? 'Form Tinjauan Pembatalan Cuti' : 'Form Evaluasi & Persetujuan' %>
                  </h3>
                  <p class="text-xs text-slate-500 mt-0.5">Bertindak selaku: <span class="font-bold text-slate-700"><%= activeApproval.step %></span></p>
                </div>
              </div>

              <div class="mb-5">
                <label for="reviewNote" class="block text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-2">
                  Catatan Pemeriksa / Alasan (Opsional)
                </label>
                <textarea 
                  id="reviewNote" 
                  name="note" 
                  rows="3" 
                  placeholder="<%= leave.status === 'CANCELLATION_PENDING' ? 'Masukkan alasan menyetujui atau menolak pembatalan cuti...' : 'Masukkan alasan disetujui atau ditolak...' %>"
                  class="w-full text-sm text-slate-800 bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-none focus:bg-white"
                  oninput="document.querySelectorAll('.sync-note').forEach(input => input.value = this.value)"
                ></textarea>
              </div>

              <div class="flex items-center gap-3">
                <% 
                  const approveUrl = activeApproval.step === 'HANDOVER' ? `/leave/delegation/approve/${activeApproval._id}` : `/leave/approval/approve/${activeApproval._id}`;
                  const rejectUrl = activeApproval.step === 'HANDOVER' ? `/leave/delegation/reject/${activeApproval._id}` : `/leave/approval/reject/${activeApproval._id}`;
                %>
                <!-- TOMBOL SETUJU (ADAPTIF TEKS BERDASARKAN STATUS PEMBATALAN) -->
                <form action="<%= approveUrl %>" method="POST" class="inline">
                  <input type="hidden" name="note" class="sync-note" value="">
                  <button type="submit" class="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold rounded-xl transition shadow-sm cursor-pointer">
                    <%= leave.status === 'CANCELLATION_PENDING' ? 'Setujui Pembatalan' : 'Terima & Setujui' %>
                  </button>
                </form>

                <!-- TOMBOL TOLAK (ADAPTIF TEKS BERDASARKAN STATUS PEMBATALAN) -->
                <form action="<%= rejectUrl %>" method="POST" class="inline">
                  <input type="hidden" name="note" class="sync-note" value="">
                  <button type="submit" class="px-5 py-2.5 bg-white hover:bg-rose-50 text-rose-600 border border-rose-200 text-xs font-bold rounded-xl transition cursor-pointer">
                    <%= leave.status === 'CANCELLATION_PENDING' ? 'Tolak Pembatalan (Tetap Cuti)' : 'Tolak Pengajuan' %>
                  </button>
                </form>
              </div>
            </div>
          <% } %>

        </div>

        <!-- ===================================== -->
        <!-- RIGHT COLUMN: TRACKING LOG TIMELINE   -->
        <!-- ===================================== -->
      <div class="bg-white border border-slate-200/60 rounded-xl shadow-sm p-6">
  <div class="mb-8">
    <h2 class="text-sm font-bold text-slate-900 tracking-tight">Jejak Log Pemeriksaan</h2>
    <p class="text-xs text-slate-400 mt-0.5">Alur dan status persetujuan berkas</p>
  </div>

  <div class="relative pl-6 space-y-8 before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-100">
    
    <% approvals.forEach((app, index) => { %>
      <div class="relative group">
        
        <div class="absolute -left-[27px] top-0 w-6 h-6 rounded-full border-4 border-white flex items-center justify-center transition-colors shadow-sm
          <%= app.status === 'APPROVED' ? 'bg-emerald-500' : app.status === 'REJECTED' ? 'bg-rose-500' : 'bg-amber-400' %>">
          <span class="text-[8px] text-white font-bold"><%= index + 1 %></span>
        </div>

        <div class="flex flex-col gap-1.5">
          <div class="flex items-center justify-between">
            <span class="text-[11px] font-bold text-slate-900 tracking-wide uppercase"><%= app.step %></span>
            
            <span class="text-[9px] font-bold px-2 py-0.5 rounded-full uppercase border
              <%= app.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50' 
                : app.status === 'REJECTED' ? 'bg-rose-50 text-rose-700 border-rose-200/50' 
                : 'bg-amber-50 text-amber-700 border-amber-200/50' %>">
              <%= app.status %>
            </span>
          </div>

          <div class="flex items-center gap-2 text-[11px]">
            <span class="font-medium text-slate-700">
              <%= (app.approverId && app.approverId.employeeData) ? app.approverId.employeeData.fullName : 'Sistem' %>
            </span>
            <span class="text-slate-300">|</span>
            <span class="text-slate-400">
              <%= app.actionDate ? new Date(app.actionDate).toLocaleString('id-ID', {day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit'}) : 'Menunggu' %>
            </span>
          </div>

          <% if (app.note) { %>
            <div class="mt-2 text-[11px] text-slate-600 bg-slate-50 border border-slate-100/50 p-3 rounded-lg leading-relaxed italic">
              "<%= app.note %>"
            </div>
          <% } %>
        </div>

      </div>
    <% }) %>
  </div>
</div>

      </div>

    </div>
  </div>
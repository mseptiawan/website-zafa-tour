<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

    <div class="max-w-2xl mx-auto">

      <!-- HEADER -->
     <%- include('../partials/page-header', { 
    section: 'Area Kerja', 
    module: 'Dinas Luar', 
    title: 'Pengajuan Dinas Luar', 
    description: 'Form pengajuan perjalanan dinas' 
}) %>

      <!-- CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

        <form action="/trip/" method="POST" class="p-8 space-y-6">

          <!-- TITLE -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-semibold text-slate-700">
              Judul Perjalanan
            </label>

            <input type="text" name="title" placeholder="Judul perjalanan" minlength="5" maxlength="100" required
              class="w-full bg-slate-50 border border-slate-200 rounded-xl text-xs px-4 py-3  text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />
          </div>

          <!-- PURPOSE -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-semibold text-slate-700">
              Tujuan Perjalanan
            </label>

            <!-- DROPDOWN CONTAINER -->
            <div class="relative w-full" id="custom-dropdown">

              <!-- HIDDEN INPUT (Untuk menampung value form yang dikirim ke backend) -->
              <input type="hidden" name="purpose" id="purpose-value" required>

              <!-- SELECT TRIGGER BUTTON -->
              <button type="button" onclick="toggleDropdown()"
                class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-3 text-[13px] font-medium text-slate-700 text-left flex items-center justify-between outline-none hover:bg-slate-50 hover:border-slate-300 focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all duration-200 cursor-pointer shadow-sm shadow-slate-100/50">
                <span id="dropdown-label" class="text-slate-400 text-xs">Pilih tujuan perjalanan</span>
                <svg id="dropdown-arrow" class="w-4 h-4 text-slate-400 stroke-[2] transition-transform duration-200"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>

              <!-- OPTIONS MENU PANELS -->
              <div id="dropdown-menu"
                class="hidden absolute z-30 w-full mt-2 bg-white border border-slate-200/50 rounded-xl shadow-xl shadow-slate-100/80 p-1.5 space-y-0.5 origin-top transform opacity-0 scale-95 transition-all duration-150 backdrop-blur-sm">

                <!-- OPTION ITEM -->
                <button type="button" onclick="selectOption('KUNJUNGAN_SALES', 'Kunjungan Sales')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Kunjungan Sales</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

                <button type="button" onclick="selectOption('RAPAT', 'Rapat / Meeting')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Rapat / Meeting</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

                <button type="button" onclick="selectOption('PELATIHAN', 'Pelatihan / Training')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Pelatihan / Training</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

                <button type="button" onclick="selectOption('SURVEI', 'Survei Lapangan')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Survei Lapangan</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

                <button type="button" onclick="selectOption('LAINNYA', 'Lainnya')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Lainnya</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

              </div>
            </div>
          </div>

          <!-- DATE -->
          <div class="grid grid-cols-2 gap-4">

            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-slate-700">
                Tanggal Mulai
              </label>

              <input type="date" name="startDate" required
                class="w-full bg-slate-50 border border-slate-200 rounded-xl text-xs  italic px-4 py-3  text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />
            </div>

            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-slate-700">
                Tanggal Selesai
              </label>

              <input type="date" name="endDate" required
                class="w-full bg-slate-50 border border-slate-200 rounded-xl text-xs italic px-4 py-3  text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />
            </div>

          </div>

          <!-- DESTINATION -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-semibold text-slate-700">
              Tujuan / Lokasi
            </label>

            <input type="text" name="destination" placeholder="Tujuan perjalanan" minlength="3" maxlength="150" required
              class="w-full bg-slate-50 border border-slate-200 rounded-xl text-xs px-4 py-3  text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />
          </div>

          <!-- DESCRIPTION -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-semibold text-slate-700">
              Deskripsi
            </label>

            <textarea name="description" rows="4" minlength="10" maxlength="1000" required
              placeholder="Deskripsi perjalanan"
              class="w-full bg-slate-50 border border-slate-200 rounded-xl text-xs px-4 py-3  text-slate-700 outline-none resize-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all"></textarea>
          </div>

          <!-- BUDGET -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-semibold text-slate-700">
              Budget
            </label>

            <input type="text" id="budget" placeholder="Budget (Rp)"
              class="w-full bg-slate-50 border border-slate-200 rounded-xl text-xs px-4 py-3  text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

            <input type="hidden" name="budget" id="budgetRaw" />
          </div>

          <!-- CONTACT PERSON -->
          <div class="space-y-1.5">

            <label class="text-[13px] font-semibold text-slate-700">
              Bertemu dengan
            </label>

            <input type="text" name="meetWith" placeholder="M Septiawan"
              class="w-full bg-slate-50 border border-slate-200 rounded-xl text-xs px-4 py-3  text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />


          </div>

          <!-- TIMELINE -->
       <div class="space-y-4">
  <label class="text-[13px] font-semibold text-slate-700 tracking-wide block">
    Timeline Perjalanan
  </label>

  <div class="relative pl-8 space-y-4 before:absolute before:left-[11px] before:top-3 before:bottom-3 before:w-0.5 before:bg-slate-200/70">
    
    <div id="timelineBox" class="space-y-4">
      
      <div class="relative flex gap-3 items-center timeline-item group">
        <div class="absolute -left-[27px] flex items-center justify-center w-2.5 h-2.5 rounded-full bg-indigo-600 ring-4 ring-indigo-50 z-10 transition-all duration-200"></div>
        
        <input type="text" name="timeline[0][address]" placeholder="Lokasi keberangkatan / alamat awal" required
          class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

        <input type="hidden" name="timeline[0][order]" value="1" />

        <button type="button" onclick="removeTimeline(this)"
          class="px-3 py-3 rounded-xl bg-slate-50 text-slate-400 hover:bg-rose-50 hover:text-rose-500 transition-all duration-200 opacity-0 group-hover:opacity-100 focus:opacity-100">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

    </div>

    <div class="relative flex items-center pt-1">
      <div class="absolute -left-[32px] flex items-center justify-center w-5 h-5 rounded-full bg-white border border-slate-200 text-slate-400 group hover:border-indigo-500 hover:text-indigo-500 transition-colors duration-200 z-10 shadow-sm">
        <svg class="w-3 h-3 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
      </div>
      
      <button type="button" onclick="addTimeline()" 
        class="text-xs font-semibold text-slate-500 hover:text-indigo-600 transition-colors duration-200 pl-1 cursor-pointer focus:outline-none">
        Tambah destinasi kunjungan berikutnya...
      </button>
    </div>

  </div>
</div>
          <!-- SUBMIT -->
          <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
  
  <a href="/trip/my" 
    class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
    Batal
  </a>

  <button type="submit" 
    class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
    <%= typeof mode !== 'undefined' ? (mode === 'CREATE' ? 'Ajukan Perjalanan' : (mode === 'EDIT' ? 'Simpan Perubahan' : 'Kirim Ulang Form')) : 'Ajukan Perjalanan' %>
  </button>

</div>

        </form>

      </div>

    </div>
  </div>

  <script>
    let timelineIndex = 1;

    // BUDGET FORMAT
    const budgetInput = document.getElementById("budget");
    const budgetRaw = document.getElementById("budgetRaw");

    budgetInput.addEventListener("input", function (e) {
      let value = e.target.value.replace(/\D/g, "");

      budgetRaw.value = value;

      if (!value) {
        e.target.value = "";
        return;
      }

      e.target.value = Number(value).toLocaleString("id-ID");
    });

    // ADD TIMELINE
  function addTimeline() {
  const box = document.getElementById("timelineBox");
  const div = document.createElement("div");
  div.className = "relative flex gap-3 items-center timeline-item group animate-fadeIn";

  div.innerHTML = `
    <div class="absolute -left-[27px] flex items-center justify-center w-2.5 h-2.5 rounded-full bg-slate-300 ring-4 ring-slate-50 z-10 group-hover:bg-indigo-400 group-hover:ring-indigo-50 transition-all duration-200"></div>
    
    <input type="text"
      name="timeline[${timelineIndex}][address]"
      placeholder="Alamat tujuan berikutnya"
      required
      class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

    <input type="hidden"
      name="timeline[${timelineIndex}][order]"
      value="${timelineIndex + 1}" />

    <button type="button"
      onclick="removeTimeline(this)"
      class="px-3 py-3 rounded-xl bg-slate-50 text-slate-400 hover:bg-rose-50 hover:text-rose-500 transition-all duration-200 opacity-0 group-hover:opacity-100 focus:opacity-100">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  `;

  box.appendChild(div);
  timelineIndex++;
}

    function removeTimeline(btn) {
      btn.parentElement.remove();
    }
   function toggleDropdown() {
      const menu = document.getElementById('dropdown-menu');
      const arrow = document.getElementById('dropdown-arrow');

      if (menu.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        setTimeout(() => {
          menu.classList.remove('opacity-0', 'scale-95');
          menu.classList.add('opacity-100', 'scale-100');
        }, 10);
        arrow.classList.add('rotate-180');
      } else {
        closeDropdown();
      }
    }

    function closeDropdown() {
      const menu = document.getElementById('dropdown-menu');
      const arrow = document.getElementById('dropdown-arrow');

      menu.classList.remove('opacity-100', 'scale-100');
      menu.classList.add('opacity-0', 'scale-95');
      arrow.classList.remove('rotate-180');

      setTimeout(() => {
        menu.classList.add('hidden');
      }, 150);
    }
   function selectOption(value, label) {
      document.getElementById('purpose-value').value = value;
      const labelEl = document.getElementById('dropdown-label');
      labelEl.textContent = label;
      labelEl.classList.remove('text-slate-400');
      labelEl.classList.add('text-slate-700');
      closeDropdown();
    }

    window.addEventListener('click', function (e) {
      const dropdown = document.getElementById('custom-dropdown');
      if (dropdown && !dropdown.contains(e.target)) {
        closeDropdown();
      }
    });


  </script>
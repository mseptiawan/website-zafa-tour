<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50  py-5 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 pb-5 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header', { 
            section: 'Area Kerja', 
            module: 'Keuangan', 
            title: 'Riwayat Slip Gaji', 
            description: 'Daftar dokumen slip pendapatan resmi Anda di PT Zafa Mulia Mandiri' 
        }) %>
      </div>
    </div>

    <% if (!payrolls || payrolls.length === 0) { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl py-16 text-center px-4">
        <div class="w-10 h-10 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-3.5 text-slate-400">
          <i class="fa-solid fa-receipt text-lg"></i>
        </div>
        <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Riwayat Slip Gaji</p>
        <p class="text-[11.5px] text-slate-400 max-w-xs mx-auto mt-0.5 leading-relaxed">Belum ada riwayat dokumen slip gaji yang diterbitkan untuk akun Anda saat ini.</p>
      </div>
    <% } else { %>

      <div class="grid grid-cols-1 gap-3 md:block md:bg-white md:border md:border-slate-200/60 md:rounded-2xl md:p-1.5 md:divide-y md:divide-slate-100/80">
        <% payrolls.forEach((pay, index) => { %>
          
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 md:bg-transparent md:border-none md:rounded-none md:p-4 hover:bg-slate-50/60 transition-all flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 select-none">
            
            <div class="flex items-center gap-3.5 min-w-0">
              <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-400 shrink-0">
                <i class="fa-solid fa-file-invoice-dollar text-[14px]"></i>
              </div>
              
              <div class="space-y-0.5 min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-[13px] font-bold text-slate-800 tracking-tight">Periode <%= pay.periodMonth %></span>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-emerald-50 text-emerald-600 border border-emerald-100/50">
                    <span class="h-1 w-1 rounded-full bg-emerald-500"></span> PAID
                  </span>
                </div>
                <div class="text-[12px] text-slate-400 font-medium">
                  Take Home Pay: <span class="font-bold text-slate-700">Rp <%= pay.netTakeHomePay.toLocaleString('id-ID') %></span>
                </div>
              </div>
            </div>
            
          <div class="flex items-center justify-end gap-2 shrink-0 pt-2 sm:pt-0">
  <% if (pay.status === 'PAID') { %>
    <span class="text-[11px] text-slate-400 font-medium px-2 hidden sm:inline-block">Processed by Bank</span>
  <% } %>

  <a href="/report/payroll/download-pdf/<%= pay._id %>" target="_blank"
     class="bg-blue-50 hover:bg-blue-100 text-blue-600 text-[11px] font-bold h-8.5 px-4 rounded-xl transition-all cursor-pointer flex items-center justify-center gap-1.5 border-none flex-1 sm:flex-none active:scale-[0.98] decoration-none">
    <i class="fa-solid fa-file-pdf text-[10px] text-blue-500"></i> Unduh PDF
  </a>
</div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </div>
</div>
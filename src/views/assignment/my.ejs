<%- layout('layouts/main', { title: title }) %>

  <div class="ml-72 min-h-screen bg-slate-50 p-6">

    <div class="max-w-5xl mx-auto">

      <!-- HEADER -->
      <div class="mb-6">

        <h1 class="text-2xl font-semibold text-slate-800">
          Penugasan Saya
        </h1>

        <p class="text-sm text-slate-500 mt-1">
          Daftar penugasan yang diberikan kepada Anda
        </p>

      </div>

      <!-- EMPTY -->
      <% if(assignments.length===0) { %>

        <div class="bg-white border border-slate-200 rounded-xl py-14 text-center">

          <p class="text-sm text-slate-500">
            Belum ada penugasan
          </p>

        </div>

        <% } %>

          <!-- LIST -->
          <div class="space-y-3">

            <% assignments.forEach(a=> { %>

              <a href="/assignment/<%= a._id %>"
                class="block bg-white border border-slate-200 rounded-xl px-5 py-4 hover:border-slate-300 hover:bg-slate-50 transition">

                <!-- TOP -->
                <div class="flex items-start justify-between gap-4">

                  <div class="min-w-0">

                    <h2 class="text-[15px] font-medium text-slate-800 break-words">
                      <%= a.title %>
                    </h2>

                    <p class="text-sm text-slate-500 mt-1 line-clamp-1 break-words">
                      <%= a.description || 'Tidak ada deskripsi' %>
                    </p>

                  </div>

                  <div class="flex-shrink-0">

                    <% if(a.endDate && new Date(a.endDate)>= new Date()) { %>

                      <span class="text-[11px] bg-emerald-50 text-emerald-600 px-2.5 py-1 rounded-md">
                        Active
                      </span>

                      <% } else { %>

                        <span class="text-[11px] bg-slate-100 text-slate-500 px-2.5 py-1 rounded-md">
                          Completed
                        </span>

                        <% } %>

                  </div>

                </div>

                <!-- META -->
                <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4 text-[13px] text-slate-500">

                  <div>
                    <span class="text-slate-400">Tipe:</span>

                    <span class="text-slate-700 ml-1">
                      <%= a.type %>
                    </span>
                  </div>

                  <div>
                    <span class="text-slate-400">Lokasi:</span>

                    <span class="text-slate-700 ml-1">
                      <%= a.location || '-' %>
                    </span>
                  </div>

                  <div>
                    <span class="text-slate-400">Mulai:</span>

                    <span class="text-slate-700 ml-1">
                      <%= new Date(a.startDate).toLocaleDateString("id-ID") %>
                    </span>
                  </div>

                  <div>
                    <span class="text-slate-400">Selesai:</span>

                    <span class="text-slate-700 ml-1">
                      <%= new Date(a.endDate).toLocaleDateString("id-ID") %>
                    </span>
                  </div>

                </div>

                <!-- ATTACHMENT -->
                <% if(a.attachment) { %>

                  <div class="mt-3 text-[12px] text-slate-400">
                    Ada lampiran surat penugasan
                  </div>

                  <% } %>

              </a>

              <% }) %>

          </div>
          <% if (pagination.totalPages> 1) { %>
            <div
              class="flex items-center justify-between mt-6 px-5 py-4 bg-white border border-slate-200 rounded-2xl shadow-sm text-[13px] antialiased">

              <!-- LEFT INFO -->
              <div class="text-slate-500 font-medium">
                Menampilkan halaman
                <span class="font-bold text-slate-900">
                  <%= pagination.page %>
                </span>
                dari
                <span class="font-bold text-slate-900">
                  <%= pagination.totalPages %>
                </span>
              </div>

              <!-- RIGHT CONTROLS -->
              <div class="flex items-center gap-2">

                <!-- PREV BUTTON -->
                <a href="?page=<%= pagination.page - 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasPrev
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                  Prev
                </a>

                <!-- NEXT BUTTON -->
                <a href="?page=<%= pagination.page + 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasNext
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
                  Next
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>

              </div>

            </div>
            <% } %>
    </div>

  </div>
    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Menu Kasbon</h3>
    <div class="grid grid-cols-2 gap-3 pt-2">
      <a href="/loans/new" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-violet-50 border border-slate-100 text-center gap-2"><div class="w-10 h-10 rounded-xl bg-violet-50 text-violet-600 flex items-center justify-center"><i class="fa-solid fa-plus text-sm"></i></div><span class="text-xs font-bold text-slate-700">Buat Kasbon</span></a>
      <a href="/loans/me" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-violet-50 border border-slate-100 text-center gap-2"><div class="w-10 h-10 rounded-xl bg-violet-50 text-violet-600 flex items-center justify-center"><i class="fa-solid fa-clock-rotate-left text-sm"></i></div><span class="text-xs font-bold text-slate-700">Riwayat Saya</span></a>
      <% if (typeof user !== 'undefined' && ['WAKIL_DIREKTUR', 'DIREKTUR_UTAMA'].includes(user.role)) { %>
      <a href="/loans/approval" class="col-span-2 flex items-center gap-3 p-4 rounded-2xl bg-amber-50/60 hover:bg-amber-50 border border-amber-100 text-left">
        <div class="w-10 h-10 rounded-xl bg-amber-500 text-white flex items-center justify-center shrink-0 shadow-sm"><i class="fa-solid fa-user-shield text-sm"></i></div>
        <div>
          <span class="text-xs font-bold text-slate-800 block">Persetujuan Kasbon</span>
          <span class="text-[10px] text-slate-500 font-medium">Validasi pengajuan kasbon staf & manager</span>
        </div>
      </a>
      <% } %>
    </div>
  </div>
</div>


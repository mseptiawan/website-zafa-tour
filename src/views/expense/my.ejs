<%- layout('layouts/main', { title: 'Klaim Saya' }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-6xl mx-auto">
    
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Klaim Saya</h1>
        <p class="text-sm text-slate-500 mt-1">Daftar riwayat pengajuan beban operasional Anda</p>
      </div>
      <a href="/expense/create" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition shadow-sm">
        + Buat Klaim Baru
      </a>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[1000px]">
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-100">
            <tr>
              <th class="px-6 py-4 text-left">Judul & Kategori</th>
              <th class="px-6 py-4 text-left">Nominal</th>
              <th class="px-6 py-4 text-left">Tanggal</th>
              <th class="px-6 py-4 text-left">Status</th>
              <th class="px-6 py-4 text-center">Bukti</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (expenses.length === 0) { %>
              <tr><td colspan="6" class="text-center py-12 text-slate-400">Belum ada pengajuan klaim</td></tr>
            <% } %>

            <% 
              const statusConfig = {
                'PENDING_MANAGER': { bg: 'bg-amber-50', text: 'text-amber-700', label: 'Menunggu Manager' },
                'PENDING_FINANCE': { bg: 'bg-blue-50', text: 'text-blue-700', label: 'Menunggu Finance' },
                'PAID': { bg: 'bg-emerald-50', text: 'text-emerald-700', label: 'Sudah Dibayar' },
                'REJECTED': { bg: 'bg-rose-50', text: 'text-rose-700', label: 'Ditolak' }
              };
            %>

            <% expenses.forEach(e => { %>
              <tr class="hover:bg-slate-50/50 transition">
                <td class="px-6 py-4">
                  <div class="font-semibold text-slate-800"><%= e.title %></div>
                  <div class="text-[11px] text-slate-400 font-medium uppercase mt-0.5"><%= e.category %></div>
                </td>
                <td class="px-6 py-4 font-mono font-medium text-slate-700">Rp <%= e.amount.toLocaleString('id-ID') %></td>
                <td class="px-6 py-4 text-slate-500"><%= new Date(e.expenseDate).toLocaleDateString('id-ID') %></td>
                
                <td class="px-6 py-4">
                  <% const s = statusConfig[e.status] || { bg: 'bg-slate-50', text: 'text-slate-600', label: e.status }; %>
                  <span class="inline-flex px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide border border-transparent <%= s.bg %> <%= s.text %>">
                    <%= s.label %>
                  </span>
                </td>

             

                <td class="px-6 py-4 text-center">
                  <% if (!e.proofFile) { %>
                    <span class="text-[10px] bg-slate-100 text-slate-500 px-2 py-1 rounded-full">Declaration</span>
                  <% } else { %>
                    <% const isImage = ['jpg','jpeg','png','webp'].includes(e.proofFile.split('.').pop().toLowerCase()); %>
                    <a href="/uploads/files/<%= e.proofFile %>" target="_blank" class="block group">
                      <% if (isImage) { %>
                        <img src="/uploads/files/<%= e.proofFile %>" class="w-10 h-10 object-cover rounded-lg border border-slate-200 shadow-sm transition group-hover:scale-105" />
                      <% } else { %>
                        <span class="text-blue-600 underline text-[11px]">Download</span>
                      <% } %>
                    </a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
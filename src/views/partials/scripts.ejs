<script src="/js/custom-modal.js"></script>
<script src="/js/sidebar-handler.js"></script>
<script src="/js/notification-handler.js"></script>

<script>
   function triggerGlobalToast({ title = "Info", message = "", type = "success" }) {
    const container = document.getElementById("toastContainer");
    if (!container) return;

    const styles = {
      success: {
        icon: "fa-circle-check",
        iconColor: "text-emerald-500",
        progress: "bg-emerald-500"
      },
      error: {
        icon: "fa-circle-xmark",
        iconColor: "text-rose-500",
        progress: "bg-rose-500"
      }
    };

    const s = styles[type] || styles.success;
    const toast = document.createElement("div");

    toast.className = "relative w-[calc(100vw-2rem)] sm:w-[340px] rounded-xl border border-slate-100 bg-white p-4 shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-4 sm:translate-y-0 sm:translate-x-12 opacity-0";

    toast.innerHTML = `
      <div class="flex items-start gap-3 pb-1">
        <div class="flex-shrink-0 text-base pt-0.5 ${s.iconColor}">
          <i class="fa-solid ${s.icon}"></i>
        </div>
        <div class="flex-1 min-w-0 text-left">
          <h4 class="text-[13px] font-semibold text-slate-800 leading-tight">
            ${title}
          </h4>
          ${message ? `<p class="mt-1 text-xs text-slate-400 leading-relaxed break-words">${message}</p>` : ''}
        </div>
        <button class="flex-shrink-0 text-slate-300 hover:text-slate-500 transition -mt-0.5 p-0.5">
          <i class="fa-solid fa-xmark text-xs"></i>
        </button>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-slate-50 overflow-hidden rounded-b-xl">
        <div class="toast-progress h-full w-full origin-left ${s.progress}"></div>
      </div>
    `;

    container.appendChild(toast);

    requestAnimationFrame(() => {
      toast.classList.remove("translate-y-4", "sm:translate-x-12", "opacity-0");
      toast.classList.add("translate-y-0", "sm:translate-x-0", "opacity-100");
    });

    const progress = toast.querySelector(".toast-progress");

    const lineAnimation = progress.animate(
      [{ transform: "scaleX(1)" }, { transform: "scaleX(0)" }],
      {
        duration: 1200,
        easing: "linear",
        fill: "forwards",
      }
    );

    const closeToast = () => {
      toast.classList.remove("translate-y-0", "sm:translate-x-0", "opacity-100");
      toast.classList.add("translate-y-2", "sm:translate-y-0", "sm:translate-x-6", "opacity-0");
      setTimeout(() => toast.remove(), 400);
    };

    toast.querySelector("button").addEventListener("click", closeToast);
    lineAnimation.onfinish = closeToast;
  }

    document.addEventListener("DOMContentLoaded", () => {
      const successMessage = <%- (typeof success !== 'undefined' && success && success.length) ? JSON.stringify(success[0]) : 'null' %>;
      const errorMessage = <%- (typeof error !== 'undefined' && error && error.length) ? JSON.stringify(error[0]) : 'null' %>;

      if (successMessage) triggerGlobalToast({ title: "Berhasil", message: successMessage, type: "success" });
      if (errorMessage) triggerGlobalToast({ title: "Gagal", message: errorMessage, type: "error" });
    });
</script>

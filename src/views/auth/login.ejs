<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In | Zafa Tour</title>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <link rel="stylesheet" href="/css/output.css" />
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body class="md:bg-[#f8fafc] min-h-screen flex antialiased items-center justify-center md:items-stretch md:justify-start">

  <div class="w-full flex flex-col md:flex-row min-h-screen">

    <!-- LEFT SIDE: LOGIN PANEL (DI MOBILE JADI CARD KETENGAH) -->
    <div class="w-full md:w-[45%] lg:w-[40%] p-4 sm:p-12 md:p-16 flex flex-col justify-between z-10 my-auto md:my-0 md:bg-white min-h-screen md:min-h-0">
      
      <!-- Top Brand Mark (Hidden di mobile agar card fokus di tengah) -->
      <div class="hidden md:flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-xl flex items-center justify-center">
        </div>
        <span class="text-slate-900 font-extrabold tracking-tight text-base">Zafa Tour</span>
      </div>

      <!-- CENTER AUTH CARD (MOBILE: KETENGAH & DIBUNGKUS CARD) -->
     <!-- CENTER AUTH CARD (MOBILE: MINIMALIS & SUPER SMOOTH) -->
   <div class="w-full max-w-md mx-auto mt-52 mb-auto md:my-auto bg-white md:bg-transparent rounded-3xl p-6 sm:p-8 md:p-0">
        
        <!-- Mobile Brand Mark -->
     <!-- Mobile Brand & User Info Header -->
        <!-- Mobile Brand & System Authentication Header -->
        <div class="flex md:hidden items-center justify-between border-b border-slate-200/40 pb-4 mb-5">
          <div class="space-y-1">
            <h2 class="text-base font-bold text-slate-900 tracking-tight leading-none">
              Zafa Tour HRIS
            </h2>
            <p class="text-[10px] text-slate-400 font-medium tracking-wide leading-none uppercase">
              Portal Log Masuk Pegawai
            </p>
          </div>
          
        
        </div>
        <div class="mb-6 md:mb-8">
          <h1 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight">Sign In</h1>
          <p class="text-xs text-slate-400 font-medium mt-1">Silakan masuk ke akun Anda menggunakan kredensial resmi.</p>
        </div>

        <!-- ERROR MESSAGE BANNER -->
        <% if (typeof query !== 'undefined' && query?.error) { %>
          <div class="mb-5 p-3 px-4 bg-rose-50/50 border border-rose-100/30 rounded-2xl flex items-center gap-2.5 text-rose-800">
            <i data-lucide="shield-alert" class="w-3.5 h-3.5 shrink-0 text-rose-500"></i>
            <span class="text-[11px] font-medium tracking-tight">Periksa kembali username atau password Anda.</span>
          </div>
        <% } %>

        <!-- FORM -->
        <form action="/login" method="POST" class="space-y-4">
          
          <!-- Input Identifier -->
         <div class="space-y-1.5">
            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-wider px-0.5">Username / Email</label>
            <input
              type="text"
              name="identifier"
              required
              placeholder="Ketik username atau email Anda..."
              class="w-full px-4 py-2.5 bg-slate-50/50 border border-slate-200/40 rounded-xl text-sm transition-all focus:outline-none focus:border-slate-400 focus:bg-white focus:ring-4 focus:ring-slate-100 placeholder:text-slate-400/70 placeholder:text-xs placeholder:font-normal"
            />
          </div>

          <!-- Input Password -->
          <div class="space-y-1.5">
            <label class="text-[10px] font-medium text-slate-400 uppercase tracking-wider px-0.5">Password</label>
            <div class="relative">
            <input
                id="passwordInput"
                type="password"
                name="password"
                required
                placeholder="Ketik password akun Anda..."
                class="w-full pl-4 pr-12 py-2.5 bg-slate-50/50 border border-slate-200/40 rounded-xl text-sm transition-all focus:outline-none focus:border-slate-400 focus:bg-white focus:ring-4 focus:ring-slate-100 placeholder:text-slate-400/70 placeholder:text-xs placeholder:font-normal"
              />
              <button 
                type="button" 
                id="toggleIcon"
                class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 transition cursor-pointer"
              >
                <i data-lucide="eye" class="w-4 h-4"></i>
              </button>
            </div>
          </div>

          <!-- Options Grid -->
          <div class="flex items-center justify-between gap-2 text-xs pt-1">
            <label class="flex items-center gap-2 text-slate-400 cursor-pointer select-none font-medium text-[11px]">
              <input 
                type="checkbox" 
                name="remember" 
                class="w-3.5 h-3.5 rounded border-slate-300 text-slate-700 focus:ring-slate-500/10 accent-slate-700 cursor-pointer"
              />
              <span>Ingat saya</span>
            </label>
            <a href="/forgot-password" class="font-semibold text-slate-500 hover:text-slate-800 transition text-[11px]">Lupa password?</a>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit"
            class="w-full py-3 bg-slate-900 text-white font-semibold text-xs rounded-xl hover:bg-slate-800 active:scale-[0.99] transition-all duration-150 shadow-xs cursor-pointer flex items-center justify-center gap-2 mt-5"
          >
            <span>Masuk</span>
          </button>

        </form>
      </div>

      <!-- Bottom Copyright -->
      <p class="text-center md:text-left text-xs text-slate-400 font-medium px-0.5 mt-auto md:mt-0 pt-4">
        &copy; 2026 Zafa Tour. All rights reserved.
      </p>
    </div>

    <!-- RIGHT SIDE: HERO PANEL -->
    <div class="hidden md:block relative flex-1 bg-slate-900 overflow-hidden border-l border-slate-200/40">
      
      <img 
        src="https://skvindia.com/wp-content/uploads/2024/09/Types-of-modern-office-interior-design-banner.webp" 
        alt="Zafa Tour Workspace" 
        class="absolute inset-0 w-full h-full object-cover opacity-45 filter brightness-95 contrast-105"
      />

      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/60 to-slate-950/30"></div>

      <div class="absolute top-8 right-8 z-10 p-3 bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 shadow-lg max-w-[140px]">
        <img src="/images/zafa.png" alt="Zafa Tour" class="w-full h-auto object-contain filter brightness-0 invert opacity-90"/>
      </div>

      <div class="absolute bottom-16 left-16 right-16 z-10 max-w-lg space-y-4">
        <div class="space-y-2">
          <h2 class="text-3xl font-black text-white leading-tight tracking-tight">
            Sistem Informasi <br />Kepegawaian Terintegrasi.
          </h2>
          <p class="text-[13px] text-slate-300 font-medium leading-relaxed max-w-sm">
            Akses seluruh data operasional, kehadiran, birokrasi cuti, dan manajemen administrasi internal PT Zafa Mulia Mandiri dalam satu dasbor kendali terpusat.
          </p>
        </div>
      </div>

    </div>

  </div>

  <!-- Lucide Icon Interactivity Logic -->
  <script>
    lucide.createIcons({
      attrs: {
        'stroke-width': 2.5
      }
    });

    const passwordInput = document.getElementById('passwordInput');
    const toggleIcon = document.getElementById('toggleIcon');

    toggleIcon.addEventListener('click', () => {
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';

      toggleIcon.innerHTML = isPassword 
        ? '<i data-lucide="eye-off" class="w-4 h-4"></i>' 
        : '<i data-lucide="eye" class="w-4 h-4"></i>';
      
      lucide.createIcons({
        attrs: {
          'stroke-width': 2.5
        }
      });
    });
  </script>

</body>
</html>
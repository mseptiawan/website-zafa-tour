<%- layout('layouts/main', { title: title }) %>

<div class=" overflow-hidden">
  <div class="w-full max-w-none mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 pb-5 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header.ejs', { 
            section: 'Area Kerja', 
            module: 'Penugasan', 
            title: 'Semua Penugasan', 
            description: 'Monitoring dan pelacakan seluruh penugasan aktif pegawai.' 
        }) %>
      </div>

      <div class="w-full md:w-auto shrink-0 pt-2 md:pt-0">
        <a href="/assignments/new"
          class="inline-flex items-center justify-center gap-1.5 h-9.5 px-4 bg-blue-600 hover:bg-blue-700 text-white text-[12px] font-bold rounded-xl shadow-xs transition-all active:scale-[0.98] w-full md:w-auto decoration-none">
          <i class="fa-solid fa-plus text-[10px] text-blue-100"></i>
          <span>Buat Penugasan</span>
        </a>
      </div>
    </div>

    <% if(assignments.length===0) { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl p-12 text-center shadow-3xs px-4">
        <div class="w-10 h-10 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-3.5 text-slate-400">
          <svg class="w-5 h-5 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Data Penugasan</p>
        <p class="text-[11.5px] text-slate-400 mt-0.5 max-w-xs mx-auto leading-relaxed">Seluruh penugasan baru yang Anda buat akan muncul secara terpusat di sini.</p>
      </div>
    <% } else { %>

      <div class="grid grid-cols-1 gap-3 md:block md:bg-white md:border md:border-slate-200/60 md:rounded-2xl md:p-1.5 md:shadow-3xs md:divide-y md:divide-slate-100/80">
        <% assignments.forEach(a=> { %>
          
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 md:bg-transparent md:border-none md:rounded-none md:p-5 flex flex-col gap-3.5 shadow-3xs md:shadow-none">

            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 space-y-0.5">
                <h2 class="text-[14px] font-bold tracking-tight text-slate-800 break-words">
                  <%= a.title %>
                </h2>
                <p class="text-[12px] text-slate-400 line-clamp-1 break-words font-medium pr-4">
                  <%= a.description || 'Tidak ada deskripsi tambahan untuk penugasan ini' %>
                </p>
              </div>

              <div class="flex-shrink-0 pt-0.5 select-none">
                <% if(a.endDate && new Date(a.endDate)>= new Date()) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-emerald-50 text-emerald-600 border border-emerald-100/50">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-slate-50 text-slate-400 border border-slate-200/50">
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span> Completed
                  </span>
                <% } %>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[11.5px] font-semibold text-slate-400">
              <div>
                Tipe: <span class="text-slate-600 font-bold"><%= a.type %></span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-slate-200 hidden sm:block"></span>
                Lokasi: <span class="text-slate-600 font-bold truncate max-w-[120px] sm:max-w-none"><%= a.location || '-' %></span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-slate-200 hidden sm:block"></span>
                Durasi: <span class="text-slate-600 font-bold">
                  <%= new Date(a.startDate).toLocaleDateString("id-ID", { day: 'numeric' , month: 'short' }) %> - <%= new Date(a.endDate).toLocaleDateString("id-ID", { day: 'numeric' , month: 'short' , year: 'numeric' }) %>
                </span>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 pt-3.5 border-t border-dashed border-slate-100">
              
              <div class="flex flex-wrap items-center gap-3">
                <% if(a.attachment) { %>
                  <div class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-bold bg-blue-50 text-blue-600 border border-blue-100/30 rounded-md select-none">
                    <i class="fa-solid fa-paperclip text-[9px] text-blue-500"></i> Terlampir
                  </div>
                <% } %>

                <div class="flex items-center gap-1.5 flex-wrap">
                  <% a.employees.slice(0, 3).forEach(e=> { %>
                    <span class="inline-block bg-slate-50 border border-slate-200/40 text-slate-600 text-[11px] font-bold px-2 py-0.5 rounded-lg select-none">
                      <%= e.fullName.split(' ')[0] %> </span>
                  <% }) %>

                  <% if(a.employees.length > 3) { %>
                    <span class="text-[10px] font-bold text-slate-400 bg-slate-50 border border-dotted border-slate-200 px-1.5 py-0.5 rounded-lg select-none">
                      +<%= a.employees.length - 3 %> Staff
                    </span>
                  <% } %>
                </div>
              </div>

              <div class="flex justify-end select-none">
                <a href="/assignments/<%= a._id %>" class="bg-slate-100 hover:bg-slate-200 text-slate-600 text-[11px] font-bold h-7 px-3 rounded-lg flex items-center justify-center gap-1 transition-all active:scale-[0.98] decoration-none">
                  Detail <i class="fa-solid fa-angle-right text-[9px] text-slate-400"></i>
                </a>
              </div>

            </div>

          </div>
        <% }) %>
      </div>
    <% } %>
 <%- include('../partials/pagination-nav') %>



  </div>
</div>
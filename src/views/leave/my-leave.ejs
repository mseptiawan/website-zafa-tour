<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
    <div class="max-w-5xl mx-auto">

      <!-- BREADCRUMB & HEADER -->
      <div class="flex items-start justify-between mb-8">
        <div>
          <nav class="flex items-center gap-2 mb-2 text-[11px] font-medium text-slate-400 uppercase tracking-widest">
            <span>Workspace</span>
            <span class="text-slate-300">/</span>
            <span class="text-slate-900">Leave History</span>
          </nav>
          <h1 class="text-2xl font-medium text-slate-800">
            Riwayat Cuti Saya
          </h1>
          <p class="text-sm text-slate-500 mt-1">
            Pantau semua pengajuan cuti kamu
          </p>
        </div>

        <a href="/leave/apply"
          class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-3 rounded-xl transition shadow-sm active:scale-[0.98]">
          + Ajukan Cuti
        </a>
      </div>

      <!-- SUMMARY CARDS -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <!-- TOTAL -->
        <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
          <p class="text-[13px] font-medium text-slate-400 uppercase tracking-wider">Total</p>
          <p class="text-2xl font-medium text-slate-800 mt-1">
            <%= summary.total || 0 %>
          </p>
        </div>

        <!-- PENDING -->
        <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
          <p class="text-[13px] font-medium text-slate-400 uppercase tracking-wider">Pending</p>
          <p class="text-2xl font-medium text-amber-500 mt-1">
            <%= summary.pending || 0 %>
          </p>
        </div>

        <!-- TERPAKAI -->
        <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
          <p class="text-[13px] font-medium text-slate-400 uppercase tracking-wider">Terpakai</p>
          <p class="text-2xl font-medium text-emerald-600 mt-1">
            <%= summary.used || 0 %>
          </p>
        </div>

        <!-- SISA -->
        <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
          <p class="text-[13px] font-medium text-slate-400 uppercase tracking-wider">Sisa Cuti</p>
          <p class="text-2xl font-medium text-blue-600 mt-1">
            <%= summary.remaining || 0 %>
          </p>
        </div>
      </div>

      <!-- TABLE CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm min-w-[900px]">
            <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-100">
              <tr>
                <th class="text-left px-6 py-4">Jenis Cuti</th>
                <th class="text-left px-6 py-4">Tanggal Durasi</th>
                <th class="text-left px-6 py-4">Durasi</th>
                <th class="text-left px-6 py-4">Status</th>
                <th class="text-left px-6 py-4">Aksi</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-slate-100">
              <% if (typeof leaves !=='undefined' && leaves.length> 0) { %>
                <% leaves.forEach(l=> { %>
                  <tr class="hover:bg-slate-50 transition">
                    <!-- JENIS -->
                    <td class="px-6 py-4 font-medium text-slate-800">
                      <%= l.type?.name %>
                    </td>

                    <!-- TANGGAL -->
                    <td class="px-6 py-4 text-slate-500">
                      <%= new Date(l.startDate).toLocaleDateString("id-ID") %>
                        <span class="text-slate-300 mx-1">/</span>
                        <%= new Date(l.endDate).toLocaleDateString("id-ID") %>
                    </td>

                    <!-- DURASI -->
                    <td class="px-6 py-4 font-semibold text-slate-700">
                      <%= l.totalDays %> Hari
                    </td>

                    <!-- STATUS BADGE -->
                    <td class="px-6 py-4">
                      <span class="text-[11px] px-2.5 py-1 rounded-md font-medium uppercase tracking-wider border <%= 
                      l.status === 'APPROVED' || l.status === 'VERIFIED'
                        ? 'bg-emerald-50/50 text-emerald-700 border-emerald-200/60'
                        : l.status === 'REJECTED'
                          ? 'bg-red-50/50 text-red-700 border-red-200/60'
                          : 'bg-amber-50/50 text-amber-700 border-amber-200/60'
                    %>">
                        <%= l.status %>
                      </span>
                    </td>

                    <!-- AKSI -->
                    <td class="px-6 py-4">
                      <a href="/leave/<%= l._id %>" title="Detail"
                        class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 hover:text-slate-800 transition shadow-sm">
                        <!-- eye icon -->
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round"
                            d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                          <path stroke-linecap="round" stroke-linejoin="round"
                            d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                      </a>
                    </td>
                  </tr>
                  <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="5" class="text-center py-12 text-slate-400">
                          Belum ada pengajuan cuti
                        </td>
                      </tr>
                      <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <% if (pagination.totalPages> 1) { %>
        <div
          class="flex items-center justify-between mt-6 px-5 py-4 bg-white border border-slate-200 rounded-2xl shadow-sm text-[13px] antialiased">

          <!-- LEFT INFO -->
          <div class="text-slate-500 font-medium">
            Menampilkan halaman
            <span class="font-bold text-slate-900">
              <%= pagination.page %>
            </span>
            dari
            <span class="font-bold text-slate-900">
              <%= pagination.totalPages %>
            </span>
          </div>

          <!-- RIGHT CONTROLS -->
          <div class="flex items-center gap-2">

            <!-- PREV BUTTON -->
            <a href="?page=<%= pagination.page - 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasPrev
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              Prev
            </a>

            <!-- NEXT BUTTON -->
            <a href="?page=<%= pagination.page + 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasNext
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
              Next
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

          </div>

        </div>
        <% } %>
    </div>
  </div>
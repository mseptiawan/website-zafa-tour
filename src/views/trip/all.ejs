<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-7xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-xl font-medium text-slate-800">
        Pengajuan Dinas Luar
      </h1>

      <p class="text-sm text-slate-500 mt-1">
        Semua pengajuan perjalanan dinas karyawan
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">

      <div class="overflow-x-auto">

        <table class="w-full text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 border-b border-slate-200">

            <tr class="text-xs uppercase tracking-wide text-slate-500">

              <th class="px-5 py-4 text-left font-medium">Karyawan</th>
              <th class="px-5 py-4 text-left font-medium">Tujuan</th>
              <th class="px-5 py-4 text-left font-medium">Tanggal</th>
              <th class="px-5 py-4 text-left font-medium">Budget</th>
              <th class="px-5 py-4 text-left font-medium">Status</th>
              <th class="px-5 py-4 text-left font-medium">Aksi</th>

            </tr>

          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (trips.length === 0) { %>

              <tr>
                <td colspan="6" class="px-5 py-14 text-center">

                  <div class="text-sm font-medium text-slate-600">
                    Tidak ada data pengajuan
                  </div>

                  <p class="text-xs text-slate-400 mt-1">
                    Semua pengajuan akan muncul di sini
                  </p>

                </td>
              </tr>

            <% } %>

            <% trips.forEach(trip => { %>

              <tr class="hover:bg-slate-50 transition">

                <!-- KARYAWAN -->
                <td class="px-5 py-4 font-medium text-slate-800">
                  <%= trip.userId?.username || "Unknown" %>
                </td>

                <!-- TUJUAN -->
                <td class="px-5 py-4 text-slate-600">
                  <%= trip.destination %>
                </td>

                <!-- TANGGAL -->
                <td class="px-5 py-4 text-slate-600">

                  <div class="text-xs leading-relaxed">

                    <div>
                      <span class="text-slate-400">Mulai:</span>
                      <%= new Date(trip.startDate).toLocaleDateString('id-ID') %>
                    </div>

                    <div>
                      <span class="text-slate-400">Selesai:</span>
                      <%= new Date(trip.endDate).toLocaleDateString('id-ID') %>
                    </div>

                  </div>

                </td>

                <!-- BUDGET -->
                <td class="px-5 py-4 font-medium text-slate-700">
                  Rp <%= Number(trip.budget).toLocaleString('id-ID') %>
                </td>

                <!-- STATUS -->
                <td class="px-5 py-4">

                  <% if (trip.status === 'PENDING') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-amber-50 text-amber-600 border border-amber-100 font-medium">
                      Menunggu Manager
                    </span>

                  <% } else if (trip.status === 'APPROVED_MANAGER') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-blue-50 text-blue-600 border border-blue-100 font-medium">
                      Menunggu Final Approval
                    </span>

                  <% } else if (trip.status === 'APPROVED_DIRECTOR') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-emerald-50 text-emerald-600 border border-emerald-100 font-medium">
                      Disetujui
                    </span>

                  <% } else { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-rose-50 text-rose-600 border border-rose-100 font-medium">
                      Ditolak
                    </span>

                  <% } %>

                </td>

                <!-- ACTION -->
                <td class="px-5 py-4">

                  <div class="flex items-center gap-2">

                    <!-- DETAIL -->
                    <a href="/trip/detail/<%= trip._id %>"
                      class="text-indigo-600 hover:text-indigo-700 font-medium text-sm">
                      Detail
                    </a>

                    <!-- APPROVE MANAGER -->
                    <% if (trip.status === 'PENDING' && user.role === 'MANAGER') { %>

                      <form method="POST" action="/trip/<%= trip._id %>/approve/manager">

                        <button class="px-2.5 py-1 text-xs rounded-lg bg-emerald-50 text-emerald-600 border border-emerald-100 font-medium hover:bg-emerald-100 transition">
                          Approve
                        </button>

                      </form>

                    <% } %>

                    <!-- FINAL APPROVAL -->
                    <% if (trip.status === 'APPROVED_MANAGER' && (user.role === 'HR' || user.role === 'PIMPINAN')) { %>

                      <form method="POST" action="/trip/<%= trip._id %>/approve/director">

                        <button class="px-2.5 py-1 text-xs rounded-lg bg-blue-50 text-blue-600 border border-blue-100 font-medium hover:bg-blue-100 transition">
                          Final
                        </button>

                      </form>

                    <% } %>

                  </div>

                </td>

              </tr>

            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>
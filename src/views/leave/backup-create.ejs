<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-2xl mx-auto">

    <div class="mb-8">
      <nav class="flex items-center gap-2 mb-2 text-[11px] font-medium text-slate-400 uppercase tracking-widest">
        <span>Area Kerja</span>
        <span class="text-slate-300">/</span>
        <span class="text-slate-900">Manajemen Cuti</span>
      </nav>
      <h1 class="text-2xl font-medium text-slate-900">
        Formulir Pengajuan Cuti
      </h1>
      <p class="text-[14px] text-slate-500 mt-1">
        Ajukan permohonan cuti baru dan tentukan delegasi tugas Anda
      </p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 mb-6 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="space-y-1 text-center sm:text-left">
        <h3 class="text-sm font-medium text-slate-400 uppercase tracking-wider">Kuota Tahun <%= leaveBalance.year %>
        </h3>
        <p class="text-xs text-slate-500">Sisa jatah cuti diperbarui otomatis oleh sistem</p>
      </div>
      <div class="flex items-center gap-8 w-full sm:w-auto justify-center">
        <div class="text-center">
          <span class="block text-2xl font-medium text-slate-800">
            <%= leaveBalance.totalQuota %>
          </span>
          <span class="text-[11px] font-medium text-slate-400 uppercase">Total</span>
        </div>
        <div class="w-px h-8 bg-slate-200"></div>
        <div class="text-center">
          <span class="block text-2xl font-medium text-slate-800">
            <%= leaveBalance.used %>
          </span>
          <span class="text-[11px] font-medium text-slate-400 uppercase">Terpakai</span>
        </div>
        <div class="w-px h-8 bg-slate-200"></div>
        <div class="text-center bg-blue-50/60 px-4 py-2 rounded-xl border border-blue-100">
          <span class="block text-2xl font-medium text-blue-600" id="user-remaining">
            <%= leaveBalance.remaining %>
          </span>
          <span class="text-[11px] font-medium text-blue-500 uppercase">Sisa Jatah</span>
        </div>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">
      <form action="/leave/apply" method="POST" enctype="multipart/form-data" id="leaveForm" class="p-8 space-y-6">

        <% if (typeof error !=='undefined' && error) { %>
        <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm border border-red-100">
          <%= error %>
        </div>
        <% } %>

        <div class="space-y-1.5">
          <label class="text-[13px] font-medium text-slate-700">
            Pilih Jenis Cuti
          </label>
          <select name="leaveTypeId" id="leaveTypeId" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all appearance-none cursor-pointer">
            <option value="" selected disabled>-- Pilih Kategori Cuti --</option>
            <% leaveTypes.forEach(type=> { %>
            <option value="<%= type._id %>" data-req-file="<%= type.requiresAttachment %>" data-deduct="<%= type.isDeductBalance %>">
              <%= type.name %> (<%= type.code %>)
            </option>
            <% }) %>
          </select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-[13px] font-medium text-slate-700">Tanggal Mulai</label>
            <input type="date" name="startDate" id="startDate" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all cursor-pointer" />
          </div>
          <div class="space-y-1.5">
            <label class="text-[13px] font-medium text-slate-700">Tanggal Selesai</label>
            <input type="date" name="endDate" id="endDate" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all cursor-pointer" />
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-medium text-slate-400 uppercase tracking-wide text-xs">
            Estimasi Durasi Pengajuan
          </label>
          <div class="flex items-center gap-2">
            <input type="text" id="displayTotalDays" value="0" readonly disabled class="w-24 bg-slate-100/80 border border-slate-200 rounded-xl px-4 py-2.5 text-[14px] text-slate-600 font-medium text-center" />
            <span class="text-xs text-slate-400 font-medium">Hari Kerja (Hari Minggu & libur nasional otomatis
              tidak dihitung)</span>
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-medium text-slate-700">
            Delegasikan Tugas Kepada
          </label>
          <select name="handoverUserId" id="handoverUserId" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all appearance-none cursor-pointer">
            <option value="" selected disabled>-- Pilih Rekan Kerja Penanggung Jawab --</option>
            <% employees.forEach(emp=> { %>
            <option value="<%= emp._id %>">
              <%= emp.name %> (@<%= emp.username %>)
            </option>
            <% }) %>
          </select>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-medium text-slate-700">
            Alasan / Keterangan Cuti
          </label>
          <textarea name="reason" id="reason" rows="4" maxlength="500" required placeholder="Jelaskan alasan detail keperluan pengambilan cuti Anda..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none resize-none transition-all"></textarea>
        </div>

        <div class="space-y-1.5">
          <label class="block text-[13px] font-medium text-slate-700 mb-1.5" id="labelFile">
            Dokumen Pendukung <span class="text-slate-400 font-normal">(Opsional)</span>
          </label>

          <div id="dropzone-empty" class="relative w-full border border-slate-200 border-dashed rounded-xl p-6 bg-white hover:bg-slate-50/50 transition flex flex-col items-center justify-center text-center">
            <input type="file" name="file" id="file-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="handleFileSelect(this)" />
            <svg class="w-5 h-5 text-slate-400 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
            </svg>
            <span class="text-[13px] font-medium text-slate-600" id="dropzone-text-main">
              Pilih Berkas atau Drop File Disini
            </span>
            <span class="text-xs text-slate-400 mt-0.5">
              PNG, JPG, atau PDF (maks 5MB)
            </span>
          </div>

          <div id="dropzone-filled" class="hidden flex items-center justify-between border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-sm">
            <div class="flex items-center gap-3 min-w-0 flex-1">
              <div class="w-10 h-10 rounded-lg overflow-hidden border border-slate-200 bg-slate-50 flex-shrink-0 flex items-center justify-center">
                <img id="img-preview" class="w-full h-full object-cover hidden" />
                <svg id="file-icon-fallback" class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <div id="name-preview" class="text-[13px] font-medium text-slate-700 truncate">file_name.jpg</div>
                <div id="size-preview" class="text-xs text-slate-400 mt-0.5">0 KB</div>
              </div>
            </div>
            <div class="flex items-center gap-2 ml-4 flex-shrink-0">
              <a id="view-file-btn" href="#" target="_blank" class="text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100/70 px-2.5 py-1.5 rounded-lg transition">
                View
              </a>
              <button type="button" onclick="triggerChangeFile()" class="text-xs font-medium text-slate-600 bg-slate-50 hover:bg-slate-100 px-2.5 py-1.5 rounded-lg transition">
                Ganti File
              </button>
            </div>
          </div>
        </div>

        <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
          <a href="/leave/my" class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
            Batal
          </a>
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
            Kirim Pengajuan
          </button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  let currentFileUrl = null;

  const selectType = document.getElementById('leaveTypeId');
  const labelFile = document.getElementById('labelFile');
  const fileInput = document.getElementById('file-input');
  const startInput = document.getElementById('startDate');
  const endInput = document.getElementById('endDate');
  const displayDays = document.getElementById('displayTotalDays');
  const dropzoneTextMain = document.getElementById('dropzone-text-main');

  selectType.addEventListener('change', function() {
    const isRequired = this.options[this.selectedIndex].getAttribute('data-req-file') === 'true';
    if (isRequired) {
      labelFile.innerHTML = 'Dokumen Pendukung <span class="text-red-500 font-medium">*Wajib Diunggah</span>';
      dropzoneTextMain.innerHTML = 'Pilih Berkas atau Drop Berkas <span class="text-red-500 font-medium">(Wajib)</span>';
    } else {
      labelFile.innerHTML = 'Dokumen Pendukung <span class="text-slate-400 font-normal">(Opsional)</span>';
      dropzoneTextMain.innerHTML = 'Pilih Berkas atau Drop File Disini';
    }
  });

  function calculateDays() {
    if (startInput.value && endInput.value) {
      const start = new Date(startInput.value);
      const end = new Date(endInput.value);
      if (start <= end) {
        let count = 0;
        let cur = new Date(start);
        while (cur <= end) {
          if (cur.getDay() !== 0) count++; 
          cur.setDate(cur.getDate() + 1);
        }
        displayDays.value = count;
      } else {
        displayDays.value = 0;
      }
    }
  }
  startInput.addEventListener('change', calculateDays);
  endInput.addEventListener('change', calculateDays);

  function handleFileSelect(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];

      if (currentFileUrl) {
        URL.revokeObjectURL(currentFileUrl);
      }

      currentFileUrl = URL.createObjectURL(file);
      document.getElementById("view-file-btn").href = currentFileUrl;
      document.getElementById("name-preview").textContent = file.name;

      const fileSizeInKB = file.size / 1024;
      if (fileSizeInKB < 1024) {
        document.getElementById("size-preview").textContent = fileSizeInKB.toFixed(1) + " KB";
      } else {
        document.getElementById("size-preview").textContent = (fileSizeInKB / 1024).toFixed(2) + " MB";
      }

      const imgPreview = document.getElementById("img-preview");
      const fileIconFallback = document.getElementById("file-icon-fallback");

      if (file.type.startsWith("image/")) {
        imgPreview.src = currentFileUrl;
        imgPreview.classList.remove("hidden");
        fileIconFallback.classList.add("hidden");
      } else {
        imgPreview.src = "";
        imgPreview.classList.add("hidden");
        fileIconFallback.classList.remove("hidden");
      }

      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
    }
  }

  function triggerChangeFile() {
    fileInput.click();
  }
</script>
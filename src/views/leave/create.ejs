<%- layout('layouts/main', { title }) %>

<!-- 1. GLOBAL ISLAND CANVAS LAYER -->
<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50  md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0">

    <!-- 2. REUSABLE PAGE HEADER COMPONENT -->
    <div class="mb-5">
      <%- include('../partials/page-header.ejs', { 
          section: 'Area Kerja', 
          module: mode === 'CREATE' ? 'Input Pengajuan Cuti' : (mode === 'EDIT' ? 'Ubah Pengajuan Cuti' : 'Ajukan Ulang Cuti'), 
          title: mode === 'CREATE' ? 'Input Pengajuan Cuti' : (mode === 'EDIT' ? 'Ubah Pengajuan Cuti' : 'Ajukan Ulang Cuti'), 
          description: 'Pastikan informasi rentang tanggal dan sisa kuota Anda telah sesuai sebelum mengirimkan form.' 
      }) %>
    </div>

    <!-- 3. PANEL INFORMASI KUOTA (Matching Premium Look) -->
    <div class="mb-5 p-4 sm:p-5 bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div>
          <p class="text-[10.5px] font-semibold text-slate-400 uppercase tracking-wider">Hak Kuota Cuti Anda</p>
          <p class="text-[12px] font-medium text-slate-500 mt-0.5">Tahun Periode Berjalan</p>
        </div>
      </div>
      
      <div class="text-right flex flex-col items-end">
        <div class="flex items-baseline gap-1">
          <span class="text-lg font-bold <%= leaveBalance.remaining === 0 ? 'text-slate-300' : 'text-slate-800' %> tabular-nums">
            <%= leaveBalance.remaining %>
          </span>
          <span class="text-[11px] font-medium text-slate-400">Hari Tersisa</span>
        </div>

        <% if (leaveBalance.remaining === 0) { %>
          <div class="text-[9px] font-medium text-slate-500 bg-slate-50 border border-slate-200/60 px-2 py-0.5 rounded-md mt-1 whitespace-nowrap uppercase tracking-wider">
            Terpotong Cuti Bersama
          </div>
        <% } %>
      </div>
    </div>

    <!-- 4. MAIN FORM SHEET CONTAINER -->
    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl p-4 sm:p-5 md:p-8 overflow-hidden">

      <% let formAction="/leave/apply" ; if (mode==='EDIT' ) formAction="/leave/update/" + leave._id; if (mode==='RESUBMIT' ) formAction="/leave/apply" ; %>

      <form action="<%= formAction %>" method="POST" enctype="multipart/form-data" class="space-y-5">

        <% if (typeof error !== 'undefined' && error && String(error).trim() !== '') { %>
          <div class="p-3.5 rounded-xl bg-rose-50 text-rose-600 text-[13px] border border-rose-100 font-medium">
            <i class="fa-solid fa-circle-exclamation mr-1"></i> <%= String(error) %>
          </div>
        <% } %>

        <!-- DROPDOWN TIPE CUTI -->
        <div class="space-y-2">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">
            Kategori / Tipe Cuti <span class="text-rose-500">*</span>
          </label>

          <div class="relative w-full" id="leave-dropdown">
            <input type="hidden" name="leaveTypeId" id="leaveTypeId" value="<%= (mode === 'EDIT' && leave.leaveTypeId) ? leave.leaveTypeId._id : '' %>" required>
            <button type="button" onclick="toggleLeaveDropdown()" class="w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] text-slate-800 text-left flex items-center justify-between outline-none focus:bg-white focus:border-slate-400 focus:ring-0 transition-all cursor-pointer">
              <span id="leave-label" class="<%= (mode === 'EDIT' && leave.leaveTypeId) ? 'text-slate-800 font-medium' : 'text-slate-400/60 text-[11.5px]' %>">
                <%= (mode === 'EDIT' && leave.leaveTypeId) ? leave.leaveTypeId.name : '-- Silahkan pilih jenis cuti --' %>
              </span>

              <span id="leave-warning" class="hidden text-[10px] text-rose-500 font-bold mr-2 uppercase tracking-wider">
                Tidak tersedia
              </span>

              <svg id="leave-arrow" class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <div id="leave-menu" class="hidden absolute z-30 w-full mt-1.5 bg-white border border-slate-200/80 rounded-xl shadow-lg p-1.5 space-y-0.5">
              <% const isMale = (employee?.jenis_kelamin || '').toLowerCase() === 'laki-laki'; %>
              <% leaveTypes.forEach(type => { %>
                <% if (isMale && type.code === 'BL') return; %>
                <button type="button" onclick="selectLeave('<%= type._id %>', '<%= type.name %>', '<%= type.code %>')" class="w-full text-left px-3 py-2 text-[13px] font-medium text-slate-600 hover:bg-slate-50 rounded-lg transition-colors cursor-pointer">
                  <%= type.name %>
                </button>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- RENTANG TANGGAL INPUT -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">
              Tanggal Mulai <span class="text-rose-500">*</span>
            </label>
            <input type="date" id="startDate" name="startDate" required class="date-input w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] text-slate-700 focus:bg-white focus:border-slate-400 focus:ring-0 outline-none transition-all" value="<%= leave ? new Date(leave.startDate).toISOString().split('T')[0] : '' %>">
            <p id="date-warning" class="hidden text-[11px] font-medium text-rose-600 mt-1 pl-0.5 leading-tight">
              Pengajuan cuti harus dilakukan minimal 7 hari sebelum tanggal mulai.
            </p>
          </div>

          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">
              Tanggal Selesai <span class="text-rose-500">*</span>
            </label>
            <input type="date" id="endDate" name="endDate" required class="date-input w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] text-slate-700 focus:bg-white focus:border-slate-400 focus:ring-0 outline-none transition-all" value="<%= leave ? new Date(leave.endDate).toISOString().split('T')[0] : '' %>">
          </div>
        </div>

        <!-- HITUNGAN DURASI -->
        <div class="space-y-2">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">
            Durasi Pengajuan Cuti
          </label>
          <div class="relative flex items-center">
            <input type="number" id="totalDays" name="totalDays" readonly required class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl pl-4 pr-24 py-2.5 text-[13px] font-bold text-slate-800 outline-none select-none" value="<%= leave ? leave.totalDays : 0 %>" />
            <span class="absolute right-4 text-[10px] font-bold uppercase tracking-wider text-slate-400 flex items-center gap-1 select-none">
              <span id="displayDays" class="text-slate-800 font-extrabold"><%= leave ? leave.totalDays : 0 %></span>
              <span id="duration-label-text">Hari Kerja</span>
            </span>
          </div>
        </div>

        <!-- REKAN DELEGASI HANDOVER -->
        <div class="space-y-2" id="handover-wrapper">
          <div class="flex justify-between items-center">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">
              Delegasi Pengganti / Handover
            </label>
            <span class="text-[9px] font-medium bg-slate-50 text-slate-400 px-2 py-0.5 rounded-md uppercase tracking-wider border border-slate-200/60 select-none">
              Opsional
            </span>
          </div>

          <div class="relative w-full">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <input type="text" id="handover-search" placeholder="Cari nama rekan handover..." encoding="utf-8" onkeyup="filterHandoverList()" class="w-full bg-slate-50/60 border border-slate-200/70 rounded-xl pl-9 pr-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 text-slate-700 outline-none focus:bg-white focus:border-slate-400 focus:ring-0 transition-all" />
          </div>

          <div id="handover-list" class="border border-slate-200/60 rounded-xl p-1.5 max-h-48 overflow-y-auto bg-slate-50/30 space-y-0.5">
            <% 
              const excludedOwners = ['rafika fitrianti', 'gusti diansyah'];
              const filteredEmployees = employees.filter(emp => 
                emp.employeeData && 
                !excludedOwners.includes(emp.employeeData.fullName.toLowerCase())
              );
              filteredEmployees.forEach(emp => { 
            %>
            <label class="handover-item flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white border border-transparent hover:border-slate-200/40 cursor-pointer transition-colors group" data-name="<%= emp.employeeData.fullName.toLowerCase() %>">
              <input type="radio" name="handoverUserId" value="<%= emp._id %>" <%=(leave && leave.handoverUserId && leave.handoverUserId.toString()===emp._id.toString()) ? 'checked' : '' %> class="w-3.5 h-3.5 text-slate-900 border-slate-300 focus:ring-0 cursor-pointer accent-slate-900 transition-colors" />
              <div class="flex flex-col">
                <span class="text-[12px] font-semibold text-slate-700 group-hover:text-slate-900 transition-colors">
                  <%= emp.employeeData.fullName %>
                </span>
                <span class="text-[10px] text-slate-400 font-medium leading-none mt-0.5">@<%= emp.username %></span>
              </div>
            </label>
            <% }) %>
          </div>

          <p class="text-[11px] text-slate-400 pl-0.5 leading-normal">
            Sistem memerlukan konfirmasi persetujuan dari rekan handover terkait sebelum pengajuan diteruskan.
          </p>
        </div>

        <!-- ALASAN / KETERANGAN -->
        <div class="space-y-2">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">
            Alasan atau Keterangan Tambahan <span class="text-rose-500">*</span>
          </label>
          <textarea name="reason" rows="4" placeholder="Jelaskan alasan pengajuan cuti Anda secara detail..." required class="w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 text-slate-800 font-medium outline-none resize-none transition-all focus:bg-white focus:border-slate-400 focus:ring-0 leading-relaxed"><%= leave ? leave.reason : '' %></textarea>
        </div>

        <!-- LAMPIRAN BERKAS / DROPZONE -->
        <div class="space-y-2">
          <label class="block text-[12px] font-semibold text-slate-700 tracking-wide">
            Surat Keterangan / Lampiran <span id="label-required-star" class="text-rose-500 hidden">*</span>
            <span id="label-optional-text" class="text-slate-400 font-normal ml-0.5">(Opsional)</span>
          </label>

          <div id="dropzone-empty" class="<%= (mode === 'EDIT' && leave.documentPath) ? 'hidden' : 'relative' %> w-full border border-slate-200 border-dashed rounded-xl p-5 bg-slate-50/50 hover:bg-slate-50 transition flex flex-col items-center justify-center text-center">
            <input type="file" name="attachments" id="file-input" accept="image/*,.pdf,.docx" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="handleFileSelect(this)" />
            <svg class="w-4 h-4 text-slate-400 mb-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
            </svg>
            <span class="text-[12px] font-semibold text-slate-700">Pilih Berkas atau Tarik File Kemari</span>
            <span class="text-[10.5px] text-slate-400 mt-0.5">PNG, JPG, PDF, atau DOCX (Maksimal 5MB)</span>
          </div>

          <div id="dropzone-filled" class="<%= (mode === 'EDIT' && leave.documentPath) ? 'flex' : 'hidden' %> items-center justify-between border border-slate-200/80 rounded-xl px-4 py-3 bg-white">
            <div class="flex items-center gap-3 min-w-0 flex-1">
              <div class="w-9 h-9 rounded-lg overflow-hidden border border-slate-200 bg-slate-50 flex-shrink-0 flex items-center justify-center">
                <% 
                  let isImage = false;
                  if (mode === 'EDIT' && leave.documentPath) {
                    const ext = leave.documentPath.split('.').pop().toLowerCase();
                    isImage = ['png', 'jpg', 'jpeg', 'webp', 'gif'].includes(ext);
                  }
                %>
                <img id="img-preview" src="<%= (mode === 'EDIT' && leave.documentPath) ? leave.documentPath : '' %>" class="w-full h-full object-cover <%= isImage ? '' : 'hidden' %>" />
                <svg id="file-icon-fallback" class="w-4 h-4 text-slate-400 <%= isImage ? 'hidden' : '' %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
              </div>

              <div class="min-w-0 flex-1">
                <div id="name-preview" class="text-[12px] font-semibold text-slate-700 truncate">
                  <%= (mode === 'EDIT' && leave.documentPath) ? leave.documentPath.split('/').pop() : 'file_name.jpg' %>
                </div>
                <div id="size-preview" class="text-[10.5px] text-slate-400 mt-0.5 font-medium">
                  <%= (mode === 'EDIT' && leave.documentPath) ? 'Berkas Tersimpan' : '0 KB' %>
                </div>
              </div>
            </div>

            <div class="flex items-center gap-1.5 ml-4 flex-shrink-0">
              <a id="view-file-btn" href="<%= (mode === 'EDIT' && leave.documentPath) ? leave.documentPath : '#' %>" target="_blank" class="h-7 text-[11px] font-semibold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 px-2.5 rounded-lg transition inline-flex items-center justify-center">Lihat</a>
              <button type="button" onclick="triggerChangeFile()" class="h-7 text-[11px] font-semibold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 px-2.5 rounded-lg transition cursor-pointer">Ganti</button>
            </div>
          </div>
        </div>

        <!-- ACTION FOOTER PANELS -->
        <div class="pt-4 border-t border-slate-100 flex items-center justify-end gap-2.5">
          <a href="/leave/my-history" class="inline-flex items-center justify-center h-9 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 rounded-xl px-5 text-[11.5px] font-semibold transition-all active:scale-[0.99]">
            Batal
          </a>
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white h-9 px-6 rounded-xl text-[11.5px] font-semibold transition-all active:scale-[0.99] cursor-pointer outline-none">
            <%= mode==='CREATE' ? 'Kirim Pengajuan' : (mode==='EDIT' ? 'Simpan Perubahan' : 'Kirim Ulang Form' ) %>
          </button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  console.log("=== DEBUG LEAVE FORM INIT ===");

  const startInput = document.getElementById('startDate');
  const endInput = document.getElementById('endDate');
  const totalInput = document.getElementById('totalDays');
  const displayDays = document.getElementById('displayDays');
  const fileInput = document.getElementById('file-input');
  const warningDiv = document.getElementById('date-warning');
  const submitBtn = document.querySelector('button[type="submit"]');
  
  const employeeGender = "<%= employee && employee.jenis_kelamin ? employee.jenis_kelamin.toLowerCase() : '' %>";
  let currentFileUrl = null;

  async function calculateDays() {
    const selectedLeaveType = document.getElementById('leave-label').textContent.toLowerCase();

    if (selectedLeaveType.includes('melahirkan')) {
      return;
    }

    const start = startInput.value;
    const end = endInput.value;

    if (start && end) {
      try {
        if (displayDays) displayDays.innerText = "...";
        
        const response = await fetch(`/api/leave/calculate-days?startDate=${start}&endDate=${end}`);
        const data = await response.json();

        if (data.success) {
          const totalDays = data.totalDays;
          
          displayDays.innerText = totalDays;
          totalInput.value = totalDays;

          if (totalDays === 0) {
            startInput.classList.add('border-rose-400', 'focus:border-rose-500');
            endInput.classList.add('border-rose-400', 'focus:border-rose-500');
            
            if (warningDiv) {
              warningDiv.textContent = "Tanggal yang Anda pilih adalah Hari Libur Resmi atau Akhir Pekan. Silahkan pilih tanggal lain.";
              warningDiv.classList.remove('hidden');
            }
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.classList.add('opacity-40', 'cursor-not-allowed');
            }
          } else {
            startInput.classList.remove('border-rose-400', 'focus:border-rose-500');
            endInput.classList.remove('border-rose-400', 'focus:border-rose-500');
            validateDateGap();
          }
        }
      } catch (err) {
        console.error("Error calculating days:", err);
        if (displayDays) displayDays.innerText = "Error";
      }
    }
  }

  function calculateMaternityDuration() {
    if (startInput.value) {
      const start = new Date(startInput.value);
      const end = new Date(start);
      end.setDate(start.getDate() + 90 - 1);

      endInput.value = end.toISOString().split('T')[0];
      displayDays.innerText = 90;
      totalInput.value = 90;
      
      if (warningDiv) warningDiv.classList.add('hidden');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-40', 'cursor-not-allowed');
      }
    }
  }

  function validateDateGap() {
    if (startInput.value === "") return;

    const startDate = new Date(startInput.value);
    startDate.setHours(0, 0, 0, 0);

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    if (startDate < today) {
      if (warningDiv) {
        warningDiv.textContent = "Pengajuan cuti tidak boleh menggunakan tanggal masa lalu.";
        warningDiv.classList.remove('hidden');
      }
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-40', 'cursor-not-allowed');
      }
      return; 
    }

    const diffTime = startDate - today;
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

    if (diffDays < 7) {
      if (warningDiv) {
        warningDiv.textContent = "Pengajuan cuti harus dilakukan minimal 7 hari sebelum tanggal mulai.";
        warningDiv.classList.remove('hidden');
      }
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-40', 'cursor-not-allowed');
      }
    } else {
      if (warningDiv) {
        warningDiv.classList.add('hidden');
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-40', 'cursor-not-allowed');
      }
    }
  }

  function handleLeaveTypeChange(typeName) {
    const name = typeName.toLowerCase();
    const starLabel = document.getElementById('label-required-star');
    const optionalLabel = document.getElementById('label-optional-text');
    const durationLabelText = document.getElementById('duration-label-text');
    const labelSpan = document.getElementById('leave-label');

    labelSpan.classList.remove('text-slate-400/60', 'italic', 'text-[11.5px]');
    labelSpan.classList.add('text-slate-800', 'font-medium');

    if (name.includes('melahirkan')) {
      if (durationLabelText) durationLabelText.textContent = "Hari Kalender";
      endInput.readOnly = true;
      endInput.classList.add('bg-slate-100', 'select-none');
      endInput.classList.remove('bg-slate-50/60');

      calculateMaternityDuration();

      fileInput.required = false;
      if (starLabel) starLabel.classList.add('hidden');
      if (optionalLabel) optionalLabel.classList.remove('hidden');
    } else {
      if (durationLabelText) durationLabelText.textContent = "Hari Kerja";
      endInput.readOnly = false;
      endInput.classList.remove('bg-slate-100', 'select-none');
      endInput.classList.add('bg-slate-50/60');
      
      fileInput.required = name.includes('sakit');
      if (starLabel) name.includes('sakit') ? starLabel.classList.remove('hidden') : starLabel.classList.add('hidden');
      if (optionalLabel) name.includes('sakit') ? optionalLabel.classList.add('hidden') : optionalLabel.classList.remove('hidden');
      
      calculateDays();
    }
  }

  startInput.addEventListener('change', () => {
    const selectedLeaveType = document.getElementById('leave-label').textContent.toLowerCase();
    if (selectedLeaveType.includes('melahirkan')) {
      calculateMaternityDuration();
    } else {
      calculateDays();
    }
  });

  endInput.addEventListener('change', () => {
    calculateDays();
  });

  function toggleLeaveDropdown() {
    const menu = document.getElementById('leave-menu');
    const arrow = document.getElementById('leave-arrow');
    menu.classList.toggle('hidden');
    arrow.classList.toggle('rotate-180');
  }

  window.selectLeave = function(id, name, code) {
    if (employeeGender === "laki-laki" && code === "BL") {
      const warn = document.getElementById("leave-warning");
      if (warn) {
        warn.classList.remove("hidden");
        warn.textContent = "Cuti melahirkan hanya untuk perempuan";
        setTimeout(() => warn.classList.add("hidden"), 2500);
      }
      return;
    }

    document.getElementById('leaveTypeId').value = id;
    document.getElementById('leave-label').textContent = name;

    toggleLeaveDropdown();
    handleLeaveTypeChange(name);
  }

  window.addEventListener('click', function(e) {
    const dropdown = document.getElementById('leave-dropdown');
    if (dropdown && !dropdown.contains(e.target)) {
      document.getElementById('leave-menu').classList.add('hidden');
      document.getElementById('leave-arrow').classList.remove('rotate-180');
    }
  });

  window.handleFileSelect = function(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];
      if (currentFileUrl) URL.revokeObjectURL(currentFileUrl);

      currentFileUrl = URL.createObjectURL(file);
      document.getElementById("view-file-btn").href = currentFileUrl;
      document.getElementById("name-preview").textContent = file.name;
      document.getElementById("size-preview").textContent = (file.size / 1024 / 1024).toFixed(2) + " MB";

      const imgPreview = document.getElementById("img-preview");
      const fileIconFallback = document.getElementById("file-icon-fallback");

      if (file.type.startsWith("image/")) {
        imgPreview.src = currentFileUrl;
        imgPreview.classList.remove("hidden");
        fileIconFallback.classList.add("hidden");
      } else {
        imgPreview.classList.add("hidden");
        fileIconFallback.classList.remove("hidden");
      }

      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
      document.getElementById("dropzone-filled").classList.add("flex");
    }
  }

  window.triggerChangeFile = function() {
    fileInput.value = '';
    const emptyZone = document.getElementById('dropzone-empty');
    const filledZone = document.getElementById('dropzone-filled');

    emptyZone.classList.remove('hidden');
    emptyZone.classList.add('relative');
    filledZone.classList.remove('flex');
    filledZone.classList.add('hidden');
  }

  window.filterHandoverList = function() {
    const searchInput = document.getElementById('handover-search').value.toLowerCase();
    const items = document.getElementsByClassName('handover-item');

    for (let item of items) {
      const name = item.getAttribute('data-name');
      item.style.display = name.includes(searchInput) ? "flex" : "none";
    }
  }
</script>
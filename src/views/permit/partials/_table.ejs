<%
// =========================================================================
// FALLBACK HELPER: Mencegah error jika typeLabels tidak di-pass dari parent
// =========================================================================
const localTypeLabels = (typeof typeLabels !== 'undefined') ? typeLabels : {
  'SAKIT': 'Izin Sakit',
  'PENDAMPINGAN_MELAHIRKAN': 'Mendampingi Istri Melahirkan',
  'MUSIBAH': 'Terkena Musibah',
  'PENTING': 'Keperluan Mendesak',
  'KEPERLUAN_KELUARGA': 'Keperluan Keluarga',
  'LAINNYA': 'Lainnya'
};

const currentUserData = (typeof user !== 'undefined') ? user : null;

function getStatusConfig(status) {
  switch(status) {
    case 'PENDING': return { label: 'Pending', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500' };
    case 'APPROVED': return { label: 'Approved', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500' };
    case 'REJECTED': return { label: 'Rejected', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' };
    case 'CANCELLED': return { label: 'Cancelled', badge: 'bg-slate-100 text-slate-500 border-slate-300/60', dot: 'bg-slate-400' };
    default: return { label: status, badge: 'bg-slate-50 text-slate-600 border-slate-200/50', dot: 'bg-slate-500' };
  }
}
%>

<div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50 shadow-2xs">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse text-[13px] table-fixed">
      <thead>
        <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
          <th class="py-4 px-6 w-[14%]">Tanggal</th>
          <% if (isApprovalPage) { %>
            <th class="py-4 px-6 w-[24%]">Pegawai & Bidang</th>
          <% } %>
          <th class="py-4 px-6 w-[18%]">Jenis Izin</th>
          <th class="py-4 px-6 w-[26%]">Alasan Pengajuan</th>
          <th class="py-4 px-6 w-[10%] text-center">Dokumen</th>
          <th class="py-4 px-6 w-[12%] text-center">Status</th>
          <th class="py-4 px-6 w-[14%] text-center">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
        <% if (permits.length === 0) { %>
          <tr>
            <td colspan="<%= isApprovalPage ? 7 : 6 %>" class="py-12 text-center text-slate-400 font-medium">Belum ada dokumen perizinan.</td>
          </tr>
        <% } else { %>
          <% permits.forEach(permit => { %>
            <% 
              const config = getStatusConfig(permit.status); 
              const isOwnPermit = permit.employeeId?._id?.toString() === currentUserData?.employeeId?.toString();
            %>
            <tr class="hover:bg-slate-50/40 transition-colors">
              
              <td class="py-4 px-6 font-medium text-slate-500 tabular-nums">
                <%= new Date(permit.date).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
              </td>

              <% if (isApprovalPage) { %>
                <td class="py-4 px-6">
                  <span class="font-bold text-slate-800 block truncate"><%= permit.employeeId ? permit.employeeId.fullName : 'Staf Internal' %></span>
                  <span class="text-[10.5px] text-slate-400 font-medium block mt-0.5">🏢 <%= permit.employeeId?.careerData?.bidangId?.name || 'Staf Umum' %></span>
                </td>
              <% } %>

              <td class="py-4 px-6">
                <span class="inline-flex items-center px-2 py-0.5 bg-slate-50 border border-slate-200/80 rounded-md text-[11px] text-slate-700 font-semibold">
                  <%= localTypeLabels[permit.type] || permit.type %>
                </span>
              </td>

              <td class="py-4 px-6">
                <p class="w-full whitespace-normal break-words text-slate-500 leading-relaxed pr-2 font-normal truncate-2-lines" title="<%= permit.reason %>"><%= permit.reason %></p>
              </td>

              <td class="py-4 px-6 text-center">
                <% if (permit.document) { %>
                  <a href="<%= permit.document %>" target="_blank" class="inline-flex items-center gap-1 text-[11px] font-semibold text-blue-600 hover:text-blue-700 hover:underline transition-all">
                    <i class="fa-solid fa-paperclip text-[10px]"></i>
                    <span>Lampiran</span>
                  </a>
                <% } else { %>
                   <span class="text-[10.5px] text-slate-400 italic">Tanpa Lampiran</span>
                <% } %>
              </td>

              <td class="py-4 px-6 text-center select-none relative group">
                <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-bold border tracking-wide uppercase <%= config.badge %> <%= (permit.status === 'REJECTED' && permit.notesByApprover) ? 'cursor-help' : '' %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label.toUpperCase() %></span>

                  <% if (permit.status === 'REJECTED' && permit.notesByApprover) { %>
                    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:block z-50 w-52 p-2.5 bg-slate-900 text-white text-[11px] rounded-xl shadow-xl font-normal normal-case leading-relaxed text-left">
                      <span class="font-bold text-rose-400 block mb-0.5">Alasan Tolak:</span>
                      "<%= permit.notesByApprover %>"
                      <div class="absolute left-1/2 -translate-x-1/2 top-full w-0 h-0 border-x-4 border-x-transparent border-t-4 border-t-slate-900"></div>
                    </div>
                  <% } %>
                </div>
              </td>

              <td class="py-4 px-6 text-center">
                <div class="flex items-center justify-center gap-1.5">
                  <% if (isApprovalPage && permit.status === 'PENDING' && !isOwnPermit) { %>
                    <form action="/permit/approval/<%= permit._id %>" method="POST" class="inline m-0">
                      <input type="hidden" name="status" value="APPROVED">
                      <button type="submit" class="h-7 px-3 bg-white border border-emerald-200 text-emerald-600 hover:bg-emerald-50 text-[11px] font-semibold rounded-lg transition-all cursor-pointer">Setuju</button>
                    </form>
                    <button type="button" onclick="openRejectModal('<%= permit._id %>')" class="h-7 px-3 bg-white border border-rose-200 text-rose-600 hover:bg-rose-50 text-[11px] font-semibold rounded-lg transition-all cursor-pointer">Tolak</button>
                  <% } else if (permit.status === 'PENDING') { %>
                    <a href="/permit/edit/<%= permit._id %>" title="Edit Formulir" class="w-8 h-8 rounded-lg bg-amber-400 text-white inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-amber-500">
                      <i class="fa-solid fa-pen-to-square text-[11px]"></i>
                    </a>
                    <a href="/permit/delete/<%= permit._id %>" onclick="return confirm('Apakah Anda yakin ingin menarik berkas perizinan ini?')" title="Hapus Berkas" class="w-8 h-8 rounded-lg border border-rose-200 bg-rose-50/40 text-rose-600 inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-rose-50">
                      <i class="fa-solid fa-trash-can text-[11px]"></i>
                    </a>
                  <% } else { %>
                    <span class="text-[11px] font-semibold text-slate-400/70 italic select-none">Selesai</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="block md:hidden space-y-3.5 w-full">
  <% if (permits.length === 0) { %>
    <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4"><p class="text-[12px] font-medium text-slate-400">Tidak ada pengajuan perizinan</p></div>
  <% } else { %>
    <% permits.forEach(permit => { %>
      <% 
        const config = getStatusConfig(permit.status); 
        const isOwnPermit = permit.employeeId?._id?.toString() === currentUserData?.employeeId?.toString();
      %>
      <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5 shadow-2xs">
        
        <div class="flex items-start justify-between gap-2">
          <div>
            <h4 class="text-[13px] font-bold text-slate-800 tracking-tight">
              <%= isApprovalPage ? (permit.employeeId ? permit.employeeId.fullName : 'Staf Internal') : (localTypeLabels[permit.type] || permit.type) %>
            </h4>
            <p class="text-[11px] text-slate-400 font-medium mt-0.5">
              📅 <%= new Date(permit.date).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
              <% if (isApprovalPage) { %> | 🏢 <%= permit.employeeId?.careerData?.bidangId?.name || 'Umum' %> <% } %>
            </p>
          </div>
          
          <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-bold tracking-wider border shrink-0 uppercase <%= config.badge %>">
            <span><%= config.label %></span>
          </div>
        </div>

        <div class="bg-slate-50 p-3 rounded-xl border border-slate-200/30 text-xs">
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-0.5">Alasan (<%= localTypeLabels[permit.type] || permit.type %>)</p>
          <p class="text-slate-600 font-normal leading-relaxed"><%= permit.reason %></p>
          <% if (permit.status === 'REJECTED' && permit.notesByApprover) { %>
            <div class="mt-2 pt-2 border-t border-slate-200/60 text-[11px] text-rose-600 font-medium"><span class="font-bold">Alasan Tolak:</span> "<%= permit.notesByApprover %>"</div>
          <% } %>
        </div>

        <div class="flex items-center justify-between gap-2 pt-0.5">
          <% if (permit.document) { %>
            <a href="<%= permit.document %>" target="_blank" class="h-7 px-2.5 bg-blue-50 border border-blue-100 text-blue-600 text-[11px] font-bold rounded-md inline-flex items-center gap-1">
              <i class="fa-solid fa-file-invoice"></i> Berkas
            </a>
          <% } else { %>
            <span class="text-[10.5px] text-slate-400 italic">Tanpa Lampiran</span>
          <% } %>

          <div class="flex items-center gap-1.5">
            <% if (isApprovalPage && permit.status === 'PENDING' && !isOwnPermit) { %>
              <form action="/permit/approval/<%= permit._id %>" method="POST" class="inline m-0">
                <input type="hidden" name="status" value="APPROVED">
                <button type="submit" class="h-7 px-3 bg-white border border-emerald-200 text-emerald-600 font-semibold text-[11px] rounded-md cursor-pointer">Setuju</button>
              </form>
              <button type="button" onclick="openRejectModal('<%= permit._id %>')" class="h-7 px-3 bg-white border border-rose-200 text-rose-600 font-semibold text-[11px] rounded-md cursor-pointer">Tolak</button>
            <% } else if (permit.status === 'PENDING') { %>
              <a href="/permit/edit/<%= permit._id %>" class="h-7 w-7 bg-amber-400 text-white flex items-center justify-center text-xs rounded-md shadow-xs" title="Ubah Data">
                <i class="fa-solid fa-marker"></i>
              </a>
            <% } else { %>
              <span class="text-[11px] font-semibold text-slate-400/80 italic select-none">Selesai</span>
            <% } %>
          </div>
        </div>

      </div>
    <% }) %>
  <% } %>
</div>
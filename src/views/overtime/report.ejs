<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="flex justify-between items-start mb-6">

      <div>
        <h1 class="text-xl font-medium text-slate-800">
          Laporan Lembur
        </h1>
        <p class="text-sm text-slate-500 mt-1">
          Semua data pengajuan lembur karyawan
        </p>
      </div>

      <div class="flex gap-2">

      <button
  onclick="openExportModal()"
  class="px-3 py-1 bg-green-600 text-white rounded"
>
  export Excel
</button>


      </div>

    </div>

    <!-- FILTER -->
    <form method="GET"
  class="bg-white border border-slate-200 rounded-xl p-4 mb-5">

  <div class="flex flex-col md:flex-row md:items-center gap-3">

    <!-- SEARCH -->
    <div class="flex-1">
      <input
        type="text"
        name="search"
        placeholder="Cari nama karyawan..."
        value="<%= query.search || '' %>"
        class="w-full border border-slate-200 px-3 py-2.5 rounded-lg text-sm
               focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500"
      />
    </div>

    <!-- STATUS -->
    <div class="w-full md:w-48">
      <select
        name="status"
        class="w-full border border-slate-200 px-3 py-2.5 rounded-lg text-sm
               focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500"
      >
        <option value="">Semua Status</option>
        <option value="Pending Manager">Pending</option>
        <option value="Approved">Approved</option>
        <option value="Rejected">Rejected</option>
      </select>
    </div>

    <!-- SORT -->
    <div class="w-full md:w-40">
      <select
        name="sort"
        class="w-full border border-slate-200 px-3 py-2.5 rounded-lg text-sm
               focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500"
      >
        <option value="desc">Terbaru</option>
        <option value="asc">Terlama</option>
      </select>
    </div>

    <!-- BUTTON -->
    <div class="flex gap-2">

      <button
        class="bg-indigo-600 text-white px-5 py-2.5 rounded-lg text-sm
               hover:bg-indigo-700 transition shadow-sm"
      >
        Filter
      </button>

      <a href="/report/overtime"
        class="px-4 py-2.5 text-sm rounded-lg border border-slate-200
               text-slate-600 hover:bg-slate-50 transition"
      >
        Reset
      </a>

    </div>

  </div>

</form>
    <!-- SUMMARY -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-5">

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Total</p>
        <p class="text-lg font-medium text-slate-800"><%= summary.totalData %></p>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Approved</p>
        <p class="text-lg font-medium text-green-600"><%= summary.approved %></p>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Rejected</p>
        <p class="text-lg font-medium text-red-600"><%= summary.rejected %></p>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-4 text-sm">
        <p class="text-slate-500">Pending</p>
        <p class="text-lg font-medium text-yellow-600"><%= summary.pending %></p>
      </div>

    </div>

    <!-- TABLE -->
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

      <div class="overflow-x-auto">

        <table class="w-full text-sm border-collapse">

          <thead class="bg-yellow-300">
            <tr class="text-left text-xs text-slate-700">

              <th class="px-3 py-3 font-normal">Karyawan</th>
              <th class="px-3 py-3 font-normal">Tanggal</th>
              <th class="px-3 py-3 font-normal">Jam</th>
              <th class="px-3 py-3 font-normal">Total</th>
              <th class="px-3 py-3 font-normal">Status</th>
              <th class="px-3 py-3 font-normal">Aksi</th>

            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">

            <% data.forEach(o => { %>
            <tr class="hover:bg-slate-50 transition">

              <td class="px-3 py-2 text-slate-700">
                <%= o.employeeName %>
              </td>

              <td class="px-3 py-2 text-slate-600">
                <%= new Date(o.date).toLocaleDateString('id-ID') %>
              </td>

              <td class="px-3 py-2 text-slate-600">
                <%= o.startTime %> - <%= o.endTime %>
              </td>

              <td class="px-3 py-2 text-slate-600">
                <%= o.totalHours %> jam
              </td>

              <td class="px-3 py-2">
                <span class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600">
                  <%= o.status %>
                </span>
              </td>

              <td class="px-3 py-2">
                <button
  class="openDetailModal text-indigo-600 text-sm hover:underline"
  data-employee="<%= o.employeeName %>"
  data-date="<%= new Date(o.date).toLocaleDateString('id-ID') %>"
  data-time="<%= o.startTime %> - <%= o.endTime %>"
  data-total="<%= o.totalHours %> jam"
  data-status="<%= o.status %>"
  data-description="<%= o.workDescription %>"
  data-result="<%= o.result || '-' %>"
  data-created="<%= new Date(o.createdAt).toLocaleString('id-ID') %>"
  data-proof="<%= o.proofFile || '' %>"
>
  Detail
</button>
              </td>

            </tr>
            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

    <!-- PAGINATION -->
    <div class="mt-4 flex items-center justify-between text-sm text-slate-600">

      <div>
        Page <%= pagination.page %> / <%= pagination.totalPages %>
      </div>

      <div class="flex gap-2">

        <a href="?page=<%= pagination.page - 1 %>"
           class="px-3 py-1 border rounded-lg hover:bg-slate-100">
          Prev
        </a>

        <a href="?page=<%= pagination.page + 1 %>"
           class="px-3 py-1 border rounded-lg hover:bg-slate-100">
          Next
        </a>

      </div>

    </div>

  </div>

</div>
<div
  id="detailModal"
  class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50 p-4"
>

  <!-- BOX -->
  <div
    class="bg-white w-full max-w-2xl rounded-2xl shadow-xl relative overflow-hidden max-h-[90vh] flex flex-col"
  >

    <!-- HEADER -->
    <div class="px-6 py-5 border-b border-slate-100 flex items-start justify-between shrink-0">

      <div>
        <h2 class="text-xl font-semibold text-slate-800">
          Detail Lembur
        </h2>

        <p class="text-sm text-slate-500 mt-1">
          Informasi lengkap pengajuan lembur karyawan
        </p>
      </div>

      <button
        id="closeModal"
        class="text-slate-400 hover:text-slate-600 text-lg"
      >
        ✕
      </button>

    </div>

    <!-- SCROLL AREA -->
    <div class="overflow-y-auto p-6">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">

        <!-- KARYAWAN -->
        <div>
          <p class="text-xs uppercase text-slate-400">Karyawan</p>
          <p id="modalEmployee" class="mt-1 font-medium text-slate-700"></p>
        </div>

        <!-- TANGGAL -->
        <div>
          <p class="text-xs uppercase text-slate-400">Tanggal</p>
          <p id="modalDate" class="mt-1 font-medium text-slate-700"></p>
        </div>

        <!-- JAM -->
        <div>
          <p class="text-xs uppercase text-slate-400">Jam</p>
          <p id="modalTime" class="mt-1 font-medium text-slate-700"></p>
        </div>

        <!-- TOTAL -->
        <div>
          <p class="text-xs uppercase text-slate-400">Total Lembur</p>
          <p id="modalTotal" class="mt-1 font-medium text-slate-700"></p>
        </div>

        <!-- STATUS -->
        <div>
          <p class="text-xs uppercase text-slate-400">Status</p>
          <p id="modalStatus" class="mt-1 font-medium text-slate-700"></p>
        </div>

        <!-- DIBUAT -->
        <div>
          <p class="text-xs uppercase text-slate-400">Dibuat</p>
          <p id="modalCreated" class="mt-1 text-slate-600"></p>
        </div>

        <!-- DESKRIPSI -->
        <div class="md:col-span-2">
          <p class="text-xs uppercase text-slate-400">Deskripsi Pekerjaan</p>
          <p id="modalDescription" class="mt-1 text-slate-600 leading-relaxed"></p>
        </div>

        <!-- HASIL -->
        <div class="md:col-span-2">
          <p class="text-xs uppercase text-slate-400">Hasil Pekerjaan</p>
          <p id="modalResult" class="mt-1 text-slate-600 leading-relaxed"></p>
        </div>

        <!-- BUKTI -->
        <div class="md:col-span-2">
          <p class="text-xs uppercase text-slate-400">Bukti Lembur</p>

          <div id="proofWrapper" class="mt-3 flex justify-center">

            <img
              id="modalProof"
              src=""
              alt="Bukti Lembur"
              class="w-56 rounded-xl border border-slate-200 shadow-sm"
            />

          </div>

          <div
            id="proofEmpty"
            class="hidden mt-3 border border-dashed border-slate-200 rounded-xl p-6 text-center text-sm text-slate-400"
          >
            Tidak ada file bukti
          </div>

        </div>

      </div>

    </div>

    <!-- FOOTER -->
    <div class="px-6 py-4 border-t border-slate-100 flex justify-end shrink-0">

      <button
        id="closeModalFooter"
        class="px-4 py-2 bg-slate-800 text-white rounded-xl hover:bg-slate-700 transition"
      >
        Tutup
      </button>

    </div>

  </div>

</div>
<script>
  const modal = document.getElementById("detailModal");

  function openModal(data) {
    document.getElementById("modalEmployee").innerText = data.employee;
    document.getElementById("modalDate").innerText = data.date;
    document.getElementById("modalTime").innerText = data.time;
    document.getElementById("modalTotal").innerText = data.total;
    document.getElementById("modalStatus").innerText = data.status;
    document.getElementById("modalDescription").innerText = data.description;
    document.getElementById("modalResult").innerText = data.result;
    document.getElementById("modalCreated").innerText = data.created;

    const proof = data.proof;
    const img = document.getElementById("modalProof");
    const wrapper = document.getElementById("proofWrapper");
    const empty = document.getElementById("proofEmpty");

    if (proof && proof !== "null" && proof !== "") {
      img.src = `/uploads/files/${proof}`;
      wrapper.classList.remove("hidden");
      empty.classList.add("hidden");
    } else {
      wrapper.classList.add("hidden");
      empty.classList.remove("hidden");
    }

    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }

  // EVENT DELEGATION (INI YANG FIX)
  document.addEventListener("click", function (e) {
    const btn = e.target.closest(".openDetailModal");

    if (!btn) return;

    openModal({
      employee: btn.dataset.employee,
      date: btn.dataset.date,
      time: btn.dataset.time,
      total: btn.dataset.total,
      status: btn.dataset.status,
      description: btn.dataset.description,
      result: btn.dataset.result,
      created: btn.dataset.created,
      proof: btn.dataset.proof
    });
  });

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  document.getElementById("closeModal")
    .addEventListener("click", closeModal);

  document.getElementById("closeModalFooter")
    .addEventListener("click", closeModal);

  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
</script>
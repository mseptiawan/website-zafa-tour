<%- layout('layouts/main', { title: 'Riwayat Lembur' }) %>

<div class=" min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-6xl mx-auto">

    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Kehadiran', 
        title: 'Riwayat Lembur', 
        description: 'Daftar lengkap pengajuan dan status aktivitas lembur Pegawai.' 
    }) %>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[1000px]">

          <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-100">
            <tr>
              <th class="text-left px-6 py-4">Tanggal Lembur</th>
              <th class="text-left px-6 py-4">Jam Pelaksanaan</th>
              <th class="text-left px-6 py-4">Durasi</th>
              <th class="text-center px-6 py-4">Status Akhir</th>
              <th class="text-right px-6 py-4">Aksi</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">

            <% if (overtimes.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-12 text-slate-400">
                Belum ada riwayat pengajuan lembur
              </td>
            </tr>
            <% } %>

            <% overtimes.forEach(o => { %>
            <tr class="hover:bg-slate-50/50 transition">

              <td class="px-6 py-4 text-slate-500 font-medium">
                <%= new Date(o.date).toLocaleDateString("id-ID", {day: '2-digit', month: 'short', year: 'numeric'}) %>
              </td>

              <td class="px-6 py-4 text-slate-600 font-medium">
                <span class="text-[11px] font-mono bg-slate-50 border border-slate-200/60 text-slate-600 px-2 py-0.5 rounded">
                  <%= o.startTime %> - <%= o.endTime %>
                </span>
              </td>

              <td class="px-6 py-4 font-semibold text-slate-700 tabular-nums">
                <%= o.totalHours %> Jam
              </td>

              <td class="px-6 py-4 whitespace-nowrap align-middle text-center">
                <% 
                  const status = o.status ? o.status.toUpperCase() : '';
                  let textStyle = 'text-amber-600', bgStyle = 'bg-amber-50/70', borderStyle = 'border-amber-200/50', dotStyle = 'bg-amber-500';

                  if (status === 'APPROVED') {
                    textStyle = 'text-emerald-600'; bgStyle = 'bg-emerald-50/70'; borderStyle = 'border-emerald-200/50'; dotStyle = 'bg-emerald-505';
                  } else if (status === 'REJECTED') {
                    textStyle = 'text-rose-600'; bgStyle = 'bg-rose-50/70'; borderStyle = 'border-rose-200/50'; dotStyle = 'bg-rose-500';
                  }
                %>

                <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-medium tracking-wide transition-all duration-200 <%= textStyle %> <%= bgStyle %> <%= borderStyle %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= dotStyle %> <%= status === 'APPROVED' ? 'animate-pulse' : '' %>"></span>
                  <span><%= o.status %></span>
                </div>
              </td>

              <td class="px-6 py-4">
                <div class="flex items-center justify-end">
                  <a href="/overtime/detail/<%= o._id %>" 
                     class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition active:scale-[0.95]" 
                     title="Lihat Detail Lembur">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                  </a>
                </div>
              </td>

            </tr>
            <% }) %>

          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
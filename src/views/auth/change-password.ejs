<%- layout('layouts/main', { title: 'Ubah Password' }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] py-5 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0">

    <%- include('../partials/page-header', {
      section: 'Pengaturan Akun',
      module: 'Keamanan',
      title: 'Ubah Password',
      description: 'Amankan akun Anda dengan memperbarui kata sandi secara berkala.'
    }) %>

    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl p-4 sm:p-5 md:p-8 overflow-hidden">
      
      <% if (query?.error === "WRONG_CURRENT_PASSWORD") { %>
        <div class="p-3.5 mb-5 rounded-xl bg-rose-50 text-rose-600 text-[13px] border border-rose-100 font-medium flex items-start gap-2.5">
          <i class="fa-solid fa-circle-exclamation w-4 h-4 shrink-0 mt-0.5 text-rose-500"></i>
          <span>Password lama yang Anda masukkan salah.</span>
        </div>
      <% } %>

      <% if (query?.error === "PASSWORD_MISMATCH") { %>
        <div class="p-3.5 mb-5 rounded-xl bg-rose-50 text-rose-600 text-[13px] border border-rose-100 font-medium flex items-start gap-2.5">
          <i class="fa-solid fa-circle-exclamation w-4 h-4 shrink-0 mt-0.5 text-rose-500"></i>
          <span>Konfirmasi password baru tidak cocok.</span>
        </div>
      <% } %>

      <% if (query?.error === "WEAK_PASSWORD") { %>
        <div class="p-3.5 mb-5 rounded-xl bg-rose-50 text-rose-600 text-[13px] border border-rose-100 font-medium flex items-start gap-2.5">
          <i class="fa-solid fa-circle-exclamation w-4 h-4 shrink-0 mt-0.5 text-rose-500"></i>
          <span>Password baru terlalu lemah. Minimal wajib 6 karakter.</span>
        </div>
      <% } %>

      <% if (query?.success === "PASSWORD_CHANGED") { %>
        <div class="p-3.5 mb-5 rounded-xl bg-emerald-50 text-emerald-600 text-[13px] border border-emerald-100 font-medium flex items-start gap-2.5">
          <i class="fa-solid fa-circle-check w-4 h-4 shrink-0 mt-0.5 text-emerald-500"></i>
          <span>Kata sandi Anda berhasil diperbarui.</span>
        </div>
      <% } %>

      <form id="change-password-form" method="POST" action="/change-password" class="space-y-5">

        <div class="space-y-2 mb-5">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Password Saat Ini <span class="text-rose-500">*</span></label>
          <input 
            type="password" 
            name="currentPassword" 
            required 
            placeholder="Ketik password yang digunakan sekarang..."
            class="w-full bg-slate-50/60 border border-slate-200/70 focus:border-slate-400 rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 focus:bg-white focus:ring-0 outline-none transition-all text-slate-800" 
          />
        </div>

        <hr class="border-t border-slate-100/80 my-2" />

        <div class="space-y-2 mb-5">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Password Baru <span class="text-rose-500">*</span></label>
          <input 
            type="password" 
            id="newPassword"
            name="password" 
            required 
            placeholder="Minimal 6 karakter kombinasi huruf & angka..."
            class="w-full bg-slate-50/60 border border-slate-200/70 focus:border-slate-400 rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 focus:bg-white focus:ring-0 outline-none transition-all text-slate-800" 
          />
        </div>

        <div class="space-y-2 mb-5">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Konfirmasi Password Baru <span class="text-rose-500">*</span></label>
          <input 
            type="password" 
            id="confirmPassword"
            name="confirmPassword" 
            required 
            placeholder="Ulangi ketik password baru Anda..."
            class="w-full bg-slate-50/60 border border-slate-200/70 focus:border-slate-400 rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 focus:bg-white focus:ring-0 outline-none transition-all text-slate-800" 
          />
        </div>

        <div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-2.5">
          <a href="/dashboard" class="w-auto text-center bg-slate-100 hover:bg-slate-200/80 text-slate-600 px-5 py-2.5 rounded-xl text-[12px] font-semibold transition-colors decoration-none">
            Batal
          </a>
          <button type="submit" class="w-auto text-center bg-blue-600 text-white px-6 py-2.5 rounded-xl text-[12px] font-semibold transition-colors border-none cursor-pointer">
            Ganti
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
  document.getElementById('change-password-form').addEventListener('submit', function(e) {
    const password = document.getElementById('newPassword').value;
    const confirm = document.getElementById('confirmPassword').value;

    if (password.length < 6) {
      e.preventDefault();
      alert('Password baru minimal harus terdiri dari 6 karakter!');
      return false;
    }

    if (password !== confirm) {
      e.preventDefault();
      alert('Konfirmasi password baru tidak cocok dengan yang Anda ketik!');
      return false;
    }
  });
</script>
<%- layout('layouts/main', { title: 'Riwayat KPI Saya' }) %>

<!-- Wrapper utama dengan min-w-0 dan overflow-hidden agar anti-meluber di HP -->
<div class="w-full min-w-0 px-2 sm:px-4 py-4 overflow-hidden">
  <div class="w-full space-y-4 md:space-y-6">

    <!-- HEADER PAGE: Responsif kolom ke baris -->
    <div class="w-full border-b border-slate-200/80 pb-4">
      <div class="flex flex-col gap-1">
        <div class="flex items-center gap-2 select-none flex-wrap">
          <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Area Kerja</span>
          <div class="w-px h-2.5 bg-slate-300"></div>
          <span class="text-[9px] font-bold text-slate-800 uppercase tracking-wider">Performance</span>
        </div>
        <h1 class="text-xl font-extrabold tracking-tight text-slate-900 sm:text-2xl">Riwayat KPI Saya</h1>
        <p class="text-xs text-slate-500">Pantau rekam jejak penilaian kinerja berkala Anda</p>
      </div>
    </div>

    <!-- MAIN INTERACTIVE CONTAINER -->
    <div class="w-full min-w-0">
      
      <!-- ==================== 1. MOBILE VIEW: CARD LIST (Hidden di layar md:) ==================== -->
      <div class="block md:hidden space-y-3 w-full min-w-0">
        <% if (!kpiList || kpiList.length === 0) { %>
          <div class="bg-white border border-slate-200 rounded-xl py-8 text-center px-4">
            <p class="text-xs font-medium text-slate-400">Belum ada data penilaian KPI untuk akun Anda.</p>
          </div>
        <% } else { %>
          <% kpiList.forEach(kpi => { %>
            <div class="w-full min-w-0 bg-white border border-slate-200 rounded-xl p-4 space-y-3 overflow-hidden">
              
              <!-- Periode & Status Badge -->
              <div class="flex items-start justify-between gap-3 w-full">
                <div class="min-w-0 flex-1">
                  <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block">Periode Evaluasi</span>
                  <h4 class="text-xs font-bold text-slate-900 tracking-tight break-words mt-0.5">
                    📅 <%= kpi.periode %>
                  </h4>
                </div>
                <div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[9px] font-bold uppercase bg-emerald-50 text-emerald-600 border-emerald-200/50 shrink-0 whitespace-nowrap">
                  <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
                  <span><%= kpi.status %></span>
                </div>
              </div>

              <!-- Nilai Box Ringkas -->
              <div class="bg-slate-50 p-2.5 rounded-lg border border-slate-100 w-full">
                <div class="flex justify-between items-center gap-2">
                  <div class="min-w-0">
                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Pencapaian</p>
                    <p class="text-[10px] text-slate-500 truncate">Bobot Kinerja Anda</p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Skor Akhir</p>
                    <p class="text-sm font-black text-indigo-600 tabular-nums"><%= kpi.totalKpiScore %></p>
                  </div>
                </div>
              </div>

              <!-- Tombol Detail Full-Width -->
              <div class="w-full pt-1">
                <a href="/kpi/histories/<%= kpi.employeeId?._id %>/<%= kpi.periode %>" 
                   class="w-full h-8 bg-white border border-slate-200 text-slate-700 font-semibold text-[11px] rounded-lg inline-flex items-center justify-center gap-1.5 transition-colors active:bg-slate-50 no-underline">
                  <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9a3 3 0 100 6 3 3 0 000-6z" />
                  </svg>
                  <span>Lihat Rincian Evaluasi</span>
                </a>
              </div>

            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- ==================== 2. DESKTOP VIEW: TABLE (Hidden di layar < md:) ==================== -->
      <div class="hidden md:block w-full bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="w-full overflow-x-auto">
          <table class="w-full text-left border-collapse text-xs table-fixed">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-[11px] font-bold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-3.5 px-6 w-[45%]">Periode Penilaian</th>
                <th class="py-3.5 px-4 w-[20%] text-center">Nilai Akhir</th>
                <th class="py-3.5 px-4 w-[20%] text-center">Status Evaluasi</th>
                <th class="py-3.5 px-6 w-[15%] text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white text-slate-600 font-medium">
              <% if (kpiList && kpiList.length > 0) { %>
                <% kpiList.forEach(kpi => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-3.5 px-6 font-semibold text-slate-800 truncate">
                      📅 <%= kpi.periode %>
                    </td>
                    <td class="py-3.5 px-4 text-center font-extrabold text-indigo-600 tabular-nums">
                      <%= kpi.totalKpiScore %>
                    </td>
                    <td class="py-3.5 px-4 text-center select-none">
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-bold uppercase bg-emerald-50 text-emerald-600 border-emerald-200/50">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 ring-4 ring-emerald-500/20"></span>
                        <span><%= kpi.status %></span>
                      </div>
                    </td>
                    <td class="py-3.5 px-6 text-center">
                      <a href="/kpi/histories/<%= kpi.employeeId?._id %>/<%= kpi.periode %>" 
                         title="Lihat Detail" 
                         class="w-7 h-7 rounded-md bg-white border border-slate-200 text-slate-500 inline-flex items-center justify-center transition-all active:scale-95 hover:bg-slate-50">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9a3 3 0 100 6 3 3 0 000-6z" />
                        </svg>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="py-10 text-center text-slate-400 font-normal">Belum ada data penilaian KPI untuk akun Anda.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div class="px-6 py-3 border-t border-slate-100 bg-slate-50/50 text-[10px] text-slate-400 font-semibold select-none">
          Menampilkan <%= kpiList ? kpiList.length : 0 %> Rekor Penilaian Anda
        </div>
      </div>

    </div>
  </div>
</div>
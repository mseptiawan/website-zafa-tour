<%- layout('layouts/main', { title: title }) %>

<% 
  // ==========================================
  // COMPONENT-LEVEL UTILITIES (JS PARSING)
  // ==========================================
  
  // Fungsi presisi untuk menghitung durasi kerja dari objek Date database
  const calculateDurationSecure = (checkInDate, checkOutDate) => {
    if (!checkInDate || !checkOutDate) return null;

    const inDate = new Date(checkInDate);
    const outDate = new Date(checkOutDate);

    // Validasi apakah parsing objek Date berhasil
    if (isNaN(inDate.getTime()) || isNaN(outDate.getTime())) return null;

    // Hitung selisih milidetik
    let diffInMs = outDate - inDate;

    // Antisipasi jika ada shift malam (Check Out melewati tengah malam / keesokan hari)
    if (diffInMs < 0) {
      diffInMs += 24 * 60 * 60 * 1000; // Tambah nilai 1 hari penuh
    }

    const hours = diffInMs / (1000 * 60 * 60);

    // Proteksi logika batas maksimal jam kerja normal dalam 1 shift
    if (hours > 24) return null;

    // Tampilkan desimal jika ada menitnya (misal 8.5), hilangkan jika bulat (misal 8)
    return hours % 1 === 0 ? hours.toFixed(0) : hours.toFixed(1);
  };
%>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD]  sm:p-6 md:p-10 antialiased selection:bg-slate-100 text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto md:mt-12 md:mt-0 space-y-6 md:space-y-8">

    <div class="hidden md:block">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Kehadiran', 
          title: 'Riwayat Absensi', 
          description: 'Pantau data kehadiran, jam kerja, dan kedisiplinan Anda secara berkala.' 
      }) %>
    </div>

    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        items: [
          { 
            label: isAdmin && !isPersonalView ? 'Hari Hadir' : 'Hari Hadir', 
            value: analytics.totalHadir, 
            unit: 'Hari', 
            icon: 'fa-solid fa-user-check', 
            bgClass: 'bg-white  border-slate-200/50 shadow-sm', 
            iconBoxClass: 'bg-emerald-50 text-emerald-600 border border-emerald-200/50' 
          },
          { 
            label: isAdmin && !isPersonalView ? 'Keterlambatan' : 'Keterlambatan', 
            value: analytics.totalLateDays, 
            unit: 'Kali', 
            icon: 'fa-solid fa-user-clock', 
            bgClass: 'bg-white border border-slate-200/50 shadow-sm', 
            labelClass: 'text-rose-600', 
            valueClass: 'text-rose-700', 
            unitClass: 'text-rose-600',
            iconBoxClass: 'bg-white text-rose-500 border border-rose-200/50' 
          },
          { 
            label: isAdmin && !isPersonalView ? 'Total Menit Telat' : 'Total Menit Telat', 
            value: analytics.totalLateMinutes, 
            unit: 'Menit', 
            icon: 'fa-solid fa-stopwatch', 
            bgClass: 'bg-white border border-slate-200/50 shadow-sm', 
            iconBoxClass: 'bg-amber-50 text-amber-600 border border-amber-200/50' 
          }
        ]
      }) %>
    </div>

    <div class="flex flex-col gap-3.5 w-full bg-white border border-slate-200/50 p-4 rounded-2xl shadow-sm select-none">
      
      <div class="block md:hidden">
        <h3 class="text-[15px] font-bold text-slate-800 tracking-tight">Log Kehadiran</h3>
      </div>

      <div class="flex items-center justify-between gap-3 w-full">
        <div class="flex items-center gap-2 flex-1 sm:flex-none">
          <% if (isAdmin) { %>
            <div class="inline-flex items-center p-0.5 bg-slate-100/80 rounded-full w-full sm:w-auto">
              <a href="/attendance/history" 
                 class="flex-1 sm:flex-none text-center px-4 py-1.5 text-[11px] rounded-full transition-all duration-200 <%= !isPersonalView ? 'font-bold bg-white text-slate-900 shadow-sm' : 'font-semibold text-slate-400 hover:text-slate-600' %>">
                Semua
              </a>
              <a href="/attendance/history?view=personal" 
                 class="flex-1 sm:flex-none text-center px-4 py-1.5 text-[11px] rounded-full transition-all duration-200 <%= isPersonalView ? 'font-bold bg-white text-slate-900 shadow-sm' : 'font-semibold text-slate-400 hover:text-slate-600' %>">
                Saya
              </a>
            </div>
          <% } else { %>
            <h3 class="hidden md:block text-[14px] font-bold text-slate-800 tracking-tight">Attendance log</h3>
          <% } %>
        </div>

        <button onclick="openFilterModal()" type="button" class="inline-flex items-center justify-center gap-2 h-8.5 px-4 bg-blue-500 hover:bg-blue-700 text-white text-[11px] font-semibold rounded-full shadow-sm transition-all active:scale-95 cursor-pointer outline-none shrink-0">
          <i class="fa-solid fa-filter text-[9px] text-slate-300"></i>
          <span>Filter</span>
        </button>
      </div>

    </div>

    <% if (listAttendance.length === 0) { %>
    <div class="bg-white border border-slate-200/50 rounded-2xl py-16 text-center shadow-sm px-4">
      <div class="w-10 h-10 bg-slate-50 border border-slate-200/50 rounded-xl flex items-center justify-center mx-auto mb-3 text-slate-400">
        <i class="fa-solid fa-clock-rotate-left text-sm"></i>
      </div>
      <p class="text-[12px] font-semibold text-slate-700">Belum ada data absensi</p>
      <p class="text-[11px] text-slate-400 max-w-xs mx-auto mt-0.5 leading-relaxed">Data kehadiran akan muncul setelah pegawai melakukan check-in atau check-out.</p>
    </div>
    <% } else { %>

    <div class="hidden md:block bg-white rounded-2xl shadow-sm overflow-hidden w-full border border-slate-200/50">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50/40 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
              <% if (isAdmin && !isPersonalView) { %><th class="py-4 px-6 w-48">Pegawai</th><% } %>
              <th class="py-4 px-6 w-36">Tanggal</th>
              <th class="py-4 px-6 w-32 text-center">Check In</th>
              <th class="py-4 px-6 w-32 text-center">Check Out</th>
              <th class="py-4 px-6 w-32 text-center">Keterlambatan</th>
              <th class="py-4 px-6 w-32 text-center">Status</th>
              <th class="py-4 px-6 w-16 text-center">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100/50 bg-white">
            <% listAttendance.forEach(row => { %>
            <tr class="hover:bg-slate-50 transition-colors text-[13px] font-medium text-slate-600">

              <% if (isAdmin && !isPersonalView) { %>
              <td class="py-4 px-6 font-bold text-slate-800 truncate max-w-[180px]">
                <%= row.fullName %>
              </td>
              <% } %>

              <td class="py-4 px-6 font-semibold text-slate-800">
                <%= new Date(row.checkIn || row.createdAt).toLocaleDateString("id-ID", {day:'2-digit', month:'short', year:'numeric'}) %>
              </td>

              <td class="py-4 px-6 text-center tabular-nums font-semibold text-slate-700">
                <%= row.checkIn ? new Date(row.checkIn).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '--:--' %>
              </td>

              <td class="py-4 px-6 text-center tabular-nums font-semibold text-slate-700">
                <%= row.checkOut ? new Date(row.checkOut).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '--:--' %>
              </td>

              <td class="py-4 px-6 text-center tabular-nums font-semibold <%= row.lateDuration > 0 ? 'text-rose-600' : 'text-slate-400' %>">
                <%= row.lateDuration > 0 ? row.lateDuration + ' mnt' : '-' %>
              </td>

              <td class="py-4 px-6 text-center whitespace-nowrap select-none">
                <% 
                  const status = row.status || '';
                  let badgeClass;
                  let statusText = status ? status.toUpperCase() : '';
                  
                  if (status === 'BELUM ABSEN' || status === 'ALFA') {
                    badgeClass = 'bg-rose-50 text-rose-600 border border-rose-200/50';
                  } else if (status === 'TERLAMBAT' || row.lateDuration > 0) {
                    badgeClass = 'bg-amber-50 text-amber-600 border border-amber-200/50';
                    statusText = 'TERLAMBAT';
                  } else {
                    badgeClass = 'bg-emerald-50 text-emerald-600 border border-emerald-200/50';
                  }
                %>
                <div class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-[10px] font-bold tracking-wider <%= badgeClass %> shadow-3xs">
                  <%= statusText %>
                </div>
              </td>

              <td class="py-4 px-6 text-center">
                <% if (row.status === 'BELUM ABSEN') { %>
                <button class="w-8 h-8 rounded-lg bg-slate-50 border border-slate-200/50 text-slate-300 cursor-not-allowed inline-flex items-center justify-center" disabled>
                  <i class="fa-solid fa-eye text-[11px]"></i>
                </button>
                <% } else { %>
                <button class="openModal w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 hover:bg-slate-50 inline-flex items-center justify-center transition-all active:scale-[0.95] cursor-pointer shadow-3xs outline-none" 
                  data-date="<%= new Date(row.createdAt).toLocaleDateString('id-ID', {day:'2-digit', month:'long', year:'numeric'}) %>" 
                  data-status="<%= row.status %>" 
                  data-checkin="<%= row.checkIn ? new Date(row.checkIn).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '-' %>" 
                  data-checkout="<%= row.checkOut ? new Date(row.checkOut).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '-' %>" 
                  data-duration="<%= row.workDuration || 0 %>" 
                  data-lateduration="<%= row.lateDuration || 0 %>" 
                  data-inphoto="<%= encodeURI(row.checkInPhoto || '') %>" 
                  data-outphoto="<%= encodeURI(row.checkOutPhoto || '') %>" 
                  data-type="<%= row.type || 'Reguler' %>">
                  <i class="fa-solid fa-eye text-[11px]"></i>
                </button>
                <% } %>
              </td>

            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="block md:hidden space-y-4 w-full">
      <% listAttendance.forEach(row => { %>
        
        <% 
          const status = row.status || '';
          let badgeClass;
          let statusText = status ? status.toUpperCase() : '';
          
          if (status === 'BELUM ABSEN' || status === 'ALFA') {
            badgeClass = 'bg-rose-50 text-rose-600 border border-rose-200/50';
          } else if (status === 'TERLAMBAT' || row.lateDuration > 0) {
            badgeClass = 'bg-amber-50 text-amber-600 border border-amber-200/50';
            statusText = 'TERLAMBAT';
          } else {
            badgeClass = 'bg-emerald-50 text-emerald-600 border border-emerald-200/50';
          }
        %>

        <div class="bg-white border border-slate-200/50 rounded-2xl p-4.5 shadow-sm space-y-4">
          
          <div class="flex items-center justify-between gap-2">
            <div class="flex flex-col">
              <% if (isAdmin && !isPersonalView) { %>
                <span class="text-[13px] font-bold text-slate-800 block truncate max-w-[150px]"><%= row.fullName %></span>
              <% } %>
              <span class="text-[12px] font-bold text-slate-900 tracking-tight"><%= new Date(row.checkIn || row.createdAt).toLocaleDateString("id-ID", {day:'2-digit', month:'short', year:'numeric'}) %></span>
            </div>
            
            <div class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-[10px] font-bold tracking-wider <%= badgeClass %>">
              <%= statusText %>
            </div>
          </div>

          <div class="flex flex-col gap-2 bg-slate-50/50 rounded-xl px-4 py-3 select-none border border-slate-100/50">
            <div class="flex items-center gap-2.5 text-[13.5px] font-medium text-slate-700">
              <span class="text-slate-400 text-xs">⏱</span>
              <span class="tabular-nums font-bold text-slate-800">
                <%= row.checkIn ? new Date(row.checkIn).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '--:--' %>
              </span>
              <span class="text-slate-300">→</span>
              <span class="tabular-nums font-bold text-slate-800">
                <%= row.checkOut ? new Date(row.checkOut).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '--:--' %>
              </span>
            </div>
            
            <% const duration = calculateDurationSecure(row.checkIn, row.checkOut); %>
            <% if (duration) { %>
              <div class="text-[11px] font-medium text-slate-500 pl-6">
                Durasi kerja: <span class="text-slate-700 font-bold"><%= duration %> jam</span>
              </div>
            <% } %>
          </div>

          <div class="flex items-center justify-between gap-3 pt-0.5">
            
            <div class="text-[11.5px] font-semibold text-slate-500 flex items-center gap-1.5">
              <% if (row.lateDuration > 0) { %>
                <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span>
                <span class="text-rose-600 font-bold">TELAT <%= row.lateDuration %> MNT</span>
              <% } else if (row.status === 'BELUM ABSEN') { %>
                <span class="text-slate-400">-</span>
              <% } else { %>
                <span class="text-emerald-600 font-bold">TEPAT WAKTU</span>
              <% } %>
            </div>

            <div class="shrink-0">
              <% if (row.status === 'BELUM ABSEN') { %>
                <button class="h-8.5 px-4 bg-slate-50 border border-slate-200/50 text-slate-300 text-[11.5px] font-semibold rounded-xl flex items-center justify-center cursor-not-allowed select-none" disabled>
                  BELUM TERSEDIA
                </button>
              <% } else { %>
                <button class="openModal h-8.5 px-4.5 bg-slate-900 hover:bg-black text-white text-[11.5px] font-bold rounded-xl flex items-center justify-center transition-all active:scale-[0.97] outline-none cursor-pointer shadow-3xs"
                  data-date="<%= new Date(row.createdAt).toLocaleDateString('id-ID', {day:'2-digit', month:'long', year:'numeric'}) %>"
                  data-status="<%= row.status %>"
                  data-checkin="<%= row.checkIn ? new Date(row.checkIn).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '-' %>"
                  data-checkout="<%= row.checkOut ? new Date(row.checkOut).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '-' %>"
                  data-duration="<%= duration || 0 %>"
                  data-lateduration="<%= row.lateDuration || 0 %>"
                  data-inphoto="<%= encodeURI(row.checkInPhoto || '') %>"
                  data-outphoto="<%= encodeURI(row.checkOutPhoto || '') %>"
                  data-type="<%= row.type || 'Reguler' %>">
                  <span>DETAIL</span>
                </button>
              <% } %>
            </div>

          </div>

        </div>
      <% }) %>
    </div>
    <% } %>

  </div>
</div>

<div id="filterModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/40 p-4 backdrop-blur-xs transition-all duration-300">
  <div class="w-full max-w-sm bg-white border border-slate-200/50 rounded-2xl shadow-xl overflow-hidden transform transition-all mx-3 sm:mx-auto">
    
    <div class="flex justify-between border-b border-slate-200/50 px-5 py-4 bg-white select-none">
      <div>
        <h2 class="text-[13px] font-bold text-slate-800 tracking-tight">Rentang Tanggal</h2>
        <p class="text-[10.5px] font-medium text-slate-400 mt-0.5">Pilih periode riwayat absensi</p>
      </div>
      <button onclick="closeFilterModal()" class="h-7 w-7 rounded-lg bg-slate-50 border border-slate-200/50 text-slate-400 hover:text-slate-800 flex items-center justify-center text-[10px] cursor-pointer outline-none">
        ✕
      </button>
    </div>

    <form action="/attendance/history" method="GET" class="p-5 space-y-4">
      <% if (isAdmin && isPersonalView) { %>
        <input type="hidden" name="view" value="personal">
      <% } %>

      <div class="space-y-3 text-[12px] font-semibold text-slate-700">
        <div class="flex flex-col gap-1.5">
          <label class="text-slate-400 font-medium">Tanggal Mulai</label>
          <input type="date" name="startDate" value="<%= filters.startDate %>" class="w-full h-9 bg-slate-50/50 border border-slate-200/80 rounded-xl px-3 text-[12px] font-semibold text-slate-700 outline-none focus:bg-white focus:border-slate-300 transition-colors cursor-pointer">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-slate-400 font-medium">Tanggal Selesai</label>
          <input type="date" name="endDate" value="<%= filters.endDate %>" class="w-full h-9 bg-slate-50/50 border border-slate-200/80 rounded-xl px-3 text-[12px] font-semibold text-slate-700 outline-none focus:bg-white focus:border-slate-300 transition-colors cursor-pointer">
        </div>
      </div>

      <div class="pt-2">
        <button type="submit" class="w-full h-9 bg-blue-500 hover:bg-blue-700 text-white text-[11.5px] font-bold tracking-wide uppercase rounded-xl transition-all active:scale-[0.99] shadow-3xs cursor-pointer flex items-center justify-center gap-1.5">
          TERAPKAN FILTER
        </button>
      </div>
    </form>
    
  </div>
</div>

<%- include('./partials/attendance-modal.ejs') %>

<script>
  const fModal = document.getElementById("filterModal");
  
  function openFilterModal() {
    fModal.classList.remove("hidden");
    fModal.classList.add("flex");
  }
  
  function closeFilterModal() {
    fModal.classList.add("hidden");
    fModal.classList.remove("flex");
  }

  fModal.addEventListener("click", (e) => {
    if (e.target === fModal) closeFilterModal();
  });
</script>
<%- layout('layouts/main', { title: title }) %>

<div class="max-w-xl mx-auto py-4 md:py-8">
  <div class="bg-white rounded-2xl border border-slate-200/60 overflow-hidden transform transition-all duration-200">
    
    <div class="p-5 space-y-4 border-b border-slate-100">
      <div class="flex items-center gap-2.5 text-amber-600">
        <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center text-xs">
          <i class="fa-solid fa-pen-to-square"></i>
        </div>
        <h3 class="text-sm font-semibold text-slate-800">Form Edit Indikator KPI</h3>
      </div>
      <p class="text-xs text-slate-500 leading-relaxed">
        Perbarui rincian data sasaran kerja, bobot, maupun target capaian indikator penilaian di bawah.
      </p>
    </div>

    <div class="p-6">
      <form action="/master/kpi-template/<%= templateId %>/details/<%= detail._id %>?_method=PUT" method="POST" class="space-y-4">
        
        <div>
          <label for="areaKinerja" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Area Kinerja</label>
          <input type="text" id="areaKinerja" name="areaKinerja" value="<%= detail.areaKinerja %>" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" required>
        </div>

        <div>
          <label for="indikator" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Indikator KPI</label>
          <textarea id="indikator" name="indikator" rows="3" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" required><%= detail.indikator %></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="bobot" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Bobot (%)</label>
            <input type="number" id="bobot" name="bobot" min="1" max="100" value="<%= detail.bobot %>" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" required>
          </div>
          <div>
            <label for="target" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Target</label>
            <input type="text" id="target" name="target" value="<%= detail.target %>" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700" required>
          </div>
        </div>

        <div>
          <label for="order" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Urutan Tampilan (Order)</label>
          <input type="number" id="order" name="order" value="<%= detail.order || 1 %>" min="1" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700">
        </div>

        <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
          <a href="/master/kpi-template/<%= templateId %>/details" class="inline-flex items-center justify-center h-8.5 px-3.5 border border-slate-200 text-slate-600 text-xs font-semibold rounded-xl hover:bg-slate-50 transition-colors">
            Batal
          </a>
          <button type="submit" class="inline-flex items-center justify-center h-8.5 px-4 bg-amber-500 hover:bg-amber-600 text-white text-xs font-semibold rounded-xl transition-all cursor-pointer">
            Perbarui Indikator
          </button>
        </div>

      </form>
    </div>
  </div>
</div>
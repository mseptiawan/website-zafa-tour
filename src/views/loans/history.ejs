<%- layout('layouts/main', { title }) %>

<% 
  const activeLoans = loans.filter(l => l.status === 'PENDING' || l.status === 'APPROVED');
  const historyLoans = loans.filter(l => l.status === 'REJECTED' || l.status === 'CANCELLED');

  const getStatusConfig = (status) => {
    switch(status) {
      case 'PENDING':
        return { label: 'Pending', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500' };
      case 'APPROVED':
        return { label: 'Approved', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500 animate-pulse' };
      case 'REJECTED':
        return { label: 'Rejected', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' };
      case 'CANCELLED':
        return { label: 'Cancelled', badge: 'bg-slate-50 text-slate-500 border-slate-200', dot: 'bg-slate-400' };
      default:
        return { label: status, badge: 'bg-slate-50 text-slate-600 border-slate-200/50', dot: 'bg-slate-500' };
    }
  };
%>

<div >
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

   <div class=" border border-slate-200/60 md:border-none md:shadow-none">
      <%- include('../partials/page-header', {
        section: 'Area Kerja',
        module: 'Finance',
        title: 'Riwayat Pinjaman',
        description: 'Pantau status pengajuan, limit, serta sisa cicilan pinjaman internal Anda.'
      }) %>
    </div>

    <div class="w-full">
   <%- include('../partials/_stats-grid', {
        gridClass: 'grid-cols-2 lg:grid-cols-4', 
        items: [
          { 
            label: 'Limit Pinjaman', 
            value: 'Rp ' + summary.maxLoan.toLocaleString('id-ID'), 
            unit: '', 
            icon: 'fa-solid fa-chart-pie', 
            labelClass: '!text-[11px] !font-medium text-slate-400 uppercase tracking-wider', 
            valueClass: '!text-base !font-semibold text-slate-800 tracking-tight', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          },
          { 
            label: 'Pinjaman Aktif', 
            value: 'Rp ' + summary.activeLoan.toLocaleString('id-ID'), 
            unit: '', 
            icon: 'fa-solid fa-hand-holding-dollar', 
            labelClass: '!text-[11px] !font-medium text-slate-400 uppercase tracking-wider', 
            valueClass: '!text-base !font-semibold text-slate-800 tracking-tight', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          },
          { 
            label: 'Cicilan Bulan Ini', 
            value: 'Rp ' + summary.installmentThisMonth.toLocaleString('id-ID'), 
            unit: '', 
            icon: 'fa-solid fa-calendar-minus', 
            labelClass: '!text-[11px] !font-medium text-amber-600 uppercase tracking-wider', 
            valueClass: '!text-base !font-semibold text-amber-700 tracking-tight', 
            iconBoxClass: 'bg-amber-50 text-amber-500 border border-amber-200/50' 
          },
          { 
            label: 'Sisa Hutang Pokok', 
            value: 'Rp ' + summary.remainingDebt.toLocaleString('id-ID'), 
            unit: '', 
            icon: 'fa-solid fa-wallet', 
            labelClass: '!text-[11px] !font-medium text-slate-500 uppercase tracking-wider', 
            valueClass: '!text-base !font-semibold text-slate-900 tracking-tight', 
            iconBoxClass: 'bg-slate-100 text-slate-500 border border-slate-200/50' 
          }
        ]
      }) %>
    </div>
    <div class="flex flex-col gap-3.5 w-full bg-white md:bg-transparent border border-slate-200/50 md:border-none p-4 md:p-0 rounded-2xl md:rounded-none  md:shadow-none select-none">
      <div class="flex items-center justify-between gap-3 w-full md:hidden">
        <h3 class="text-[14px] font-medium text-slate-800 tracking-tight">Daftar Berkas</h3>
        <a href="/loans/new" class="inline-flex items-center justify-center gap-1.5 h-8.5 px-4 bg-blue-600 text-white text-[11px] font-medium rounded-full  transition-all active:scale-95 outline-none cursor-pointer">
          <i class="fa-solid fa-plus text-[9px]"></i>
          <span>Ajukan</span>
        </a>
      </div>

    <%- include('../partials/_tab-nav', {
  tabs: [
    { 
      id: 'active', 
      label: `Pinjaman Berjalan (${activeLoans.length})`,
      isActive: true 
    },
    { 
      id: 'history', 
      label: `Riwayat Selesai (${historyLoans.length})`,
      isActive: false 
    }
  ]
}) %>
    </div>

    <div id="tab-content-active" class="tab-pane space-y-4 block opacity-100 transition-all duration-300 transform translate-y-0">
      
      <div class="hidden md:block bg-white rounded-2xl  overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Tgl Pengajuan</th>
                <th class="py-4 px-6">Jumlah Pinjaman</th>
                <th class="py-4 px-6 text-center">Tenor</th>
                <th class="py-4 px-6 text-right">Cicilan / Bulan</th>
                <th class="py-4 px-6 text-center">Status</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (activeLoans.length === 0) { %>
                <tr>
                  <td colspan="6" class="py-12 text-center text-slate-400 font-medium">Belum ada riwayat pengajuan berjalan.</td>
                </tr>
              <% } else { %>
                <% activeLoans.forEach(loan => { %>
                  <% const config = getStatusConfig(loan.status); %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6 font-medium text-slate-800">
                      <%= new Date(loan.createdAt).toLocaleDateString('id-ID', {day: '2-digit', month: 'long', year: 'numeric'}) %>
                    </td>
                    <td class="py-4 px-6 font-medium text-slate-700 tabular-nums">Rp <%= loan.amountRequested.toLocaleString('id-ID') %></td>
                    <td class="py-4 px-6 text-center"><%= loan.tenorMonths %> Bulan</td>
                    <td class="py-4 px-6 text-right tabular-nums font-medium text-slate-900">
                      Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %><span class="text-[10px] font-medium text-slate-400">/bln</span>
                    </td>
                    <td class="py-4 px-6 text-center select-none">
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                        <span><%= config.label.toUpperCase() %></span>
                      </div>
                    </td>
                    <td class="py-4 px-6">
                      <div class="flex items-center justify-center gap-2">
                        <a href="/loans/detail/<%= loan._id %>" title="Lihat Detail & Cicilan" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                          <i class="fa-solid fa-eye text-[11px]"></i>
                        </a>
                        <% if (loan.status === 'PENDING') { %>
                          <a href="/loans/edit/<%= loan._id %>" title="Edit Pengajuan" class="w-8 h-8 rounded-lg bg-amber-400 text-white inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-amber-500">
                            <i class="fa-solid fa-pen-to-square text-[11px]"></i>
                          </a>
                          <form id="form-cancel-active-<%= loan._id %>" action="/loans/cancel/<%= loan._id %>" method="POST" class="inline m-0">
                            <button type="button" onclick="openConfirmModal({
                              title: 'Tarik Pengajuan?',
                              message: 'Apakah kamu yakin ingin membatalkan permohonan pinjaman ini?',
                              confirmText: 'Ya, Tarik',
                              confirmClass: 'bg-rose-600 hover:bg-rose-700',
                              onConfirm: () => { document.getElementById('form-cancel-active-<%= loan._id %>').submit(); }
                            })" class="w-8 h-8 rounded-lg border border-rose-200 bg-rose-50/40 text-rose-600 inline-flex items-center justify-center transition-all active:scale-[0.95] hover:bg-rose-50 cursor-pointer" title="Batalkan">
                              <i class="fa-solid fa-trash-can text-[11px]"></i>
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-3.5 w-full">
        <% if (activeLoans.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4 ">
            <p class="text-[12px] font-medium text-slate-400">Tidak ada pinjaman berjalan</p>
          </div>
        <% } else { %>
          <% activeLoans.forEach(loan => { %>
            <% const config = getStatusConfig(loan.status); %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4  space-y-3.5">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight">Pinjaman</h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    <%= new Date(loan.createdAt).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                  </p>
                </div>
                <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
                  <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label %></span>
                </div>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
                <div>
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Total Pokok</p>
                  <p class="text-[13px] font-semibold text-slate-800 tabular-nums mt-0.5">Rp <%= loan.amountRequested.toLocaleString('id-ID') %></p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Potong / Bulan</p>
                  <p class="text-[13px] font-semibold text-blue-600 tabular-nums mt-0.5">Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %></p>
                </div>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-500"><i class="fa-solid fa-clock text-slate-400 mr-1"></i>Tenor <%= loan.tenorMonths %> Bulan</span>
                <div class="flex items-center gap-1.5">
                  <% if (loan.status === 'PENDING') { %>
                    <a href="/loans/edit/<%= loan._id %>" class="h-8 w-8 rounded-lg bg-amber-400 text-white flex items-center justify-center text-xs active:scale-95"><i class="fa-solid fa-marker"></i></a>
                  <% } %>
                  <a href="/loans/detail/<%= loan._id %>" class="h-8 px-3.5 bg-blue-50 text-blue-600 text-[11px] font-medium rounded-lg flex items-center justify-center tracking-wide active:scale-95">
                    DETAIL
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane space-y-4 hidden opacity-0 transition-all duration-300 transform translate-y-2">
      
      <div class="hidden md:block bg-white rounded-2xl  overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Tgl Pengajuan</th>
                <th class="py-4 px-6">Jumlah Pinjaman</th>
                <th class="py-4 px-6 text-center">Tenor</th>
                <th class="py-4 px-6 text-right">Cicilan / Bulan</th>
                <th class="py-4 px-6 text-center">Status</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (historyLoans.length === 0) { %>
                <tr>
                  <td colspan="6" class="py-12 text-center text-slate-400 font-medium">Belum ada dokumen riwayat selesai.</td>
                </tr>
              <% } else { %>
                <% historyLoans.forEach(loan => { %>
                  <% const config = getStatusConfig(loan.status); %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6 font-medium text-slate-800">
                      <%= new Date(loan.createdAt).toLocaleDateString('id-ID', {day: '2-digit', month: 'long', year: 'numeric'}) %>
                    </td>
                    <td class="py-4 px-6 font-medium text-slate-700 tabular-nums">Rp <%= loan.amountRequested.toLocaleString('id-ID') %></td>
                    <td class="py-4 px-6 text-center"><%= loan.tenorMonths %> Bulan</td>
                    <td class="py-4 px-6 text-right tabular-nums font-medium text-slate-900">
                      Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %><span class="text-[10px] font-medium text-slate-400">/bln</span>
                    </td>
                    <td class="py-4 px-6 text-center select-none">
                      <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                        <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                        <span><%= config.label.toUpperCase() %></span>
                      </div>
                    </td>
                    <td class="py-4 px-6 text-center">
                      <a href="/loans/detail/<%= loan._id %>" title="Lihat Berkas" class="w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 inline-flex items-center justify-center transition-all active:scale-[0.95]">
                        <i class="fa-solid fa-eye text-[11px]"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-3.5 w-full">
        <% if (historyLoans.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4 ">
            <p class="text-[12px] font-medium text-slate-400">Belum ada arsip riwayat selesai</p>
          </div>
        <% } else { %>
          <% historyLoans.forEach(loan => { %>
            <% const config = getStatusConfig(loan.status); %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4  space-y-3.5">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight">Pinjaman Karyawan</h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    <%= new Date(loan.createdAt).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                  </p>
                </div>
                <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
                  <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label %></span>
                </div>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
                <div>
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Total Pokok</p>
                  <p class="text-[13px] font-semibold text-slate-800 tabular-nums mt-0.5">Rp <%= loan.amountRequested.toLocaleString('id-ID') %></p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Potong / Bulan</p>
                  <p class="text-[13px] font-semibold text-slate-700 tabular-nums mt-0.5">Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %></p>
                </div>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-400"><i class="fa-solid fa-box-archive mr-1"></i>Arsip Selesai</span>
                <a href="/loans/detail/<%= loan._id %>" class="h-8 px-3.5 bg-slate-100 text-slate-700 text-[11px] font-medium border border-slate-200 rounded-lg flex items-center justify-center tracking-wide active:scale-95">
                  LIHAT
                </a>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

  </div>
</div>

<script>
  function switchTab(tabName) {
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.add('hidden');
      pane.classList.remove('block', 'opacity-100', 'translate-y-0');
    });

    const activeContent = document.getElementById(`tab-content-${tabName}`);
    if (activeContent) {
      activeContent.classList.remove('hidden');
      activeContent.classList.add('block');
      setTimeout(() => {
        activeContent.classList.add('opacity-100', 'translate-y-0');
      }, 10);
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
      btn.classList.add('font-medium', 'text-slate-500');
    });

    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    if (activeBtn) {
      activeBtn.classList.remove('font-medium', 'text-slate-500');
      activeBtn.classList.add('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
    }
  }
</script>
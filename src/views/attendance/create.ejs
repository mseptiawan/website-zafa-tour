<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">

  <div class="max-w-3xl mx-auto">

    <!-- HEADER -->
    <div class="mb-8 text-center">
      <h1 class="text-xl font-semibold text-slate-800">
        Absensi Kamera
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Pastikan wajah terlihat jelas sebelum melakukan absen
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-6">

      <% if (already) { %>

        <!-- ALREADY CHECKED -->
        <div class="text-center space-y-4 py-6">

          <div class="w-14 h-14 mx-auto flex items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
            ✔
          </div>

          <div>
            <h2 class="text-base font-medium text-slate-800">
              Sudah Absen Hari Ini
            </h2>
            <p class="text-sm text-slate-500 mt-1">
              Data kehadiran sudah tersimpan
            </p>
          </div>

              <% if (already && !hasCheckedOut) { %>

  <form action="/attendance/checkout" method="POST" class="inline-block">
    <button
      class="px-5 py-2 bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium rounded-lg transition"
    >
      Pulang
    </button>
  </form>

<% } else if (hasCheckedOut) { %>

  <p class="text-sm text-slate-500 font-medium">
    ✔ Sudah pulang hari ini
  </p>

<% } %>

        </div>

      <% } else { %>

        <!-- CAMERA -->
        <div class="space-y-4">

          <div class="relative overflow-hidden rounded-xl border border-slate-200 bg-black aspect-video">
            <video id="video" autoplay class="w-full h-full object-cover"></video>
            <canvas id="canvas" class="hidden"></canvas>
          </div>

          <!-- FORM -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <!-- TYPE -->
            <div>
              <label class="text-xs text-slate-500">Kategori</label>
              <select name="type"
                class="mt-1 w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-200">
                <option value="KANTOR">Kantor</option>
                <option value="DINAS_LUAR">Dinas Luar</option>
              </select>
            </div>

            <!-- NOTE -->
            <div>
              <label class="text-xs text-slate-500">Catatan</label>
              <input type="text" name="note"
                class="mt-1 w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-200"
                placeholder="Opsional..." />
            </div>

          </div>

          <!-- BUTTON -->
          <button
            onclick="takePhoto()"
            type="button"
            class="w-full bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium py-3 rounded-lg transition"
          >
            Ambil Foto & Absen
          </button>

        </div>

      <% } %>

    </div>

    <!-- FOOTER -->
    <p class="text-center text-xs text-slate-400 mt-6">
      Sistem otomatis mencatat waktu dan lokasi absensi
    </p>

  </div>
</div>
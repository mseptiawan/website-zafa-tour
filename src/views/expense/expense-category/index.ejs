<%- layout('layouts/main', { title }) %>

<div id="categories-data" data-json="<%= JSON.stringify(categories || []) %>" class="hidden"></div>

<div class="min-h-screen ml-0 md:ml-72 bg-slate-50/50 py-5 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto mt-4 md:mt-0 space-y-6">

    <%- include('../../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Finance', 
        title: 'Master Kategori Pengeluaran', 
        description: 'Kelola master data kategori klaim beban/reimbursement pegawai secara terpusat.' 
    }) %>

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white p-4 rounded-2xl border border-slate-200/60 md:border-slate-200/80">
      <div>
        <p class="text-[11px] font-bold text-slate-400 uppercase tracking-wider select-none">Total Kategori Aktif</p>
        <h3 class="text-xl font-bold text-slate-800 mt-1 block tabular-nums" id="total-kategori">0</h3>
      </div>
      <div class="flex items-center gap-2">
        <button id="btn-add-category" class="flex items-center gap-2 bg-blue-500 hover:bg-blue-600 text-white text-[12px] font-semibold px-5 py-2.5 rounded-xl transition-all active:scale-98 cursor-pointer">
          <i class="fa-solid fa-plus text-[10px]"></i>
          <span>Tambah Kategori</span>
        </button>
      </div>
    </div>

    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[800px]">
          <thead class="bg-slate-50/70 text-slate-500 text-[11px] uppercase tracking-wider border-b border-slate-100">
            <tr>
              <th class="text-left px-6 py-4 font-bold">Nama Kategori</th>
              <th class="text-left px-6 py-4 font-bold">Keterangan / Deskripsi</th>
              <th class="text-left px-6 py-4 font-bold">Status</th>
              <th class="text-right px-6 py-4 font-bold">Aksi</th>
            </tr>
          </thead>
          <tbody id="category-table-body" class="divide-y divide-slate-100 text-[13px]">
            </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<div id="category-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-xs hidden items-center justify-center p-4 z-[110] transition-all">
  <div class="bg-white rounded-2xl w-full max-w-md overflow-hidden border border-slate-200/60 shadow-lg transform transition-all">
    <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
      <h3 id="modal-title" class="text-[13px] font-bold text-slate-800 uppercase tracking-wide">Tambah Kategori Pengeluaran</h3>
      <button id="btn-close-modal-x" class="text-slate-400 hover:text-slate-600 p-1 text-sm cursor-pointer">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <form id="category-form">
      <input type="hidden" id="form-id">
      <div class="p-5 space-y-4">
        <div class="space-y-2">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Nama Kategori</label>
          <input type="text" id="form-name" required placeholder="Contoh: Operasional & ATK" class="w-full bg-slate-50/60 border border-slate-200/70 focus:border-slate-400 rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 focus:bg-white focus:ring-0 outline-none transition-all text-slate-800" />
        </div>
        <div class="space-y-2">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Deskripsi / Catatan</label>
          <textarea id="form-description" rows="4" placeholder="Deskripsi singkat cakupan biaya kategori ini..." class="w-full bg-slate-50/60 border border-slate-200/70 focus:border-slate-400 rounded-xl px-4 py-2.5 text-[13px] placeholder:text-[11.5px] placeholder:text-slate-400/60 focus:bg-white focus:ring-0 outline-none resize-none transition-all text-slate-800 leading-relaxed"></textarea>
        </div>
      </div>
      <div class="px-5 py-3.5 bg-slate-50 border-t border-slate-100 flex justify-end gap-2.5">
        <button type="button" id="btn-close-modal-cancel" class="border border-slate-200 text-slate-600 px-4 py-2 rounded-xl text-[12px] font-semibold hover:bg-slate-50 transition-colors cursor-pointer">Batal</button>
        <button type="submit" class="bg-blue-500 text-white px-5 py-2 rounded-xl text-[12px] font-semibold transition-colors hover:bg-blue-600 cursor-pointer">Simpan</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/expense-category.js" defer></script>
<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xs">
  <div class="overflow-x-auto">
    <table class="w-full min-w-[1000px] text-sm text-left border-collapse">
      <thead class="border-b border-slate-100 bg-slate-50 text-[11px] tracking-wider text-slate-400 uppercase font-bold">
        <tr>
          <% if (type === 'active') { %>
          <th class="px-6 py-4.5">Tgl Pengajuan</th>
          <th class="px-6 py-4.5">Nama Pegawai</th>
          <th class="px-6 py-4.5 text-right">Volume Pinjaman</th>
          <th class="px-6 py-4.5 text-center">Tenor</th>
          <th class="px-6 py-4.5 text-right">Amortisasi / Bln</th>
          <th class="px-6 py-4.5 text-right pr-8">Aksi</th>
          <% } else { %>
          <th class="px-6 py-4.5">Nama Pegawai</th>
          <th class="px-6 py-4.5 text-right">Total Dana</th>
          <th class="px-6 py-4.5 text-center">Status Mitigasi</th>
          <th class="px-6 py-4.5">Otorisasi Catatan</th>
          <th class="px-6 py-4.5 text-right pr-8">Aksi</th>
          <% } %>
        </tr>
      </thead>

      <tbody class="divide-y divide-slate-100 text-[13px]">
        <% if (loans.length === 0) { %>
        <tr>
          <td colspan="<%= type === 'active' ? 6 : 5 %>" class="py-16 text-center text-slate-400 font-medium">
            <div class="flex flex-col items-center justify-center space-y-2">
              <i class="fa-solid fa-inbox text-xl text-slate-300"></i>
              <span>Belum ada data aplikasi pinjaman terdaftar</span>
            </div>
          </td>
        </tr>
        <% } else { %>
        <% loans.forEach(loan => { %>
        <tr class="transition-colors hover:bg-slate-50/60 group">
          <% if (type === 'active') { %>
          <td class="px-6 py-4.5 font-medium whitespace-nowrap text-slate-500 tabular-nums">
            <%= new Date(loan.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
          </td>

          <td class="px-6 py-4.5 font-semibold text-slate-800">
            <%= loan.employeeId?.fullName || "Pegawai" %>
          </td>

          <td class="px-6 py-4.5 text-right font-bold text-slate-900 tabular-nums">
            Rp <%= loan.amountRequested.toLocaleString('id-ID') %>
          </td>

          <td class="px-6 py-4.5 text-center">
            <span class="inline-flex items-center justify-center px-2.5 py-1 rounded-md bg-slate-100 text-slate-700 font-semibold text-xs tabular-nums">
              <%= loan.tenorMonths %> Bulan
            </span>
          </td>

          <td class="px-6 py-4.5 text-right font-bold text-blue-600 tabular-nums">
            Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %>
            <span class="text-[10px] font-medium text-slate-400 block mt-0.5">Auto-debet</span>
          </td>

          <td class="px-6 py-4.5 pr-8">
            <div class="flex items-center justify-end">
              <a href="/loans/detail/<%= loan._id %>" title="Periksa Berkas" class="inline-flex h-8 px-3.5 items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white text-xs font-semibold text-slate-600 shadow-2xs transition-all group-hover:border-blue-500 group-hover:text-blue-600 active:scale-[0.97]">
                <span>Tinjau</span>
                <i class="fa-solid fa-chevron-right text-[10px]"></i>
              </a>
            </div>
          </td>
          <% } else { %>
          <td class="px-6 py-4.5 font-semibold text-slate-800">
            <%= loan.employeeId?.fullName || "Pegawai" %>
          </td>

          <td class="px-6 py-4.5 text-right font-bold text-slate-900 tabular-nums">
            Rp <%= loan.amountRequested.toLocaleString('id-ID') %>
          </td>

          <td class="px-6 py-4.5 align-middle whitespace-nowrap text-center">
            <% 
              const textStyles = { 'APPROVED': 'text-emerald-700 border-emerald-200/60 bg-emerald-50/50', 'REJECTED': 'text-rose-700 border-rose-200/60 bg-rose-50/50', 'PENDING': 'text-amber-700 border-amber-200/60 bg-amber-50/50', 'CANCELLED': 'text-slate-500 border-slate-200 bg-slate-50' }; 
              const dotStyles = { 'APPROVED': 'bg-emerald-500', 'REJECTED': 'bg-rose-500', 'PENDING': 'bg-amber-500', 'CANCELLED': 'bg-slate-400' }; 
              const statusLabels = { 'APPROVED': 'Approved', 'REJECTED': 'Rejected', 'PENDING': 'Pending', 'CANCELLED': 'Cancelled' }; 
            %>
            <div class="<%= textStyles[loan.approvalStatus] || 'text-slate-500' %> inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[10px] font-bold tracking-wide shadow-2xs">
              <span class="<%= dotStyles[loan.approvalStatus] || 'bg-slate-400' %> <%= loan.approvalStatus === 'APPROVED' ? 'animate-pulse' : '' %> h-1.5 w-1.5 rounded-full"></span>
              <span><%= statusLabels[loan.approvalStatus] || loan.approvalStatus %></span>
            </div>
          </td>

          <td class="px-6 py-4.5 text-slate-500 max-w-xs truncate font-medium">
            <%= loan.note || '-' %>
          </td>

          <td class="px-6 py-4.5 pr-8">
            <div class="flex items-center justify-end">
              <a href="/loans/detail/<%= loan._id %>" title="Lihat Riwayat" class="inline-flex h-8 px-3.5 items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white text-xs font-semibold text-slate-600 shadow-2xs transition-all hover:bg-slate-50 active:scale-[0.97]">
                <span>Detail</span>
              </a>
            </div>
          </td>
          <% } %>
        </tr>
        <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
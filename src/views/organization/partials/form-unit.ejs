<div id="form-panel-unit" class="hidden space-y-4">
  <div>
    <h3 class="mb-1 text-[13px] font-bold">Tambah Sub-Unit Kerja</h3>
    <p class="text-[11px] text-slate-400">
      Membuat sub-bagian yang menginduk pada bidang tertentu.
    </p>
  </div>
  <form onsubmit="handleCreateUnit(event)" class="space-y-3">
    <div class="relative">
      <select
        id="input-unit-bidangId"
        required
        class="w-full cursor-pointer appearance-none rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-2.5 text-[12.5px] font-medium text-slate-700 transition outline-none focus:border-slate-400 focus:bg-white"
      ></select>
      <div
        class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3.5 text-slate-400"
      >
        <svg class="h-4 w-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </div>
    </div>
    <input
      type="text"
      id="input-unit-name"
      placeholder="Contoh: Mobile Dev, Front Office..."
      required
      class="w-full rounded-xl border border-slate-200/60 bg-slate-50 px-3.5 py-2.5 text-[12.5px] font-medium transition outline-none focus:border-slate-400 focus:bg-white"
    />
    <textarea
      id="input-unit-desc"
      rows="2"
      placeholder="Deskripsi singkat tugas unit kerja..."
      class="w-full resize-none rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-2 text-[12.5px] font-medium transition outline-none focus:border-slate-400 focus:bg-white"
    ></textarea>
    <button
      type="submit"
      class="w-full cursor-pointer rounded-xl bg-blue-600 py-2.5 text-[12.5px] font-medium text-white shadow-xs transition hover:bg-blue-700"
    >
      Simpan
    </button>
  </form>
</div>

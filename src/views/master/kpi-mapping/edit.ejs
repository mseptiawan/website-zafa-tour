<%- layout('layouts/main', { title }) %>

<div class="max-w-xl mx-auto py-4 md:py-8">
  <div class="bg-white rounded-2xl border border-slate-200/60 overflow-hidden transform transition-all duration-200">
    
    <div class="p-5 space-y-4 border-b border-slate-100">
      <div class="flex items-center gap-2.5 text-amber-600">
        <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center text-xs">
          <i class="fa-solid fa-sliders"></i>
        </div>
        <h3 class="text-sm font-semibold text-slate-800">Ubah Konfigurasi Mapping KPI</h3>
      </div>
      <p class="text-xs text-slate-500 leading-relaxed">
        Sesuaikan kembali kecocokan integrasi template kriteria indikator dengan penempatan kluster ruang lingkap penugasan baru.
      </p>
    </div>

    <div class="p-6">
      <form action="/master/kpi-mapping/<%= mapping._id %>?_method=PUT" method="POST" class="space-y-4">
        
        <div>
          <label for="templateId" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Pilih Master Template KPI</label>
         <!-- Bagian dropdown template kpi di edit.ejs -->
<select id="templateId" name="templateId" class="...">
  <% templates.forEach(template => { %>
    <option value="<%= template._id %>" <%= mapping.kpiTemplateId && mapping.kpiTemplateId._id.toString() === template._id.toString() ? 'selected' : '' %>>
      <%= template.name %>
    </option>
  <% }) %>
</select>
        </div>

        <div>
          <label for="unitId" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Unit Kerja / Divisi</label>
          <select id="unitId" name="unitId" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700 bg-white cursor-pointer" required>
            <% units.forEach(unit => { %>
              <option value="<%= unit._id %>" <%= mapping.unitId && mapping.unitId._id.toString() === unit._id.toString() ? 'selected' : '' %>><%= unit.name %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label for="positionId" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Posisi / Jabatan Struktural (Opsional)</label>
          <select id="positionId" name="positionId" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700 bg-white cursor-pointer">
            <option value="">Semua Posisi / Struktur Unit Kerja</option>
            <% positions.forEach(position => { %>
              <option value="<%= position._id %>" <%= mapping.positionId && mapping.positionId._id.toString() === position._id.toString() ? 'selected' : '' %>><%= position.name %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label for="isActive" class="block text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Status Aktivasi Pemetaan</label>
          <select id="isActive" name="isActive" class="w-full text-xs font-medium bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-slate-700 bg-white cursor-pointer">
            <option value="true" <%= mapping.isActive ? 'selected' : '' %>>Aktif (Otomatis Terapkan)</option>
            <option value="false" <%= !mapping.isActive ? 'selected' : '' %>>Non-Aktif (Tangguhkan Sementara)</option>
          </select>
        </div>

        <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
          <a href="/master/kpi-mapping" class="inline-flex items-center justify-center h-8.5 px-3.5 border border-slate-200 text-slate-600 text-xs font-semibold rounded-xl hover:bg-slate-50 transition-colors">
            Kembali
          </a>
          <button type="submit" class="inline-flex items-center justify-center h-8.5 px-4 bg-amber-500 hover:bg-amber-600 text-white text-xs font-semibold rounded-xl transition-all cursor-pointer">
            Perbarui Pemetaan
          </button>
        </div>

      </form>
    </div>
  </div>
</div>
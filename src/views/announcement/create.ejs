<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-3xl mx-auto">

    <div class="mb-6">
      <h1 class="text-[24px] font-medium text-slate-800">
        Buat Pengumuman
      </h1>

      <p class="text-[13px] text-slate-500 mt-1">
        Publikasikan informasi internal perusahaan
      </p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6">

      <form
  method="POST"
  action="/announcement/"
  enctype="multipart/form-data"
  class="space-y-5"
>

        <!-- TITLE -->
        <div>
          <label class="text-[12px] text-slate-600">Judul</label>
          <input
            type="text"
            name="title"
            required
            class="w-full border rounded-lg px-3 py-2 text-[13px]"
          />
        </div>

        <!-- CONTENT -->
        <div>
          <label class="text-[12px] text-slate-600">Isi</label>
          <textarea
            name="content"
            rows="5"
            required
            class="w-full border rounded-lg px-3 py-2 text-[13px]"
          ></textarea>
        </div>

        <!-- CATEGORY -->
        <div>
          <label class="text-[12px] text-slate-600">Kategori</label>

          <select
            name="category"
            class="w-full border rounded-lg px-3 py-2 text-[13px]"
          >
            <option value="LIGHT">Pengumuman Ringan</option>

            <% if (user.role === "PIMPINAN") { %>
              <option value="OFFICIAL">Pengumuman Resmi</option>
            <% } %>
          </select>
        </div>

        <!-- FILE (OPTIONAL) -->
        <div>
          <label class="text-[12px] text-slate-600">
            File Pengumuman
            <span class="text-slate-400">(opsional)</span>
          </label>

          <input
            type="file"
            name="attachment"
            class="w-full text-[12px] border rounded-lg px-3 py-2"
          />

          <p class="text-[10px] text-slate-400 mt-1">
            Bisa diisi atau dikosongkan
          </p>
        </div>

        <!-- BUTTON -->
        <button
          class="bg-slate-900 hover:bg-slate-800 text-white px-5 py-2 rounded-lg text-[13px]"
        >
          Simpan
        </button>

      </form>

    </div>

  </div>
</div>
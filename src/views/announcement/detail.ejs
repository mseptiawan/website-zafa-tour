<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-4xl mx-auto">

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">

      <!-- HEADER -->
      <div class="border-b border-slate-100 px-6 py-5">

        <div class="flex items-start justify-between gap-4">

          <div>
            <h1 class="text-2xl text-slate-800 tracking-tight leading-snug">
              <%= announcement.title %>
            </h1>

            <div class="flex items-center gap-2 mt-3">

              <% if(announcement.category === "OFFICIAL") { %>

                <span
                  class="bg-rose-50 text-rose-600 border border-rose-200 px-3 py-1 rounded-full text-[11px]"
                >
                  Pengumuman Resmi
                </span>

              <% } else { %>

                <span
                  class="bg-slate-100 text-slate-600 border border-slate-200 px-3 py-1 rounded-full text-[11px]"
                >
                  Pengumuman Ringan
                </span>

              <% } %>

              <% if(announcement.isPinned) { %>

                <span
                  class="bg-amber-50 text-amber-600 border border-amber-200 px-3 py-1 rounded-full text-[11px]"
                >
                  Disematkan
                </span>

              <% } %>

            </div>

            <div class="flex items-center gap-3 mt-4 text-[12px] text-slate-500">

  <!-- CREATED BY -->
  <span>
    Dibuat oleh
    <span class="text-slate-700 font-medium">
      <%= announcement.createdBy?.username || 'Unknown' %>
    </span>
  </span>

  <!-- DOT -->
  <span>•</span>

  <!-- DATE -->
  <span>
    <%= new Date(announcement.createdAt).toLocaleDateString("id-ID", {
      day: "2-digit",
      month: "long",
      year: "numeric"
    }) %>
  </span>

</div>
          </div>

        </div>
      </div>

      <!-- CONTENT -->
      <div class="px-6 py-6">

        <div
          class="text-[15px] text-slate-700 leading-8 whitespace-pre-line"
        >
          <%= announcement.content %>
        </div>

        <!-- ATTACHMENT -->
        <% if(announcement.attachment) { %>

          <div class="mt-8">

            <div
              class="border border-slate-200 rounded-xl p-4 flex items-center justify-between bg-slate-50"
            >

              <div>
                <p class="text-sm text-slate-700">
                  Surat / SK Lampiran
                </p>

                <p class="text-xs text-slate-400 mt-1">
                  Dokumen resmi pengumuman perusahaan
                </p>
              </div>

              <a
                href="/uploads/<%= announcement.attachment %>"
                target="_blank"
                class="bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 rounded-lg text-sm transition"
              >
                Lihat File
              </a>

            </div>

          </div>

        <% } %>

        <!-- PUBLISH -->
        <% if(
          announcement.category === "OFFICIAL"
          && announcement.status === "DRAFT"
        ) { %>

          <div class="mt-8 pt-6 border-t border-slate-100">

            <form
              method="POST"
              action="/announcement/<%= announcement._id %>/publish"
            >

              <button
                class="bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-lg text-sm transition"
              >
                Publish Pengumuman
              </button>

            </form>

          </div>

        <% } %>

      </div>

    </div>

  </div>

</div>
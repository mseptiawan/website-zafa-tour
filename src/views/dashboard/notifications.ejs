<%- layout('layouts/main') -%>

<div
  class="container-fluid py-6 pl-4 pr-6 ml-72 min-h-screen text-slate-700 bg-slate-50/50 selection:bg-blue-500 selection:text-white"
>
  <div
    class="max-w-2xl mx-auto bg-white rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden flex flex-col"
  >
    <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-white">
      <div>
        <h1 class="text-xl font-bold tracking-tight text-slate-900 flex items-center gap-2">
          Notifications
          <span
            class="inline-flex items-center justify-center bg-slate-950 text-white font-semibold text-[11px] px-2 py-0.5 rounded-full"
          >
            8
          </span>
        </h1>
      </div>
      <button
        class="text-xs font-semibold text-slate-900 underline hover:text-slate-600 transition-colors"
      >
        Mark all as read
      </button>
    </div>

    <div class="divide-y divide-slate-100">
      <div class="p-4 bg-slate-50/50 flex gap-3 items-start transition-colors hover:bg-slate-50">
        <div class="relative shrink-0">
          <div
            class="w-8 h-8 rounded-full bg-slate-200 overflow-hidden flex items-center justify-center text-xs font-bold text-slate-600"
          >
            AS
          </div>
          <span
            class="absolute top-0 right-0 block h-2 w-2 rounded-full ring-2 ring-white bg-emerald-500"
          ></span>
        </div>
        <div class="min-w-0 text-xs">
          <p class="text-slate-600 font-medium">
            <span class="font-semibold text-slate-900">Anna Srzand</span>
            joined to
            <span class="font-semibold text-slate-900">🔥 Final Presentation</span>
          </p>
          <p class="text-[10px] text-slate-400 font-medium mt-0.5">2h ago • Social Media Plan</p>
        </div>
      </div>

      <div class="p-4 bg-slate-50/50 flex gap-3 items-start transition-colors hover:bg-slate-50">
        <div class="relative shrink-0">
          <div
            class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center text-xs font-bold text-amber-700"
          >
            JR
          </div>
        </div>
        <div class="min-w-0 text-xs">
          <p class="text-slate-600 font-medium">
            <span class="font-semibold text-slate-900">Jess Raddon</span>
            mentioned you in
            <span class="font-semibold text-slate-900">😍 Tennis List</span>
          </p>
          <p class="text-[10px] text-slate-400 font-medium mt-0.5">4h ago • Hobby List</p>
        </div>
      </div>

      <div class="p-4 flex gap-3 items-start transition-colors hover:bg-slate-50/50">
        <div class="relative shrink-0">
          <div
            class="w-8 h-8 rounded-full bg-slate-200 overflow-hidden flex items-center justify-center text-xs font-bold text-slate-600"
          >
            SM
          </div>
          <span
            class="absolute bottom-0 right-0 block h-2 w-2 rounded-full ring-2 ring-white bg-amber-500"
          ></span>
        </div>
        <div class="min-w-0 text-xs w-full">
          <p class="text-slate-600 font-medium">
            <span class="font-semibold text-slate-900">Sandra Marx</span>
            is requesting to upgrade Plan
          </p>
          <p class="text-[10px] text-slate-400 font-medium mt-0.5 mb-2.5">12h ago • Hobby List</p>
          <div class="flex gap-2">
            <button
              class="bg-slate-950 hover:bg-slate-800 text-white font-semibold px-3 py-1.5 rounded-lg text-[11px] transition-colors shadow-sm"
            >
              Accept
            </button>
            <button
              class="bg-white hover:bg-slate-50 text-slate-700 font-semibold px-3 py-1.5 rounded-lg text-[11px] border border-slate-200 transition-colors shadow-sm"
            >
              Decline
            </button>
          </div>
        </div>
      </div>

      <div class="p-4 flex gap-3 items-start transition-colors hover:bg-slate-50/50">
        <div class="shrink-0">
          <div
            class="w-8 h-8 rounded-full bg-slate-200 overflow-hidden flex items-center justify-center text-xs font-bold text-slate-600"
          >
            AS
          </div>
        </div>
        <div class="min-w-0 text-xs w-full">
          <p class="text-slate-600 font-medium">
            <span class="font-semibold text-slate-900">Adam Smith</span>
            upload a file
          </p>
          <p class="text-[10px] text-slate-400 font-medium mt-0.5 mb-2">1d ago</p>
          <div
            class="inline-flex items-center gap-2 p-2 bg-slate-50 border border-slate-200/60 rounded-lg max-w-xs hover:bg-slate-100/70 transition-colors cursor-pointer"
          >
            <i class="fa-solid fa-file-lines text-slate-400 text-sm"></i>
            <div class="min-w-0 text-[11px]">
              <span class="font-semibold text-slate-800 truncate block">landing_page_ver2.fig</span>
              <span class="text-[10px] text-slate-400 font-medium">2mb</span>
            </div>
          </div>
        </div>
      </div>

      <div class="p-4 flex gap-3 items-start transition-colors hover:bg-slate-50/50">
        <div class="shrink-0">
          <div
            class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-bold text-indigo-700"
          >
            RT
          </div>
        </div>
        <div class="min-w-0 text-xs w-full">
          <p class="text-slate-600 font-medium">
            <span class="font-semibold text-slate-900">Ralpg Turner</span>
            edited 🥂 Celebrate Info
          </p>
          <p class="text-[10px] text-slate-400 font-medium mt-0.5 mb-2">4h ago • Hobby List</p>
          <div
            class="p-2 bg-indigo-50/30 border-l-2 border-slate-300 rounded text-slate-500 font-medium italic text-[11px]"
          >
            "Let's add it to the main
            <span class="bg-indigo-100 text-indigo-800 px-0.5 rounded font-normal not-italic">
              secret
            </span>
            documentary"
          </div>
        </div>
      </div>
    </div>

    <div class="p-4 bg-white divide-y divide-slate-100 opacity-30 pointer-events-none">
      <div class="flex gap-3 items-center py-2 animate-pulse">
        <div class="w-8 h-8 rounded-lg bg-slate-200"></div>
        <div class="flex-1 space-y-1.5">
          <div class="h-2 bg-slate-200 rounded w-1/2"></div>
          <div class="h-2 bg-slate-200 rounded w-1/4"></div>
        </div>
      </div>
    </div>
  </div>
</div>

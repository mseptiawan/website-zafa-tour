<%- layout('layouts/main', { title }) %>

<style>
  #invoice-print-zone {
    display: none;
  }

  @media print {
    html, body, body * {
      visibility: hidden !important;
      background: transparent !important;
    }
    
    #invoice-print-zone, #invoice-print-zone * {
      visibility: visible !important;
    }
    
    #invoice-print-zone {
      display: block !important;
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      border: none !important;
      box-shadow: none !important;
      color: black !important;
    }

    .yellow-header-badge {
      background-color: #facc15 !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color: black !important;
    }
  }

  .yellow-header-badge {
    background-color: #facc15;
    color: black;
  }
</style>

<div class="ml-0  min-h-screen bg-slate-50/50 p-4 md:p-8 antialiased text-slate-900 pb-24 md:pb-8">
  <div class="mx-auto w-full space-y-5">

    <div class="bg-white border border-slate-200/60 rounded-2xl p-5 shadow-[0_4px_12px_rgba(0,0,0,0.02)] no-print">
      <h1 class="text-base font-bold tracking-tight text-slate-900">Riwayat Slip Gaji</h1>
      <p class="text-[11px] text-slate-400 mt-0.5">Daftar dokumen slip pendapatan resmi Anda di PT Zafa Mulia Mandiri</p>
    </div>

    <% if (payrolls.length === 0) { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl p-12 text-center text-slate-400 font-medium no-print">
        <i class="fa-solid fa-receipt text-3xl block mb-3 text-slate-300"></i> 
        Belum ada riwayat dokumen slip gaji yang diterbitkan untuk akun Anda.
      </div>
    <% } else { %>

      <div class="no-print grid grid-cols-1 gap-4 md:block md:bg-white md:border md:border-slate-200/60 md:rounded-2xl md:p-2 md:shadow-2xs md:divide-y md:divide-slate-100">
        <% payrolls.forEach((pay, index) => { %>
          
          <div class="bg-white border border-slate-200/60 rounded-2xl p-5 shadow-[0_4px_12px_rgba(15,23,42,0.03)] md:bg-transparent md:border-none md:rounded-none md:p-4 md:shadow-none hover:bg-slate-50/50 transition-colors flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            
            <div class="flex items-start justify-between md:justify-start gap-4">
              <div class="md:hidden w-10 h-10 rounded-xl bg-slate-50 border border-slate-200 flex items-center justify-center text-slate-400 shrink-0 mt-0.5">
                <i class="fa-solid fa-file-invoice-dollar text-base"></i>
              </div>
              
              <div class="space-y-1.5 md:space-y-1 min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="text-sm md:text-xs font-bold text-slate-800 tracking-tight">Periode: <%= pay.periodMonth %></span>
                  <span class="text-[10px] font-bold px-2.5 py-0.5 rounded-full <%= pay.status === 'PAID' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100/50' : 'bg-amber-50 text-amber-600 border border-amber-100/50' %>">
                    <%= pay.status === 'PAID' ? 'Lunas' : 'Diterbitkan' %>
                  </span>
                </div>
                <div class="text-xs md:text-[11px] text-slate-400 font-normal">
                  Take Home Pay: <span class="font-bold text-slate-700">Rp <%= pay.netTakeHomePay.toLocaleString('id-ID') %></span>
                </div>
              </div>
            </div>
            
            <div class="flex items-center justify-end gap-2 border-t border-slate-100 pt-4 md:border-none md:pt-0">
              <div class="flex items-center gap-2 w-full md:w-auto justify-end">
                
                <% if (pay.status === 'PAID' && pay.mutationFile) { %>
                  <a href="<%= pay.mutationFile %>" target="_blank" class="bg-emerald-50 hover:bg-emerald-100 text-emerald-600 text-xs md:text-[11px] font-semibold h-9 md:h-8 px-4 md:px-3 rounded-xl transition-all active:scale-[0.97] inline-flex items-center justify-center gap-1.5 border border-emerald-100 flex-1 md:flex-none">
                    <i class="fa-solid fa-cloud-download text-[11px]"></i> Bukti TF
                  </a>
                <% } else if (pay.status === 'PAID') { %>
                  <span class="text-[10px] text-slate-400 italic font-normal px-2 hidden md:inline-block">Processed by Bank</span>
                <% } %>

                <button type="button" onclick="executePrintSlip(<%= index %>)" class="bg-slate-900 hover:bg-slate-800 text-white text-xs md:text-[11px] font-medium h-9 md:h-8 px-4 md:px-3.5 rounded-xl transition-all active:scale-[0.97] cursor-pointer flex items-center justify-center gap-1.5 shadow-sm flex-1 md:flex-none">
                  <i class="fa-solid fa-print text-[10px]"></i> Cetak
                </button>
              </div>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>

    <div id="invoice-print-zone" class="bg-white p-2 space-y-6 text-black"></div>

  </div>
</div>

<script>
  const payrollsList = <%- JSON.stringify(payrolls) %>;
  const employeeProfile = <%- JSON.stringify(employee) %>;

  function executePrintSlip(index) {
    const payroll = payrollsList[index];
    if (!payroll) return;

    const overtimePay = payroll.overtime?.amount || 0;

    let allowancesRowsHTML = '';
    payroll.allowances.forEach(allow => {
      allowancesRowsHTML += `
        <tr class="h-7">
          <td class="p-1.5 font-normal">${allow.componentName}</td>
          <td class="p-1.5 text-right border-l border-black font-normal">${allow.amount}</td>
        </tr>`;
    });
    if (payroll.allowances.length < 1) {
      allowancesRowsHTML += `<tr class="h-7"><td>&nbsp;</td><td class="border-l border-black"></td></tr>`;
    }

    let deductionsRowsHTML = '';
    payroll.deductions.forEach(ded => {
      deductionsRowsHTML += `
        <tr class="h-7">
          <td class="p-1.5 font-normal">${ded.componentName}</td>
          <td class="p-1.5 text-right border-l border-black font-normal">${ded.amount}</td>
        </tr>`;
    });
    if (payroll.loanDeduction && payroll.loanDeduction.amount > 0) {
      deductionsRowsHTML += `
        <tr class="h-7">
          <td class="p-1.5 font-normal">Cicilan Pinjaman</td>
          <td class="p-1.5 text-right border-l border-black font-normal">${payroll.loanDeduction.amount}</td>
        </tr>`;
    }
    const totalDedCount = payroll.deductions.length + (payroll.loanDeduction?.amount > 0 ? 1 : 0);
    for (let i = totalDedCount; i < 2; i++) {
      deductionsRowsHTML += `<tr class="h-7"><td>&nbsp;</td><td class="border-l border-black"></td></tr>`;
    }

    const joinDateRaw = employeeProfile.careerData?.tanggal_mulai_bergabung ? new Date(employeeProfile.careerData.tanggal_mulai_bergabung).toISOString().split('T')[0] : '-';

    const finalPrintTemplate = `
      <div class="flex justify-between items-start">
        <div class="border border-black px-6 py-1 mt-2">
          <span class="text-xs font-normal tracking-wide" style="color: #f43f5e;">Pribadi & Rahasia</span>
        </div>
        <div class="text-center space-y-0.5">
          <div class="inline-flex flex-col items-center justify-center">
            <span class="text-2xl font-normal tracking-tighter" style="font-family: 'Times New Roman', Times, serif;">ZM</span>
            <span class="text-[8px] font-normal tracking-widest uppercase -mt-1">ZAFA TOUR</span>
          </div>
          <div class="text-[10px] font-normal uppercase tracking-tight">Zafa Mulia Mandiri</div>
        </div>
      </div>

      <div class="pt-1">
        <h2 class="text-xs font-normal">PT Zafa Mulia Mandiri</h2>
      </div>

      <div class="space-y-0.5">
        <h3 class="text-xs font-normal">Slip Gaji</h3>
        <p class="text-xs font-normal">Periode : ${payroll.periodMonth}</p>
      </div>

      <div class="grid grid-cols-2 gap-x-12 text-xs">
        <table class="w-full border-none">
          <tr class="h-5">
            <td class="w-28 font-normal">Nama</td>
            <td class="w-3">:</td>
            <td class="font-normal">${employeeProfile.fullName}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">ID Pegawai</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.employeeIdNumber}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Bagian</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.careerData?.bidangId?.name || 'BOD'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Job Title</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.careerData?.positionId?.name || 'Staff'}</td>
          </tr>
        </table>

        <table class="w-full border-none">
          <tr class="h-5">
            <td class="w-32 font-normal">Golongan</td>
            <td class="w-3">:</td>
            <td class="font-normal">${employeeProfile.careerData?.unitId?.name || 'Marketing'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Status Pegawai</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.careerData?.status_pegawai || 'Pegawai Tetap'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Status PTKP</td>
            <td>:</td>
            <td class="font-normal">TK0</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Tanggal Bergabung</td>
            <td>:</td>
            <td class="font-normal">${joinDateRaw}</td>
          </tr>
        </table>
      </div>

      <div class="grid grid-cols-2 gap-6 items-start">
        <div class="border border-black">
          <table class="w-full text-xs text-left border-collapse">
            <thead>
              <tr class="yellow-header-badge border-b border-black">
                <th class="p-1.5 font-normal">Komponen Pendapatan</th>
                <th class="p-1.5 text-center border-l border-black font-normal w-24">Jumlah</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black">
              <tr class="h-7">
                <td class="p-1.5 font-normal">Upah Pokok</td>
                <td class="p-1.5 text-right border-l border-black font-normal">${payroll.basicSalary}</td>
              </tr>
              ${overtimePay > 0 ? `
                <tr class="h-7">
                  <td class="p-1.5 font-normal">Upah Kerja Lembur</td>
                  <td class="p-1.5 text-right border-l border-black font-normal">${overtimePay}</td>
                </tr>` : ''
              }
              ${allowancesRowsHTML}
              <tr class="h-7 border-t border-black">
                <td class="p-1.5 font-normal">Total Pendapatan</td>
                <td class="p-1.5 text-right border-l border-black font-normal">${payroll.totalEarnings + overtimePay}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="border border-black">
          <table class="w-full text-xs text-left border-collapse">
            <thead>
              <tr class="yellow-header-badge border-b border-black">
                <th class="p-1.5 font-normal">Komponen Potongan</th>
                <th class="p-1.5 text-center border-l border-black font-normal w-24">Jumlah</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black">
              ${deductionsRowsHTML}
              <tr class="h-7 border-t border-black">
                <td class="p-1.5 font-normal">Total Potongan</td>
                <td class="p-1.5 text-right border-l border-black font-normal">${payroll.totalDeductions}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="pt-2 flex justify-between items-start text-xs">
        <table class="w-auto border-none">
          <tr class="h-5">
            <td class="w-36 font-normal">Nama Bank</td>
            <td class="w-3">:</td>
            <td class="font-normal">${employeeProfile.financialData?.nama_bank || 'BCA'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Nomor Rekening</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.financialData?.nomor_rekening || '-'}</td>
          </tr>
          <tr class="h-5">
            <td class="font-normal">Nama Pemilik Rekening</td>
            <td>:</td>
            <td class="font-normal">${employeeProfile.financialData?.nama_pemilik_rekening || '-'}</td>
          </tr>
        </table>

        <div class="flex items-center gap-4 pr-16">
          <span class="font-normal">Take Home Pay</span>
          <span>:</span>
          <span class="font-normal">${payroll.netTakeHomePay}</span>
        </div>
      </div>

      <div class="border-b border-black pt-4"></div>

      <div class="flex items-center gap-1.5 text-[10px] font-normal pt-1">
        <span style="font-family: 'Times New Roman', Times, serif;">ZM</span>
        <span>PT Zafa Mulia Mandiri</span>
      </div>
    `;

    const printZone = document.getElementById('invoice-print-zone');
    if (printZone) {
      printZone.innerHTML = finalPrintTemplate;
      window.print();
    }
  }
</script>
<div class="flex w-full overflow-x-auto scrollbar-none pb-1 select-none">
  <div class="bg-white border border-slate-200/60 p-1 shadow-3xs inline-flex items-center gap-1 rounded-xl min-w-full sm:min-w-0">
    <% tabs.forEach((tab, index) => { %>
      <button type="button" 
        onclick="switchTab('<%= tab.id %>')" 
        id="tab-btn-<%= tab.id %>" 
        class="tab-btn flex-1 sm:flex-none text-center whitespace-nowrap px-4 py-1.5 text-[11px] font-medium rounded-lg transition-all duration-200 outline-none cursor-pointer <%= index === 0 ? 'font-bold bg-blue-600 text-white shadow-3xs' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-50/80' %>">
        <%= tab.label %>
      </button>
    <% }) %>
  </div>
</div>

<script>
  function switchTab(tabName) {
    // 1. Sembunyikan semua pane kontainer tab di halaman ini
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.add('hidden');
      pane.classList.remove('block', 'opacity-100', 'translate-y-0');
    });

    // 2. Aktifkan pane target yang dipilih
    const activeContent = document.getElementById(`tab-content-${tabName}`);
    if (activeContent) {
      activeContent.classList.remove('hidden');
      activeContent.classList.add('block');
      setTimeout(() => {
        activeContent.classList.add('opacity-100', 'translate-y-0');
      }, 10);
    }

    // 3. Kembalikan semua tombol tab ke style dasar tidak aktif
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.className = "tab-btn flex-1 sm:flex-none text-center whitespace-nowrap px-4 py-1.5 text-[11px] font-medium rounded-lg text-slate-500 hover:text-slate-800 hover:bg-slate-50/80 transition-all duration-200 outline-none cursor-pointer";
    });

    // 4. Nyalakan warna biru pada tombol tab yang sedang aktif saat ini
    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    if (activeBtn) {
      activeBtn.className = "tab-btn flex-1 sm:flex-none text-center whitespace-nowrap px-4 py-1.5 text-[11px] font-bold rounded-lg bg-blue-600 text-white shadow-3xs transition-all duration-200 outline-none cursor-pointer";
    }
  }
</script>
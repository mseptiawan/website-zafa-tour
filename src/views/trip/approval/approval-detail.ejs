<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

    <div class="max-w-4xl mx-auto">

      <!-- BACK -->
      <a href="/trip/approval"
        class="inline-flex items-center gap-2 text-[14px] font-bold text-slate-400 hover:text-slate-900 mb-6 uppercase tracking-widest transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Kembali
      </a>

      <!-- CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">

        <!-- HEADER -->
        <div class="p-8 border-b border-slate-100">

          <div class="flex items-center gap-2 mb-2">
            <span class="px-2.5 py-0.5 text-[11px] rounded-full border font-bold uppercase tracking-wider
            <%= trip.status === 'APPROVED'
              ? 'bg-emerald-50 text-emerald-600 border-emerald-200'
              : trip.status === 'REJECTED'
              ? 'bg-red-50 text-red-600 border-red-200'
              : 'bg-slate-50 text-slate-600 border-slate-200'
            %>">
              <%= trip.status %>
            </span>

            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">
              Step: <%= trip.currentStep || 'SELESAI' %>
            </span>
          </div>

          <h1 class="text-2xl font-bold text-slate-900">
            <%= trip.title %>
          </h1>

        </div>

        <!-- BODY -->
        <div class="p-8 space-y-6">

          <!-- INFO GRID -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 bg-slate-50 p-5 rounded-xl border border-slate-100">

            <div class="space-y-0.5">
              <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Pengaju</div>
              <div class="text-[14px] font-bold text-slate-800">
                <%= trip.userId?.username || '-' %>
              </div>
            </div>

            <div class="space-y-0.5">
              <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Destinasi</div>
              <div class="text-[14px] font-bold text-slate-800">
                <%= trip.destination || '-' %>
              </div>
            </div>

            <div class="space-y-0.5">
              <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Budget</div>
              <div class="text-[14px] font-bold text-slate-800">
                Rp <%= (trip.budget || 0).toLocaleString('id-ID') %>
              </div>
            </div>

          </div>

          <!-- DESCRIPTION -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700 block">Deskripsi</label>
            <div
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] text-slate-700 leading-relaxed">
              <%= trip.description || '-' %>
            </div>
          </div>

          <!-- TIMELINE -->
          <div class="space-y-2">
            <label class="text-[13px] font-bold text-slate-700 block">Timeline Kunjungan</label>

            <div class="space-y-3 pl-2">
              <% (trip.timeline || []).forEach(item=> { %>
                <div class="relative border-l-2 border-slate-200 pl-4 py-0.5">
                  <div class="absolute -left-[5px] top-2 w-2 h-2 rounded-full bg-slate-300"></div>
                  <p class="text-[14px] text-slate-700 font-medium">
                    <%= item.address %>
                  </p>
                </div>
                <% }) %>
            </div>
          </div>

          <!-- APPROVAL HISTORY -->
          <div class="space-y-3">
            <label class="text-[13px] font-bold text-slate-700 block">History Approval</label>

            <% if (!trip.approvals || trip.approvals.length===0) { %>
              <div class="p-4 rounded-xl bg-slate-50 text-slate-400 text-[14px] border border-slate-200/60 text-center">
                Belum ada data tracker approval
              </div>
              <% } %>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <% (trip.approvals || []).forEach(a=> { %>
                    <div
                      class="border border-slate-200 rounded-xl p-4 bg-white shadow-sm flex flex-col justify-between space-y-2">
                      <div>
                        <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                          <%= a.step %> • <%= a.actor %>
                        </div>
                        <div class="text-[14px] font-bold text-slate-900 mt-0.5">
                          <%= a.status %>
                        </div>
                      </div>
                      <div class="text-[13px] text-slate-500 pt-2 border-t border-slate-100">
                        <span class="font-medium text-slate-400">Catatan:</span>
                        <%= a.note || '-' %>
                      </div>
                    </div>
                    <% }) %>
                </div>
          </div>

          <!-- ACTION LOGIC (KEEP RULES) -->
          <% const isFinal=['APPROVED', 'REJECTED' ].includes(trip.status); const isManagerStep=user.role==='MANAGER' &&
            trip.currentStep==='MANAGER' && !isFinal; const isPimpinanStep=user.role==='PIMPINAN' &&
            trip.currentStep==='PIMPINAN' && !isFinal; const isHrStep=user.role==='HR' && trip.currentStep==='PIMPINAN'
            && trip.delegation?.active===true && trip.delegation?.to==='HR' && !isFinal; const canApprove=!isFinal &&
            (isManagerStep || isPimpinanStep || isHrStep); const requesterIsHR=trip.requesterRole==='HR' ; const
            canDelegate=user.role==='PIMPINAN' && trip.currentStep==='PIMPINAN' && !trip.delegation?.active && !isFinal
            && !requesterIsHR; const isDelegatedToHR=trip.delegation?.active===true && trip.delegation?.to==='HR' ;
            const isPimpinanBlocked=user.role==='PIMPINAN' && isDelegatedToHR && trip.currentStep==='PIMPINAN' ; %>

            <!-- ===================== -->
            <!-- ACTION BUTTONS        -->
            <!-- ===================== -->
            <% if (canApprove && !isPimpinanBlocked) { %>
              <div
                class="pt-6 border-t border-slate-100 flex flex-wrap gap-4 items-end justify-between bg-slate-50/50 -mx-8 -mb-8 p-8 border-b rounded-b-2xl">

                <!-- REJECT FORM -->
                <form method="POST" action="/trip/approval/<%= trip._id %>"
                  class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-end w-full md:w-auto order-2 md:order-1">
                  <div class="space-y-1.5">
                    <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider">Alasan
                      Penolakan</label>
                    <input name="note" required placeholder="Berikan alasan jika menolak..."
                      class="w-full sm:w-72 bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-[14px] focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all" />
                  </div>
                  <input type="hidden" name="action" value="REJECT" />
                  <button type="submit"
                    class="bg-red-600 hover:bg-red-700 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-md shadow-red-100 transition-all whitespace-nowrap">
                    Tolak Pengajuan
                  </button>
                </form>

                <!-- APPROVE FORM -->
                <form method="POST" action="/trip/approval/<%= trip._id %>"
                  class="w-full md:w-auto order-1 md:order-2 flex justify-end">
                  <input type="hidden" name="action" value="APPROVE" />
                  <button type="submit"
                    class="w-full sm:w-auto bg-slate-900 hover:bg-black text-white px-8 py-3 rounded-xl text-sm font-bold shadow-lg shadow-slate-200 transition-all">
                    Setujui Pengajuan
                  </button>
                </form>

              </div>
              <% } %>

                <!-- ===================== -->
                <!-- STATUS TRACK TRACKER  -->
                <!-- ===================== -->
                <% if (!canApprove || isPimpinanBlocked) { %>
                  <div class="flex justify-between items-center pt-6 border-t border-slate-100">

                    <div class="text-[14px] text-slate-500 font-medium">
                      <% if (trip.status==='APPROVED' ) { %>
                        <span class="text-emerald-600 font-bold">✓</span> Trip ini telah disetujui sepenuhnya
                        <% } else if (trip.status==='REJECTED' ) { %>
                          <span class="text-red-600 font-bold">✕</span> Pengajuan trip ini telah ditolak
                          <% } else if (trip.delegation?.active) { %>
                            <span class="text-amber-500 font-bold">ℹ</span> Delegasi aktif: HR sedang memproses berkas
                            <% } else { %>
                              <span class="text-blue-500 font-bold">•</span> Menunggu konfirmasi step saat ini
                              <% } %>
                    </div>

                    <span class="text-xs px-3 py-1 rounded-full border font-bold uppercase tracking-wider
              <%= trip.status === 'APPROVED'
                ? 'bg-emerald-50 text-emerald-600 border-emerald-200'
                : trip.status === 'REJECTED'
                ? 'bg-red-50 text-red-600 border-red-200'
                : trip.delegation?.active
                ? 'bg-amber-50 text-amber-600 border-amber-200'
                : 'bg-blue-50 text-blue-600 border-blue-200'
              %>">
                      <%= trip.delegation?.active ? 'HR (DELEGATED)' : trip.currentStep %>
                    </span>

                  </div>
                  <% } %>

                    <!-- ===================== -->
                    <!-- DELEGATION BUTTON     -->
                    <!-- ===================== -->
                    <% if (canDelegate) { %>
                      <div class="mt-6 pt-6 border-t border-slate-100 flex justify-start">
                        <form method="POST" action="/trip/<%= trip._id %>/delegate">
                          <button type="submit"
                            class="bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-xl text-sm font-bold shadow-md shadow-amber-100 transition-all">
                            Delegasikan Wewenang ke HR
                          </button>
                        </form>
                      </div>
                      <% } %>

        </div>
      </div>

    </div>
  </div>
<%- layout('layouts/main', { title: title }) %>

  <div class=" min-h-screen bg-slate-50/50 p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
    <div class="max-w-5xl mx-auto">

      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
          <h1 class="text-xl font-semibold text-slate-900 tracking-tight">
            Semua Penugasan
          </h1>
          <p class="text-[13px] text-slate-400 mt-1">
            Monitoring dan pelacakan penugasan dinas Pegawai
          </p>
        </div>

        <a href="/assignment/new"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl text-[13px] font-medium transition-all duration-200 border border-blue-700/30 shadow-sm shadow-blue-100/50 active:scale-[0.98] self-start sm:self-auto">
          <svg class="w-4 h-4 text-white/90 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Buat Penugasan
        </a>
      </div>

      <% if(assignments.length===0) { %>
        <div class="bg-white border border-slate-200/60 rounded-2xl p-12 text-center shadow-sm">
          <div
            class="w-12 h-12 bg-slate-50 border border-slate-100 rounded-xl flex items-center justify-center mx-auto mb-3 text-slate-400">
            <svg class="w-5 h-5 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <p class="text-[13px] font-medium text-slate-700">Belum ada data penugasan</p>
          <p class="text-[11px] text-slate-400 mt-0.5">Seluruh penugasan baru yang Anda buat akan muncul di sini.</p>
        </div>
        <% } else { %>

          <div class="space-y-3">
            <% assignments.forEach(a=> { %>
              <a href="/assignment/<%= a._id %>"
                class="block bg-white border border-slate-200/60 rounded-2xl p-5 hover:border-slate-300 hover:shadow-sm hover:bg-slate-50/30 transition-all duration-200 group">

                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 space-y-1">
                    <h2
                      class="text-[14px] font-semibold text-slate-800 break-words group-hover:text-blue-600 transition-colors">
                      <%= a.title %>
                    </h2>
                    <p class="text-[13px] text-slate-400 line-clamp-1 break-words leading-relaxed pr-4">
                      <%= a.description || 'Tidak ada deskripsi tambahan untuk penugasan ini' %>
                    </p>
                  </div>

                  <div class="flex-shrink-0">
                    <% if(a.endDate && new Date(a.endDate)>= new Date()) { %>
                      <span
                        class="inline-flex items-center px-2.5 py-1 text-[11px] rounded-lg border font-medium tracking-wide bg-emerald-50/60 text-emerald-600 border-emerald-100">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5"></span>
                        Active
                      </span>
                      <% } else { %>
                        <span
                          class="inline-flex items-center px-2.5 py-1 text-[11px] rounded-lg border font-medium tracking-wide bg-slate-50 text-slate-400 border-slate-200/60">
                          <span class="w-1.5 h-1.5 rounded-full bg-slate-300 mr-1.5"></span>
                          Completed
                        </span>
                        <% } %>
                  </div>
                </div>

                <div
                  class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4 pt-3.5 border-t border-slate-100/70 text-[12px] text-slate-400 font-medium">
                  <div>
                    Tipe: <span class="text-slate-600 ml-0.5">
                      <%= a.type %>
                    </span>
                  </div>
                  <div class="flex items-center">
                    <span class="w-1 h-1 rounded-full bg-slate-200 mr-4 hidden sm:block"></span>
                    Lokasi: <span class="text-slate-600 ml-0.5 truncate max-w-[120px] sm:max-w-none">
                      <%= a.location || '-' %>
                    </span>
                  </div>
                  <div class="flex items-center">
                    <span class="w-1 h-1 rounded-full bg-slate-200 mr-4 hidden sm:block"></span>
                    Durasi: <span class="text-slate-600 ml-0.5">
                      <%= new Date(a.startDate).toLocaleDateString("id-ID", { day: 'numeric' , month: 'short' }) %> -
                        <%= new Date(a.endDate).toLocaleDateString("id-ID", { day: 'numeric' , month: 'short' ,
                          year: 'numeric' }) %>
                    </span>
                  </div>
                </div>

                <div
                  class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mt-4 pt-3 border-t border-dashed border-slate-100">
                  <div>
                    <% if(a.attachment) { %>
                      <div
                        class="inline-flex items-center gap-1.5 text-[11px] font-medium text-blue-600 bg-blue-50/50 border border-blue-100/60 px-2 py-0.5 rounded-md">
                        <svg class="w-3.5 h-3.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round"
                            d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l4.5-4.5a4.5 4.5 0 011.243-0.88m6.364 6.364l-.001-.001m1.036-1.036a4.5 4.5 0 001.24-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364l4.5 4.5a4.5 4.5 0 001.242.88" />
                        </svg>
                        Surat Tugas Terlampir
                      </div>
                      <% } else { %>
                        <div class="text-[11px] text-slate-300 font-normal">Tanpa lampiran berkas</div>
                        <% } %>
                  </div>

                  <div class="flex items-center gap-1.5 flex-wrap">
                    <% a.employees.slice(0, 5).forEach(e=> { %>
                      <span
                        class="inline-block bg-slate-50 border border-slate-200/60 text-slate-600 text-[11px] font-medium px-2 py-0.5 rounded-md shadow-sm shadow-slate-100/50">
                        <%= e.fullName %>
                      </span>
                      <% }) %>

                        <% if(a.employees.length> 5) { %>
                          <span
                            class="text-[11px] font-medium text-slate-400 bg-slate-50/50 px-1.5 py-0.5 rounded-md border border-dotted border-slate-200">
                            +<%= a.employees.length - 5 %> staff
                          </span>
                          <% } %>
                  </div>
                </div>

              </a>
              <% }) %>
          </div>


          <% } %>
            <% if (pagination.totalPages> 1) { %>
              <div
                class="flex items-center justify-between mt-6 px-5 py-4 bg-white border border-slate-200 rounded-2xl shadow-sm text-[13px] antialiased">

                <div class="text-slate-500 font-medium">
                  Menampilkan halaman
                  <span class="font-bold text-slate-900">
                    <%= pagination.page %>
                  </span>
                  dari
                  <span class="font-bold text-slate-900">
                    <%= pagination.totalPages %>
                  </span>
                </div>

                <div class="flex items-center gap-2">

                  <a href="?page=<%= pagination.page - 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasPrev
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                    Prev
                  </a>

                  <a href="?page=<%= pagination.page + 1 %>" class="px-4 py-2 rounded-xl border font-bold transition-all focus:ring-4 focus:ring-slate-100 flex items-center gap-1.5
          <%= pagination.hasNext
            ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 hover:text-slate-900'
            : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
                    Next
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>

                </div>

              </div>
              <% } %>
    </div>
  </div>
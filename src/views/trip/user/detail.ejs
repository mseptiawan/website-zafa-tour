<%- layout('layouts/main', { title }) %>

<% 
  // Periksa apakah user memiliki role manajemen/approver dinas luar
  const APPROVER_ROLES = ["MANAGER_ADMINISTRASI", "WAKIL_DIREKTUR", "DIREKTUR_UTAMA", "MANAGER_KEUANGAN"];
  const isManagement = APPROVER_ROLES.includes((user.role || '').toUpperCase());
  const backLink = isManagement ? '/trip/approval' : '/trip/my';
  
  // Mencari approval aktif untuk user log-in saat ini
  const activeApproval = typeof approvals !== 'undefined' ? approvals.find(app => app.status === 'PENDING' && (app.step || '').toUpperCase() === (user.role || '').toUpperCase()) : null;
%>

<div>
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-6">

    <!-- BACK BUTTON -->
    <a href="<%= backLink %>" class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 transition-colors group select-none">
      <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Kembali</span>
    </a>

    <!-- 3-COLUMN GRID LAYOUT -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 md:gap-6 items-start">

      <!-- LEFT COLUMN: MAIN INFORMATION & OPERATIONAL ACTIONS -->
      <div class="space-y-5 md:space-y-6 lg:col-span-2">

        <!-- DETAIL CARD -->
        <div class="bg-white border border-slate-200/60 rounded-2xl overflow-hidden shadow-2xs">

          <!-- CARD HEADER -->
          <div class="p-4 md:px-8 md:py-5 border-b border-slate-100 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3 min-w-0 flex-1">
              <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-200/50 flex items-center justify-center text-slate-400 shrink-0 hidden sm:flex">
                <i class="fa-solid fa-user-tie text-sm"></i>
              </div>
              <div class="min-w-0 flex-1">
                <h1 class="text-[14px] md:text-[15px] font-semibold text-slate-900 tracking-tight truncate mb-0.5">
                  <%= trip.userId?.username || 'Nama Pegawai' %>
                </h1>
                <p class="text-[10px] md:text-[11px] font-semibold text-slate-400 uppercase tracking-wider truncate">
                  <%= trip.title %>
                </p>
              </div>
            </div>

            <span class="px-2.5 py-0.5 md:px-3 md:py-1 rounded-full font-bold text-[9.5px] md:text-[10px] uppercase tracking-wider border shrink-0 select-none
              <%= trip.status === 'PENDING' ? 'bg-amber-50 text-amber-700 border-amber-200/50'
                : trip.status === 'APPROVED' || trip.status === 'READY_TO_TRAVEL' ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50'
                : trip.status === 'ON_TRIP' || trip.status === 'IN_REVIEW' ? 'bg-blue-50 text-blue-700 border-blue-200/50'
                : 'bg-rose-50 text-rose-700 border-rose-200/50' %>">
              <%= trip.status %>
            </span>
          </div>

          <!-- CARD BODY -->
          <div class="p-5 md:p-6 space-y-5 bg-white">
            <!-- GRID INFO UTAMA -->
            <div class="grid grid-cols-2 gap-x-6 gap-y-4 md:gap-x-8">
              <div>
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Kota / Lokasi Tujuan</div>
                <div class="text-[13px] md:text-[14px] font-medium text-slate-800 break-words">
                  <%= trip.destination || '-' %>
                </div>
              </div>

              <div>
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Klien / Hubungan Kerja</div>
                <div class="text-[13px] md:text-[14px] font-medium text-slate-800 break-words">
                  <%= trip.meetWith || '-' %>
                </div>
              </div>

              <div>
                <div class="text-[10px] font-bold text-slate-400 tracking-wider mb-0.5">TANGGAL MULAI DINAS</div>
                <div class="text-[13px] font-medium text-slate-800 tabular-nums">
                  <%= trip.startDate ? new Date(trip.startDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
                </div>
              </div>

              <div>
                <div class="text-[10px] font-bold text-slate-400 tracking-wider mb-0.5">TANGGAL SELESAI DINAS</div>
                <div class="text-[13px] font-medium text-slate-800 tabular-nums">
                  <%= trip.endDate ? new Date(trip.endDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
                </div>
              </div>

              <div class="col-span-2 pt-1">
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Kategori / Keperluan</div>
                <div class="text-[12px] font-medium text-slate-700 bg-slate-50 px-2.5 py-1 rounded-md inline-block border border-slate-200/60 break-words max-w-full">
                  <%= trip.purpose || '-' %>
                </div>
              </div>
            </div>

            <!-- BOX DESKRIPSI -->
            <div class="bg-slate-50/80 rounded-lg p-3 border border-slate-200/50">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Deskripsi / Maksud Dinas</span>
              <p class="text-[12px] text-slate-600 leading-relaxed whitespace-normal break-words">
                <%= trip.description || '-' %>
              </p>
            </div>

            <!-- ESTIMATED BUDGET -->
            <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
              <div>
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Total Estimasi Anggaran</div>
                <div class="text-sm md:text-base font-bold text-blue-600 tabular-nums mt-0.5">
                  Rp <%= (trip.budget?.total || 0).toLocaleString('id-ID') %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- OPERATIONAL ACTIONS (READY TO TRAVEL & ON TRIP) -->
        <% if (trip.status === 'READY_TO_TRAVEL' && !isManagement) { %>
        <div class="bg-white border border-cyan-100 rounded-2xl p-4 md:p-6 shadow-2xs flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 bg-gradient-to-r from-cyan-50/20 to-white">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-cyan-50 flex items-center justify-center text-cyan-600 shrink-0"><i class="fa-solid fa-suitcase-rolling text-sm"></i></div>
            <div>
              <h2 class="text-xs md:text-sm font-semibold text-cyan-900">Perjalanan Siap Dimulai</h2>
              <p class="text-[11px] md:text-xs text-cyan-600/90 mt-0.5 max-w-md leading-relaxed break-words">
                Dana operasional dinas luar telah dicairkan. Harap lakukan aktivasi sistem saat Anda bertolak.
              </p>
            </div>
          </div>
          <form method="POST" action="/trip/<%= trip._id %>/start" class="w-full sm:w-auto m-0">
            <button class="w-full sm:w-auto h-10 px-5 bg-cyan-600 text-white text-[12px] font-semibold rounded-xl hover:bg-cyan-700 transition active:scale-[0.97] shadow-sm whitespace-nowrap cursor-pointer">
              Mulai Perjalanan
            </button>
          </form>
        </div>
        <% } %>

        <% if (trip.status === 'ON_TRIP' && !isManagement) { %>
        <div class="bg-white border border-slate-200/60 rounded-2xl shadow-2xs p-4 md:p-6">
          <div class="mb-5 flex items-start gap-4 pb-4 border-b border-slate-100">
            <div class="w-9 h-9 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 shrink-0"><i class="fa-solid fa-pen-to-square text-sm"></i></div>
            <div>
              <h2 class="text-[12px] font-bold text-slate-900 uppercase tracking-wider">Laporan Pelaksanaan Dinas Luar</h2>
              <p class="text-[11px] text-slate-400 mt-0.5 break-words">Isi dokumentasi hasil aktivitas dinas serta lampirkan bukti fisik resmi.</p>
            </div>
          </div>

          <form method="POST" action="/trip/<%= trip._id %>/report" enctype="multipart/form-data" class="m-0 space-y-4">
            <div>
              <label class="block text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Ringkasan Hasil Kegiatan</label>
              <textarea name="description" rows="4" required class="w-full border border-slate-200/80 rounded-xl p-3 text-[12px] text-slate-800 placeholder-slate-400 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 outline-none transition bg-slate-50/30 resize-none" placeholder="Tuliskan intisari pertemuan, pencapaian agenda dinas luar, atau poin penting lainnya..."></textarea>
            </div>

            <div>
              <label class="block text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Berkas Lampiran / Evidence</label>
              <div class="relative w-full border border-slate-200 border-dashed rounded-xl p-6 bg-slate-50/20 hover:bg-slate-50 hover:border-blue-400 transition-all flex flex-col items-center justify-center text-center group cursor-pointer" onclick="document.getElementById('attachments').click()">
                <input type="file" name="attachments" id="attachments" class="hidden" onchange="handleAttachmentLabel(this)" />
                <div class="w-10 h-10 rounded-xl bg-white border border-slate-200 shadow-3xs flex items-center justify-center text-slate-400 mb-2 group-hover:text-blue-500"><i class="fa-solid fa-cloud-arrow-up text-sm"></i></div>
                <span id="upload-label" class="text-[12px] font-bold text-slate-500 group-hover:text-blue-600">Pilih Dokumen Laporan (PDF/ZIP)</span>
                <p class="text-[10px] text-slate-400 mt-0.5">Maks berkas berkisar 5MB</p>
              </div>
            </div>

            <button type="submit" class="w-full h-11 bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold rounded-xl tracking-wider transition-all active:scale-[0.97] cursor-pointer shadow-sm">
              SUBMIT DOKUMEN LAPORAN
            </button>
          </form>
        </div>
        <% } %>

        <!-- MOBILE TRIGGER FOR BUDGET BREAKDOWN SHEET -->
        <div class="flex flex-col gap-2.5 md:hidden w-full select-none">
          <button type="button" onclick="toggleBottomSheet('budgetSheet', true)" class="w-full h-11 bg-white border border-slate-200 text-slate-700 text-xs font-semibold rounded-xl flex items-center justify-center gap-2 shadow-2xs active:bg-slate-50">
            <i class="fa-solid fa-table-list text-slate-400"></i> Rincian Alokasi Dana Anggaran
          </button>
        </div>

        <!-- DESKTOP BUDGET DETAILS TABLE -->
        <div class="pt-4 border-t border-slate-100">
          <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Rincian Pos Alokasi Anggaran</div>

          <div class="overflow-x-auto border border-slate-200/60 rounded-lg">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-200/60">
                  <th class="p-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider">Komponen Komparasi / Item</th>
                  <th class="p-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-center">Kuantitas</th>
                  <th class="p-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-right">Harga Satuan</th>
                  <th class="p-2.5 text-[10px] font-bold text-slate-500 uppercase tracking-wider text-right">Subtotal</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 text-[12px] text-slate-700">
                <% if (trip.budget && trip.budget.items && trip.budget.items.length > 0) { %>
                <% trip.budget.items.forEach(function(item) { %>
                <tr>
                  <td class="p-2.5 font-medium text-slate-800">
                    <%= item.title %>
                    <% if(item.description) { %>
                    <span class="block text-[10px] text-slate-400 italic font-normal"><%= item.description %></span>
                    <% } %>
                  </td>
                  <td class="p-2.5 text-center tabular-nums text-slate-600">
                    <%= item.quantity %> <%= item.unit || 'Hari' %>
                  </td>
                  <td class="p-2.5 text-right tabular-nums text-slate-600">
                    Rp <%= (item.pricePerUnit || 0).toLocaleString('id-ID') %>
                  </td>
                  <td class="p-2.5 text-right font-semibold tabular-nums text-slate-900">
                    Rp <%= (item.allocatedAmount || 0).toLocaleString('id-ID') %>
                  </td>
                </tr>
                <% }); %>
                <% } else { %>
                <tr>
                  <td colspan="4" class="p-4 text-center text-slate-400 italic text-[11px]">
                    Tidak ada rincian alokasi anggaran.
                  </td>
                </tr>
                <% } %>
              </tbody>
              <tfoot>
                <tr class="bg-blue-50/50 font-bold border-t border-slate-200 text-slate-900">
                  <td colspan="3" class="p-2.5 text-[10px] uppercase tracking-wider text-slate-500 text-right">Total Pagu Akhir:</td>
                  <td class="p-2.5 text-right text-blue-600 tabular-nums text-[13px]">
                    Rp <%= (trip.budget?.total || 0).toLocaleString('id-ID') %>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN: TRACKING LOGS & MANAGEMENT APPROVAL PANEL -->
      <div class="space-y-5 md:space-y-6 lg:col-span-1 w-full flex flex-col pb-24 md:pb-0">

        <!-- LOG HISTORY COMPONENT -->
        <div class="w-full">
          <%- include('partials/_log-history', { approvals }) %>
        </div>

        <!-- ACTION PANEL WIDGET -->
        <% if (activeApproval) { %>
        <div class="w-full bg-white border border-slate-200/60 rounded-2xl p-4 md:p-5 shadow-2xs">
          <%- include('partials/_action-panel', { activeApproval, user }) %>
        </div>
        <% } %>

        <div class="h-14 block md:hidden pointer-events-none select-none"></div>
      </div>

    </div>
  </div>
</div>

<!-- RESPONSIVE BOTTOM SHEET FOR BUDGET (MOBILE ONLY) -->
<div id="budgetSheet" class="fixed inset-0 z-50 hidden bg-slate-950/40 backdrop-blur-xs transition-opacity duration-300 items-end justify-center" onclick="closeSheetOnOverlay(event, 'budgetSheet')">
  <div class="w-full max-w-xl bg-white rounded-t-3xl border-t border-slate-200 p-4 space-y-4 max-h-[80vh] overflow-y-auto transform translate-y-0 transition-transform duration-300 pb-24">
    <div class="flex items-center justify-between border-b border-slate-100 pb-3 select-none">
      <div>
        <h3 class="text-[12px] font-bold text-slate-800 uppercase tracking-wider">Rincian Komponen Anggaran</h3>
        <p class="text-[10px] text-slate-400 mt-0.5">Alokasi dana operasional perjalanan dinas</p>
      </div>
      <button type="button" onclick="toggleBottomSheet('budgetSheet', false)" class="h-7 w-7 rounded-lg bg-slate-50 text-slate-400 flex items-center justify-center text-xs font-semibold border border-slate-200/50">✕</button>
    </div>

    <div class="space-y-2.5 text-xs">
      <div class="bg-slate-50/50 border border-slate-200/40 rounded-xl p-3 flex items-center justify-between">
        <span class="font-semibold text-slate-500">Transportasi Operasional</span>
        <span class="font-bold text-slate-900 tabular-nums">Rp <%= (trip.budget?.transport || 0).toLocaleString('id-ID') %></span>
      </div>
      <div class="bg-slate-50/50 border border-slate-200/40 rounded-xl p-3 flex items-center justify-between">
        <span class="font-semibold text-slate-500">Akomodasi / Hotel</span>
        <span class="font-bold text-slate-900 tabular-nums">Rp <%= (trip.budget?.accommodation || 0).toLocaleString('id-ID') %></span>
      </div>
      <div class="bg-slate-50/50 border border-slate-200/40 rounded-xl p-3 flex items-center justify-between">
        <span class="font-semibold text-slate-500">Uang Saku & Konsumsi</span>
        <span class="font-bold text-slate-900 tabular-nums">Rp <%= (trip.budget?.allowance || 0).toLocaleString('id-ID') %></span>
      </div>
      <div class="bg-blue-50/40 border border-blue-100 rounded-xl p-3.5 flex items-center justify-between border-dashed">
        <span class="font-bold text-blue-600 uppercase text-[10px] tracking-wider">Total Keseluruhan</span>
        <span class="font-extrabold text-blue-700 tabular-nums text-[13px]">Rp <%= (trip.budget?.total || 0).toLocaleString('id-ID') %></span>
      </div>
    </div>
  </div>
</div>

<!-- CLIENT HANDLERS & RESPONSIVE SCRIPTS -->
<script>
  function toggleBottomSheet(sheetId, shouldOpen) {
    const sheet = document.getElementById(sheetId);
    if (!sheet) return;

    if (shouldOpen) {
      sheet.classList.replace('hidden', 'flex');
      document.body.style.overflow = 'hidden';
    } else {
      sheet.classList.replace('flex', 'hidden');
      document.body.style.overflow = '';
    }
  }

  function closeSheetOnOverlay(event, sheetId) {
    const sheet = document.getElementById(sheetId);
    if (event.target === sheet) {
      toggleBottomSheet(sheetId, false);
    }
  }

  function handleAttachmentLabel(input) {
    const label = document.getElementById('upload-label');
    if (input.files && input.files.length > 0) {
      label.textContent = input.files[0].name;
      label.classList.add('text-blue-600');
    } else {
      label.textContent = "Pilih Dokumen Laporan (PDF/ZIP)";
      label.classList.remove('text-blue-600');
    }
  }
</script>
<%- layout('layouts/main', { title }) %>

<% 
  // Ambil data gaji pokok pegawai (Pastikan backend mengirim variabel 'salary' / 'gajiPokok')
  const gajiPokok = typeof salary !== 'undefined' ? salary : 0; 
  const maxLoanLimit = gajiPokok * 3;
  const maxInstallmentLimit = gajiPokok * 0.3;
%>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] p-4 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0 space-y-4">

    <div class="border-b border-slate-200/60 pb-4">
      <%- include('../partials/page-header', {
        section: 'Area Kerja',
        module: 'Finance',
        title: (typeof loan !== 'undefined' && loan) ? 'Ubah Pengajuan Pinjaman' : 'Pengajuan Pinjaman',
        description: (typeof loan !== 'undefined' && loan) ? 'Update data permohonan pinjaman internal Anda.' : 'Ajukan pinjaman internal atau modal kerja Anda di sini.',
        layoutSize: 'small' 
      }) %>
    </div>

    <details class="group bg-slate-50 border border-slate-200/60 rounded-xl transition-all select-none">
      <summary class="p-3.5 text-[11.5px] font-bold text-slate-700 cursor-pointer list-none flex items-center justify-between outline-none">
        <div class="flex items-center gap-2">
          <i class="fa-solid fa-circle-info text-blue-500 text-xs"></i>
          <span>Lihat Batas & Ketentuan Pinjaman</span>
        </div>
        <svg class="w-3.5 h-3.5 text-slate-400 transition-transform group-open:rotate-180 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </summary>
      <div class="px-3.5 pb-4 pt-1 border-t border-slate-200/40 grid grid-cols-1 sm:grid-cols-2 gap-2 text-[11px] text-slate-600 font-medium">
        <div class="bg-white p-2.5 rounded-lg border border-slate-100">
          <p class="text-slate-400 font-bold text-[9px] uppercase tracking-wider mb-0.5">Maksimum Pinjaman (3x Gaji)</p>
          <p class="text-[12px] font-bold text-slate-800 tabular-nums">Rp <%= String(maxLoanLimit).replace(/\B(?=(\d{3})+(?!\d))/g, ".") %></p>
        </div>
        <div class="bg-white p-2.5 rounded-lg border border-slate-100">
          <p class="text-slate-400 font-bold text-[9px] uppercase tracking-wider mb-0.5">Maksimum Cicilan (30% Gaji)</p>
          <p class="text-[12px] font-bold text-slate-800 tabular-nums">Rp <%= String(maxInstallmentLimit).replace(/\B(?=(\d{3})+(?!\d))/g, ".") %></p>
        </div>
      </div>
    </details>

    <% 
      const activeError = (typeof errorMessage !== 'undefined' && errorMessage) ? errorMessage : ((typeof error !== 'undefined' && error) ? error : '');
      const isSalaryError = activeError && (activeError.includes('Cicilan bulanan') || activeError.includes('maksimal 30%') || activeError.includes('Maksimum pinjaman'));
    %>

    <div class="bg-white border-0 md:border md:border-slate-200/60 rounded-2xl shadow-3xs overflow-hidden">
      <form id="loanForm" action="<%= typeof loan !== 'undefined' && loan ? '/loans/update/' + loan._id : '/loans' %>" method="POST" class="p-4 sm:p-6 md:p-8 space-y-4">

        <div class="space-y-1.5">
          <label class="text-[11.5px] font-bold text-slate-700 uppercase tracking-wide">
            Jumlah Pinjaman (IDR)
          </label>

          <% 
            let amountValue = '';
            if (typeof loan !== 'undefined' && loan) {
              amountValue = loan.amountRequested || '';
            } else if (typeof formData !== 'undefined' && formData) {
              amountValue = formData.amountRequested || '';
            } else if (typeof old !== 'undefined' && old) {
              amountValue = old.amount || '';
            }

            const formatRupiahInitial = (angka) => {
              if (!angka) return '';
              return String(angka).replace(/\D/g, "").replace(/\B(?=(\d{3})+(?!\d))/g, ".");
            };
          %>

          <input type="text" id="inputRupiah" required value="<%= formatRupiahInitial(amountValue) %>" placeholder="Contoh: 5.000.000" class="w-full h-11 bg-slate-50 border <%= isSalaryError ? 'border-rose-400 focus:border-rose-500' : 'border-slate-200/80 focus:border-slate-400' %> rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white transition-colors shadow-3xs" />
          <input type="hidden" name="amountRequested" id="amountRequestedHidden" value="<%= amountValue %>" />

          <% if (isSalaryError) { %>
          <p class="text-[10px] font-bold text-rose-500 flex items-center gap-1.5 mt-1.5 uppercase tracking-wider">
            <i class="fa-solid fa-circle-exclamation text-[10px]"></i>
            Batas pengajuan terlampaui. Cek rincian ketentuan kembali.
          </p>
          <% } %>
        </div>

        <div class="space-y-1.5">
          <label class="text-[11.5px] font-bold text-slate-700 uppercase tracking-wide">
            Tenor Pinjaman (Bulan)
          </label>

          <%
            let currentTenor = '';
            if (typeof loan !== 'undefined' && loan) {
              currentTenor = Number(loan.tenorMonths) || '';
            } else if (typeof formData !== 'undefined' && formData) {
              currentTenor = Number(formData.tenorMonths) || '';
            } else if (typeof old !== 'undefined' && old) {
              currentTenor = Number(old.tenor) || '';
            }
          %>

        <div class="relative">
  <select name="tenorMonths" id="selectTenor" required class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[11.5px] font-semibold text-slate-700 outline-none focus:bg-white transition-colors cursor-pointer appearance-none shadow-3xs">
    <option value="" disabled <%= !currentTenor ? 'selected' : '' %>>-- Pilih Tenor (Maks. 12 Bulan) --</option>
    <% for(let i = 1; i <= 12; i++) { %>
    <option value="<%= i %>" <%= currentTenor === i ? 'selected' : '' %> class="text-[12.5px]"><%= i %> Bulan</option>
    <% } %>
  </select>
  <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
    <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</div>

          <% if (activeError && String(activeError).trim() !== '') { %>
          <div class="mt-2 p-3 bg-rose-50 border border-rose-100 rounded-xl text-[11px] font-semibold text-rose-600 leading-relaxed shadow-3xs">
            <i class="fa-solid fa-circle-exclamation mr-1.5 text-[10px]"></i><%= activeError %>
          </div>
          <% } %>
        </div>

        <div id="calcPreview" class="hidden p-4 bg-blue-50/40 border border-blue-100/70 rounded-xl shadow-3xs space-y-2">
          <div class="flex justify-between items-center">
            <div>
              <span class="text-slate-500 font-bold uppercase tracking-wider text-[9.5px] block">Estimasi Potong Gaji</span>
              <span class="text-[10px] text-slate-400">Nilai cicilan flat per bulan</span>
            </div>
            <span id="previewCicilan" class="text-xl font-extrabold text-blue-600 tracking-tight tabular-nums">Rp 0</span>
          </div>

          <div id="warningMsg" class="hidden text-[11px] text-rose-500 font-semibold pt-2.5 border-t border-slate-200/60 flex items-start gap-1.5 leading-snug">
            </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-[11.5px] font-bold text-slate-700 uppercase tracking-wide">
            Alasan Peminjaman
          </label>
          <% 
            let reasonValue = '';
            if (typeof loan !== 'undefined' && loan) {
              reasonValue = loan.reason || '';
            } else if (typeof formData !== 'undefined' && formData) {
              reasonValue = formData.reason || '';
            } else if (typeof old !== 'undefined' && old) {
              reasonValue = old.reason || '';
            }
          %>
          <textarea name="reason" rows="3" maxlength="500" required placeholder="Jelaskan tujuan dan alasan pengajuan pinjaman secara detail..." class="w-full bg-slate-50 border border-slate-200/80 rounded-xl px-4 py-3 focus:bg-white text-[12.5px] font-medium text-slate-800 outline-none resize-none transition-colors placeholder:text-slate-400/80 shadow-3xs"><%= reasonValue %></textarea>
        </div>

        <div class="pt-4 border-t border-slate-100 flex items-center justify-end gap-2.5">
          <a href="/loans/my" class="inline-flex items-center justify-center h-9 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 rounded-xl px-5 text-[11.5px] font-semibold transition-all active:scale-[0.99] decoration-none">
            Batal
          </a>
          <button type="submit" id="btnSubmit" class="bg-blue-600 hover:bg-blue-700 text-white h-9 px-6 rounded-xl text-[11.5px] font-bold transition-all active:scale-[0.99] cursor-pointer shadow-3xs outline-none">
            <%= typeof loan !== 'undefined' && loan ? 'Simpan Perubahan' : 'Ajukan Pinjaman' %>
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
  const GAJI_POKOK = Number("<%= gajiPokok %>");
  const MAX_LOAN = Number("<%= maxLoanLimit %>");
  const MAX_INSTALLMENT = Number("<%= maxInstallmentLimit %>");

  const inputRupiah = document.getElementById('inputRupiah');
  const hiddenInput = document.getElementById('amountRequestedHidden');
  const selectTenor = document.getElementById('selectTenor');
  const btnSubmit = document.getElementById('btnSubmit');

  const calcPreview = document.getElementById('calcPreview');
  const previewCicilan = document.getElementById('previewCicilan');
  const warningMsg = document.getElementById('warningMsg');

  const formatNumberWithDots = (value) => {
    let clean = value.replace(/\D/g, '');
    return clean.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  };

  function hitungSimulasi() {
    const nominal = Number(hiddenInput.value) || 0;
    const tenor = Number(selectTenor.value) || 0;

    if (nominal > 0 || tenor > 0) {
      calcPreview.classList.remove('hidden');
    } else {
      calcPreview.classList.add('hidden');
    }

    let cicilanPerBulan = 0;
    if (nominal > 0 && tenor > 0) {
      cicilanPerBulan = Math.ceil(nominal / tenor);
      previewCicilan.innerText = "Rp " + formatNumberWithDots(String(cicilanPerBulan));
    } else {
      previewCicilan.innerText = "Rp 0";
    }

    let isError = false;
    let pesanError = "";

    if (nominal > MAX_LOAN) {
      isError = true;
      pesanError = `• Total pinjaman melebihi batas 3 kali gaji pokok (Maks: Rp ${formatNumberWithDots(String(MAX_LOAN))})`;
    }

    if (cicilanPerBulan > MAX_INSTALLMENT) {
      isError = true;
      pesanError += (pesanError ? '<br>' : '') + `• Cicilan bulanan (Rp ${formatNumberWithDots(String(cicilanPerBulan))}) melebihi batas 30% gaji (Maks: Rp ${formatNumberWithDots(String(MAX_INSTALLMENT))})`;
    }

    if (isError && nominal > 0 && tenor > 0) {
      warningMsg.innerHTML = pesanError;
      warningMsg.classList.remove('hidden');
      btnSubmit.disabled = true;
      btnSubmit.classList.add('opacity-40', 'cursor-not-allowed');
      btnSubmit.classList.remove('hover:bg-blue-600');
    } else {
      warningMsg.classList.add('hidden');
      btnSubmit.disabled = false;
      btnSubmit.classList.remove('opacity-40', 'cursor-not-allowed');
      btnSubmit.classList.add('hover:bg-blue-600');
    }
  }

  inputRupiah.addEventListener('input', function(e) {
    const formatted = formatNumberWithDots(this.value);
    this.value = formatted;
    hiddenInput.value = formatted.replace(/\./g, '');
    hitungSimulasi();
  });

  selectTenor.addEventListener('change', function() {
    hitungSimulasi();
  });

  if (hiddenInput.value || selectTenor.value) {
    hitungSimulasi();
  }
</script>
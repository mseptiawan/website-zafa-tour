<%- layout('layouts/main', { title }) %>

<%
  const isRejected = trip.status === "REJECTED";

  const lastReject =
    trip.approvals
      ?.slice()
      .reverse()
      .find(a => a.status === "REJECTED");
%>

<div style="
  margin-left:280px;
  min-height:100vh;
  padding:32px;
  background:#f8fafc;
  font-family:system-ui,sans-serif;
  color:#0f172a;
">

  <div style="max-width:720px; margin:auto;">

    <!-- HEADER -->
    <div style="margin-bottom:24px;">

      <h1 style="
        font-size:22px;
        font-weight:700;
        margin-bottom:6px;
      ">

        <%= isRejected
          ? "Resubmit Pengajuan Dinas Luar"
          : "Edit Pengajuan Dinas Luar"
        %>

      </h1>

      <p style="
        font-size:13px;
        color:#64748b;
      ">

        <%= isRejected
          ? "Perbaiki pengajuan yang ditolak lalu ajukan kembali"
          : "Perbarui data pengajuan sebelum masuk approval"
        %>

      </p>

    </div>

    <!-- CARD -->
    <div style="
      background:#fff;
      border:1px solid #e2e8f0;
      border-radius:16px;
      padding:24px;
      box-shadow:0 1px 2px rgba(0,0,0,.04);
    ">

      <!-- STATUS -->
      <div style="
        margin-bottom:18px;
        padding:14px;
        border-radius:12px;

        background:
          <%= isRejected ? '#fef2f2' : '#eff6ff' %>;

        border:
          1px solid
          <%= isRejected ? '#fecaca' : '#bfdbfe' %>;
      ">

        <div style="
          font-size:12px;
          font-weight:700;
          letter-spacing:.4px;

          color:
            <%= isRejected ? '#b91c1c' : '#1d4ed8' %>;
        ">
          STATUS PENGAJUAN
        </div>

        <div style="
          margin-top:4px;
          font-size:14px;
          font-weight:600;
        ">
          <%= trip.status %>
        </div>

        <% if (isRejected) { %>

          <div style="
            margin-top:10px;
            font-size:13px;
            color:#7f1d1d;
            line-height:1.6;
          ">
            Pengajuan sebelumnya ditolak dan perlu diperbaiki sebelum diajukan kembali.
          </div>

          <% if (lastReject?.note) { %>

            <div style="
              margin-top:14px;
              background:#fff;
              border:1px solid #fecaca;
              border-radius:10px;
              padding:12px;
            ">

              <div style="
                font-size:11px;
                font-weight:700;
                color:#991b1b;
                margin-bottom:6px;
              ">
                ALASAN PENOLAKAN
              </div>

              <div style="
                font-size:13px;
                line-height:1.6;
                color:#450a0a;
              ">
                <%= lastReject.note %>
              </div>

            </div>

          <% } %>

        <% } %>

      </div>

      <!-- FORM -->
      <form
        action="<%= trip.status === 'REJECTED'
    ? '/trip/' + trip._id + '/update'
    : '/trip/edit/' + trip._id %>"
        method="POST"
        style="
          display:flex;
          flex-direction:column;
          gap:14px;
        "
      >

        <!-- TITLE -->
        <div>

          <label style="
            display:block;
            margin-bottom:6px;
            font-size:12px;
            font-weight:600;
            color:#475569;
          ">
            Judul Perjalanan
          </label>

          <input
            type="text"
            name="title"
            value="<%= trip.title %>"
            minlength="5"
            maxlength="100"
            required
            style="
              width:100%;
              padding:11px 12px;
              border-radius:10px;
              border:1px solid #e2e8f0;
              outline:none;
            "
          />

        </div>

        <!-- PURPOSE -->
        <div>

          <label style="
            display:block;
            margin-bottom:6px;
            font-size:12px;
            font-weight:600;
            color:#475569;
          ">
            Tujuan Perjalanan
          </label>

          <select
            name="purpose"
            required
            style="
              width:100%;
              padding:11px 12px;
              border-radius:10px;
              border:1px solid #e2e8f0;
              background:#fff;
            "
          >

            <option value="">Pilih tujuan perjalanan</option>

            <% const purposes = ["SALES_VISIT","MEETING","TRAINING","SURVEY","OTHER"]; %>

            <% purposes.forEach(p => { %>

              <option
                value="<%= p %>"
                <%= trip.purpose === p ? 'selected' : '' %>
              >
                <%= p %>
              </option>

            <% }) %>

          </select>

        </div>

        <!-- DATE -->
        <div style="
          display:grid;
          grid-template-columns:1fr 1fr;
          gap:12px;
        ">

          <div>

            <label style="
              display:block;
              margin-bottom:6px;
              font-size:12px;
              font-weight:600;
              color:#475569;
            ">
              Tanggal Mulai
            </label>

            <input
              type="date"
              name="startDate"
              value="<%= trip.startDate ? new Date(trip.startDate).toISOString().split('T')[0] : '' %>"
              required
              style="
                width:100%;
                padding:11px 12px;
                border-radius:10px;
                border:1px solid #e2e8f0;
              "
            />

          </div>

          <div>

            <label style="
              display:block;
              margin-bottom:6px;
              font-size:12px;
              font-weight:600;
              color:#475569;
            ">
              Tanggal Selesai
            </label>

            <input
              type="date"
              name="endDate"
              value="<%= trip.endDate ? new Date(trip.endDate).toISOString().split('T')[0] : '' %>"
              required
              style="
                width:100%;
                padding:11px 12px;
                border-radius:10px;
                border:1px solid #e2e8f0;
              "
            />

          </div>

        </div>

        <!-- DESTINATION -->
        <div>

          <label style="
            display:block;
            margin-bottom:6px;
            font-size:12px;
            font-weight:600;
            color:#475569;
          ">
            Destinasi
          </label>

          <input
            type="text"
            name="destination"
            value="<%= trip.destination %>"
            minlength="3"
            maxlength="150"
            required
            style="
              width:100%;
              padding:11px 12px;
              border-radius:10px;
              border:1px solid #e2e8f0;
            "
          />

        </div>

        <!-- DESCRIPTION -->
        <div>

          <label style="
            display:block;
            margin-bottom:6px;
            font-size:12px;
            font-weight:600;
            color:#475569;
          ">
            Deskripsi Perjalanan
          </label>

          <textarea
            name="description"
            rows="4"
            minlength="10"
            maxlength="1000"
            required
            style="
              width:100%;
              padding:11px 12px;
              border-radius:10px;
              border:1px solid #e2e8f0;
              resize:none;
            "
          ><%= trip.description %></textarea>

        </div>

        <!-- BUDGET -->
        <div>

          <label style="
            display:block;
            margin-bottom:6px;
            font-size:12px;
            font-weight:600;
            color:#475569;
          ">
            Budget
          </label>

          <input
            type="text"
            id="budget"
            value="<%= (trip.budget || 0).toLocaleString('id-ID') %>"
            required
            style="
              width:100%;
              padding:11px 12px;
              border-radius:10px;
              border:1px solid #e2e8f0;
            "
          />

          <input
            type="hidden"
            name="budget"
            id="budgetRaw"
            value="<%= trip.budget %>"
          />

        </div>

        <!-- CONTACT -->
        <div style="
          display:grid;
          grid-template-columns:1fr 1fr;
          gap:12px;
        ">

          <div>

            <label style="
              display:block;
              margin-bottom:6px;
              font-size:12px;
              font-weight:600;
              color:#475569;
            ">
              Nama Contact Person
            </label>

            <input
              type="text"
              name="contactPerson[name]"
              value="<%= trip.contactPerson?.name || '' %>"
              style="
                width:100%;
                padding:11px 12px;
                border-radius:10px;
                border:1px solid #e2e8f0;
              "
            />

          </div>

          <div>

            <label style="
              display:block;
              margin-bottom:6px;
              font-size:12px;
              font-weight:600;
              color:#475569;
            ">
              No HP
            </label>

            <input
              type="text"
              name="contactPerson[phone]"
              value="<%= trip.contactPerson?.phone || '' %>"
              style="
                width:100%;
                padding:11px 12px;
                border-radius:10px;
                border:1px solid #e2e8f0;
              "
            />

          </div>

        </div>

        <!-- TIMELINE -->
        <div>

          <label style="
            display:block;
            margin-bottom:8px;
            font-size:12px;
            font-weight:600;
            color:#475569;
          ">
            Timeline Perjalanan
          </label>

          <div
            id="timelineBox"
            style="
              display:flex;
              flex-direction:column;
              gap:10px;
            "
          >

            <% if (trip.timeline && trip.timeline.length) { %>

              <% trip.timeline.forEach((t, i) => { %>

                <div style="
                  display:flex;
                  gap:8px;
                ">

                  <input
                    type="text"
                    name="timeline[<%= i %>][address]"
                    value="<%= t.address %>"
                    required
                    style="
                      flex:1;
                      padding:11px 12px;
                      border-radius:10px;
                      border:1px solid #e2e8f0;
                    "
                  />

                  <input
                    type="hidden"
                    name="timeline[<%= i %>][order]"
                    value="<%= i + 1 %>"
                  />

                  <button
                    type="button"
                    onclick="removeTimeline(this)"
                    style="
                      padding:0 14px;
                      border:none;
                      background:#fee2e2;
                      color:#dc2626;
                      border-radius:10px;
                      cursor:pointer;
                    "
                  >
                    ✕
                  </button>

                </div>

              <% }) %>

            <% } %>

          </div>

          <button
            type="button"
            onclick="addTimeline()"
            style="
              margin-top:10px;
              background:none;
              border:none;
              color:#4f46e5;
              cursor:pointer;
              font-size:13px;
              font-weight:600;
            "
          >
            + Tambah Timeline
          </button>

        </div>

        <!-- SUBMIT -->
        <button
          type="submit"
          style="
            margin-top:8px;
            padding:12px;
            border:none;
            border-radius:12px;

            background:
              <%= isRejected ? '#dc2626' : '#4f46e5' %>;

            color:#fff;
            font-size:14px;
            font-weight:600;
            cursor:pointer;
          "
        >

          <%= isRejected
            ? "Resubmit Pengajuan"
            : "Simpan Perubahan"
          %>

        </button>

      </form>

    </div>

  </div>

</div>

<script>
let timelineIndex = <%= trip.timeline ? trip.timeline.length : 0 %>;

// =========================
// BUDGET FORMAT
// =========================
const budgetInput = document.getElementById("budget");
const budgetRaw = document.getElementById("budgetRaw");

budgetInput.addEventListener("input", function(e){

  let value = e.target.value.replace(/\D/g, "");

  budgetRaw.value = value;

  if(!value){
    e.target.value = "";
    return;
  }

  e.target.value = Number(value).toLocaleString("id-ID");
});

// =========================
// ADD TIMELINE
// =========================
function addTimeline(){

  const box = document.getElementById("timelineBox");

  const div = document.createElement("div");

  div.style = `
    display:flex;
    gap:8px;
  `;

  div.innerHTML = `
    <input
      type="text"
      name="timeline[${timelineIndex}][address]"
      placeholder="Alamat berikutnya"
      required
      style="
        flex:1;
        padding:11px 12px;
        border-radius:10px;
        border:1px solid #e2e8f0;
      "
    />

    <input
      type="hidden"
      name="timeline[${timelineIndex}][order]"
      value="${timelineIndex + 1}"
    />

    <button
      type="button"
      onclick="removeTimeline(this)"
      style="
        padding:0 14px;
        border:none;
        background:#fee2e2;
        color:#dc2626;
        border-radius:10px;
        cursor:pointer;
      "
    >
      ✕
    </button>
  `;

  box.appendChild(div);

  timelineIndex++;
}

// =========================
// REMOVE TIMELINE
// =========================
function removeTimeline(btn){
  btn.parentElement.remove();
}
</script>
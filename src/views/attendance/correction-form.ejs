<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-2xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6 text-center">
      <h1 class="text-xl font-medium text-slate-800">
        Ajukan Koreksi Absensi
      </h1>

      <p class="text-sm text-slate-500 mt-1">
        Isi detail koreksi absensi dengan lengkap
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-xl p-6">

      <form method="POST"
        action="/attendance/correction"
        class="space-y-4">

        <!-- TANGGAL -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">
            Tanggal
          </label>

          <input
            type="date"
            name="startDate"
            required
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm
            focus:outline-none focus:ring-1 focus:ring-indigo-400"
          >
        </div>

        <!-- JAM -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">

          <!-- JAM MULAI -->
          <div>
            <label class="block text-xs text-slate-500 mb-1">
              Jam Mulai
            </label>

            <input
              type="time"
              name="startTime"
              required
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm
              focus:outline-none focus:ring-1 focus:ring-indigo-400"
            >
          </div>

          <!-- JAM SELESAI -->
          <div>
            <label class="block text-xs text-slate-500 mb-1">
              Jam Selesai
            </label>

            <input
              type="time"
              name="endTime"
              required
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm
              focus:outline-none focus:ring-1 focus:ring-indigo-400"
            >
          </div>

        </div>

        <!-- ALASAN -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">
            Jenis Alasan
          </label>

          <select
            name="reasonType"
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm
            bg-white focus:outline-none focus:ring-1 focus:ring-indigo-400"
          >
            <option value="TIDAK_TERCATAT">
              Tidak Tercatat Absen
            </option>

            <option value="LUPA_ABSEN">
              Lupa Absen
            </option>

            <option value="ABSEN_TIDAK_SEMPURNA">
              Absen Tidak Sempurna
            </option>

            <option value="LAINNYA">
              Lainnya
            </option>
          </select>
        </div>

        <!-- PENJELASAN -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">
            Penjelasan
          </label>

          <textarea
            name="reason"
            rows="4"
            minlength="10"
            maxlength="500"
            required
            placeholder="Jelaskan alasan koreksi absensi..."
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm
            focus:outline-none focus:ring-1 focus:ring-indigo-400"
          ></textarea>
        </div>

        <!-- BUTTON -->
        <button
          type="submit"
          class="w-full bg-indigo-600 hover:bg-indigo-700
          text-white text-sm font-medium py-2.5 rounded-lg transition"
        >
          Kirim Pengajuan
        </button>

      </form>

    </div>

  </div>

</div>
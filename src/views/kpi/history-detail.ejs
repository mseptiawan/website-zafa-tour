<%- layout('layouts/main', { title: 'Detail Penilaian KPI' }) %>

<div>
  <div class="max-w-none mx-auto">

    <div class="mb-6">
      <a href="/kpi/histories" class="text-sm text-slate-500 hover:text-indigo-600 flex items-center gap-2 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Kembali
      </a>
    </div>



  <div class="bg-white border border-slate-200 rounded-2xl p-8  mb-6 flex justify-between items-start">
      <div>
        <h1 class="text-2xl font-bold text-slate-800"><%= kpi.employeeId.fullName %></h1>
        <p class="text-slate-500 mt-1">Periode: <span class="font-medium text-slate-700"><%= kpi.periode %></span></p>
        <div class="mt-4 inline-flex items-center gap-1.5 px-3 py-1 rounded-full border bg-emerald-50/70 border-emerald-200/50 text-emerald-600 text-xs font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 ring-4 ring-emerald-500/20"></span>
          <%= kpi.status %>
        </div>
      </div>

      <div class="text-center">
        <div class="text-xs uppercase tracking-wider text-slate-400 font-bold mb-1">Skor Akhir</div>
        <div class="text-5xl font-extrabold text-indigo-600"><%= kpi.totalKpiScore %></div>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl  overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
          <tr>
            <th class="text-left px-6 py-4">Indikator Kinerja</th>
            <th class="text-center px-6 py-4">Bobot</th>
            <th class="text-center px-6 py-4">Nilai Input</th>
            <th class="text-center px-6 py-4">Skor</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% kpi.results.forEach(res => { %>
          <tr class="hover:bg-slate-50/60 transition">
            <td class="px-6 py-4">
              <div class="font-medium text-slate-800"><%= res.indikator %></div>
              <div class="text-[11px] text-slate-400 uppercase tracking-wide mt-0.5"><%= res.areaKinerja %></div>
            </td>
            <td class="px-6 py-4 text-center text-slate-600 font-medium"><%= res.bobot %>%</td>
            <td class="px-6 py-4 text-center font-bold text-indigo-600"><%= res.score %></td>
            <td class="px-6 py-4 text-center font-bold text-slate-800"><%= res.finalScore %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</div>
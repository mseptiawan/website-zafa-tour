<%- layout('layouts/main', { title: 'Ajukan Klaim Beban' }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD]  md:p-10 antialiased selection:bg-slate-100 text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0 space-y-5">

    <div class="mb-5 border-b border-slate-200/60 pb-5">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Finance', 
          title: 'Formulir Klaim Pengeluaran', 
          description: 'Catat pengeluaran operasional Anda dan lampirkan bukti transaksi yang valid.' 
      }) %>
    </div>

    <div class="bg-white border-0 md:border md:border-slate-200/60 rounded-2xl shadow-3xs overflow-hidden max-w-2xl">
      <form action="/expense/create" method="POST" enctype="multipart/form-data" class="p-4 sm:p-6 md:p-8 space-y-6">

        <div class="space-y-4">
          <h3 class="text-[10.5px] font-semibold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2 select-none">Informasi Transaksi</h3>
          
          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700">Judul Pengeluaran</label>
            <input type="text" name="title" value="<%= old?.title || '' %>" placeholder="Contoh: Pembelian Tinta Printer & Kertas HVS"
              class="w-full h-11 bg-slate-50 border <%= errors?.title ? 'border-rose-400' : 'border-slate-200/80 focus:border-slate-400' %> rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white transition-colors shadow-3xs" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[12px] font-semibold text-slate-700">Kategori Beban</label>
              <div class="relative">
                <select name="category" class="w-full h-11 bg-slate-50 border <%= errors?.category ? 'border-rose-400' : 'border-slate-200/80 focus:border-slate-400' %> rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 outline-none focus:bg-white transition-colors cursor-pointer appearance-none shadow-3xs">
                  <option value="" disabled <%= !old?.category ? 'selected' : '' %>>-- Pilih Kategori Operasional --</option>
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat._id %>" <%= old?.category === String(cat._id) ? 'selected' : '' %>><%= cat.name %></option>
                  <% }) %>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
                  <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>
            </div>
            
            <div class="space-y-1.5">
              <label class="text-[12px] font-semibold text-slate-700">Tanggal Nota</label>
              <input type="date" id="expenseDate" name="expenseDate" value="<%= old?.expenseDate || '' %>"
                class="w-full h-11 bg-slate-50 border <%= errors?.expenseDate ? 'border-rose-400' : 'border-slate-200/80 focus:border-slate-400' %> rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 outline-none focus:bg-white transition-colors cursor-pointer shadow-3xs" />
            </div>
          </div>

          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700">Nominal Tagihan</label>
            <div class="relative flex items-center">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none select-none">
                <span class="text-slate-400 font-semibold text-[12.5px]">Rp</span>
              </div>
              <input type="text" id="nominalInput" placeholder="0" class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl pl-10 pr-4 text-[13.5px] font-semibold text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition-colors tabular-nums shadow-3xs" />
              <input type="hidden" name="amount" id="amountReal" value="<%= old?.amount || '' %>" />
            </div>
          </div>
        </div>

        <div class="space-y-4 pt-2">
          <div class="flex items-center justify-between border-b border-slate-100 pb-2 flex-wrap gap-2 select-none">
            <h3 class="text-[10.5px] font-semibold text-slate-400 uppercase tracking-wider">Bukti Dokumen</h3>
            <label class="flex items-center gap-2 cursor-pointer group">
              <input type="checkbox" id="noReceipt" name="noReceipt" <%= old?.noReceipt ? 'checked' : '' %> onchange="toggleReceiptMode()" class="w-3.5 h-3.5 rounded border-slate-300 text-slate-900 focus:ring-0 cursor-pointer accent-slate-950 transition-colors shadow-3xs" />
              <span class="text-[11px] font-semibold text-slate-400 group-hover:text-slate-700 transition-colors">Nota Hilang / Tidak Ada (Self Dec)</span>
            </label>
          </div>

          <div id="fileSection" class="<%= old?.noReceipt ? 'hidden' : '' %> transition-all duration-300">
            <div id="dropzone-empty" class="relative w-full border border-dashed rounded-xl p-6 bg-slate-50/20 hover:bg-slate-50 <%= errors?.proofFile ? 'border-rose-400' : 'border-slate-200' %> transition-colors flex flex-col items-center justify-center text-center cursor-pointer shadow-3xs">
              <input type="file" name="proofFile" id="file-input" accept="image/*,application/pdf" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="handleFileSelect(this)" />
              <svg class="w-4 h-4 text-slate-400 mb-1.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
              </svg>
              <span class="text-[12px] font-semibold text-slate-700">Pilih Berkas atau Tarik File Kesini</span>
              <p class="text-[10.5px] font-medium text-slate-400 mt-0.5">Mendukung format JPG, PNG, atau PDF (Maksimal 5MB)</p>
              <% if (errors?.proofFile) { %>
                <span class="text-rose-500 text-[10.5px] font-semibold mt-1.5 block"><%= errors.proofFile %></span>
              <% } %>
            </div>

            <div id="dropzone-filled" class="hidden flex items-center justify-between border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-3xs">
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div class="w-8 h-8 rounded-lg bg-slate-50 border border-slate-200/60 flex items-center justify-center text-slate-400 shrink-0 shadow-3xs">
                  <i class="fa-solid fa-file-invoice text-xs"></i>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-[12px] font-semibold text-slate-700 truncate" id="name-preview">file.jpg</p>
                  <p class="text-[10.5px] text-slate-400 font-medium leading-none mt-0.5">Berkas siap diunggah</p>
                </div>
              </div>
              <button type="button" onclick="resetFile()" class="h-7 text-[11px] font-semibold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 px-2.5 rounded-lg transition-colors cursor-pointer ml-4 shrink-0">Ganti</button>
            </div>
          </div>

          <div id="extraSections" class="<%= old?.noReceipt ? '' : 'hidden' %> space-y-4">
            <div class="space-y-1.5">
              <label class="text-[12px] font-semibold text-slate-700">Alasan Ketiadaan Nota</label>
              <textarea id="reasonInput" name="noReceiptReason" rows="2" placeholder="Jelaskan secara singkat kenapa nota tidak tersedia..."
                class="w-full bg-slate-50 border <%= errors?.noReceiptReason ? 'border-rose-400' : 'border-slate-200/80 focus:border-slate-400' %> rounded-xl px-4 py-3 text-[12.5px] font-medium text-slate-800 outline-none focus:bg-white transition-colors resize-none shadow-3xs"><%= old?.noReceiptReason || '' %></textarea>
              <% if (errors?.noReceiptReason) { %>
                <p class="text-rose-500 text-[10.5px] font-semibold pl-1"><%= errors.noReceiptReason %></p>
              <% } %>
            </div>

            <label class="flex items-start gap-3 bg-slate-50/50 border <%= errors?.selfDeclaration ? 'border-rose-400' : 'border-slate-200/60' %> p-4 rounded-xl cursor-pointer shadow-3xs select-none">
              <input type="checkbox" id="declarationCheck" name="selfDeclaration" <%= old?.selfDeclaration ? 'checked' : '' %> class="mt-0.5 w-3.5 h-3.5 rounded border-slate-300 text-slate-900 focus:ring-0 cursor-pointer accent-slate-950 transition-colors" />
              <div>
                <p class="text-[12px] font-semibold text-slate-800">Pernyataan Tanggung Jawab Mutlak</p>
                <p class="text-[11px] text-slate-400 font-medium mt-1 leading-relaxed">Saya menyatakan bahwa pengeluaran ini benar dilakukan untuk kepentingan operasional perusahaan, dan saya bersedia mempertanggungjawabkannya apabila terdapat kekeliruan di kemudian hari.</p>
                <% if (errors?.selfDeclaration) { %>
                  <p class="text-rose-500 text-[10.5px] font-semibold mt-1.5"><%= errors.selfDeclaration %></p>
                <% } %>
              </div>
            </label>
          </div>
        </div>

        <div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-2.5">
          <a href="/expense/my" class="inline-flex items-center justify-center h-9 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 rounded-xl px-5 text-[11.5px] font-semibold transition-all active:scale-[0.99]">
            Batal
          </a>
          <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white h-9 px-6 rounded-xl text-[11.5px] font-semibold transition-all active:scale-[0.99] cursor-pointer shadow-3xs outline-none">
            Kirim
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
  function toggleReceiptMode() {
    const isChecked = document.getElementById("noReceipt").checked;
    const fileSection = document.getElementById("fileSection");
    const extraSections = document.getElementById("extraSections");
    const fileInput = document.getElementById("file-input");

    if (isChecked) {
      fileSection.classList.add("hidden");
      fileInput.value = ""; 
      extraSections.classList.remove("hidden");
    } else {
      fileSection.classList.remove("hidden");
      extraSections.classList.add("hidden");
    }
  }

  function handleFileSelect(input) {
    if (input.files.length > 0) {
      let fileName = input.files[0].name;
      if(fileName.length > 30) fileName = fileName.substring(0, 25) + '...';
      document.getElementById("name-preview").textContent = fileName;
      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
    }
  }

  function resetFile() {
    document.getElementById("file-input").value = "";
    document.getElementById("dropzone-empty").classList.remove("hidden");
    document.getElementById("dropzone-filled").classList.add("hidden");
  }

  document.addEventListener("DOMContentLoaded", () => {
    toggleReceiptMode();

    const expenseDateInput = document.getElementById("expenseDate");
    if (expenseDateInput) {
      const today = new Date();
      const formattedToday = today.toISOString().split('T')[0];
      expenseDateInput.setAttribute("max", formattedToday);
    }

    const nominalInput = document.getElementById("nominalInput");
    const amountReal = document.getElementById("amountReal");

    if (nominalInput && amountReal) {
      if (amountReal.value) {
        nominalInput.value = formatRupiah(amountReal.value);
      }

      nominalInput.addEventListener("input", function () {
        let value = this.value.replace(/[^0-9]/g, "");
        amountReal.value = value;
        this.value = value ? formatRupiah(value) : "";
      });
    }

    function formatRupiah(angka) {
      return angka.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    }
  });
</script>
<div class="bg-white border border-slate-200/60 rounded-2xl  overflow-hidden">
  
  <!-- DESKTOP TABLE: Modern Clean Look -->
  <div class="hidden md:block overflow-x-auto">
    <table class="w-full min-w-[900px] text-sm text-left border-collapse">
      <thead class="bg-slate-50/50 border-b border-slate-100 text-[10px] tracking-[0.1em] text-slate-400 uppercase font-bold">
        <tr>
          <th class="px-8 py-5">Pegawai</th>
          <th class="px-6 py-5">Tanggal</th>
          <th class="px-6 py-5 text-center">Waktu</th>
          <th class="px-6 py-5 text-center">Durasi</th>
          <th class="px-6 py-5 text-center">Status</th>
          <% if (type === 'history') { %><th class="px-6 py-5 text-center">Diproses</th><% } %>
          <th class="px-6 py-5 text-right pr-8">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <% if (overtimes.length === 0) { %>
          <tr><td colspan="<%= type === 'active' ? 6 : 7 %>" class="py-20 text-center text-slate-400 italic">Belum ada pengajuan lembur yang ditemukan</td></tr>
        <% } else { %>
          <% overtimes.forEach(o => { %>
            <tr class="group hover:bg-slate-50/80 transition-colors duration-200">
              <td class="px-8 py-5">
                <div class="text-[13px] font-semibold text-slate-900"><%= o.employeeName %></div>
                <div class="text-[11px] text-slate-400 mt-0.5">ID: <%= o.employeeId || 'N/A' %></div>
              </td>
              <td class="px-6 py-5 text-[13px] font-medium text-slate-600">
                <%= new Date(o.date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </td>
              <td class="px-6 py-5 text-center">
                <span class="text-[11px] font-mono font-medium text-slate-500 bg-slate-100 px-2 py-1 rounded-md"><%= o.startTime %> - <%= o.endTime %></span>
              </td>
              <td class="px-6 py-5 text-center font-bold text-slate-900 tabular-nums tracking-tight">
                <%= o.totalHours %> <span class="text-[10px] text-slate-400 font-normal">Jam</span>
              </td>
              <td class="px-6 py-5 text-center">
                <% 
                  const status = o.status.toLowerCase();
                  let color = 'bg-amber-50 text-amber-700 border-amber-200';
                  if (status.includes('approve')) color = 'bg-emerald-50 text-emerald-700 border-emerald-200';
                  if (status.includes('reject')) color = 'bg-rose-50 text-rose-700 border-rose-200';
                %>
                <span class="px-3 py-1 rounded-full border text-[10px] font-bold uppercase tracking-wide <%= color %>">
                  <%= o.status %>
                </span>
              </td>
              <% if (type === 'history') { %>
                <td class="px-6 py-5 text-center text-[12px] text-slate-500">-</td>
              <% } %>
              <td class="px-6 py-5 text-right pr-8">
                <a href="/overtime/detail/<%= o._id %>" class="inline-flex items-center gap-2 text-[11px] font-bold text-slate-500 hover:text-blue-600 transition-colors uppercase tracking-widest">
                  Detail <i class="fa-solid fa-arrow-right"></i>
                </a>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- MOBILE LIST: Card-Based Premium UI -->
  <div class="block md:hidden p-4 space-y-4">
    <% if (overtimes.length === 0) { %>
      <div class="py-10 text-center text-slate-400 text-sm">Belum ada data tersedia</div>
    <% } else { %>
      <% overtimes.forEach(o => { %>
        <div class="bg-white border border-slate-200 rounded-2xl p-5 space-y-4">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-bold text-slate-900"><%= o.employeeName %></h3>
              <p class="text-[11px] text-slate-400 uppercase tracking-widest mt-0.5"><%= new Date(o.date).toLocaleDateString('id-ID', {day:'numeric', month:'short'}) %></p>
            </div>
            <span class="px-2.5 py-0.5 rounded-full bg-amber-50 text-amber-700 text-[9px] font-bold uppercase"><%= o.status %></span>
          </div>
          
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-slate-50 p-3 rounded-xl">
              <p class="text-slate-400 text-[9px] uppercase font-bold tracking-wider">Jam</p>
              <p class="font-mono text-xs font-semibold text-slate-700 mt-1"><%= o.startTime %> - <%= o.endTime %></p>
            </div>
            <div class="bg-slate-50 p-3 rounded-xl">
              <p class="text-slate-400 text-[9px] uppercase font-bold tracking-wider">Durasi</p>
              <p class="font-bold text-slate-800 text-xs mt-1"><%= o.totalHours %> Jam</p>
            </div>
          </div>

          <div class="flex gap-2 pt-1">
            <a href="/overtime/detail/<%= o._id %>" class="flex-1 h-10 rounded-xl border border-slate-200 flex items-center justify-center text-xs font-bold text-slate-600 hover:bg-slate-50 transition-all uppercase tracking-wide">Detail</a>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="mb-3 flex items-center gap-3">
          <span class="text-[10px] tracking-[0.2em] text-slate-400 uppercase">Area Kerja</span>
          <div class="h-3 w-px bg-slate-300"></div>
          <span class="text-[10px] tracking-[0.2em] text-slate-700 uppercase">Kehadiran</span>
        </div>

        <h1 class="text-3xl text-slate-900 tracking-tight">Riwayat Absensi</h1>
        
        <% if (isAdmin) { %>
          <div class="mt-4 flex gap-2">
            <a href="/attendance/history" class="px-4 py-1.5 rounded-lg text-xs border <%= !isPersonalView ? 'bg-slate-900 text-white' : 'bg-white text-slate-600' %>">Semua Karyawan</a>
            <a href="/attendance/history?view=personal" class="px-4 py-1.5 rounded-lg text-xs border <%= isPersonalView ? 'bg-slate-900 text-white' : 'bg-white text-slate-600' %>">Absensi Saya</a>
          </div>
        <% } %>
      </div>

      <form action="/attendance/history" method="GET" class="flex gap-2">
        <% if (isAdmin && isPersonalView) { %><input type="hidden" name="view" value="personal"><% } %>
        <input type="date" name="startDate" value="<%= filters.startDate %>" class="px-3 py-2 rounded-xl border border-slate-200 text-sm">
        <input type="date" name="endDate" value="<%= filters.endDate %>" class="px-3 py-2 rounded-xl border border-slate-200 text-sm">
        <button type="submit" class="bg-white border border-slate-200 px-4 py-2 rounded-xl text-sm hover:bg-slate-50">Filter</button>
      </form>
    </div>

    <div class="grid md:grid-cols-3 gap-5 mb-8">
      <div class="bg-white border border-slate-200 rounded-2xl p-5 flex justify-between">
        <div><p class="text-xs text-slate-400 uppercase">Hadir</p><h3 class="text-2xl text-slate-800 mt-2"><%= analytics.totalHadir %> <span class="text-sm text-slate-400">hari</span></h3></div>
      </div>
      <div class="bg-white border border-slate-200 rounded-2xl p-5 flex justify-between">
        <div><p class="text-xs text-slate-400 uppercase">Terlambat</p><h3 class="text-2xl text-slate-800 mt-2"><%= analytics.totalLateDays %> <span class="text-sm text-slate-400">kali</span></h3></div>
      </div>
      <div class="bg-white border border-slate-200 rounded-2xl p-5 flex justify-between">
        <div><p class="text-xs text-slate-400 uppercase">Total Menit</p><h3 class="text-2xl text-slate-800 mt-2"><%= analytics.totalLateMinutes %> <span class="text-sm text-slate-400">menit</span></h3></div>
      </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
      <div class="p-5 border-b border-slate-100 bg-white">
        <h3 class="font-medium text-slate-700">Daftar Riwayat Kehadiran</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[800px]">
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase border-b border-slate-100">
            <tr>
              <% if (isAdmin && !isPersonalView) { %><th class="px-6 py-4 text-left">Pegawai</th><% } %>
              <th class="px-6 py-4 text-left">Tanggal</th>
              <th class="px-6 py-4 text-left">Masuk</th>
              <th class="px-6 py-4 text-left">Keluar</th>
              <th class="px-6 py-4 text-left">Status</th>
              <th class="px-6 py-4 text-left">Terlambat</th>
              <th class="px-6 py-4 text-center">Foto</th>
              <th class="px-6 py-4 text-center">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (listAttendance.length === 0) { %>
              <tr>
                <td colspan="<%= (isAdmin && !isPersonalView) ? 8 : 7 %>" class="py-12 text-center text-slate-400">Belum ada data riwayat absensi</td>
              </tr>
            <% } %>
            
            <% listAttendance.forEach(row => { %>
              <tr class="hover:bg-slate-50 transition bg-white">
                
                <% if (isAdmin && !isPersonalView) { %>
                  <td class="px-6 py-4 font-medium text-slate-800">
                    <%= row.userId?.username || '-' %>
                  </td>
                <% } %>
                
                <td class="px-6 py-4 text-slate-600">
                  <%= new Date(row.checkIn || row.createdAt).toLocaleDateString("id-ID", {day:'numeric', month:'short', year:'numeric'}) %>
                </td>
                
                <td class="px-6 py-4 text-slate-500">
                  <%= row.checkIn ? new Date(row.checkIn).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '--:--' %>
                </td>
                
                <td class="px-6 py-4 text-slate-500">
                  <%= row.checkOut ? new Date(row.checkOut).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '--:--' %>
                </td>
                
                <td class="px-6 py-4">
                  <% if (row.status === 'BELUM ABSEN') { %>
                    <span class="text-xs font-medium text-red-600">
                      Belum Absen
                    </span>
                  <% } else { %>
                    <span class="px-2.5 py-0.5 rounded-full text-[11px] text-slate-600 bg-slate-100 border border-slate-200">
                      <%= row.status %>
                    </span>
                  <% } %>
                </td>
                
                <td class="px-6 py-4 text-slate-500">
                  <%= row.lateDuration > 0 ? row.lateDuration + ' menit' : '-' %>
                </td>
                
                <td class="px-6 py-4 text-center text-slate-400">
                  <%= row.checkInPhoto ? '📷' : '-' %>
                </td>
                
                <td class="px-6 py-4 text-center">
                  <% if (row.status === 'BELUM ABSEN') { %>
                    <button class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-300 cursor-not-allowed" title="Data belum tersedia">👁</button>
                  <% } else { %>
                    <button class="openModal w-8 h-8 rounded-lg border border-slate-200 flex items-center justify-center hover:bg-slate-50 text-slate-500"
                      data-date="<%= new Date(row.createdAt).toLocaleDateString('id-ID') %>"
                      data-status="<%= row.status %>"
                      data-checkin="<%= row.checkIn ? new Date(row.checkIn).toLocaleTimeString('id-ID') : '-' %>"
                      data-checkout="<%= row.checkOut ? new Date(row.checkOut).toLocaleTimeString('id-ID') : '-' %>"
                      data-duration="<%= row.workDuration || 0 %>"
                      data-lateduration="<%= row.lateDuration || 0 %>"
                      data-inphoto="<%= row.checkInPhoto || '' %>"
                      data-outphoto="<%= row.checkOutPhoto || '' %>"
                      data-type="<%= row.type %>">👁</button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<%- include('./partials/attendance-modal.ejs') %>
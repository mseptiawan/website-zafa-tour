<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">

  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-800">
        Perjalanan Saya
      </h1>
      <p class="text-sm text-slate-500 mt-2">
        Daftar pengajuan dinas luar yang kamu ajukan
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

      <div class="overflow-x-auto">
        <table class="w-full text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wider">
            <tr>
              <th class="p-4 text-left">Judul</th>
              <th class="text-left">Tujuan</th>
              <th class="text-left">Tanggal</th>
              <th class="text-left">Budget</th>
              <th class="text-left">Status</th>
              <th class="text-left">Aksi</th>
            </tr>
          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (trips.length === 0) { %>
              <tr>
                <td colspan="6" class="p-10 text-center text-slate-400">
                  Belum ada pengajuan perjalanan
                </td>
              </tr>
            <% } %>

            <% trips.forEach(trip => { %>
              <tr class="hover:bg-slate-50 transition">

                <!-- JUDUL -->
                <td class="p-4 font-semibold text-slate-800">
                  <%= trip.title %>
                </td>

                <!-- TUJUAN -->
                <td class="text-slate-600">
                  <%= trip.destination %>
                </td>

                <!-- TANGGAL -->
                <td class="text-slate-600">
                  <%= new Date(trip.startDate).toLocaleDateString('id-ID') %>
                  -
                  <%= new Date(trip.endDate).toLocaleDateString('id-ID') %>
                </td>

                <!-- BUDGET -->
                <td class="text-slate-600 font-medium">
                  Rp <%= Number(trip.budget).toLocaleString('id-ID') %>
                </td>

                <!-- STATUS -->
                <td>
                  <% if (trip.status === 'PENDING') { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-yellow-50 text-yellow-700 font-medium">
                      Pending
                    </span>

                  <% } else if (trip.status === 'APPROVED_MANAGER') { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-blue-50 text-blue-600 font-medium">
                      Approved Manager
                    </span>

                  <% } else if (trip.status === 'APPROVED_DIRECTOR') { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-emerald-50 text-emerald-600 font-medium">
                      Approved Director
                    </span>

                  <% } else { %>
                    <span class="px-3 py-1 text-xs rounded-full bg-red-50 text-red-600 font-medium">
                      Rejected
                    </span>
                  <% } %>
                </td>

                <!-- AKSI -->
                <td>
                  <a
                    href="/trip/detail/<%= trip._id %>"
                    class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-700 font-medium text-sm"
                  >
                    Detail
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </td>

              </tr>
            <% }) %>

          </tbody>

        </table>
      </div>

    </div>

  </div>

</div>
<%- include('./sidebar-config') %>

<!-- SEKARANG ASIDE DIKUNCI HANYA UNTUK VISIBLE DI DESKTOP (md:flex) -->
<aside id="sidebar" class="fixed inset-y-0 left-0 w-72 bg-white text-black flex flex-col z-[100] border-r border-slate-100 shadow-sm hidden md:flex">
  
  <div class="h-20 flex items-center px-8 border-b border-slate-100 relative shrink-0">
    <div class="flex items-center gap-4 relative z-10">
      <div class="leading-tight">
        <h1 class="text-lg font-bold tracking-wide text-slate-800">Zafa Tour</h1>
        <p class="text-[10px] text-slate-500 uppercase tracking-[0.25em] font-medium">PT Zafa Mulia Mandiri</p>
      </div>
    </div>
  </div>

  <nav id="sidebarNav" class="flex-1 overflow-y-auto scrollbar-hide px-4 py-6 space-y-7 pb-10">
    <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all group border border-transparent">
      <svg class="w-5 h-5 text-slate-500 group-hover:text-slate-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
      </svg>
      <span class="text-xs font-medium text-slate-600 group-hover:text-slate-800">Dashboard</span>
    </a>

    <% if (locals.sidebarSections) { %>
      <% locals.sidebarSections.forEach(section => { %>
        <% if (section.show && section.menus.some(m => m.show && m.submenus.some(s => s.show))) { %>
        <section>
          <p class="text-[7px] text-slate-500 font-bold px-4 mb-3 uppercase tracking-[0.2em]"><%= section.title %></p>
          <div class="space-y-1">
            <% section.menus.forEach(menu => { %>
              <% if (menu.show && menu.submenus.some(s => s.show)) { %>
              <details class="group outline-none" data-menu="<%= menu.id %>">
                <summary class="flex items-center justify-between px-4 py-3 rounded-xl cursor-pointer list-none transition-all border border-transparent">
                  <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-slate-500 group-hover:text-slate-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><%- menu.icon %></svg>
                    <span class="text-xs font-medium text-slate-600 group-hover:text-slate-800"><%= menu.name %></span>
                  </div>
                  <svg class="w-4 h-4 text-slate-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="mt-1 ml-9 flex flex-col border-l border-slate-200 space-y-1">
                  <% menu.submenus.forEach(sub => { %>
                    <% if (sub.show) { %>
                    <a href="<%= sub.path %>" class="sidebar-link py-2 px-4 text-xs text-slate-500 hover:text-slate-800 transition"><%= sub.name %></a>
                    <% } %>
                  <% }); %>
                </div>
              </details>
              <% } %>
            <% }); %>
          </div>
        </section>
        <% } %>
      <% }); %>
    <% } %>
  </nav>

  <div class="p-4 border-t border-slate-100 bg-white">
    <div class="flex items-center justify-between p-3 rounded-2xl bg-slate-50/50 border border-slate-100">
      <% if (typeof user !== 'undefined' && user !== null) { %>
        <a href="/employee/detail/<%= user.employeeId %>" class="flex items-center gap-3 min-w-0 flex-1 group/profile">
          <div class="w-10 h-10 rounded-full bg-slate-200 border border-slate-300 overflow-hidden shrink-0">
            <% 
              let profilePic = user.foto_profile 
                ? user.foto_profile 
                : (user.gender === "Perempuan" 
                   ? "https://img.freepik.com/premium-vector/smiling-woman-avatar_937492-6135.jpg" 
                   : "https://img.freepik.com/vektor-premium/avatar-kartun-pengusaha-mYoung-pria-mengenakan-setelan-jas-dan-dasi_645574-600.jpg");
            %>
            <img src="<%= profilePic %>" class="w-full h-full object-cover" />
          </div>
          <div class="min-w-0 flex-1 leading-normal">
            <p class="text-xs font-semibold text-slate-800 truncate"><%= user.fullName || 'User' %></p>
            <p class="text-[8px] font-medium uppercase tracking-[0.15em] text-slate-400 truncate mt-0.5"><%= user.role || 'Pegawai' %></p>
          </div>
        </a>
      <% } %>
      <a href="/logout" title="Keluar Aplikasi" onclick="localStorage.clear();" class="p-2 ml-2 text-slate-400 hover:text-red-500 rounded-xl hover:bg-red-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
      </a>
    </div>
  </div>
</aside>
<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 sm:p-6 md:p-10 antialiased pb-24 md:pb-8 text-slate-800">
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

    <div class="border border-slate-200/60 md:border-none md:shadow-none">
      <%- include('../partials/page-header', {
        section: 'Area Kerja',
        module: 'Kepegawaian',
        title: 'Manajemen Reward & Punishment',
        description: 'Pusat pencatatan formal berkas penghargaan dan sanksi kedisiplinan pegawai.'
      }) %>
    </div>

    <div class="flex items-center justify-between bg-white p-4 rounded-2xl border border-slate-200/50 shadow-2xs">
      <h3 class="text-sm font-bold text-slate-800">Riwayat Log Pegawai</h3>
      <a href="/reward-punishment/new" class="inline-flex items-center justify-center gap-2 h-10 px-4 bg-blue-600 hover:bg-blue-700 text-white text-[12px] font-semibold rounded-xl transition-all shadow-sm cursor-pointer">
        <i class="fa-solid fa-plus text-[10px]"></i>
        <span>Tambah Log Baru</span>
      </a>
    </div>

    <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50 shadow-2xs">
      <div class="overflow-x-auto overflow-y-visible">
        <table class="w-full text-left border-collapse text-[13px] table-fixed">
          <thead>
            <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider">
              <th class="py-4 px-6 w-[15%]">Tanggal Berlaku</th>
              <th class="py-4 px-6 w-[20%]">Nama Pegawai</th>
              <th class="py-4 px-6 w-[15%]">Kategori / Jenis</th>
              <th class="py-4 px-6 w-[25%]">Alasan / SK</th>
              <th class="py-4 px-6 w-[13%] text-right">Dampak Finansial</th>
              <th class="py-4 px-6 w-[12%] text-center">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
            <% if (logs.length === 0) { %>
            <tr>
              <td colspan="6" class="py-12 text-center text-slate-400 font-medium">Belum ada pencatatan data log.</td>
            </tr>
            <% } else { %>
            <% logs.forEach(log => { %>
            <tr class="hover:bg-slate-50/40 transition-colors">
              <td class="py-4 px-6 text-slate-500 tabular-nums">
                <%= new Date(log.dateIssued).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
              </td>
              <td class="py-4 px-6 font-bold text-slate-800 truncate">
                <%= log.employeeId ? log.employeeId.fullName : 'Pegawai Terhapus' %>
              </td>
              <td class="py-4 px-6">
                <% if(log.typeId?.category === 'REWARD') { %>
                <span class="inline-flex items-center gap-1.5 text-[12px] text-slate-600 font-medium">
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                  <%= log.typeId?.name %>
                </span>
                <% } else { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-rose-50 border border-rose-200 rounded-md text-[11px] text-rose-700 font-bold uppercase">
                  <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span><%= log.typeId?.name %>
                </span>
                <% } %>
              </td>
              
              <td class="py-4 px-6 max-w-[260px]">
                <div class="flex items-center justify-between gap-2">
                  <p class="text-slate-700 font-normal leading-relaxed truncate mb-0.5">
                    <%= log.reason %>
                  </p>
                  <button 
                    type="button"
                    class="open-reason-modal text-slate-400 hover:text-blue-600 bg-slate-50 hover:bg-blue-50 p-1 rounded-md transition-all flex-shrink-0 cursor-pointer"
                    data-sk="<%= log.skNumber || '-' %>"
                    data-employee="<%= log.employeeId ? log.employeeId.fullName : 'Pegawai Terhapus' %>"
                    data-category="<%= log.typeId?.category %>"
                    data-rule="<%= log.typeId?.name %>"
                    data-reason="<%= log.reason %>"
                    title="Lihat Detail Alasan"
                  >
                    <i class="fa-solid fa-eye text-[11px]"></i>
                  </button>
                </div>
                <span class="text-[10.5px] text-slate-400 font-medium tracking-wide block mt-0.5">
                  📄 SK: <%= log.skNumber || '-' %>
                </span>
              </td>

              <td class="py-4 px-6 text-right tabular-nums font-bold <%= log.typeId?.financialImpact >= 0 ? 'text-emerald-600' : 'text-rose-600' %>">
                <%= log.typeId?.financialImpact >= 0 ? '+' : '' %><%= log.typeId?.financialImpact.toLocaleString('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }) %>
              </td>
              <td class="py-4 px-6 text-center">
                <a href="/reward-punishment/delete/<%= log._id %>" onclick="return confirm('Hapus pencatatan log ini?')" class="w-8 h-8 rounded-lg border border-rose-200 bg-rose-50/40 text-rose-600 inline-flex items-center justify-center transition-all hover:bg-rose-50">
                  <i class="fa-solid fa-trash-can text-[11px]"></i>
                </a>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="reasonModal" class="fixed inset-0 z-[150] hidden">
  <div id="modalOverlay" class="absolute inset-0 bg-slate-900/40 backdrop-blur-xs transition-opacity"></div>
  
  <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div class="bg-white rounded-2xl shadow-2xl border border-slate-200/80 max-w-md w-full overflow-hidden transform scale-95 opacity-0 transition-all duration-200 ease-out pointer-events-auto" id="modalContent">
      
      <div class="px-6 py-4 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
        <div>
          <span id="modalBadge" class="px-2 py-0.5 rounded-md text-[10px] font-bold border tracking-wider uppercase"></span>
          <h3 class="text-sm font-bold text-slate-800 mt-1" id="modalTitleRule">Detail Regulasi</h3>
        </div>
        <button id="closeModal" class="text-slate-400 hover:text-slate-600 p-1.5 rounded-xl hover:bg-slate-200/50 transition-colors cursor-pointer">
          <i class="fa-solid fa-xmark text-xs"></i>
        </button>
      </div>
      
      <div class="p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-0.5">Nama Pegawai</label>
            <p id="modalEmployeeName" class="text-[13px] font-bold text-slate-800"></p>
          </div>
          <div>
            <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-0.5">No. SK Resmi</label>
            <p id="modalSkNumber" class="text-[13px] font-semibold text-slate-600 select-all"></p>
          </div>
        </div>
        <hr class="border-slate-100">
        <div>
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Alasan / Keterangan Penjelasan</label>
          <div class="bg-slate-50 border border-slate-100 rounded-xl p-3.5 text-[13px] text-slate-700 leading-relaxed max-h-60 overflow-y-auto whitespace-pre-line" id="modalReasonText">
          </div>
        </div>
      </div>
      
      <div class="px-6 py-3.5 bg-slate-50 border-t border-slate-100 flex justify-end">
        <button id="closeModalBtn" class="px-4 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl text-xs font-semibold hover:bg-slate-50 active:bg-slate-100 transition-colors shadow-xs cursor-pointer">
          Tutup
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('reasonModal');
    const modalContent = document.getElementById('modalContent');
    const overlay = document.getElementById('modalOverlay');
    const closeBtn = document.getElementById('closeModal');
    const closeBtn2 = document.getElementById('closeModalBtn');
    
    const modalBadge = document.getElementById('modalBadge');
    const modalTitleRule = document.getElementById('modalTitleRule');
    const modalEmployeeName = document.getElementById('modalEmployeeName');
    const modalSkNumber = document.getElementById('modalSkNumber');
    const modalReasonText = document.getElementById('modalReasonText');

    function openModal(button) {
      const sk = button.getAttribute('data-sk');
      const employee = button.getAttribute('data-employee');
      const category = button.getAttribute('data-category');
      const rule = button.getAttribute('data-rule');
      const reason = button.getAttribute('data-reason');

      modalSkNumber.textContent = sk;
      modalEmployeeName.textContent = employee;
      modalTitleRule.textContent = rule;
      modalReasonText.textContent = reason;
      modalBadge.textContent = category;

      if (category === 'REWARD') {
        modalBadge.className = "px-2 py-0.5 rounded-md text-[10px] font-bold border bg-blue-50 border-blue-200 text-blue-700";
      } else {
        modalBadge.className = "px-2 py-0.5 rounded-md text-[10px] font-bold border bg-rose-50 border-rose-200 text-rose-700";
      }

      modal.classList.remove('hidden');
      setTimeout(() => {
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      }, 10);
    }

    function closeModal() {
      modalContent.classList.remove('scale-100', 'opacity-100');
      modalContent.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 150);
    }

    document.querySelectorAll('.open-reason-modal').forEach(button => {
      button.addEventListener('click', () => openModal(button));
    });

    closeBtn.addEventListener('click', closeModal);
    closeBtn2.addEventListener('click', closeModal);
    overlay.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  });
</script>
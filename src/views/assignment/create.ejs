<%- layout('layouts/main', { title: title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

    <div class="max-w-2xl mx-auto">

      <!-- HEADER -->
      <div class="mb-8">

        <nav class="flex items-center gap-2 mb-2 text-[11px] font-semibold text-slate-400 uppercase tracking-widest">
          <span>Workspace</span>
          <span>/</span>
          <span class="text-slate-700">Assignment</span>
        </nav>

        <h1 class="text-2xl font-semibold text-slate-800">
          Buat Penugasan
        </h1>

        <p class="text-sm text-slate-500 mt-1">
          Tambahkan tugas atau penugasan untuk karyawan.
        </p>

      </div>

      <!-- CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

        <form method="POST" enctype="multipart/form-data" class="p-8 space-y-6" action="/assignment/">

          <!-- TITLE -->
          <div class="space-y-1.5">

            <label class="text-[13px] font-semibold text-slate-700">
              Judul Penugasan
            </label>

            <input name="title" placeholder="Ketik judul penugasan..."
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

          </div>

          <!-- DESCRIPTION -->
          <div class="space-y-1.5">

            <label class="text-[13px] font-semibold text-slate-700">
              Deskripsi
            </label>

            <textarea name="description" rows="5" placeholder="Tulis detail penugasan..."
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none resize-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all"></textarea>

          </div>

          <!-- TYPE -->
          <div class="space-y-2">
            <label class="text-[13px] font-medium text-slate-500 block">Tipe Penugasan</label>

            <!-- DROPDOWN CONTAINER -->
            <div class="relative w-full" id="assignment-type-dropdown">

              <!-- HIDDEN INPUT (Untuk menampung value form backend) -->
              <input type="hidden" name="type" id="assignment-type-value" value="UNDANGAN" required>

              <!-- SELECT TRIGGER BUTTON -->
              <button type="button" onclick="toggleTypeDropdown()"
                class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl px-4 py-3 text-[13px] font-medium text-slate-700 text-left flex items-center justify-between outline-none hover:bg-slate-50 hover:border-slate-300 focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all duration-200 cursor-pointer shadow-sm shadow-slate-100/50">
                <span id="assignment-type-label" class="text-slate-700">Undangan</span>
                <svg id="assignment-type-arrow"
                  class="w-4 h-4 text-slate-400 stroke-[2] transition-transform duration-200" fill="none"
                  stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>

              <!-- OPTIONS MENU PANEL -->
              <div id="assignment-type-menu"
                class="hidden absolute z-30 w-full mt-2 bg-white border border-slate-200/50 rounded-xl shadow-xl shadow-slate-100/80 p-1.5 space-y-0.5 origin-top transform opacity-0 scale-95 transition-all duration-150 backdrop-blur-sm">

                <!-- OPTION: UNDANGAN -->
                <button type="button" onclick="selectAssignmentType('UNDANGAN', 'Undangan')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Undangan</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

                <!-- OPTION: INTERNAL -->
                <button type="button" onclick="selectAssignmentType('INTERNAL', 'Internal')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Internal</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

                <!-- OPTION: TRAINING -->
                <button type="button" onclick="selectAssignmentType('TRAINING', 'Training')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Training</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

                <!-- OPTION: LAINNYA -->
                <button type="button" onclick="selectAssignmentType('LAINNYA', 'Lainnya')"
                  class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                  <span>Lainnya</span>
                  <span
                    class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                </button>

              </div>
            </div>
          </div>

          <!-- LOCATION -->
          <div class="space-y-1.5">

            <label class="text-[13px] font-semibold text-slate-700">
              Lokasi
            </label>

            <input name="location" placeholder="Lokasi kegiatan"
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

          </div>

          <!-- DATE -->
          <div class="grid grid-cols-2 gap-4">

            <div class="space-y-1.5">

              <label class="text-[13px] font-semibold text-slate-700">
                Tanggal Mulai
              </label>

              <input type="date" name="startDate"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

            </div>

            <div class="space-y-1.5">

              <label class="text-[13px] font-semibold text-slate-700">
                Tanggal Selesai
              </label>

              <input type="date" name="endDate"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

            </div>

          </div>

          <!-- ATTACHMENT -->
          <div class="space-y-1.5">

            <label class="text-[13px] font-semibold text-slate-700">
              Surat Penugasan
              <span class="text-slate-400 font-normal">(opsional)</span>
            </label>

            <div class="relative group">

              <input type="file" name="attachment" id="file-input"
                class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                onchange="handleFileSelect(this)" />

              <!-- EMPTY -->
              <div id="dropzone-empty"
                class="border-2 border-dashed border-slate-200 rounded-xl py-8 flex flex-col items-center justify-center bg-slate-50 group-hover:bg-slate-100 group-hover:border-slate-300 transition-all">

                <svg class="w-8 h-8 text-slate-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
                    stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>

                <p class="text-sm text-slate-600 font-medium">
                  Klik untuk upload file
                </p>

                <p class="text-xs text-slate-400 mt-1">
                  PDF atau gambar dokumen
                </p>

              </div>

              <!-- FILLED -->
              <!-- FILLED -->
              <div id="dropzone-filled"
                class="hidden border border-slate-200 rounded-xl p-4 bg-white flex items-center justify-between shadow-sm">

                <div class="flex items-center gap-3">

                  <div
                    class="w-12 h-12 rounded-lg bg-slate-100 flex items-center justify-center overflow-hidden border border-slate-200">

                    <img id="img-preview" class="hidden w-full h-full object-cover" />

                    <svg id="doc-icon" class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor"
                      viewBox="0 0 24 24">
                      <path
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                        stroke-width="1.5" />
                    </svg>

                  </div>

                  <div class="overflow-hidden">
                    <p id="name-preview" class="text-sm font-medium text-slate-700 truncate max-w-[220px]">
                      file.pdf
                    </p>

                    <p id="size-preview" class="text-xs text-slate-400">
                      1.2 MB
                    </p>
                  </div>

                </div>

                <!-- ACTIONS -->
                <div class="flex items-center gap-2">

                  <a id="view-file-btn" href="#"
                    class="text-xs font-medium text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg transition">
                    View
                  </a>

                  <button type="button" onclick="changeFile()"
                    class="text-xs font-medium text-slate-600 hover:bg-slate-100 px-3 py-2 rounded-lg transition">
                    Change
                  </button>



                </div>

              </div>
            </div>

          </div>

          <!-- EMPLOYEE -->
          <div class="space-y-2">
            <label class="text-[13px] font-medium text-slate-500 block">Pilih Karyawan</label>

            <!-- SEARCH INPUT CONTAINER -->
            <div class="relative w-full">
              <!-- Ikon Kaca Pembesar (Search Icon) untuk memperkuat UI -->
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>

              <input type="text" id="employee-search" placeholder="Cari nama staf atau karyawan..."
                class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl pl-10 pr-4 py-3 text-[13px] font-medium text-slate-700 placeholder-slate-400 outline-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all duration-200 shadow-sm shadow-slate-100/50" />
            </div>

            <!-- SCROLLABLE LIST CONTAINER -->
            <div id="employee-list"
              class="border border-slate-200/60 rounded-xl p-1.5 max-h-64 overflow-y-auto bg-slate-50/50 space-y-0.5 shadow-inner shadow-slate-50">

              <% employees.forEach(e=> { %>
                <!-- EMPLOYEE ITEM ROW -->
                <label
                  class="employee-item flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white border border-transparent hover:border-slate-200/40 cursor-pointer transition-all duration-150 group"
                  data-name="<%= e.fullName.toLowerCase() %>">

                  <!-- MODERN CHECKBOX WITH ROYAL BLUE ACCENT -->
                  <input type="checkbox" name="employees" value="<%= e._id %>"
                    class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-100 focus:ring-offset-0 cursor-pointer accent-blue-600 transition-colors" />

                  <div class="flex flex-col">
                    <span class="text-[13px] font-medium text-slate-600 group-hover:text-slate-900 transition-colors">
                      <%= e.fullName %>
                    </span>
                  </div>
                </label>
                <% }) %>

            </div>

            <!-- HELPER TEXT -->
            <p class="text-[11px] text-slate-400 pl-1 leading-normal">
              Cari nama di atas, lalu centang satu atau beberapa karyawan yang akan didelegasikan.
            </p>
          </div>

          <!-- ACTION -->

          <div class="pt-6 border-t border-slate-100/80 flex items-center justify-end gap-3">

            <!-- BUTTON BATAL (SECONDARY ACTION) -->
            <a href="/assignment"
              class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-5 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
              Batal
            </a>

            <!-- BUTTON KIRIM (PRIMARY ACTION) -->
            <button type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all border border-blue-700/30 shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
              Kirim Penugasan
            </button>

          </div>


        </form>

      </div>

    </div>

  </div>

  <script>
    function handleFileSelect(input) {
      if (input.files && input.files[0]) {

        const file = input.files[0];

        document.getElementById("name-preview").textContent = file.name;

        document.getElementById("size-preview").textContent =
          (file.size / (1024 * 1024)).toFixed(2) + " MB";

        const fileUrl = URL.createObjectURL(file);
        document.getElementById("view-file-btn").href = fileUrl;

        const reader = new FileReader();

        if (file.type.startsWith("image/")) {

          reader.onload = e => {
            document.getElementById("img-preview").src = e.target.result;
            document.getElementById("img-preview").classList.remove("hidden");
            document.getElementById("doc-icon").classList.add("hidden");
          };

          reader.readAsDataURL(file);

        } else {
          document.getElementById("img-preview").classList.add("hidden");
          document.getElementById("doc-icon").classList.remove("hidden");
        }

        document.getElementById("dropzone-empty").classList.add("hidden");
        document.getElementById("dropzone-filled").classList.remove("hidden");
      }
    }
    function changeFile() {
      const input = document.getElementById("file-input");

      // reset supaya file yang sama bisa dipilih lagi
      input.value = "";

      input.click();
    }

    // SEARCH EMPLOYEE
    const searchInput = document.getElementById("employee-search");

    searchInput.addEventListener("keyup", function () {
      const keyword = this.value.toLowerCase();

      document.querySelectorAll(".employee-item").forEach(item => {
        const name = item.dataset.name;

        if (name.includes(keyword)) {
          item.style.display = "flex";
        } else {
          item.style.display = "none";
        }
      });
    });

    function toggleTypeDropdown() {
      const menu = document.getElementById('assignment-type-menu');
      const arrow = document.getElementById('assignment-type-arrow');

      if (menu.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        setTimeout(() => {
          menu.classList.remove('opacity-0', 'scale-95');
          menu.classList.add('opacity-100', 'scale-100');
        }, 10);
        arrow.classList.add('rotate-180');
      } else {
        closeTypeDropdown();
      }
    }

    function closeTypeDropdown() {
      const menu = document.getElementById('assignment-type-menu');
      const arrow = document.getElementById('assignment-type-arrow');

      menu.classList.remove('opacity-100', 'scale-100');
      menu.classList.add('opacity-0', 'scale-95');
      arrow.classList.remove('rotate-180');

      setTimeout(() => {
        menu.classList.add('hidden');
      }, 150);
    }

    function selectAssignmentType(value, label) {
      // Masukkan value ke hidden input form
      document.getElementById('assignment-type-value').value = value;

      // Perbarui teks di tombol trigger utama
      const labelEl = document.getElementById('assignment-type-label');
      labelEl.textContent = label;

      closeTypeDropdown();
    }

    // Otomatis menutup menu jika user mengklik di luar area dropdown tipe penugasan
    window.addEventListener('click', function (e) {
      const dropdown = document.getElementById('assignment-type-dropdown');
      if (dropdown && !dropdown.contains(e.target)) {
        closeTypeDropdown();
      }
    });
  </script>
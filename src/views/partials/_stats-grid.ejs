<% 
  const totalItems = items.length;
  let desktopGridCols = 'lg:grid-cols-3'; // default fallback
  
  if (totalItems === 4) {
    desktopGridCols = 'lg:grid-cols-4';
  } else if (totalItems === 2) {
    desktopGridCols = 'lg:grid-cols-2';
  }
%>

<div class="grid grid-cols-1 sm:grid-cols-2 <%= desktopGridCols %> gap-2.5 sm:gap-4 md:gap-5 w-full select-none">
  <% items.forEach(item => { %>
    
    <div class="<%= item.bgClass || 'bg-white' %> rounded-xl md:rounded-2xl p-3 md:p-5 flex items-center justify-between border border-slate-200/75 shadow-[0_1px_2px_0_rgba(0,0,0,0.02)] w-full min-w-0">
      
      <div class="space-y-0.5 md:space-y-1 min-w-0 flex-1">
        <span class="text-[10px] sm:text-[11px] md:text-[12px] font-medium <%= item.labelClass || 'text-slate-400' %> uppercase tracking-wider block whitespace-normal break-words leading-tight md:truncate">
          <%= item.label %>
        </span>
        
        <span class="text-base sm:text-lg md:text-2xl font-semibold <%= item.valueClass || 'text-slate-900' %> tracking-tight tabular-nums block truncate">
          <%= (typeof item.value !== 'undefined' && item.value !== null) ? item.value : 0 %> 
          <% if (item.unit) { %>
            <span class="text-[9px] sm:text-[10px] md:text-xs font-medium <%= item.unitClass || 'text-slate-500' %> inline-block ml-0.5"><%= item.unit %></span>
          <% } %>
        </span>
      </div>

      <div class="hidden md:flex w-11 h-11 rounded-xl items-center justify-center <%= item.iconBoxClass || 'bg-slate-50 text-slate-600' %> shrink-0 ml-3">
        <i class="<%= item.icon %> text-base"></i>
      </div>

    </div>

  <% }) %>
</div>
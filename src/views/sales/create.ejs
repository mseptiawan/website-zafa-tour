<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

    <div class="max-w-2xl mx-auto">

      <div class="mb-8">

        <nav class="flex items-center gap-2 mb-2 text-[11px] font-semibold text-slate-400 uppercase tracking-widest">
          <span>Area Kerja</span>
          <span class="text-slate-300">/</span>
          <span class="text-slate-900">Kunjungan</span>
        </nav>

        <h1 class="text-2xl font-bold text-slate-900">
          Catat Kunjungan
        </h1>

        <p class=" text-slate-500 mt-1 text-sm">
          Catat kunjungan customer, atau prospek
        </p>

      </div>

      <!-- CARD -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

        <form action="/sales/" method="POST" enctype="multipart/form-data" class="p-8 space-y-6">

          <% if (error) { %>
            <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm border border-red-100">
              <%= error %>
            </div>
            <% } %>

              <!-- TITLE -->
              <div class="space-y-1.5">

                <label class="text-[13px] font-bold text-slate-700">
                  Judul Kunjungan
                </label>

                <input type="text" name="title" required value="<%= old?.title || '' %>"
                  placeholder="Contoh: Mempererat kerjasama dengan mitra" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none transition-all" />

              </div>

              <!-- ADDRESS -->
              <div class="space-y-1.5">

                <label class="text-[13px] font-bold text-slate-700">
                  Alamat
                </label>

                <input type="text" name="address" required value="<%= old?.address || '' %>"
                  placeholder="Alamat lengkap customer" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none transition-all" />

              </div>

              <!-- MEET WITH -->
              <div class="space-y-1.5">

                <label class="text-[13px] font-bold text-slate-700">
                  Bertemu Dengan
                </label>

                <input type="text" name="meetWith" required value="<%= old?.meetWith || '' %>"
                  placeholder="M Septiawan" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none transition-all" />

              </div>

              <!-- RESULT -->
              <div class="space-y-1.5">

                <label class="text-[13px] font-bold text-slate-700">
                  Hasil Kunjungan
                </label>

                <textarea name="result" rows="5" maxlength="500" placeholder="Jelaskan hasil kunjungan" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none resize-none transition-all"><%= old?.result || '' %></textarea>

              </div>

              <!-- FILE -->
              <div class="space-y-1.5">
                <label class="block text-[13px] font-medium text-slate-700 mb-1.5">
                  Lampiran <span class="text-slate-400 font-normal">(Opsional)</span>
                </label>

                <!-- EMPTY STATE (Upload Box) -->
                <div id="dropzone-empty"
                  class="relative w-full border border-slate-200 border-dashed rounded-xl p-6 bg-white hover:bg-slate-50/50 transition flex flex-col items-center justify-center text-center">

                  <input type="file" name="attachments" id="file-input"
                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="handleFileSelect(this)" />

                  <svg class="w-5 h-5 text-slate-400 mb-2" fill="none" stroke="currentColor" stroke-width="1.5"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
                  </svg>

                  <span class="text-[13px] font-medium text-slate-600">
                    Pilih Berkas atau Drop File Disini
                  </span>

                  <span class="text-xs text-slate-400 mt-0.5">
                    PNG, JPG, PDF, atau DOCX (maks 5MB)
                  </span>
                </div>

                <!-- FILLED STATE (Preview Box) -->
                <div id="dropzone-filled"
                  class="hidden flex items-center justify-between border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-sm">

                  <div class="flex items-center gap-3 min-w-0 flex-1">
                    <!-- Thumbnail Preview (Image/Document Icon placeholder) -->
                    <div
                      class="w-10 h-10 rounded-lg overflow-hidden border border-slate-200 bg-slate-50 flex-shrink-0 flex items-center justify-center">
                      <img id="img-preview" class="w-full h-full object-cover hidden" />
                      <!-- Default Fallback Icon (for PDF/Docx or loading) -->
                      <svg id="file-icon-fallback" class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor"
                        stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                          d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                      </svg>
                    </div>

                    <div class="min-w-0 flex-1">
                      <div id="name-preview" class="text-[13px] font-medium text-slate-700 truncate">
                        file_name.jpg
                      </div>
                      <div id="size-preview" class="text-xs text-slate-400 mt-0.5">
                        0 KB
                      </div>
                    </div>
                  </div>

                  <!-- Action Buttons (View & Ganti File) -->
                  <div class="flex items-center gap-2 ml-4 flex-shrink-0">
                    <a id="view-file-btn" href="#" target="_blank"
                      class="text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100/70 px-2.5 py-1.5 rounded-lg transition">
                      View
                    </a>
                    <button type="button" onclick="triggerChangeFile()"
                      class="text-xs font-medium text-slate-600 bg-slate-50 hover:bg-slate-100 px-2.5 py-1.5 rounded-lg transition">
                      Ganti File
                    </button>
                  </div>

                </div>
              </div>

              <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">

                <!-- BUTTON BATAL -->
                <a href="/sales/my"
                  class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
                  Batal
                </a>

                <!-- BUTTON SIMPAN KUNJUNGAN (Sesuai Warna Standar Biru) -->
                <button type="submit"
                  class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
                  Simpan
                </button>

              </div>
        </form>

      </div>

    </div>

  </div>
  <script>
    let currentFileUrl = null;

    function handleFileSelect(input) {
      if (input.files && input.files.length > 0) {
        const file = input.files[0];

        // Revoke URL lama jika ada untuk menghindari memory leak
        if (currentFileUrl) {
          URL.revokeObjectURL(currentFileUrl);
        }

        // Buat blob URL untuk tombol View
        currentFileUrl = URL.createObjectURL(file);
        const viewBtn = document.getElementById("view-file-btn");
        viewBtn.href = currentFileUrl;

        // Set text nama dan ukuran file (Konversi ke KB / MB yang dinamis & rapi)
        document.getElementById("name-preview").textContent = file.name;

        const fileSizeInKB = file.size / 1024;
        if (fileSizeInKB < 1024) {
          document.getElementById("size-preview").textContent = fileSizeInKB.toFixed(1) + " KB";
        } else {
          document.getElementById("size-preview").textContent = (fileSizeInKB / 1024).toFixed(2) + " MB";
        }

        // Handle Thumbnail Preview
        const imgPreview = document.getElementById("img-preview");
        const fileIconFallback = document.getElementById("file-icon-fallback");

        if (file.type.startsWith("image/")) {
          imgPreview.src = currentFileUrl;
          imgPreview.classList.remove("hidden");
          fileIconFallback.classList.add("hidden");
        } else {
          imgPreview.src = "";
          imgPreview.classList.add("hidden");
          fileIconFallback.classList.remove("hidden");
        }

        // Toggle container visibility
        document.getElementById("dropzone-empty").classList.add("hidden");
        document.getElementById("dropzone-filled").classList.remove("hidden");
      }
    }

    function triggerChangeFile() {
      document.getElementById("file-input").click();
    }
  </script>
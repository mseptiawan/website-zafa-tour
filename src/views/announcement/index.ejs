<%- layout('layouts/main', { title }) %>

<div class="ml-0  min-h-screen md:ml-72 md:bg-[#FCFCFD] p-4 md:p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
  <div class="w-full max-w-none mx-auto mt-16 md:mt-0">

  <%- include('../partials/page-header', { 
    section: 'Area Kerja', 
    module: 'Informasi', 
    title: 'Pengumuman', 
    description: 'Pantau seluruh informasi internal, kebijakan manajemen, dan rilis berita terbaru perusahaan.' 
}) %>

    
<% if(announcements.length > 0) { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6 w-full">

    <% announcements.forEach(a => { %>
      <a href="/announcement/<%= a._id %>"
         class="group relative flex sm:flex-col justify-between  rounded-xl sm:rounded-2xl p-4 sm:p-6 transition-all duration-300  border-l-4 border-slate-800 md:border-none shadow-xs md:shadow-sm  min-h-0 sm:min-h-[200px] w-full items-center sm:items-stretch gap-4 sm:gap-0">

        <div class="flex-1 min-w-0 sm:flex-initial">
          <div class="flex items-center gap-1.5 mb-1.5 sm:mb-3 flex-wrap">
            <% if(a.isPinned) { %>
              <span class="inline-flex items-center gap-0.5 bg-amber-50 text-amber-700 px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-md sm:rounded-lg text-[9px] sm:text-[10px] font-bold tracking-wider uppercase">
                📌 Pinned
              </span>
            <% } %>

            <% if(a.category === "OFFICIAL") { %>
              <span class="inline-flex items-center bg-blue-50 text-blue-700 px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-md sm:rounded-lg text-[9px] sm:text-[10px] font-bold tracking-wider uppercase">
                Official
              </span>
            <% } else { %>
              <span class="inline-flex items-center bg-slate-50 text-slate-600 px-1.5 py-0.5 sm:px-2.5 sm:py-1 rounded-md sm:rounded-lg text-[9px] sm:text-[10px] font-bold tracking-wider uppercase">
                General
              </span>
            <% } %>
          </div>

         <h2 class="text-[14px] sm:text-[14px] font-semibold text-slate-800 leading-normal break-words mb-1 sm:mb-2 transition-colors line-clamp-1 sm:line-clamp-2">
  <%= a.title %>
</h2>

    <p class="hidden sm:block text-[13px] text-slate-500 leading-relaxed mb-4" 
   style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
  <%= a.content %>
</p>
          <div class="block sm:hidden text-[11px] text-slate-400 font-medium">
            <%= a.createdBy?.employeeData?.fullName || 'Anonim' %> • <%= new Date(a.createdAt).toLocaleDateString("id-ID", { day: "2-digit", month: "short" }) %>
          </div>
        </div>

        <div class="pt-0 sm:pt-4 flex items-center justify-between flex-shrink-0 border-t border-transparent sm:border-slate-50">
          <div class="hidden sm:flex items-center gap-3 min-w-0">
            <div class="w-7 h-7 rounded-lg bg-slate-50 flex-shrink-0 flex items-center justify-center text-[11px] font-bold text-slate-700 uppercase  transition-colors">
              <%= a.createdBy?.employeeData?.fullName ? a.createdBy?.employeeData.fullName.charAt(0) : '?' %>
            </div>

            <div class="flex flex-col min-w-0">
              <span class="text-[12px] font-bold text-slate-800 truncate">
                <%= a.createdBy?.employeeData?.fullName || 'Tidak Diketahui' %>
              </span>
              <span class="text-[11px] text-slate-400 font-medium core-date">
                <%= new Date(a.createdAt).toLocaleDateString("id-ID", { day: "2-digit", month: "short", year: "numeric" }) %>
              </span>
            </div>
          </div>

          <div class="w-7 h-7 rounded-lg bg-slate-50 flex items-center justify-center  transition-all duration-200">
            <svg class="w-3.5 h-3.5 text-slate-400  transform  transition-all duration-200 stroke-[2.5]"
              fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>

      </a>
    <% }) %>

  </div>
<% } else { %>
      <div class="bg-white  rounded-2xl py-20 text-center ">
        <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-slate-400 ">
          <svg class="w-6 h-6 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-slate-800">Belum Ada Pengumuman</h3>
        <p class="text-slate-400 text-[12px] mt-1 max-w-xs mx-auto">Seluruh rilis informasi internal penting dari manajemen akan tampil di sini.</p>
      </div>
    <% } %>

   <% if (pagination.totalPages > 1) { %>
  <!-- Jarak atas diperdekat (mt-8), tanpa background, dan rata kanan (justify-end) -->
  <div class="flex items-center justify-end mt-8 w-full border-t border-slate-100 pt-2 ">
    
    <!-- Hanya tombol navigasi Next & Prev -->
    <div class="flex items-center gap-6">
      <a href="?page=<%= pagination.page - 1 %>"
         class="py-1 text-[12px] font-semibold transition-all flex items-center gap-1.5 <%= pagination.hasPrev ? 'text-slate-600 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %>">
        <svg class="w-3.5 h-3.5 stroke-[2.3]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Prev
      </a>

      <a href="?page=<%= pagination.page + 1 %>"
         class="py-1 text-[12px] font-semibold transition-all flex items-center gap-1.5 <%= pagination.hasNext ? 'text-slate-600 hover:text-slate-900' : 'text-slate-300 pointer-events-none' %>">
        Next
        <svg class="w-3.5 h-3.5 stroke-[2.3]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

  </div>
<% } %>

  </div>
</div>
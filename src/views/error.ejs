<%- layout('layouts/main', { title: 'Terjadi Kesalahan' }) %>
<div class="ml-72 min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-50/70 p-8 flex items-center justify-center antialiased">
  <div class="max-w-md w-full text-center">
    
    <!-- Ilustrasi / Icon Anggun -->
    <div class="mb-6 inline-flex items-center justify-center h-16 w-16 rounded-2xl bg-rose-50 border border-rose-100 shadow-sm animate-pulse">
      <span class="text-3xl">⚠️</span>
    </div>

    <!-- Judul Error -->
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900 mb-2">
      Oops! Terjadi Kendala Sistem
    </h1>
    
    <p class="text-sm text-slate-500 mb-6">
      Aplikasi mengalami kesalahan saat memproses permintaan Anda. Jangan khawatir, detail teknis telah dicatat untuk diperbaiki.
    </p>

    <!-- Box Detail Error (Hanya muncul jika ada message) -->
    <div class="bg-slate-50 border border-slate-200/80 rounded-2xl p-4 mb-8 text-left shadow-inner max-h-40 overflow-y-auto custom-scrollbar">
      <span class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Pesan Error:</span>
      <p class="text-xs font-mono text-rose-600 break-words leading-relaxed">
        <%= typeof message !== 'undefined' ? message : 'Unknown system error occurred.' %>
      </p>
    </div>

    <!-- Tombol Navigasi Aksi -->
    <div class="flex items-center justify-center gap-3">
      <button onclick="window.history.back()" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-xs font-semibold text-slate-600 shadow-sm hover:bg-slate-50 transition-all duration-200 cursor-pointer">
        Kembali ke Halaman Sebelumnya
      </button>
      
      <a href="/dashboard" class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-xs font-semibold text-white shadow-sm hover:bg-slate-800 transition-all duration-200">
        Menu Utama
      </a>
    </div>

  </div>
</div>

<style>
  /* Kustomisasi scrollbar mini untuk box error code */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>
<div class="overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-xs">
  
  <div class="hidden md:block overflow-x-auto">
    <table class="w-full min-w-[900px] text-sm text-left border-collapse">
      <thead class="border-b border-slate-100 bg-slate-50 text-[11px] tracking-wider text-slate-400 uppercase font-bold">
        <tr>
          <th class="px-6 py-4">Pegawai</th>
          <th class="px-6 py-4">Tgl Lembur</th>
          <th class="px-6 py-4 text-center">Jam</th>
          <th class="px-6 py-4 text-center">Durasi</th>
          <th class="px-6 py-4 text-center">Status</th>
          <% if (type === 'history') { %><th class="px-6 py-4 text-center">Tgl Proses</th><% } %>
          <th class="px-6 py-4 text-right pr-8">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 text-[13px]">
        <% if (overtimes.length === 0) { %>
          <tr><td colspan="<%= type === 'active' ? 6 : 7 %>" class="py-16 text-center text-slate-400">Belum ada data</td></tr>
        <% } else { %>
          <% overtimes.forEach(o => { %>
            <tr>
              <td class="px-6 py-4 font-semibold text-slate-800"><%= o.employeeName %></td>
              <td class="px-6 py-4 text-slate-600"><%= new Date(o.date).toLocaleDateString('id-ID') %></td>
              <td class="px-6 py-4 text-center font-medium"><%= o.startTime %> - <%= o.endTime %></td>
              <td class="px-6 py-4 text-center font-bold text-blue-600"><%= o.totalHours %> Jam</td>
              <td class="px-6 py-4 text-center">
                 <span class="px-2.5 py-1 rounded-full bg-amber-50 text-amber-700 text-[10px] font-bold"><%= o.status %></span>
              </td>
              <% if (type === 'history') { %><td class="px-6 py-4 text-center">-</td><% } %>
              <td class="px-6 py-4 text-right pr-8">
                <a href="/overtime/detail/<%= o._id %>" class="text-blue-600 hover:underline font-semibold">Detail</a>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="block md:hidden p-4 space-y-3">
    <% if (overtimes.length === 0) { %>
      <div class="py-10 text-center text-slate-400 text-sm">Belum ada data</div>
    <% } else { %>
      <% overtimes.forEach(o => { %>
        <div class="bg-slate-50/50 border border-slate-200 rounded-2xl p-4">
          <div class="flex justify-between items-start mb-3">
            <div>
              <h3 class="font-bold text-slate-800"><%= o.employeeName %></h3>
              <p class="text-[11px] text-slate-500"><%= new Date(o.date).toLocaleDateString('id-ID') %></p>
            </div>
            <span class="text-[10px] px-2 py-1 rounded-full bg-amber-50 text-amber-700 font-bold"><%= o.status %></span>
          </div>
          <div class="grid grid-cols-2 gap-2 text-xs mb-4">
            <div class="bg-white p-2 rounded-lg border border-slate-100">
              <p class="text-slate-400 text-[10px]">Jam</p>
              <p class="font-semibold text-slate-700"><%= o.startTime %> - <%= o.endTime %></p>
            </div>
            <div class="bg-white p-2 rounded-lg border border-slate-100">
              <p class="text-slate-400 text-[10px]">Durasi</p>
              <p class="font-semibold text-blue-600"><%= o.totalHours %> Jam</p>
            </div>
          </div>
          <div class="flex gap-2">
            <a href="/overtime/detail/<%= o._id %>" class="flex-1 h-9 rounded-xl border border-slate-200 flex items-center justify-center text-xs font-semibold hover:bg-white transition-all">Detail</a>
            <% if(o.status === 'Pending Manager') { %>
              <button class="flex-1 h-9 rounded-xl bg-blue-600 text-white text-xs font-semibold shadow-md active:scale-[0.98]">Approve</button>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
<%- layout('layouts/main', { title: 'Catat Lembur' }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] p-4 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto mt-4 md:mt-0 space-y-5">

    <div class="mb-5 border-b border-slate-200/60 pb-5">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Lembur', 
          title: 'Catat Lembur', 
          description: 'Isi rincian detail lembur yang dilakukan secara aktual.' 
      }) %>
    </div>

    <div class="bg-white border-0 md:border md:border-slate-200/60 rounded-2xl shadow-3xs overflow-hidden max-w-2xl">
      
      <% if (errors && Object.keys(errors).length > 0) { %>
        <div class="m-4 sm:m-6 md:m-8 mb-0 p-3.5 bg-rose-50 border border-rose-100 rounded-xl shadow-3xs">
          <ul class="space-y-1">
            <% Object.values(errors).forEach(function(message) { %>
              <li class="text-[11.5px] font-semibold text-rose-600 list-none flex items-center gap-1.5">
                <i class="fa-solid fa-circle-exclamation text-[10px]"></i> <%= message %>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>
      
      <form id="overtime-form" action="/overtime/" method="POST" enctype="multipart/form-data" class="p-4 sm:p-6 md:p-8 space-y-5">

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Tanggal Lembur <span class="text-rose-500">*</span>
          </label>
          <input
            type="date"
            id="dateInput"
            name="date"
            required
            min="<%= dateLimit.min %>"
            max="<%= dateLimit.max %>"
            class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs cursor-pointer"
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">Jam Mulai <span class="text-rose-500">*</span></label>
            <input type="text" id="startTime" name="startTime" required placeholder="16:30" class="timepicker w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 focus:bg-white focus:border-slate-400 outline-none transition-colors shadow-3xs cursor-pointer" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">Jam Selesai <span class="text-rose-500">*</span></label>
            <input type="text" id="endTime" name="endTime" required placeholder="21:00" class="timepicker w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 focus:bg-white focus:border-slate-400 outline-none transition-colors shadow-3xs cursor-pointer" />
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Pekerjaan Yang Dilakukan <span class="text-rose-500">*</span>
          </label>
          <textarea name="workDescription" required rows="4" minlength="10" maxlength="500" placeholder="Jelaskan rincian agenda tugas pekerjaan lembur Anda secara mendetail..." class="w-full bg-slate-50 border border-slate-200/80 rounded-xl px-4 py-3 text-[12.5px] font-medium text-slate-800 outline-none resize-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs"></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">Lokasi Kerja <span class="text-rose-500">*</span></label>
            <div class="relative">
              <select id="locationType" name="location[type]" required class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-700 outline-none focus:bg-white focus:border-slate-400 transition-colors cursor-pointer appearance-none shadow-3xs">
                <option value="OFFICE">Kantor (Office)</option>
                <option value="REMOTE">Remote (WFH)</option>
                <option value="CLIENT_SITE">Lokasi Klien (Client Site)</option>
                <option value="OTHER">Lainnya</option>
              </select>
              <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-400">
                <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </div>
            </div>
          </div>

          <div class="space-y-1.5">
            <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">Detail Lokasi <span class="text-rose-500">*</span></label>
            <input type="text" id="locationDetail" name="location[detail]" required placeholder="Contoh: Gedung A atau Alamat Klien" class="w-full h-11 bg-slate-50 border border-slate-200/80 rounded-xl px-4 text-[12.5px] font-semibold text-slate-800 outline-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs" />
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Hasil <span class="text-slate-400 font-normal lowercase">((opsional))</span>
          </label>
          <textarea name="result" rows="3" minlength="10" maxlength="500" placeholder="Hasil atau output yang dicapai dari pengerjaan lembur..." class="w-full bg-slate-50 border border-slate-200/80 rounded-xl px-4 py-3 text-[12.5px] font-medium text-slate-800 outline-none resize-none focus:bg-white focus:border-slate-400 transition-colors shadow-3xs"></textarea>
        </div>

        <div class="space-y-1.5">
          <label class="block text-[12px] font-semibold text-slate-700 uppercase tracking-wide">
            Bukti Lampiran <span class="text-slate-400 font-normal lowercase">((opsional))</span>
          </label>

          <div id="dropzone-empty" class="relative w-full border border-dashed rounded-xl p-6 bg-slate-50/20 hover:bg-slate-50 border-slate-200 transition-colors flex flex-col items-center justify-center text-center shadow-3xs">
            <input type="file" name="proofFile" id="file-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="handleFileSelect(this)" />
            <svg class="w-4 h-4 text-slate-400 mb-1.5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
            </svg>
            <span class="text-[12px] font-semibold text-slate-700">Pilih Berkas atau Tarik File Kemari</span>
            <span class="text-[10.5px] text-slate-400 mt-0.5">PNG, JPG, PDF, atau DOCX (Maksimal 5MB)</span>
          </div>

          <div id="dropzone-filled" class="hidden flex items-center justify-between border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-3xs">
            <div class="flex items-center gap-3 min-w-0 flex-1">
              <div class="w-8 h-8 rounded-lg overflow-hidden border border-slate-200 bg-slate-50 flex-shrink-0 flex items-center justify-center shadow-3xs">
                <img id="img-preview" class="w-full h-full object-cover hidden" />
                <svg id="file-icon-fallback" class="w-4 h-4 text-slate-400 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <div id="name-preview" class="text-[12px] font-semibold text-slate-700 truncate">
                  file_name.jpg
                </div>
                <div id="size-preview" class="text-[10.5px] text-slate-400 font-medium leading-none mt-0.5">
                  0 KB
                </div>
              </div>
            </div>
            <div class="flex items-center gap-1.5 ml-4 flex-shrink-0">
              <a id="view-file-btn" href="#" target="_blank" class="h-7 text-[11px] font-semibold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 px-2.5 rounded-lg transition inline-flex items-center justify-center">
                Lihat
              </a>
              <button type="button" onclick="triggerChangeFile()" class="h-7 text-[11px] font-semibold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 px-2.5 rounded-lg transition cursor-pointer">
                Ganti
              </button>
            </div>
          </div>
        </div>

        <div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-2.5">
          <a href="/overtime/my" class="inline-flex items-center justify-center h-9 bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 rounded-xl px-5 text-[11.5px] font-semibold transition-all active:scale-[0.99]">
            Batal
          </a>
          <button type="submit" class="bg-slate-900 hover:bg-black text-white h-9 px-6 rounded-xl text-[11.5px] font-semibold transition-all active:scale-[0.99] cursor-pointer shadow-3xs outline-none">
            Kirim Pengajuan
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
  let currentFileUrl = null;

  function handleFileSelect(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];

      if (currentFileUrl) {
        URL.revokeObjectURL(currentFileUrl);
      }

      currentFileUrl = URL.createObjectURL(file);
      const viewBtn = document.getElementById("view-file-btn");
      viewBtn.href = currentFileUrl;

      document.getElementById("name-preview").textContent = file.name;

      const fileSizeInKB = file.size / 1024;
      if (fileSizeInKB < 1024) {
        document.getElementById("size-preview").textContent = fileSizeInKB.toFixed(1) + " KB";
      } else {
        document.getElementById("size-preview").textContent = (fileSizeInKB / 1024).toFixed(2) + " MB";
      }

      const imgPreview = document.getElementById("img-preview");
      const fileIconFallback = document.getElementById("file-icon-fallback");

      if (file.type.startsWith("image/")) {
        imgPreview.src = currentFileUrl;
        imgPreview.classList.remove("hidden");
        fileIconFallback.classList.add("hidden");
      } else {
        imgPreview.src = "";
        imgPreview.classList.add("hidden");
        fileIconFallback.classList.remove("hidden");
      }

      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
    }
  }

  function triggerChangeFile() {
    document.getElementById("file-input").click();
  }
</script>

<script>
  flatpickr(".timepicker", {
    enableTime: true,
    noCalendar: true,
    dateFormat: "H:i",
    time_24hr: true,
    minTime: "16:30",
    maxTime: "23:59",
  });
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const dateInput = document.getElementById("dateInput");
  dateInput.min = dateInput.getAttribute("min");
  dateInput.max = dateInput.getAttribute("max");
});
</script>

<script>
  const locationType = document.getElementById('locationType');
  const locationDetail = document.getElementById('locationDetail');

  function updateDetailLocation() {
    if (locationType.value === 'OFFICE') {
      locationDetail.value = 'Kantor pusat zafa tour palembang';
    } else {
      if (locationDetail.value === 'Kantor pusat zafa tour palembang') {
          locationDetail.value = '';
      }
    }
  }

  locationType.addEventListener('change', updateDetailLocation);
  document.addEventListener('DOMContentLoaded', updateDetailLocation);
</script>

<script>
  document.getElementById('overtime-form').addEventListener('submit', function (e) {
    const startTimeRaw = document.getElementById('startTime').value;
    const endTimeRaw = document.getElementById('endTime').value;

    if (startTimeRaw && endTimeRaw) {
      const [startHour, startMin] = startTimeRaw.split(':').map(Number);
      const [endHour, endMin] = endTimeRaw.split(':').map(Number);

      const totalStartMinutes = startHour * 60 + startMin;
      const totalEndMinutes = endHour * 60 + endMin;

      if (totalEndMinutes <= totalStartMinutes) {
        e.preventDefault(); 
        alert('Jam Selesai lembur harus lebih besar dari Jam Mulai!');
        return false;
      }
    }
  });
</script>
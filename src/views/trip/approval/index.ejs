<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8">

    <div class="mb-6">
      <h2 class="text-2xl font-semibold text-slate-800">
        Persetujuan Dinas Luar
      </h2>

      <p class="text-sm text-slate-500 mt-1">
        Kelola dan tinjau semua pengajuan perjalanan dinas tim Anda
      </p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">

      <div class="overflow-x-auto">

        <table class="w-full min-w-[900px] text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
            <tr>
              <th class="px-6 py-4 text-left">Pengaju</th>
              <th class="px-6 py-4 text-left">Judul</th>
              <th class="px-6 py-4 text-left">Tujuan</th>

              <% if (user.role==="HR" ) { %>
                <th class="px-6 py-4 text-left">Delegasi</th>
                <% } %>

                  <th class="px-6 py-4 text-left">Budget</th>
                  <th class="px-6 py-4 text-left">Status</th>
                  <th class="px-6 py-4 text-center">Aksi</th>
            </tr>
          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (trips.length===0) { %>
              <tr>
                <td colspan="10" class="text-center py-10 text-slate-400">
                  Tidak ada pengajuan
                </td>
              </tr>
              <% } %>

                <% trips.forEach(t=> { %>
                  <tr class="hover:bg-slate-50 transition">

                    <!-- PENGAJU -->
                    <td class="px-6 py-4 font-medium text-slate-700">
                      <%= t.userId?.username || '-' %>
                    </td>

                    <!-- JUDUL -->
                    <td class="px-6 py-4 text-slate-600">
                      <%= t.title %>
                    </td>

                    <!-- TUJUAN -->
                    <td class="px-6 py-4 text-slate-500">
                      <%= t.destination || '-' %>
                    </td>

                    <!-- DELEGASI -->
                    <% if (user.role==="HR" ) { %>
                      <td class="px-6 py-4">
                        <% if (t.delegation?.active) { %>
                          <span
                            class="text-xs px-3 py-1 rounded-full bg-amber-50 text-amber-700 border border-amber-200">
                            Pimpinan → HR
                          </span>
                          <% } else { %>
                            <span class="text-slate-400">-</span>
                            <% } %>
                      </td>
                      <% } %>

                        <!-- BUDGET -->
                        <td class="px-6 py-4 font-medium text-slate-700">
                          Rp <%= (t.budget || 0).toLocaleString('id-ID') %>
                        </td>

                        <!-- STATUS -->
                        <td class="px-6 py-4">
                          <span class="
                  text-xs px-3 py-1 rounded-md border font-medium
                  <%= t.status === 'APPROVED'
                    ? 'bg-emerald-50 text-emerald-600 border-emerald-200'
                    : t.status === 'REJECTED'
                      ? 'bg-red-50 text-red-600 border-red-200'
                      : 'bg-blue-50 text-blue-600 border-blue-200'
                  %>
                ">
                            <%= t.status %>
                          </span>
                        </td>

                        <!-- AKSI -->
                        <td class="px-6 py-4 text-center">

                          <a href="/trip/approval/<%= t._id %>" title="Tinjau"
                            class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 transition">

                            <!-- eye icon -->
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7
           -1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>

                          </a>

                        </td>

                  </tr>
                  <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </div>
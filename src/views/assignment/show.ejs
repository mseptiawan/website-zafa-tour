<%- layout('layouts/main', { title }) %>

<div class=" min-h-screen bg-slate-50/60 p-8 antialiased">
  <div class="max-w-4xl mx-auto">

    <a href="/assignment"
      class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 mb-6 transition-colors group">
      <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Kembali ke Daftar
    </a>

    <div class="bg-white border border-slate-200/60 rounded-2xl shadow-[0_4px_20px_-5px_rgba(0,0,0,0.05)] overflow-hidden">
      
      <div class="px-8 py-6 border-b border-slate-100 flex items-start justify-between bg-white gap-6">
        <div>
          <h1 class="text-[17px] font-semibold text-slate-900 tracking-tight leading-none mb-2"><%= assignment.title %></h1>
          <p class="text-[12px] font-medium text-slate-500 uppercase tracking-wider">Tipe: <%= assignment.type %></p>
        </div>
        <span class="px-3 py-1 rounded-full font-semibold text-[10px] uppercase tracking-wider border <%= new Date(assignment.endDate) >= new Date() ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-slate-100 text-slate-600 border-slate-200' %>">
          <%= new Date(assignment.endDate) >= new Date() ? 'Active' : 'Completed' %>
        </span>
      </div>

      <div class="p-8 space-y-8">
        <div class="grid grid-cols-2 gap-x-12 gap-y-6">
          <div>
            <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Lokasi Tujuan</div>
            <div class="text-[15px] font-semibold text-slate-900"><%= assignment.location || '-' %></div>
          </div>
          <div>
            <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Durasi</div>
            <div class="text-[15px] font-semibold text-slate-900">
              <%= new Date(assignment.startDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %> 
              - 
              <%= new Date(assignment.endDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
            </div>
          </div>
        </div>

        <div class="relative pl-5 border-l-2 border-slate-200">
          <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-2">Deskripsi Penugasan</div>
          <p class="text-[13px] text-slate-600 leading-relaxed italic">"<%= assignment.description || 'Tidak ada deskripsi tambahan.' %>"</p>
        </div>

        <div class="pt-6 border-t border-slate-100">
          <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-3">Pegawai Ditugaskan</div>
          <div class="flex flex-wrap gap-2">
            <% assignment.employees.forEach(e => { %>
              <span class="inline-flex items-center gap-1.5 bg-slate-50 border border-slate-100 text-slate-700 text-[11px] font-semibold px-3 py-1.5 rounded-lg">
                <i class="fa-solid fa-user text-[10px] text-slate-400"></i> <%= e.fullName %>
              </span>
            <% }) %>
          </div>
        </div>

        <% if (assignment.attachment) { %>
        <div class="pt-6 border-t border-slate-100">
          <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-3">Surat Perintah Kerja (SPK)</div>
          <div class="flex items-center justify-between border border-slate-100 rounded-xl p-3 bg-slate-50/50 hover:border-slate-300 transition-colors">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-400"><i class="fa-solid fa-file-pdf text-[12px]"></i></div>
              <span class="text-[12px] font-medium text-slate-700">Lampiran_Penugasan.pdf</span>
            </div>
            <a href="/uploads/files/<%= assignment.attachment %>" target="_blank" class="text-[10px] font-semibold text-blue-600 bg-blue-50 px-3 py-1.5 rounded-lg hover:bg-blue-100 transition-colors">VIEW</a>
          </div>
        </div>
        <% } %>

      </div>
    </div>
  </div>
</div>
<% 
  // HELPER MAPPING UNTUK STATUS BADGE STYLE
  const getStatusConfig = (status, currentType) => {
    const activeStatus = currentType === 'active' ? 'PENDING' : status;
    switch(activeStatus) {
      case 'APPROVED':
        return { label: 'Bersedia', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500' };
      case 'REJECTED':
        return { label: 'Ditolak', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' };
      case 'PENDING':
      default:
        return { label: 'Menunggu Konfirmasi', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500 animate-pulse' };
    }
  };
%>

<!-- =========================================================================
     VIEW DESKTOP (Lebar layar >= md)
     ========================================================================= -->
<div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse text-[13px]">
      <thead>
        <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
          <th class="py-4 px-6">Rekan Kerja</th>
          <th class="py-4 px-6">Jenis Cuti</th>
          <th class="py-4 px-6 text-center">Durasi Kerja</th>
          <th class="py-4 px-6">Tanggal Pelaksanaan</th>
          <th class="py-4 px-6 text-center">Status Konfirmasi</th>
          <th class="py-4 px-6 text-center">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
        <% if (delegations.length === 0) { %>
          <tr>
            <td colspan="6" class="py-12 text-center text-slate-400 font-medium">
              <%= type === 'active' ? 'Tidak ada permintaan delegasi aktif saat ini.' : 'Belum ada riwayat konfirmasi delegasi tugas.' %>
            </td>
          </tr>
        <% } else { %>
          <% delegations.forEach(del => { %>
            <% const config = getStatusConfig(del.status, type); %>
            <tr class="hover:bg-slate-50/50 transition-colors">
              <!-- Kolom Rekan Kerja -->
              <td class="py-4 px-6">
                <span class="font-semibold text-slate-800 block text-[13px]">
                  <%= (del.leaveId && del.leaveId.userId && del.leaveId.userId.employeeData) ? del.leaveId.userId.employeeData.fullName : '-' %>
                </span>
              </td>
              <!-- Kolom Jenis Cuti -->
              <td class="py-4 px-6 font-medium text-slate-500">
                <%= (del.leaveId && del.leaveId.leaveTypeId) ? del.leaveId.leaveTypeId.name : '-' %>
              </td>
              <!-- Kolom Durasi -->
              <td class="py-4 px-6 text-center text-slate-800 font-semibold">
                <%= del.leaveId ? del.leaveId.totalDays : 0 %> Hari
              </td>
              <!-- Kolom Tanggal Pelaksanaan -->
              <td class="py-4 px-6 font-medium text-slate-500 whitespace-nowrap tabular-nums">
                <% if (del.leaveId && del.leaveId.startDate && del.leaveId.endDate) { %>
                  <%= new Date(del.leaveId.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                  <%= new Date(del.leaveId.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                <% } else { %> - <% } %>
              </td>
              <!-- Kolom Status -->
              <td class="py-4 px-6 text-center select-none">
                <div class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wide border <%= config.badge %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                  <span><%= config.label.toUpperCase() %></span>
                </div>
              </td>
              <!-- Kolom Aksi -->
              <td class="py-4 px-6">
                <div class="flex items-center justify-center">
                  <% if (del.leaveId) { %>
                    <a href="/leave/detail/<%= del.leaveId._id %>" title="<%= type === 'active' ? 'Tinjau Berkas' : 'Lihat Detail' %>" 
                       class="inline-flex h-8 px-4 items-center justify-center gap-1.5 rounded-lg border border-slate-200 bg-white text-xs font-semibold text-slate-600 transition-all active:scale-[0.95] hover:bg-slate-50 hover:text-slate-800">
                      <span><%= type === 'active' ? 'Tinjau' : 'Detail' %></span>
                      <% if (type === 'active') { %>
                        <i class="fa-solid fa-chevron-right text-[10px] text-slate-400"></i>
                      <% } %>
                    </a>
                  <% } else { %>
                    <span class="text-xs text-slate-400">-</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- =========================================================================
     VIEW MOBILE / CARD LAYOUT (Lebar layar < md)
     ========================================================================= -->
<div class="block md:hidden space-y-3.5 w-full">
  <% if (delegations.length === 0) { %>
    <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
      <p class="text-[12px] font-medium text-slate-400">
        <%= type === 'active' ? 'Tidak ada permintaan delegasi aktif' : 'Belum ada riwayat konfirmasi' %>
      </p>
    </div>
  <% } else { %>
    <% delegations.forEach(del => { %>
      <% const config = getStatusConfig(del.status, type); %>
      <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5">
        
        <!-- Header Kartu: Nama & Status -->
        <div class="flex items-start justify-between gap-2">
          <div>
            <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight">
              <%= (del.leaveId && del.leaveId.userId && del.leaveId.userId.employeeData) ? del.leaveId.userId.employeeData.fullName : '-' %>
            </h4>
            <p class="text-[11px] text-slate-400 font-medium mt-0.5">
              <%= (del.leaveId && del.leaveId.leaveTypeId) ? del.leaveId.leaveTypeId.name : '-' %>
            </p>
          </div>
          <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-medium tracking-wider border shrink-0 <%= config.badge %>">
            <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
            <span><%= type === 'active' ? 'PENDING' : config.label %></span>
          </div>
        </div>

        <!-- Detail Konten Box -->
        <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
          <div>
            <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Periode Pelaksanaan</p>
            <p class="text-[11px] font-semibold text-slate-700 mt-0.5 whitespace-nowrap tabular-nums">
              <% if (del.leaveId && del.leaveId.startDate && del.leaveId.endDate) { %>
                <%= new Date(del.leaveId.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                <%= new Date(del.leaveId.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %>
              <% } else { %> - <% } %>
            </p>
          </div>
          <div class="text-right">
            <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Durasi Backup</p>
            <p class="text-[13px] font-semibold text-blue-600 mt-0.5 tabular-nums"><%= del.leaveId ? del.leaveId.totalDays : 0 %> Hari</p>
          </div>
        </div>

        <!-- Bagian Aksi Bawah -->
        <div class="flex items-center justify-between gap-2 pt-0.5">
          <span class="text-[11px] font-medium text-slate-400">
            <i class="fa-solid fa-briefcase text-slate-300 mr-1"></i>Delegasi Tugas
          </span>
          <% if (del.leaveId) { %>
            <a href="/leave/detail/<%= del.leaveId._id %>" 
               class="h-8 px-4 <%= type === 'active' ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-700 border border-slate-200' %> text-[11px] font-medium rounded-lg flex items-center justify-center tracking-wide active:scale-95">
              <%= type === 'active' ? 'TINJAU' : 'LIHAT DETAIL' %>
            </a>
          <% } %>
        </div>

      </div>
    <% }) %>
  <% } %>
</div>
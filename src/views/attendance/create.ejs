<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">
  <div class="max-w-xl mx-auto">
    <div class="mb-8 text-center">
      <h1 class="text-xl font-semibold text-slate-800">Absensi Kamera</h1>
      <p class="text-sm text-slate-400 mt-1">Pastikan posisi wajah sudah tepat</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-6">
      <% if (already) { %>
        <div class="text-center py-6 space-y-4">
          <div class="w-12 h-12 mx-auto flex items-center justify-center rounded-full bg-emerald-50 text-emerald-600">✔</div>
          <h2 class="text-sm font-medium text-slate-800">Sudah Absen Hari Ini</h2>
          <% if (!hasCheckedOut) { %>
            <form action="/attendance/checkout" method="POST">
              <button class="px-6 py-2 text-sm font-medium rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition">Pulang</button>
            </form>
          <% } else { %>
            <p class="text-xs text-slate-400">Sudah checkout</p>
          <% } %>
        </div>
      <% } else { %>
        <form id="attendance-form" class="space-y-5">
          <div class="relative bg-slate-100 rounded-xl overflow-hidden aspect-video border border-slate-200">
            <video id="video" autoplay playsinline muted class="w-full h-full object-cover"></video>
            <canvas id="canvas" class="hidden"></canvas>
          </div>

          <div>
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wide">Kategori</label>
            <div class="mt-2 grid grid-cols-2 gap-3">
              <label class="flex items-center justify-center p-2 border rounded-lg cursor-pointer hover:border-blue-500 transition">
                <input type="radio" name="type" value="KANTOR" checked class="peer sr-only">
                <span class="text-sm text-slate-600 peer-checked:text-blue-600 font-medium">Kantor</span>
              </label>
              <label class="flex items-center justify-center p-2 border rounded-lg cursor-pointer hover:border-blue-500 transition">
                <input type="radio" name="type" value="LUAR KANTOR" class="peer sr-only">
                <span class="text-sm text-slate-600 peer-checked:text-blue-600 font-medium">Luar Kantor</span>
              </label>
            </div>
          </div>

          <button type="button" onclick="handleAbsen(event)"
            class="w-full py-2.5 text-sm font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition shadow-sm">
            Ambil Foto & Absen
          </button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<script>
let stream = null, lat = null, lng = null, pendingBlob = null;
const video = document.getElementById("video"), canvas = document.getElementById("canvas");

// Fungsi utama ambil absen langsung
async function handleAbsen(event) {
  const btn = event.target;
  btn.disabled = true; btn.innerText = "Memproses...";

  try {
    const pos = await getLocation();
    lat = pos.lat; lng = pos.lng;
    
    // Ambil foto
    canvas.width = video.videoWidth; canvas.height = video.videoHeight;
    canvas.getContext("2d").drawImage(video, 0, 0, canvas.width, canvas.height);
    const blob = await new Promise(r => canvas.toBlob(r, "image/jpeg", 0.8));
    
    // Kirim langsung
    const formData = new FormData();
    formData.append("photo", blob, "selfie.jpg");
    formData.append("lat", lat);
    formData.append("lng", lng);
    formData.append("type", document.querySelector('input[name="type"]:checked').value);

    const res = await fetch("/attendance/checkin", { method: "POST", body: formData });
    const data = await res.json();
    
    if (data.success) {
      location.reload();
    } else {
      alert(data.message);
      btn.disabled = false; btn.innerText = "Ambil Foto & Absen";
    }
  } catch (e) { 
    alert("Pastikan GPS aktif & izin kamera diberikan"); 
    btn.disabled = false; btn.innerText = "Ambil Foto & Absen"; 
  }
}

async function getLocation() {
  return new Promise((res, rej) => navigator.geolocation.getCurrentPosition(
    p => res({lat: p.coords.latitude, lng: p.coords.longitude}), rej, {enableHighAccuracy: true}
  ));
}

async function startCamera() {
  if (<%- already %>) return;
  try {
    stream = await navigator.mediaDevices.getUserMedia({ video: true });
    video.srcObject = stream;
  } catch (err) { console.error("Kamera tidak diizinkan", err); }
}

function stopCamera() {
  if (!stream) return;
  stream.getTracks().forEach(t => t.stop());
}

startCamera();
document.addEventListener("visibilitychange", () => document.hidden ? stopCamera() : startCamera());
</script>
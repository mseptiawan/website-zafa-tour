<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password</title>

  <link rel="stylesheet" href="/css/output.css" />
</head>

<body class="bg-slate-100 h-screen flex items-center justify-center">

  <div class="w-full max-w-md bg-white p-8 rounded-xl shadow">

    <!-- TITLE -->
    <h1 class="text-xl font-bold text-center text-slate-900 mb-2">
      Reset Password
    </h1>

    <p class="text-center text-sm text-slate-500 mb-6">
      Masukkan password baru kamu
    </p>

    <!-- ERROR HANDLING -->
    <% if (query?.error === "PASSWORD_MISMATCH") { %>
      <div class="bg-red-100 text-red-700 text-sm p-3 rounded mb-4">
        Password dan konfirmasi tidak sama
      </div>
    <% } %>

    <% if (query?.error === "WEAK_PASSWORD") { %>
      <div class="bg-red-100 text-red-700 text-sm p-3 rounded mb-4">
        Password minimal 6 karakter
      </div>
    <% } %>

    <% if (query?.error === "SERVER_ERROR") { %>
      <div class="bg-red-100 text-red-700 text-sm p-3 rounded mb-4">
        Terjadi kesalahan server
      </div>
    <% } %>

    <!-- FORM -->
    <form action="/reset-password" method="POST" class="flex flex-col gap-3">

      <!-- TOKEN WAJIB -->
      <input
        type="hidden"
        name="token"
        value="<%= token %>"
      />

      <!-- PASSWORD -->
      <input
        type="password"
        name="password"
        placeholder="Password baru"
        class="border border-slate-300 p-3 rounded-lg focus:outline-none focus:border-blue-500"
        required
      />

      <!-- CONFIRM PASSWORD -->
      <input
        type="password"
        name="confirmPassword"
        placeholder="Konfirmasi password"
        class="border border-slate-300 p-3 rounded-lg focus:outline-none focus:border-blue-500"
        required
      />

      <!-- BUTTON -->
      <button
        type="submit"
        class="bg-blue-600 w-[150px] mx-autotext-white py-3 rounded-lg hover:bg-blue-500 transition"
      >
        Reset Password
      </button>

    </form>

    <!-- BACK -->
    <div class="text-center mt-4 text-sm">
      <a href="/" class="text-blue-600 hover:underline">
        Kembali ke login
      </a>
    </div>

  </div>

</body>
</html>
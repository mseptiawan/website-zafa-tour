<%- layout('layouts/main', { title }) %>

<% 
  const APPROVER_ROLES = ["MANAGER_ADMINISTRASI", "WAKIL_DIREKTUR", "DIREKTUR_UTAMA", "MANAGER_KEUANGAN"];
  const isManagement = APPROVER_ROLES.includes((user.role || '').toUpperCase());
  const backLink = isManagement ? '/loans/approval' : '/loans/my';
  const activeApproval = approvals.find(app => app.status === 'PENDING' && (app.step || '').toUpperCase() === (user.role || '').toUpperCase());
%>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50  sm:p-6 md:p-10 antialiased pb-40 md:pb-8">
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-6">

    <a href="<%= backLink %>" class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 transition-colors group select-none">
      <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      <span>Kembali</span>
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 md:gap-6 items-start">
      
      <div class="space-y-5 md:space-y-6 lg:col-span-2">
        
        <div class="bg-white border border-slate-200/60 rounded-2xl overflow-hidden shadow-2xs">
          <div class="p-4 md:px-8 md:py-5 border-b border-slate-100 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-200/50 flex items-center justify-center text-slate-400 shrink-0 hidden sm:flex">
                <i class="fa-solid fa-user-tie text-sm"></i>
              </div>
              <div class="min-w-0">
                <h1 class="text-[14px] md:text-[15px] font-semibold text-slate-900 tracking-tight truncate mb-0.5">
                  <%= loan.employeeId?.fullName || 'Detail Pinjaman' %>
                </h1>
                <p class="text-[10px] md:text-[11px] font-semibold text-slate-400 uppercase tracking-wider truncate">
                  <%= loan.employeeId?.careerData?.bidangId?.name || 'Umum' %> • <%= loan.employeeId?.careerData?.unitId?.name || 'Pusat' %>
                </p>
              </div>
            </div>
            
            <span class="px-2.5 py-0.5 md:px-3 md:py-1 rounded-full font-bold text-[9.5px] md:text-[10px] uppercase tracking-wider border shrink-0 select-none <%= loan.status === 'PENDING' ? 'bg-amber-50 text-amber-700 border-amber-200/50' : loan.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50' : 'bg-rose-50 text-rose-700 border-rose-200/50' %>">
              <%= loan.status %>
            </span>
          </div>

          <div class="p-4 md:p-8 space-y-6">
            <div class="grid grid-cols-2 gap-x-4 gap-y-5 md:gap-x-12 md:gap-y-6">
              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Total Pinjaman</div>
                <div class="text-[14px] md:text-[15px] font-bold text-slate-900 tabular-nums">Rp <%= loan.amountRequested.toLocaleString('id-ID') %></div>
              </div>
              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Tenor Pinjaman</div>
                <div class="text-[14px] md:text-[15px] font-semibold text-slate-800"><%= loan.tenorMonths %> Bulan</div>
              </div>
              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Potongan / Bulan</div>
                <div class="text-[14px] md:text-[15px] font-bold text-blue-600 tabular-nums">Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %></div>
              </div>
              <div>
                <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1">Tanggal Pencairan</div>
                <div class="text-[14px] md:text-[15px] font-semibold text-slate-800"><%= loan.disbursementDate ? new Date(loan.disbursementDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %></div>
              </div>
            </div>

            <div class="bg-slate-50/60 rounded-xl p-3.5 border border-slate-200/40">
              <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Alasan Permohonan</span>
              <p class="text-[12px] text-slate-600 leading-relaxed italic whitespace-normal break-words">
                "<%= loan.reason || '-' %>"
              </p>
            </div>

            <div class="pt-5 border-t border-slate-100">
              <div class="text-[9px] md:text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-2.5">Bukti Pencairan Dana</div>
              <% if (loan.paymentProof) { %>
              <div class="flex items-center justify-between border border-slate-200/60 rounded-xl p-2.5 bg-slate-50/30 hover:border-slate-300 transition-colors">
                <div class="flex items-center gap-2.5 min-w-0">
                  <div class="w-7 h-7 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-400 shrink-0"><i class="fa-solid fa-file-image text-[11px]"></i></div>
                  <span class="text-[11.5px] font-semibold text-slate-700 truncate">Bukti_Transfer_Pencairan.jpg</span>
                </div>
                <a href="<%= loan.paymentProof %>" target="_blank" class="text-[9.5px] font-bold text-blue-600 bg-blue-50 border border-blue-100 px-2.5 py-1.5 rounded-lg shrink-0 transition-all active:scale-95">VIEW</a>
              </div>
              <% } else { %>
              <div class="flex flex-col items-center justify-center p-5 rounded-xl bg-slate-50/40 border border-slate-200/40 text-center">
                <i class="fa-solid fa-file-circle-xmark text-slate-300 text-lg mb-1.5"></i>
                <p class="text-[11px] font-medium text-slate-400">Bukti transfer belum diunggah</p>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-2.5 md:hidden w-full select-none">
          <button type="button" onclick="toggleBottomSheet('cicilanSheet', true)" class="w-full h-11 bg-white border border-slate-200 text-slate-700 text-xs font-semibold rounded-xl flex items-center justify-center gap-2 shadow-2xs active:bg-slate-50">
            <i class="fa-solid fa-table-list text-slate-400"></i> Lihat Jadwal Breakdown Cicilan
          </button>
        </div>

        <div class="hidden md:block bg-white border border-slate-200/60 rounded-2xl overflow-hidden shadow-2xs">
          <div class="px-8 py-4.5 border-b border-slate-100">
            <h3 class="text-[11px] font-bold text-slate-900 uppercase tracking-wider">Jadwal Breakdown Cicilan</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-[13px] border-collapse">
              <thead class="bg-slate-50/70 text-[10px] uppercase text-slate-400 font-bold tracking-wider border-b border-slate-100">
                <tr>
                  <th class="px-8 py-3.5">Cicilan Ke</th>
                  <th class="px-8 py-3.5">Periode</th>
                  <th class="px-8 py-3.5">Nominal</th>
                  <th class="px-8 py-3.5 text-right">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-50 font-medium text-slate-600 bg-white">
                <% if (payments.length === 0) { %>
                <tr>
                  <td colspan="4" class="text-center py-10 text-slate-400 font-medium">Jadwal belum digenerate oleh finance</td>
                </tr>
                <% } %>
                <% payments.forEach(p => { %>
                <tr class="hover:bg-slate-50/50 transition-colors">
                  <td class="px-8 py-3.5 text-slate-400 font-semibold">Ke-<%= p.installmentNumber %></td>
                  <td class="px-8 py-3.5 text-slate-700">
                    <%= new Date(p.periodMonth.split('-')[0], p.periodMonth.split('-')[1]-1, 1).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) %>
                  </td>
                  <td class="px-8 py-3.5 text-slate-900 font-bold tabular-nums">Rp <%= p.amount.toLocaleString('id-ID') %></td>
                  <td class="px-8 py-3.5 text-right">
                    <span class="text-[9.5px] font-bold px-2 py-0.5 rounded-md border <%= p.isPaid ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50' : 'bg-slate-50 text-slate-400 border-slate-200' %>">
                      <%= p.isPaid ? 'LUNAS' : 'BELUM DIBAYAR' %>
                    </span>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <div class="space-y-5 md:space-y-6 lg:col-span-1 w-full flex flex-col pb-24 md:pb-0">
        
        <div class="w-full">
          <%- include('partials/_log-history', { approvals }) %>
        </div>

        <% if (activeApproval) { %>
          <div class="w-full bg-white border border-slate-200/60 rounded-2xl p-4 md:p-5 shadow-2xs">
            <%- include('partials/_action-panel', { activeApproval, user }) %>
          </div>
        <% } %>

        <div class="h-14 block md:hidden pointer-events-none select-none"></div>

      </div>
    </div>
  </div>
</div>

<div id="cicilanSheet" class="fixed inset-0 z-50 hidden bg-slate-950/40 backdrop-blur-xs transition-opacity duration-300 items-end justify-center" onclick="closeSheetOnOverlay(event, 'cicilanSheet')">
  <div class="w-full max-w-xl bg-white rounded-t-3xl border-t border-slate-200 p-4 space-y-4 max-h-[80vh] overflow-y-auto transform translate-y-0 transition-transform duration-300 pb-24">
    <div class="flex items-center justify-between border-b border-slate-100 pb-3 select-none">
      <div>
        <h3 class="text-[12px] font-bold text-slate-800 uppercase tracking-wider">Jadwal Breakdown Cicilan</h3>
        <p class="text-[10px] text-slate-400 mt-0.5">Rincian auto-debet potongan berkala</p>
      </div>
      <button type="button" onclick="toggleBottomSheet('cicilanSheet', false)" class="h-7 w-7 rounded-lg bg-slate-50 text-slate-400 flex items-center justify-center text-xs font-semibold border border-slate-200/50">✕</button>
    </div>
    
    <div class="space-y-2.5">
      <% if (payments.length === 0) { %>
        <p class="text-center py-6 text-xs text-slate-400 font-medium">Jadwal berkala belum diatur</p>
      <% } %>
      <% payments.forEach(p => { %>
        <div class="bg-slate-50/50 border border-slate-200/40 rounded-xl p-3 flex items-center justify-between text-xs">
          <div>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Cicilan Ke-<%= p.installmentNumber %></p>
            <p class="text-slate-800 font-semibold mt-0.5"><%= new Date(p.periodMonth.split('-')[0], p.periodMonth.split('-')[1]-1, 1).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) %></p>
          </div>
          <div class="text-right">
            <span class="inline-block text-[9px] font-bold px-1.5 py-0.5 rounded border mb-1 <%= p.isPaid ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-slate-100 text-slate-400 border-slate-200' %>"><%= p.isPaid ? 'LUNAS' : 'BELUM' %></span>
            <p class="text-slate-900 font-bold tabular-nums">Rp <%= p.amount.toLocaleString('id-ID') %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
  function toggleBottomSheet(sheetId, shouldOpen) {
    const sheet = document.getElementById(sheetId);
    if (!sheet) return;

    if (shouldOpen) {
      sheet.classList.replace('hidden', 'flex');
      document.body.style.overflow = 'hidden';
    } else {
      sheet.classList.replace('flex', 'hidden');
      document.body.style.overflow = '';
    }
  }

  function closeSheetOnOverlay(event, sheetId) {
    const sheet = document.getElementById(sheetId);
    if (event.target === sheet) {
      toggleBottomSheet(sheetId, false);
    }
  }
</script>
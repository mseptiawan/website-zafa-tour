<%- layout('layouts/main', { title: title }) %>

<% 
  // ==========================================
  // COMPONENT-LEVEL UTILITIES (STATUS MAPPER)
  // ==========================================
  const getStatusConfig = (status) => {
    switch(status) {
      case 'PENDING_MANAGER':
        return { 
          label: 'Review Manager', 
          badge: 'bg-amber-50 text-amber-600 border border-amber-200/50', 
        };
      case 'PENDING_FINANCE':
        return { 
          label: 'Proses Finance', 
          badge: 'bg-blue-50 text-blue-600 border border-blue-200/50', 
        };
      case 'PAID':
        return { 
          label: 'Selesai & Lunas', 
          badge: 'bg-emerald-50 text-emerald-600 border border-emerald-200/50', 
        };
      case 'REJECTED':
        return { 
          label: 'Ditolak', 
          badge: 'bg-rose-50 text-rose-600 border border-rose-200/50', 
        };
      default:
        return { 
          label: status, 
          badge: 'bg-slate-50 text-slate-600 border border-slate-200/50', 
        };
    }
  };

  const activeExpenses = expenses.filter(e => e.status === 'PENDING_MANAGER' || e.status === 'PENDING_FINANCE');
  const historyExpenses = expenses.filter(e => e.status === 'PAID' || e.status === 'REJECTED');
%>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] sm:p-6 md:p-10 antialiased selection:bg-slate-100 text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto md:space-y-8 space-y-6">

    <div class="hidden md:block">
      <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Finance', 
          title: 'Riwayat Klaim Beban', 
          description: 'Pantau status persetujuan berkas dan rekam jejak pencairan dana reimbursement Anda.' 
      }) %>
    </div>

    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        items: [
          { 
            label: 'Sedang Diproses', 
            value: activeExpenses.length, 
            unit: 'Berkas', 
            icon: 'fa-solid fa-spinner', 
            bgClass: 'bg-white border-slate-200/50 ', 
            iconBoxClass: 'bg-blue-50 text-blue-600 border border-blue-200/50' 
          },
          { 
            label: 'Selesai Pencairan', 
            value: historyExpenses.filter(e => e.status === 'PAID').length, 
            unit: 'Berkas', 
            icon: 'fa-solid fa-check-to-slot', 
            bgClass: 'bg-white border border-slate-200/50 ', 
            iconBoxClass: 'bg-emerald-50 text-emerald-600 border border-emerald-200/50' 
          },
          { 
            label: 'Total Diajukan', 
            value: expenses.length, 
            unit: 'Berkas', 
            icon: 'fa-solid fa-wallet', 
            bgClass: 'bg-gradient-to-br from-slate-900 to-slate-800 border-slate-800 ', 
            labelClass: 'text-slate-300', 
            valueClass: 'text-white', 
            unitClass: 'text-slate-400',
            iconBoxClass: 'bg-white/10 text-white border-transparent' 
          }
        ]
      }) %>
    </div>

    <div class="flex flex-col gap-3.5 w-full bg-white md:bg-transparent border border-slate-200/50 md:border-none p-4 md:p-0 rounded-2xl md:rounded-none  md:shadow-none select-none">
      <div class="flex items-center justify-between gap-3 w-full md:hidden">
        <div>
          <h3 class="text-[15px] font-bold text-slate-800 tracking-tight">Daftar Pengajuan Klaim</h3>
        </div>
        <a href="/expense/create" class="inline-flex items-center justify-center gap-1.5 h-8.5 px-4 bg-blue-600 hover:bg-blue-700 text-white text-[11px] font-bold rounded-full  shadow-blue-100 transition-all active:scale-95 cursor-pointer outline-none shrink-0 decoration-none">
          <i class="fa-solid fa-plus text-[9px] text-blue-100"></i>
          <span>Buat</span>
        </a>
      </div>

      <%- include('../partials/_tab-nav', {
        tabs: [
          { id: 'active', label: `Dalam Proses (${activeExpenses.length})` },
          { id: 'history', label: `Riwayat Pengajuan (${historyExpenses.length})` }
        ]
      }) %>
    </div>

    <div id="tab-content-active" class="tab-pane space-y-6 block opacity-100 transition-all duration-300 transform translate-y-0">
      
      <div class="hidden md:block bg-white rounded-2xl  overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/40 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Detail Pengajuan</th>
                <th class="py-4 px-6 w-40">Tanggal Nota</th>
                <th class="py-4 px-6 w-36 text-center">Lampiran</th>
                <th class="py-4 px-6 w-44 text-right">Nominal Klaim</th>
                <th class="py-4 px-6 w-44 text-center">Posisi Dokumen</th>
                <th class="py-4 px-6 w-16 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100/50 bg-white">
              <% if (activeExpenses.length === 0) { %>
              <tr>
                <td colspan="6" class="py-12 text-center text-slate-400 text-xs font-medium">
                  Tidak ada pengajuan klaim yang sedang diproses.
                </td>
              </tr>
              <% } else { %>
              <% activeExpenses.forEach(e => { %>
              <% const config = getStatusConfig(e.status); %>
              <tr class="hover:bg-slate-50 transition-colors text-[13px] font-medium text-slate-600">
                <td class="py-4 px-6 font-bold text-slate-800 max-w-[220px] truncate"><%= e.title %></td>
                <td class="py-4 px-6 font-semibold text-slate-700">
                  <%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </td>
                <td class="py-4 px-6 text-center">
                  <% if (!e.proofFile) { %>
                  <span class="text-[11px] text-slate-400 font-medium italic">Tanpa Nota</span>
                  <% } else { %>
                  <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="inline-flex items-center gap-1 text-[11px] font-bold text-blue-600 hover:text-blue-700 transition">
                    <i class="fa-solid fa-arrow-down-to-bracket text-[10px]"></i> Unduh
                  </a>
                  <% } %>
                </td>
                <td class="py-4 px-6 text-right tabular-nums font-bold text-slate-900">
                  Rp <%= e.amount.toLocaleString('id-ID') %>
                </td>
                <td class="py-4 px-6 text-center select-none">
                  <div class="inline-flex items-center justify-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-medium tracking-wider <%= config.badge %> ">
                    <span class="w-1.5 h-1.5 rounded-full <%= config.dot %>"></span>
                    <span><%= config.label.toUpperCase() %></span>
                  </div>
                </td>
                <td class="py-4 px-6 text-center">
                  <button type="button" class="openExpenseModal w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 hover:bg-slate-50 inline-flex items-center justify-center transition-all active:scale-[0.95] cursor-pointer  outline-none" data-title="<%= e.title %>" data-date="<%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>" data-amount="Rp <%= e.amount.toLocaleString('id-ID') %>" data-status="<%= config.label %>" data-badge-class="<%= config.badge %>" data-dot-class="<%= config.dot %>" data-description="<%= e.description || '-' %>" data-proof="<%= e.proofFile || '' %>">
                    <i class="fa-solid fa-eye text-[11px]"></i>
                  </button>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-4 w-full">
        <% if (activeExpenses.length === 0) { %>
        <div class="bg-white border border-slate-200/50 rounded-2xl py-12 text-center  px-4">
          <p class="text-[12px] font-semibold text-slate-400">Tidak ada pengajuan aktif</p>
        </div>
        <% } else { %>
        <% activeExpenses.forEach(e => { %>
        <% const config = getStatusConfig(e.status); %>
        <div class="bg-white border border-slate-200/50 rounded-2xl p-4.5  space-y-4">
          <div class="flex items-center justify-between gap-2">
            <div>
              <h3 class="text-[13px] font-bold text-slate-800 tracking-tight line-clamp-1"><%= e.title %></h3>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                <%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </p>
            </div>
            <div class="inline-flex items-center justify-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold tracking-wider shrink-0 <%= config.badge %>">
              <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
              <span><%= config.label %></span>
            </div>
          </div>

          <div class="bg-slate-50/50 rounded-xl px-4 py-3 border border-slate-100/50">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Nominal Klaim</p>
            <p class="text-[15px] font-bold text-slate-900 tabular-nums mt-0.5">Rp <%= e.amount.toLocaleString('id-ID') %></p>
          </div>

          <div class="flex items-center justify-end gap-3 pt-0.5">
  <button type="button" class="openExpenseModal h-8.5 px-4.5 bg-blue-50 text-blue-600 hover:bg-blue-100 text-[11.5px] font-bold rounded-xl flex items-center justify-center transition-all active:scale-[0.97] outline-none cursor-pointer " 
    data-title="<%= e.title %>" 
    data-date="<%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>" 
    data-amount="Rp <%= e.amount.toLocaleString('id-ID') %>" 
    data-status="<%= config.label %>" 
    data-badge-class="<%= config.badge %>" 
    data-dot-class="<%= config.dot %>" 
    data-description="<%= e.description || '-' %>" 
    data-proof="<%= e.proofFile || '' %>">
    <span>DETAIL</span>
  </button>
</div>
        </div>
        <% }) %>
        <% } %>
      </div>

    </div>

    <div id="tab-content-history" class="tab-pane space-y-6 hidden opacity-0 transition-all duration-300 transform translate-y-2">

      <div class="hidden md:block bg-white rounded-2xl  overflow-hidden w-full border border-slate-200/50">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/40 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Detail Pengajuan</th>
                <th class="py-4 px-6 w-40">Tanggal Nota</th>
                <th class="py-4 px-6 w-36 text-center">Lampiran</th>
                <th class="py-4 px-6 w-44 text-right">Nominal Klaim</th>
                <th class="py-4 px-6 w-44 text-center">Status Akhir</th>
                <th class="py-4 px-6 w-16 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100/50 bg-white">
              <% if (historyExpenses.length === 0) { %>
              <tr>
                <td colspan="6" class="py-12 text-center text-slate-400 text-xs font-medium">
                  Belum ada riwayat pengajuan berkas reimbursement.
                </td>
              </tr>
              <% } else { %>
              <% historyExpenses.forEach(e => { %>
              <% const config = getStatusConfig(e.status); %>
              <tr class="hover:bg-slate-50 transition-colors text-[13px] font-medium text-slate-600">
                <td class="py-4 px-6 font-bold text-slate-800 max-w-[220px] truncate"><%= e.title %></td>
                <td class="py-4 px-6 font-semibold text-slate-700">
                  <%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </td>
                <td class="py-4 px-6 text-center">
                  <% if (!e.proofFile) { %>
                  <span class="text-[11px] text-slate-400 font-medium italic">Tanpa Nota</span>
                  <% } else { %>
                  <a href="/uploads/files/<%= e.proofFile %>" target="_blank" download class="inline-flex items-center gap-1 text-[11px] font-bold text-blue-600 hover:text-blue-700 transition">
                    <i class="fa-solid fa-arrow-down-to-bracket text-[10px]"></i> Unduh
                  </a>
                  <% } %>
                </td>
                <td class="py-4 px-6 text-right tabular-nums font-bold text-slate-900">
                  Rp <%= e.amount.toLocaleString('id-ID') %>
                </td>
                <td class="py-4 px-6 text-center select-none">
                  <div class="inline-flex items-center justify-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-bold tracking-wider <%= config.badge %> ">
                    <span class="w-1.5 h-1.5 rounded-full <%= config.dot %> <%= e.status === 'PAID' ? 'animate-pulse' : '' %>"></span>
                    <span><%= config.label.toUpperCase() %></span>
                  </div>
                </td>
                <td class="py-4 px-6 text-center">
                  <button type="button" class="openExpenseModal w-8 h-8 rounded-lg bg-white border border-slate-200/80 text-slate-400 hover:text-slate-800 hover:bg-slate-50 inline-flex items-center justify-center transition-all active:scale-[0.95] cursor-pointer  outline-none" data-title="<%= e.title %>" data-date="<%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>" data-amount="Rp <%= e.amount.toLocaleString('id-ID') %>" data-status="<%= config.label %>" data-badge-class="<%= config.badge %>" data-dot-class="<%= config.dot %>" data-description="<%= e.description || '-' %>" data-proof="<%= e.proofFile || '' %>" data-reason="<%= e.rejectionReason || '' %>" data-paidat="<%= e.paidAt ? new Date(e.paidAt).toLocaleDateString('id-ID', {day: '2-digit', month: 'long', year: 'numeric'}) : '' %>">
                    <i class="fa-solid fa-eye text-[11px]"></i>
                  </button>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-4 w-full">
        <% if (historyExpenses.length === 0) { %>
        <div class="bg-white border border-slate-200/50 rounded-2xl py-12 text-center  px-4">
          <p class="text-[12px] font-semibold text-slate-400">Belum ada riwayat dokumen</p>
        </div>
        <% } else { %>
        <% historyExpenses.forEach(e => { %>
        <% const config = getStatusConfig(e.status); %>
        <div class="bg-white border border-slate-200/50 rounded-2xl p-4.5  space-y-4">
          <div class="flex items-center justify-between gap-2">
            <div>
              <h3 class="text-[13px] font-bold text-slate-800 tracking-tight line-clamp-1"><%= e.title %></h3>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                <%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </p>
            </div>
            <div class="inline-flex items-center justify-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold tracking-wider shrink-0 <%= config.badge %>">
              <span class="w-1 h-1 rounded-full <%= config.dot %>"></span>
              <span><%= config.label %></span>
            </div>
          </div>

          <div class="bg-slate-50/50 rounded-xl px-4 py-3 border border-slate-100/50">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Nominal Klaim</p>
            <p class="text-[15px] font-bold text-slate-900 tabular-nums mt-0.5">Rp <%= e.amount.toLocaleString('id-ID') %></p>
          </div>

          <div class="flex items-center justify-between gap-3 pt-0.5">
            <div class="text-[11px] font-semibold text-slate-500">
              <% if (e.status === 'REJECTED') { %>
              <span class="text-rose-600 font-bold">❌ GAGAL / DITOLAK</span>
              <% } else { %>
              <span class="text-emerald-600 font-bold">✓ SELESAI DICAIRKAN</span>
              <% } %>
            </div>
            <button type="button" class="openExpenseModal h-8.5 px-4.5 bg-blue-50 text-blue-600 hover:bg-blue-100 text-[11.5px] font-bold rounded-xl flex items-center justify-center transition-all active:scale-[0.97] outline-none cursor-pointer " data-title="<%= e.title %>" data-date="<%= new Date(e.expenseDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>" data-amount="Rp <%= e.amount.toLocaleString('id-ID') %>" data-status="<%= config.label %>" data-badge-class="<%= config.badge %>" data-dot-class="<%= config.dot %>" data-description="<%= e.description || '-' %>" data-proof="<%= e.proofFile || '' %>" data-reason="<%= e.rejectionReason || '' %>" data-paidat="<%= e.paidAt ? new Date(e.paidAt).toLocaleDateString('id-ID', {day: '2-digit', month: 'long', year: 'numeric'}) : '' %>">
              <span>DETAIL</span>
            </button>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>

    </div>

  </div>
</div>

<div id="expenseDetailModal" class="fixed inset-0 z-[110] hidden items-center justify-center bg-slate-950/40 p-4 backdrop-blur-xs transition-all duration-300">
  <div class="w-full max-w-md bg-white border border-slate-200/50 rounded-2xl shadow-xl overflow-hidden transform transition-all mx-3 sm:mx-auto">

    <div class="flex justify-between border-b border-slate-200/50 px-5 py-4 bg-white select-none">
      <div>
        <h2 class="text-[13px] font-bold text-slate-800 tracking-tight">Rincian Klaim Pengeluaran</h2>
        <p class="text-[10.5px] font-medium text-slate-400 mt-0.5">Detail berkas data pengajuan internal</p>
      </div>
      <button onclick="closeExpenseModal()" class="h-7 w-7 rounded-lg bg-slate-50 border border-slate-200/50 text-slate-400 hover:text-slate-800 flex items-center justify-center text-[10px] cursor-pointer outline-none">
        ✕
      </button>
    </div>

    <div class="p-5 space-y-4 text-xs font-semibold text-slate-700">
      <div>
        <label class="text-slate-400 text-[10px] font-bold uppercase tracking-wider block mb-1">Judul Klaim</label>
        <p id="modalTitle" class="text-[13px] font-bold text-slate-800 break-words"></p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="text-slate-400 text-[10px] font-bold uppercase tracking-wider block mb-1">Tanggal Nota</label>
          <p id="modalDate" class="text-slate-800 font-bold"></p>
        </div>
        <div>
          <label class="text-slate-400 text-[10px] font-bold uppercase tracking-wider block mb-1">Status Pengajuan</label>
          <div id="modalBadgeContainer" class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[9.5px] font-bold tracking-wide border">
            <span id="modalDot" class="w-1.5 h-1.5 rounded-full"></span>
            <span id="modalStatusText"></span>
          </div>
        </div>
      </div>

      <div class="bg-slate-50/70 border border-slate-200/40 rounded-xl p-3.5">
        <label class="text-slate-400 text-[10px] font-bold uppercase tracking-wider block mb-0.5">Nominal Akhir Klaim</label>
        <p id="modalAmount" class="text-lg font-black text-slate-900 tabular-nums"></p>
      </div>

      <div>
        <label class="text-slate-400 text-[10px] font-bold uppercase tracking-wider block mb-1">Keterangan / Deskripsi</label>
        <p id="modalDescription" class="text-slate-600 font-medium leading-relaxed bg-slate-50/40 p-3 rounded-xl border border-slate-200/30 max-h-24 overflow-y-auto break-words"></p>
      </div>

      <div id="modalPaidContainer" class="hidden">
        <label class="text-slate-400 text-[10px] font-bold uppercase tracking-wider block mb-1">Tanggal Cair / Lunas</label>
        <p id="modalPaidAt" class="text-emerald-600 font-bold"></p>
      </div>

      <div id="modalReasonContainer" class="hidden bg-rose-50/50 border border-rose-100 rounded-xl p-3 text-rose-800">
        <label class="text-rose-500 text-[10px] font-bold uppercase tracking-wider block mb-1">Alasan Penolakan</label>
        <p id="modalRejectionReason" class="text-[11px] font-medium leading-relaxed"></p>
      </div>

      <div class="pt-2 border-t border-slate-100 flex flex-col gap-2">
        <label class="text-slate-400 text-[10px] font-bold uppercase tracking-wider block">Dokumen Lampiran Nota</label>
        <div id="modalDownloadContainer"></div>
      </div>
    </div>
  </div>
</div>

<% if (pagination.totalPages > 1) { %>
  <div class="flex items-center justify-end mt-8 w-full border-t border-slate-200/60 pt-4">
    <div class="flex items-center gap-5">
      <a href="?page=<%= pagination.page - 1 %>" class="py-1 text-[11.5px] font-semibold transition-colors flex items-center gap-1 <%= pagination.hasPrev ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none select-none' %>">
        <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Prev
      </a>
      <a href="?page=<%= pagination.page + 1 %>" class="py-1 text-[11.5px] font-semibold transition-colors flex items-center gap-1 <%= pagination.hasNext ? 'text-slate-500 hover:text-slate-900' : 'text-slate-300 pointer-events-none select-none' %>">
        Next
        <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
<% } %>

<script>
  // Logika Pengendali Bukal/Tutup Modal Detail Berkas Klaim (Fungsi switch tab lama dihapus karena sudah di-handle partial)
  const expModal = document.getElementById("expenseDetailModal");

  function closeExpenseModal() {
    expModal.classList.add("hidden");
    expModal.classList.remove("flex");
  }

  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll(".openExpenseModal");

    buttons.forEach(btn => {
      btn.addEventListener("click", () => {
        const title = btn.getAttribute("data-title");
        const date = btn.getAttribute("data-date");
        const amount = btn.getAttribute("data-amount");
        const status = btn.getAttribute("data-status");
        const badgeClass = btn.getAttribute("data-badge-class");
        const dotClass = btn.getAttribute("data-dot-class");
        const desc = btn.getAttribute("data-description");
        const proof = btn.getAttribute("data-proof");
        const reason = btn.getAttribute("data-reason");
        const paidAt = btn.getAttribute("data-paidat");

        document.getElementById("modalTitle").innerText = title;
        document.getElementById("modalDate").innerText = date;
        document.getElementById("modalAmount").innerText = amount;
        document.getElementById("modalDescription").innerText = desc;
        document.getElementById("modalStatusText").innerText = status.toUpperCase();

        const badgeContainer = document.getElementById("modalBadgeContainer");
        const modalDot = document.getElementById("modalDot");
        badgeContainer.className = `inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[9.5px] font-bold tracking-wide border ${badgeClass}`;
        modalDot.className = `w-1.5 h-1.5 rounded-full ${dotClass}`;

        const paidContainer = document.getElementById("modalPaidContainer");
        if (paidAt) {
          document.getElementById("modalPaidAt").innerText = paidAt;
          paidContainer.classList.remove("hidden");
        } else {
          paidContainer.classList.add("hidden");
        }

        const reasonContainer = document.getElementById("modalReasonContainer");
        if (reason) {
          document.getElementById("modalRejectionReason").innerText = reason;
          reasonContainer.classList.remove("hidden");
        } else {
          reasonContainer.classList.add("hidden");
        }

        const downloadContainer = document.getElementById("modalDownloadContainer");
        if (proof && proof !== "") {
          downloadContainer.innerHTML = `
            <a href="/uploads/files/${proof}" target="_blank" download class="w-full h-9 bg-blue-500 hover:bg-blue-700 text-white text-[11.5px] font-bold tracking-wide uppercase rounded-xl transition-all active:scale-[0.99]  cursor-pointer flex items-center justify-center gap-2">
              <i class="fa-solid fa-cloud-arrow-down text-xs"></i> UNDUH NOTA LAMPIRAN
            </a>`;
        } else {
          downloadContainer.innerHTML = `
            <div class="w-full h-9 bg-slate-100 border border-slate-200 text-slate-400 text-[11px] font-bold rounded-xl flex items-center justify-center select-none cursor-not-allowed">
              BUKTI NOTA TIDAK TERSEDIA
            </div>`;
        }

        expModal.classList.remove("hidden");
        expModal.classList.add("flex");
      });
    });

    expModal.addEventListener("click", (e) => {
      if (e.target === expModal) closeExpenseModal();
    });
  });
</script>
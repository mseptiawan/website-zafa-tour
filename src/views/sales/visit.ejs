<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">

  <div class="max-w-2xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-2xl text-slate-800">
        Input Sales Visit
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Catat kunjungan toko / pelanggan / prospek
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">

      <form action="/sales/visit" method="POST" enctype="multipart/form-data" class="space-y-4">

        <!-- Customer -->
        <div>
          <label class="text-xs text-slate-500">Nama Toko / Customer</label>
          <input
            type="text"
            name="customerName"
            required
            class="w-full mt-1 p-2.5 text-sm text-slate-700 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-slate-300"
          />
        </div>

        <!-- Alamat -->
        <div>
          <label class="text-xs text-slate-500">Alamat</label>
          <input
            type="text"
            name="address"
            required
            class="w-full mt-1 p-2.5 text-sm text-slate-700 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-slate-300"
          />
        </div>

        <!-- Meet -->
        <div>
          <label class="text-xs text-slate-500">Bertemu Dengan</label>
          <input
            type="text"
            name="meetWith"
            placeholder="Owner / staff toko"
            required
            class="w-full mt-1 p-2.5 text-sm text-slate-700 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-slate-300"
          />
        </div>

        <!-- Result -->
        <div>
          <label class="text-xs text-slate-500">Hasil Kunjungan</label>
          <textarea
            name="result"
            rows="3"
            class="w-full mt-1 p-2.5 text-sm text-slate-700 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-slate-300"
          ></textarea>
        </div>

        <!-- File -->
        <div>
          <label class="text-xs text-slate-500">Foto Bukti</label>
          <input
            type="file"
            name="photo"
            class="w-full mt-1 text-sm text-slate-600"
          />
        </div>

        <!-- GPS -->
        <div>
          <label class="text-xs text-slate-500">Lokasi GPS</label>
          <input
            type="text"
            name="location"
            placeholder="lat,lng"
            class="w-full mt-1 p-2.5 text-sm text-slate-700 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-slate-300"
          />
        </div>

        <!-- BUTTON -->
        <button
          type="submit"
          class="w-full bg-slate-900 hover:bg-slate-800 text-white text-sm py-2.5 rounded-lg transition"
        >
          Simpan Kunjungan
        </button>

      </form>

    </div>

  </div>
</div>
<%- layout('layouts/main', { title: title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50  p-4 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 pb-5 select-none">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header.ejs', { 
            section: 'Area Kerja', 
            module: 'Penugasan', 
            title: 'Penugasan Saya', 
            description: 'Kelola daftar riwayat dan pantau penugasan aktif yang diberikan kepada Anda.' 
        }) %>
      </div>
    </div>

    <% if(assignments.length===0) { %>
      <div class="rounded-2xl border border-slate-200/60 bg-white p-12 text-center shadow-3xs px-4">
        <div class="mx-auto mb-3.5 flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200/60 bg-slate-50 text-slate-400">
          <svg class="h-5 w-5 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <p class="text-[12.5px] font-semibold text-slate-700">Belum Ada Penugasan</p>
        <p class="mt-0.5 text-[11.5px] text-slate-400 max-w-xs mx-auto leading-relaxed">
          Saat ini Anda tidak memiliki surat perintah atau tugas aktif yang tercatat.
        </p>
      </div>
    <% } else { %>

      <div class="grid grid-cols-1 gap-3 md:block md:bg-white md:border md:border-slate-200/60 md:rounded-2xl md:p-1.5 md:shadow-3xs md:divide-y md:divide-slate-100/80">
        <% assignments.forEach(a=> { %>
          
          <div class="bg-white border border-slate-200/60 rounded-2xl p-4 md:bg-transparent md:border-none md:rounded-none md:p-5 flex flex-col gap-3.5 shadow-3xs md:shadow-none">
            
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 space-y-0.5">
                <h2 class="text-[14px] font-bold tracking-tight text-slate-800 break-words">
                  <%= a.title %>
                </h2>
                <p class="line-clamp-2 pr-4 text-[12px] leading-relaxed break-words text-slate-400 font-medium">
                  <%= a.description || 'Tidak ada deskripsi tambahan untuk penugasan ini' %>
                </p>
              </div>

              <div class="flex-shrink-0 pt-0.5">
                <% if(a.endDate && new Date(a.endDate)>= new Date()) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-emerald-50 text-emerald-600 border border-emerald-100/50">
                    <span class="h-1 w-1 rounded-full bg-emerald-500"></span> Active
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold bg-slate-50 text-slate-400 border border-slate-200/50">
                    <span class="h-1 w-1 rounded-full bg-slate-300"></span> Completed
                  </span>
                <% } %>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 pt-3.5 border-t border-slate-100/80">
              
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[11.5px] font-semibold text-slate-400">
                <div>
                  Tipe: <span class="text-slate-600 font-bold"><%= a.type %></span>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="h-1 w-1 rounded-full bg-slate-200 hidden sm:block"></span>
                  Lokasi: <span class="text-slate-600 font-bold"><%= a.location || '-' %></span>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="h-1 w-1 rounded-full bg-slate-200 hidden sm:block"></span>
                  Durasi: <span class="text-slate-600 font-bold">
                    <%= new Date(a.startDate).toLocaleDateString("id-ID", { day: 'numeric' , month: 'short' }) %> - <%= new Date(a.endDate).toLocaleDateString("id-ID", { day: 'numeric' , month: 'short' , year: 'numeric' }) %>
                  </span>
                </div>
              </div>

              <div class="flex items-center gap-2 justify-end">
                <% if(a.attachment) { %>
                  <a href="/uploads/files/<%= a.attachment %>" target="_blank" class="inline-flex items-center gap-1 bg-blue-50 hover:bg-blue-100 text-blue-600 rounded-lg px-2 py-1 text-[11px] font-bold transition-colors decoration-none">
                    <svg class="w-3 h-3 stroke-[2.5] text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l4.5-4.5a4.5 4.5 0 011.243-0.88m6.364 6.364l-.001-.001m1.036-1.036a4.5 4.5 0 001.24-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364l4.5 4.5a4.5 4.5 0 001.242.88" />
                    </svg>
                    <span>Surat Tugas</span>
                  </a>
                <% } %>

                <a href="/assignments/<%= a._id %>" class="bg-slate-100 hover:bg-slate-200 text-slate-600 text-[11px] font-bold h-7 px-3 rounded-lg flex items-center justify-center gap-1 transition-all active:scale-[0.98] decoration-none">
                  Lihat Detail <i class="fa-solid fa-angle-right text-[9px] text-slate-400"></i>
                </a>
              </div>

            </div>

          </div>
        <% }) %>
      </div>
    <% } %> 

 <%- include('../partials/pagination-nav') %>
   
  </div>
</div>
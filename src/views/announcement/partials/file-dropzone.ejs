<div class="mb-2 space-y-2">
  <label class="block text-[12px] font-semibold tracking-wide text-slate-700">
    <%= labelName %>
    <span class="font-normal text-slate-400">(Opsional)</span>
  </label>
  <div class="relative">
    <input
      type="file"
      name="<%= inputName %>"
      id="file-input"
      class="absolute inset-0 z-10 h-full w-full cursor-pointer opacity-0"
      onchange="handleFileSelect(this)"
    />

    <div
      id="dropzone-empty"
      class="flex w-full flex-col items-center rounded-xl border border-dashed border-slate-200 bg-slate-50/50 p-5 text-center transition hover:bg-slate-50"
    >
      <svg
        class="mb-1.5 h-4 w-4 text-slate-400"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"
        />
      </svg>
      <span class="text-[12px] font-medium text-slate-600">Pilih Berkas atau Drop File Disini</span>
      <span class="mt-0.5 text-[11px] text-slate-400">PNG, JPG, PDF (maks 5MB)</span>
    </div>

    <div
      id="dropzone-filled"
      class="flex hidden flex-col justify-between gap-3 rounded-xl border border-slate-200 bg-white p-3.5 shadow-xs sm:flex-row sm:items-center"
    >
      <div class="flex min-w-0 flex-1 items-center gap-3">
        <div
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-slate-200/60 bg-slate-50"
        >
          <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            />
          </svg>
        </div>
        <div class="min-w-0 flex-1">
          <div id="name-preview" class="truncate text-[12px] font-semibold text-slate-700">
            file.pdf
          </div>
          <div id="size-preview" class="mt-0.5 text-[11px] text-slate-400">0 KB</div>
        </div>
      </div>
      <div class="relative z-20 flex w-full shrink-0 items-center gap-2 sm:w-auto">
        <a
          id="view-file-btn"
          href="#"
          target="_blank"
          class="flex-1 rounded-lg bg-slate-100 px-3 py-1.5 text-center text-[11px] font-medium text-slate-700 transition-colors hover:bg-slate-200/80 sm:flex-initial"
        >
          View
        </a>
        <button
          type="button"
          onclick="document.getElementById('file-input').click()"
          class="flex-1 rounded-lg border border-slate-200/60 bg-slate-50 px-3 py-1.5 text-[11px] font-medium text-slate-600 transition-colors hover:bg-slate-100 sm:flex-initial"
        >
          Ganti
        </button>
      </div>
    </div>
  </div>
</div>

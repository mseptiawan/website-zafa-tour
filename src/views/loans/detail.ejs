<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/60 p-8 antialiased">
    <div class="max-w-6xl mx-auto">

      <% 
        const isApproverView = approvals.some(app => {
          return app.status === 'PENDING' && (app.step || '').toUpperCase() === (user.role || '').toUpperCase();
        });
        const APPROVER_ROLES = ["MANAGER", "HR", "PIMPINAN", "KEUANGAN", "GENERAL_MANAGER"];
        const isManagement = APPROVER_ROLES.includes((user.role || '').toUpperCase());
        const backLink = isManagement ? '/loans/manage-requests' : '/loans/my';
      %>

      <a href="<%= backLink %>"
        class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 mb-6 transition-colors group">
        <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Kembali
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
        
        <div class="lg:col-span-2 space-y-6">
          
          <div class="bg-white border border-slate-200/60 rounded-xl shadow-[0_1px_3px_rgba(15,23,42,0.03)] overflow-hidden">
            
            <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-white">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200/60 flex items-center justify-center text-slate-500 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h1 class="text-sm font-bold text-slate-900 tracking-tight leading-none mb-1.5">
                    <%= (loan.employeeId) ? loan.employeeId.fullName : 'Detail Pengajuan Loan' %>
                  </h1>
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] font-medium">
                    <span class="text-slate-500 flex items-center gap-1">
                      <i class="fa-solid fa-briefcase text-slate-400 text-[10px]"></i>
                      Unit: 
                      <span class="text-slate-700 font-semibold">
                        <%= (loan.employeeId && loan.employeeId.unitId) ? loan.employeeId.unitId.name : 'Tidak Ada' %>
                      </span>
                    </span>
                  </div>
                </div>
              </div>

              <div>
                <span class="text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-wider border
                  <%= loan.status === 'PENDING' ? 'bg-amber-50 text-amber-700 border-amber-200/50'
                    : loan.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200/50'
                    : loan.status === 'REJECTED' ? 'bg-rose-50 text-rose-700 border-rose-200/50'
                    : 'bg-slate-100 text-slate-600 border-slate-300'
                  %>">
                  <%= loan.status %>
                </span>
              </div>
            </div>

            <div class="p-6 space-y-6">
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Total Pinjaman</div>
                  <div class="text-[13px] font-bold text-slate-900 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80 tabular-nums">
                    Rp <%= loan.amountRequested.toLocaleString('id-ID') %>
                  </div>
                </div>

                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Tenor Pinjaman</div>
                  <div class="text-[13px] font-semibold text-slate-800 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80">
                    <%= loan.tenorMonths %> Bulan
                  </div>
                </div>

                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Potongan Per Bulan</div>
                  <div class="text-[13px] font-bold text-slate-800 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80 tabular-nums">
                    Rp <%= loan.monthlyDeduction.toLocaleString('id-ID') %> / bulan
                  </div>
                </div>

                <div>
                  <div class="text-[11px] font-medium text-slate-400 uppercase tracking-wide mb-0.5">Tanggal Pencairan Dana</div>
                  <div class="text-[13px] font-medium text-slate-800 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100/80">
                    <%= loan.disbursementDate ? new Date(loan.disbursementDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %>
                  </div>
                </div>
              </div>

              <div class="pt-4 border-t border-slate-100">
                <div class="text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-2">Alasan Peminjaman</div>
                <div class="text-[13px] text-slate-600 leading-relaxed bg-slate-50/50 border border-slate-100 p-4 rounded-xl whitespace-pre-line">
                  <%= loan.reason || '-' %>
                </div>
              </div>

              <div class="pt-4 border-t border-slate-100">
                <div class="text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-2.5">Bukti Pencairan Dana (Transfer Keuangan)</div>
                <% if (loan.paymentProof) { %>
                  <div class="flex items-center justify-between border border-slate-100 rounded-xl p-3 bg-white hover:border-slate-300 transition-colors">
                    <div class="flex items-center gap-3 min-w-0">
                      <div class="w-10 h-10 rounded-lg border border-slate-100 bg-slate-50 flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375’ .375 0 11-.75 0 .375.375 0 01.75 0z" />
                        </svg>
                      </div>
                      <div class="min-w-0">
                        <div class="text-[13px] font-medium text-slate-700 truncate">Bukti_Transfer_Pencairan.jpg</div>
                        <div class="text-[10px] text-slate-400 uppercase mt-0.5">Dokumen Finansial</div>
                      </div>
                    </div>
                    <a href="<%= loan.paymentProof %>" target="_blank"
                      class="text-xs font-semibold text-blue-600 bg-blue-50/50 hover:bg-blue-100/80 px-3 py-1.5 rounded-lg transition shrink-0">
                      View File
                    </a>
                  </div>
                <% } else { %>
                  <div class="text-xs text-slate-400 bg-slate-50/50 p-4 rounded-xl border border-dashed border-slate-200 text-center">
                    Belum ada bukti transfer pencairan dana dari tim keuangan.
                  </div>
                <% } %>
              </div>

            </div>
          </div>

          <div class="bg-white border border-slate-200 rounded-xl shadow-[0_1px_3px_rgba(15,23,42,0.03)] overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 bg-white">
              <h3 class="text-xs font-bold text-slate-800 uppercase tracking-wider">Jadwal Breakdown Pembayaran Cicilan</h3>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-slate-50 text-slate-500 text-[11px] uppercase tracking-wider border-b border-slate-100">
                  <tr>
                    <th class="text-left px-6 py-3">Cicilan Ke</th>
                    <th class="text-left px-6 py-3">Bulan Periode</th>
                    <th class="text-left px-6 py-3">Nominal Tagihan</th>
                    <th class="text-right px-6 py-3">Status Bayar</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-700">
                  <% if (payments.length === 0) { %>
                    <tr>
                      <td colspan="4" class="text-center py-6 text-xs text-slate-400">
                        Jadwal cicilan belum digenerate (Menunggu pengajuan APPROVED oleh keuangan)
                      </td>
                    </tr>
                  <% } %>
                  <% payments.forEach(payment => { %>
                    <tr class="hover:bg-slate-50/30 transition text-xs">
                      <td class="px-6 py-3.5 font-medium text-slate-500">
                        Ke-<%= payment.installmentNumber %>
                      </td>
                      <td class="px-6 py-3.5 font-semibold text-slate-700">
                        <% 
                          const [year, month] = payment.periodMonth.split('-');
                          const dateObj = new Date(year, parseInt(month) - 1, 1);
                          const formattedPeriod = dateObj.toLocaleDateString('id-ID', { month: 'long', year: 'numeric' });
                        %>
                        <%= formattedPeriod %>
                      </td>
                      <td class="px-6 py-3.5 font-bold tabular-nums">
                        Rp <%= payment.amount.toLocaleString('id-ID') %>
                      </td>
                      <td class="px-6 py-3.5 text-right">
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[10px] font-semibold
                          <%= payment.isPaid ? 'bg-emerald-50 text-emerald-700 border-emerald-200/40' : 'bg-slate-50 text-slate-500 border-slate-200' %>">
                          <span class="w-1 h-1 rounded-full <%= payment.isPaid ? 'bg-emerald-500' : 'bg-slate-400' %>"></span>
                          <%= payment.isPaid ? 'Lunas' : 'Belum Dibayar' %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <% 
            const activeApproval = approvals.find(app => {
              return app.status === 'PENDING' && (app.step || '').toUpperCase() === (user.role || '').toUpperCase();
            });
          %>

          <% if (activeApproval) { %>
            <div class="bg-white border border-slate-200 rounded-xl shadow-[0_1px_3px_rgba(15,23,42,0.03)] p-6">
              <div class="flex items-center gap-2 mb-4">
                <div class="p-1.5 bg-blue-50 text-blue-600 rounded-lg">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm font-bold text-slate-900">Form Evaluasi & Persetujuan Pinjaman</h3>
                  <p class="text-xs text-slate-500 mt-0.5">Bertindak selaku: <span class="font-bold text-slate-700"><%= activeApproval.step %></span></p>
                </div>
              </div>

              <div class="mb-5">
                <label for="reviewNote" class="block text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-2">
                  Catatan Pemeriksa / Alasan (Opsional)
                </label>
                <textarea 
                  id="reviewNote" 
                  name="note" 
                  rows="3" 
                  placeholder="Masukkan catatan evaluasi pinjaman..."
                  class="w-full text-sm text-slate-800 bg-slate-50 border border-slate-200 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-none focus:bg-white"
                  oninput="document.querySelectorAll('.sync-note').forEach(input => input.value = this.value)"
                ></textarea>
              </div>

              <div class="flex items-center gap-3">
                <form action="/loans/approval/approve/<%= activeApproval._id %>" method="POST" class="inline">
                  <input type="hidden" name="note" class="sync-note" value="">
                  <button type="submit" class="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold rounded-xl transition shadow-sm cursor-pointer">
                    Terima & Setujui
                  </button>
                </form>

                <form action="/loans/approval/reject/<%= activeApproval._id %>" method="POST" class="inline">
                  <input type="hidden" name="note" class="sync-note" value="">
                  <button type="submit" class="px-5 py-2.5 bg-white hover:bg-rose-50 text-rose-600 border border-rose-200 text-xs font-bold rounded-xl transition cursor-pointer">
                    Tolk Pengajuan
                  </button>
                </form>
              </div>
            </div>
          <% } %>

        </div>

        <div class="bg-white border border-slate-200/60 rounded-xl shadow-[0_1px_3px_rgba(15,23,42,0.03)] p-6">
          <div class="mb-5">
            <h2 class="text-sm font-bold text-slate-900 tracking-tight">Jejak Log Pemeriksaan</h2>
            <p class="text-xs text-slate-400 mt-0.5">Alur dan status persetujuan berkas</p>
          </div>

          <div class="relative pl-4 space-y-6 before:absolute before:left-[4px] before:top-1.5 before:bottom-1.5 before:w-[1px] before:bg-slate-200">
            <% approvals.forEach(app => { %>
              <div class="relative group flex flex-col gap-1">

                <div class="absolute -left-[16px] top-1 w-2 h-2 rounded-full border border-white shadow-sm ring-4 ring-white transition-colors
                  <%= app.status === 'APPROVED' ? 'bg-emerald-500' : app.status === 'REJECTED' ? 'bg-rose-500' : 'bg-amber-400' %>">
                </div>

                <div class="flex flex-col gap-1 pl-1">
                  <div class="flex flex-wrap items-center gap-1.5 text-xs">
                    <span class="font-semibold text-slate-800">
                      <%= (app.approverId && app.approverId.username) ? app.approverId.username : 'Sistem Otomatis' %>
                    </span>
                    <span class="text-[10px] text-slate-400 font-medium bg-slate-100 px-1.5 py-0.5 rounded">
                      <%= app.step %>
                    </span>
                  </div>

                  <div class="flex items-center justify-between mt-0.5">
                    <span class="text-[10px] font-bold tracking-wide uppercase px-1.5 py-0.5 rounded
                      <%= app.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-700' : app.status === 'REJECTED' ? 'bg-rose-50 text-rose-700' : 'bg-amber-50 text-amber-700' %>">
                      <%= app.status %>
                    </span>
                    <span class="text-[10px] text-slate-400 font-normal">
                      <%= app.actionDate ? new Date(app.actionDate).toLocaleString('id-ID', {day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit'}) : 'Dalam Antrean' %>
                    </span>
                  </div>

                  <% if (app.note) { %>
                    <div class="text-[11px] text-slate-600 leading-relaxed bg-slate-50 border border-slate-100 p-2.5 rounded-lg mt-1.5 break-words">
                      <span class="text-[9px] font-bold text-slate-400 block uppercase tracking-wider mb-0.5">Catatan:</span>
                      <%= app.note %>
                    </div>
                  <% } %>
                </div>

              </div>
            <% }) %>
          </div>
        </div>

      </div>

    </div>
  </div>
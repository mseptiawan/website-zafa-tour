<!-- QUICK ACTION MENU -->
<div id="quickActionMenuMobile" class="fixed inset-0 z-[998] hidden bg-slate-950/30 md:hidden transition-opacity duration-200" onclick="toggleQuickMenuMobile()">
  <div class="absolute bottom-20 inset-x-4 bg-white rounded-3xl p-5 shadow-2xl space-y-3 transform translate-y-10 transition-transform duration-200" onclick="event.stopPropagation()">
    <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider px-1">Buat Pengajuan & Aktivitas</h3>
    <div class="grid grid-cols-4 gap-2">
      <a href="/leave/apply" class="flex flex-col items-center p-2.5 rounded-2xl bg-slate-50 hover:bg-blue-50 border border-slate-100 text-center gap-1.5">
        <div class="w-9 h-9 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center"><i class="fa-solid fa-plane-departure text-xs"></i></div>
        <span class="text-[9px] font-semibold text-slate-700 leading-tight">Cuti</span>
      </a>
      <a href="/permit/new" class="flex flex-col items-center p-2.5 rounded-2xl bg-slate-50 hover:bg-amber-50 border border-slate-100 text-center gap-1.5">
        <div class="w-9 h-9 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center"><i class="fa-solid fa-shield-halved text-xs"></i></div>
        <span class="text-[9px] font-semibold text-slate-700 leading-tight">Izin</span>
      </a>
      <a href="/loans/new" class="flex flex-col items-center p-2.5 rounded-2xl bg-slate-50 hover:bg-purple-50 border border-slate-100 text-center gap-1.5">
        <div class="w-9 h-9 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center"><i class="fa-solid fa-wallet text-xs"></i></div>
        <span class="text-[9px] font-semibold text-slate-700 leading-tight">Kasbon</span>
      </a>
      <a href="/expense/create" class="flex flex-col items-center p-2.5 rounded-2xl bg-slate-50 hover:bg-rose-50 border border-slate-100 text-center gap-1.5">
        <div class="w-9 h-9 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center"><i class="fa-solid fa-file-invoice-dollar text-xs"></i></div>
        <span class="text-[9px] font-semibold text-slate-700 leading-tight">Reimbursement</span>
      </a>
      <a href="/sales/new" class="flex flex-col items-center p-2.5 rounded-2xl bg-slate-50 hover:bg-indigo-50 border border-slate-100 text-center gap-1.5">
        <div class="w-9 h-9 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center"><i class="fa-solid fa-map-location-dot text-xs"></i></div>
        <span class="text-[9px] font-semibold text-slate-700 leading-tight">Sales Visit</span>
      </a>
      <a href="/overtime/new" class="flex flex-col items-center p-2.5 rounded-2xl bg-slate-50 hover:bg-orange-50 border border-slate-100 text-center gap-1.5">
        <div class="w-9 h-9 rounded-xl bg-orange-50 text-orange-600 flex items-center justify-center"><i class="fa-solid fa-cloud-moon text-xs"></i></div>
        <span class="text-[9px] font-semibold text-slate-700 leading-tight">Lembur</span>
      </a>
    </div>
  </div>
</div>

<!-- CONFIRM MODAL -->
<div id="confirmModal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-slate-950/50 p-4">
  <div class="w-full max-w-md overflow-hidden rounded-3xl bg-white shadow-2xl">
    <div class="relative border-b border-slate-100 px-6 py-5">
      <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-amber-500 via-orange-500 to-red-500"></div>
      <div class="flex items-start gap-4">
        <div id="confirmModalIcon" class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-amber-50">
          <i class="fas fa-triangle-exclamation text-xl text-amber-600"></i>
        </div>
        <div class="flex-1">
          <h3 id="confirmModalTitle" class="text-lg font-semibold text-slate-900">Konfirmasi Tindakan</h3>
          <p class="mt-1 text-sm text-slate-500">Mohon periksa kembali sebelum melanjutkan.</p>
        </div>
      </div>
    </div>
    <div class="px-6 py-5">
      <p id="confirmModalMessage" class="text-sm leading-relaxed text-slate-600">Apakah Anda yakin ingin melanjutkan tindakan ini?</p>
    </div>
    <div class="flex items-center justify-end gap-3 border-t border-slate-100 bg-slate-50/70 px-6 py-4">
      <button type="button" onclick="closeConfirmModal()" class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50">Batal</button>
      <button type="button" id="confirmModalButton" class="rounded-xl bg-red-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-red-700">Ya, Lanjutkan</button>
    </div>
  </div>
</div>

<!-- RIWAYAT MENU -->
<div id="riwayatMenuMobile" class="fixed inset-0 z-[9999] hidden bg-slate-950/30 md:hidden transition-opacity duration-200" onclick="toggleRiwayatMenuMobile()">
  <div class="absolute bottom-0 inset-x-0 bg-white rounded-t-3xl p-6 shadow-2xl space-y-4 transform translate-y-full transition-transform duration-200" onclick="event.stopPropagation()">
    <div class="w-12 h-1 bg-slate-200 rounded-full mx-auto mb-2" onclick="toggleRiwayatMenuMobile()"></div>
    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Pilih Riwayat Pengajuan</h3>
    <div class="grid grid-cols-2 gap-3 pt-2">
      <a href="/leave/apply" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-blue-50 border border-slate-100 text-center gap-2">
        <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center"><i class="fa-solid fa-clock-rotate-left text-sm"></i></div>
        <span class="text-xs font-bold text-slate-700">Riwayat Cuti</span>
      </a>
      <a href="/permit/history" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-amber-50 border border-slate-100 text-center gap-2">
        <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center"><i class="fa-solid fa-clock-rotate-left text-sm"></i></div>
        <span class="text-xs font-bold text-slate-700">Riwayat Izin</span>
      </a>
    </div>
  </div>
</div>

<!-- EXPENSE MENU -->
<div id="expenseMenuMobile" class="fixed inset-0 z-[9999] hidden bg-slate-950/30 md:hidden transition-opacity duration-200" onclick="toggleExpenseMenuMobile()">
  <div class="absolute bottom-0 inset-x-0 bg-white rounded-t-3xl p-6 shadow-2xl space-y-4 transform translate-y-full transition-transform duration-200" onclick="event.stopPropagation()">
    <div class="w-12 h-1 bg-slate-200 rounded-full mx-auto mb-2" onclick="toggleExpenseMenuMobile()"></div>
    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Menu Reimbursement & Keuangan</h3>
    <div class="grid grid-cols-2 gap-3 pt-2">
      <a href="/expense/create" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-cyan-50 border border-slate-100 text-center gap-2">
        <div class="w-10 h-10 rounded-xl bg-cyan-50 text-cyan-600 flex items-center justify-center"><i class="fa-solid fa-file-circle-plus text-sm"></i></div>
        <span class="text-xs font-bold text-slate-700">Buat Reimbursement</span>
      </a>
      <a href="/expense/my" class="flex flex-col items-center p-4 rounded-2xl bg-slate-50 hover:bg-blue-50 border border-slate-100 text-center gap-2">
        <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center"><i class="fa-solid fa-clock-rotate-left text-sm"></i></div>
        <span class="text-xs font-bold text-slate-700">Riwayat Saya</span>
      </a>
      <% if (typeof user !== 'undefined' && user.role) { %>
        <% const approverRoles = ['MANAGER_ADMINISTRASI', 'MANAGER_HAJI_UMRAH', 'MANAGER_KEUANGAN', 'WAKIL_DIREKTUR']; if (approverRoles.includes(user.role)) { %>
        <a href="/expense/approval/manager" class="col-span-2 flex items-center gap-3 p-4 rounded-2xl bg-amber-50/60 hover:bg-amber-50 border border-amber-100 text-left">
          <div class="w-10 h-10 rounded-xl bg-amber-500 text-white flex items-center justify-center shrink-0 shadow-sm"><i class="fa-solid fa-user-shield text-sm"></i></div>
          <div>
            <span class="text-xs font-bold text-slate-800 block">Persetujuan Reimbursement</span>
            <span class="text-[10px] text-slate-500 font-medium">Validasi berkas reimbursement pending milik staf</span>
          </div>
        </a>
        <% } %>
        <% if (user.role === 'MANAGER_KEUANGAN') { %>
        <a href="/expense/finance" class="col-span-2 flex items-center gap-3 p-4 rounded-2xl bg-emerald-50/60 hover:bg-emerald-50 border border-emerald-100 text-left">
          <div class="w-10 h-10 rounded-xl bg-emerald-600 text-white flex items-center justify-center shrink-0 shadow-sm"><i class="fa-solid fa-money-bill-transfer text-sm"></i></div>
          <div>
            <span class="text-xs font-bold text-slate-800 block">Validasi & Pencairan</span>
            <span class="text-[10px] text-slate-500 font-medium">Transfer dana & upload bukti transfer resmi</span>
          </div>
        </a>
        <% } %>
      <% } %>
    </div>
  </div>
</div>

<!-- LOAN MENU -->
<div id="loanMenuMobile" class="fixed inset-0 z-[9999] hidden bg-slate-950/30 md:hidden transition-opacity duration-200" onclick="toggleLoanMenuMobile()">
  <div class="absolute bottom-0 inset-x-0 bg-white rounded-t-3xl p-6 shadow-2xl space-y-4 transform translate-y-full transition-transform duration-200" onclick="event.stopPropagation()">

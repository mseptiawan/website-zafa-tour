<%- layout('layouts/main', { title }) %>

<div class="min-h-screen bg-slate-50/50 md:ml-72 md:p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
  <!-- Wrapper dengan margin yang lebih fleksibel untuk mobile -->
  <div class="max-w-none mx-auto space-y-6 md:space-y-8">

    <!-- Header Page -->
    <%- include('../partials/page-header', {
      section: 'Area Kerja',
      module: 'Kehadiran',
      title: 'Riwayat & Status Izin',
      description: 'Pantau status, otorisasi, dan riwayat dokumentasi perizinan operasional kerja pegawai.'
    }) %>

    <!-- Stats Grid: Dibuat grid-cols-1 di mobile, 2 di tablet, 4 di desktop -->
   <div class="w-full">
  <%- include('../partials/_stats-grid', {
    items: [
      { 
        label: 'Total Pengajuan', 
        value: summary.totalPermits, 
        unit: 'Berkas', 
        icon: 'fa-solid fa-folder-open', 
        bgClass: 'bg-white border border-slate-200/50 shadow-sm', 
        iconBoxClass: 'bg-slate-50 text-slate-600 border border-slate-100' 
      },
      { 
        label: 'Disetujui Wadir', 
        value: summary.approved, 
        unit: 'Berkas', 
        icon: 'fa-solid fa-circle-check', 
        bgClass: 'bg-white border border-slate-200/50 shadow-sm', 
        iconBoxClass: 'bg-emerald-50 text-emerald-600 border border-emerald-200/50' 
      },
      { 
        label: 'Pending Approval', 
        value: summary.pending, 
        unit: 'Berkas', 
        icon: 'fa-solid fa-hourglass-half', 
        bgClass: 'bg-white border border-slate-200/50 shadow-sm', 
        iconBoxClass: 'bg-amber-50 text-amber-600 border border-amber-200/50' 
      },
      { 
        label: 'Ditolak', 
        value: summary.rejected, 
        unit: 'Berkas', 
        icon: 'fa-solid fa-circle-xmark', 
        bgClass: 'bg-gradient-to-br from-slate-900 to-slate-800 border border-slate-800 shadow-sm', 
        valueClass: 'text-white', 
        labelClass: 'text-slate-300',
        unitClass: 'text-slate-400',
        iconBoxClass: 'bg-white/10 text-white border border-white/10' 
      }
    ]
  }) %>
</div>

    <!-- Tab Navigation -->
    <%- include('../partials/_tab-nav', {
      tabs: [
        { id: 'active', label: `Permintaan Masuk (${permits.filter(p => p.status === 'PENDING').length})` },
        { id: 'history', label: `Arsip Keputusan (${permits.filter(p => p.status !== 'PENDING').length})` }
      ]
    }) %>

    <!-- Tab Content -->
    <div class="relative">
      <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300">
        <%- include('partials/_table', { permits: permits.filter(p => p.status === 'PENDING'), type: 'active' }) %>
      </div>

      <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300">
        <%- include('partials/_table', { permits: permits.filter(p => p.status !== 'PENDING'), type: 'history' }) %>
      </div>
    </div>

  </div>

  <div id="approvalModal" class="fixed inset-0 z-[110] hidden flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm overflow-hidden transform transition-all">
      <form id="approvalForm" action="" method="POST">
        <input type="hidden" name="status" id="status">

        <div class="p-6">
          <h3 id="modalTitle" class="text-lg font-bold text-slate-800">Konfirmasi</h3>
          <p class="text-sm text-slate-500 mt-2">Apakah Anda yakin ingin <span id="actionLabel"></span> pengajuan ini?</p>

          <div class="mt-6">
            <textarea name="notes" placeholder="Tambahkan catatan (opsional)" class="w-full text-sm border border-slate-200 rounded-xl p-3 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
          </div>
        </div>

        <div class="p-4 bg-slate-50 flex gap-2">
          <button type="button" onclick="closeApprovalModal()" class="flex-1 py-2 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg">Batal</button>
          <button type="submit" class="flex-1 py-2 text-sm font-bold text-white bg-blue-600 rounded-lg hover:bg-blue-700">Ya, Proses</button>
        </div>
      </form>
    </div>
  </div>


</div>



<script>
  function openApprovalModal(id, status) {
    // 1. Update action form dengan ID yang benar: /permit/approval/:id
    const form = document.getElementById('approvalForm');
    form.action = '/permit/approval/' + id;

    // 2. Update status dan label
    document.getElementById('status').value = status;
    document.getElementById('actionLabel').innerText = status === 'APPROVED' ? 'MENYETUJUI' : 'MENOLAK';

    // 3. Tampilkan modal
    document.getElementById('approvalModal').classList.remove('hidden');
  }

  function closeApprovalModal() {
    document.getElementById('approvalModal').classList.add('hidden');
  }
</script>

💡 Penjelasan Perbaikan:

Dinamis action: Fungsi openApprovalModal sekarang secara otomatis mengubah form.action menjad
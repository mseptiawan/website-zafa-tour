<% layout('layouts/main') -%>

<div class="max-w-4xl mx-auto p-6">

  <!-- HEADER -->
  <div class="mb-6">

    <h1 class="text-2xl font-bold">
      Detail Pengajuan Cuti
    </h1>

    <p class="text-slate-500 text-sm">
      Informasi lengkap pengajuan cuti karyawan
    </p>

  </div>

  <!-- CARD -->
  <div class="bg-white rounded-2xl shadow p-8">

    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- JENIS CUTI -->
      <div>

        <p class="text-sm text-slate-500">
          Jenis Cuti
        </p>

        <h2 class="font-semibold text-lg mt-1">
          <%= leave.type %>
        </h2>

      </div>

      <!-- STATUS -->
      <div>

        <p class="text-sm text-slate-500">
          Status
        </p>

        <div class="mt-2">

          <span class="px-3 py-1 rounded-full text-xs font-medium

            <%= leave.status === 'Approved'
              ? 'bg-green-100 text-green-700'
              : leave.status === 'Rejected'
              ? 'bg-red-100 text-red-700'
              : 'bg-yellow-100 text-yellow-700'
            %>">

            <%= leave.status %>

          </span>

        </div>

      </div>

      <!-- TANGGAL MULAI -->
      <div>

        <p class="text-sm text-slate-500">
          Tanggal Mulai
        </p>

        <h2 class="font-semibold mt-1">

          <%= new Date(leave.startDate)
            .toLocaleDateString("id-ID") %>

        </h2>

      </div>

      <!-- TANGGAL SELESAI -->
      <div>

        <p class="text-sm text-slate-500">
          Tanggal Selesai
        </p>

        <h2 class="font-semibold mt-1">

          <%= new Date(leave.endDate)
            .toLocaleDateString("id-ID") %>

        </h2>

      </div>

      <!-- DURASI -->
      <div>

        <p class="text-sm text-slate-500">
          Durasi
        </p>

        <h2 class="font-semibold mt-1">
          <%= leave.totalDays %> Hari
        </h2>

      </div>

      <!-- CREATED -->
      <div>

        <p class="text-sm text-slate-500">
          Tanggal Pengajuan
        </p>

        <h2 class="font-semibold mt-1">

          <%= new Date(leave.createdAt)
            .toLocaleDateString("id-ID") %>

        </h2>

      </div>

    </div>

    <!-- ALASAN -->
    <div class="mt-8">

      <p class="text-sm text-slate-500 mb-2">
        Alasan Cuti
      </p>

      <div class="bg-slate-50 rounded-xl p-4 leading-relaxed">

        <%= leave.reason %>

      </div>

    </div>

    <!-- FILE -->
    <% if(leave.file){ %>

      <div class="mt-8">

        <p class="text-sm text-slate-500 mb-2">
          Lampiran Bukti
        </p>

        <div class="bg-slate-50 rounded-xl p-4 flex items-center justify-between">

          <div>

            <p class="font-medium">
              <%= leave.file %>
            </p>

            <p class="text-xs text-slate-400 mt-1">
              File pendukung pengajuan cuti
            </p>

          </div>

          <a
            href="/uploads/<%= leave.file %>"
            target="_blank"
            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm">

            Lihat File

          </a>

        </div>

      </div>

    <% } %>

    <!-- BUTTON -->
    <div class="mt-8">

      <a
        href="/leave/my"
        class="bg-slate-200 hover:bg-slate-300 px-5 py-3 rounded-xl text-sm inline-block">

        ← Kembali

      </a>

    </div>

  </div>

</div>
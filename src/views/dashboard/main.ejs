<%- layout('layouts/main') -%>

<div class="relative z-10 pt-5 md:pt-0">
  
  <!-- HEADER DASHBOARD -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
    <div>
      <h1 class="text-xl md:text-2xl font-semibold tracking-tight text-slate-950">
        <span class="md:hidden">Zafa Tour</span>
        <span class="hidden md:block">Zafa Tour, Melayani Dengan Hati</span>
      </h1>
      <p class="text-sm text-slate-500 mt-0.5 flex flex-wrap items-center gap-1.5">
        Hai, <span class="font-semibold text-slate-900"><%= user.fullName || user.username %></span> 
        <span class="text-[10px] md:text-[11px] bg-slate-200/80 px-2 py-0.5 rounded-md text-slate-700 font-semibold tracking-wide uppercase">Peran: <%= user.role.replace(/_/g, ' ') %></span>
      </p>
    </div>
    <div class="flex items-center gap-3 w-full sm:w-auto">
      <span class="hidden sm:inline-flex items-center justify-center gap-2 bg-slate-900 text-slate-100 px-4 py-2 text-xs font-semibold rounded-xl uppercase tracking-wider">
        <i class="fa-solid fa-calendar-day text-sm text-slate-400"></i> Tahun Buku: <%= new Date().getFullYear() %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-16 gap-6 items-stretch">
    
    <!-- KOLOM KIRI (7/16) - OPERASIONAL UTAMA -->
    <div class="grid-cols-1 lg:col-span-7 flex flex-col gap-6">
      <% if (user.role !== "DIREKTUR_UTAMA") { %>
      <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden flex flex-col justify-between">
        <div class="px-5 py-4 border-b border-slate-100 flex flex-row justify-between items-center bg-white gap-2">
          <h5 class="text-xs font-semibold tracking-wide text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-user-clock text-slate-400"></i> Presensi Hari Ini
          </h5>
          <span class="text-[11px] font-semibold text-slate-400 bg-slate-50 px-2.5 py-1 rounded-lg border border-slate-100 whitespace-nowrap">
            <%= new Date().toLocaleDateString('id-ID', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
          </span>
        </div>
        <div class="p-5">
          <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
            <div class="text-center sm:text-left">
              <h2 class="text-3xl font-semibold tracking-tight text-slate-950 mb-0.5">
                <%= attendance && attendance.checkIn ? new Date(attendance.checkIn).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) : '08:00' %>
                <span class="text-sm font-medium text-slate-400">WIB</span>
              </h2>
              <p class="text-[11px] text-slate-400 font-medium">Jam Masuk Kantor Zafa Tour</p>
            </div>
            
            <div class="flex gap-2.5 w-full sm:w-auto">
              <% if (!already) { %>
                <form action="/attendance" method="GET" class="m-0 p-0 w-full sm:w-auto">
                  <button type="submit" class="w-full justify-center inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-xs px-6 py-2.5 rounded-xl transition-all active:scale-95 cursor-pointer whitespace-nowrap">
                    <i class="fa-solid fa-sign-in-alt"></i> Masuk
                  </button>
                </form>
              <% } else if (already && !hasCheckedOut) { %>
                <form action="/attendance" method="GET" class="m-0 p-0 w-full sm:w-auto">
                  <button type="submit" class="w-full justify-center inline-flex items-center gap-2 bg-rose-500 hover:bg-rose-600 text-white font-semibold text-xs px-6 py-2.5 rounded-xl transition-all active:scale-95 cursor-pointer whitespace-nowrap">
                    <i class="fa-solid fa-sign-out-alt"></i> Pulang
                  </button>
                </form>
              <% } else { %>
                <div class="w-full justify-center inline-flex items-center gap-2 bg-slate-100 text-slate-500 font-semibold text-xs px-6 py-2.5 rounded-xl">
                  <i class="fa-solid fa-clipboard-check"></i> Presensi Selesai
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <% if (user.role !== "DIREKTUR_UTAMA") { %>
      <!-- 2. BOKS LOG KERJA -->
     <!-- 2. BOKS LOG KERJA -->
      <!-- 2. BOKS LOG KERJA -->
<div class="bg-white rounded-2xl border border-slate-100 overflow-hidden flex flex-col min-h-[400px]">
  <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white gap-2 select-none">
    <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
      <i class="fa-solid fa-list-check text-indigo-600"></i> Log Kerja & Aktivitas Hari Ini
    </h5>
    <button onclick="triggerCarryOver()" class="text-[10px] font-semibold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 px-2.5 py-1 rounded-lg border border-indigo-100/50 transition-colors cursor-pointer whitespace-nowrap">
      <i class="fa-solid fa-arrows-spin mr-1"></i> Carry Over
    </button>
  </div>
  
  <div class="p-4 space-y-3 flex-1 overflow-y-auto max-h-[380px]">
    <% if (initialLogs && initialLogs.length > 0) { %>
      <% initialLogs.forEach(log => { %>
        <div class="p-3.5 bg-slate-50/70 rounded-xl border border-slate-200/40 hover:bg-slate-50 transition-colors flex flex-col gap-2 w-full min-w-0">
          
          <!-- Baris Atas: Kategori KPI & Status Mongoose Enum -->
          <div class="flex items-center justify-between gap-2 w-full select-none">
            <span class="inline-flex text-[9px] font-bold px-2 py-0.5 rounded bg-blue-50 text-blue-600 border border-blue-100 uppercase tracking-wider truncate">
              <%= log.kpiTemplateId?.name || 'Aktivitas Umum' %>
            </span>
            <span class="inline-flex items-center text-[9px] font-bold px-2 py-0.5 rounded-md shrink-0 uppercase tracking-wide border 
              <%= log.status === 'Completed' ? 'bg-emerald-50 text-emerald-700 border-emerald-100' : 
                  log.status === 'In Progress' ? 'bg-blue-50 text-blue-700 border-blue-100' : 
                  log.status === 'Canceled' ? 'bg-slate-100 text-slate-600 border-slate-200' : 
                  'bg-amber-50 text-amber-700 border-amber-100' %>">
              <%= log.status %>
            </span>
          </div>

          <!-- Baris Tengah: Judul & Deskripsi Hasil Sesuai Skema -->
          <div class="min-w-0">
            <h6 class="text-xs font-bold text-slate-900 break-words leading-tight">
              <%= log.title %> <!-- Menggunakan log.title -->
            </h6>
            <% if (log.resultDescription) { %> <!-- Menggunakan log.resultDescription -->
              <p class="text-[11px] text-slate-500 mt-1 line-clamp-2 break-words font-medium leading-normal">
                <%= log.resultDescription %>
              </p>
            <% } %>
          </div>

          <!-- Baris Bawah: Waktu & Dokumen Pendukung -->
          <div class="flex items-center justify-between text-[9.5px] text-slate-400 font-medium pt-1.5 border-t border-slate-200/30 select-none">
            <span><i class="fa-regular fa-clock mr-1"></i> <%= moment(log.createdAt).format('HH:mm') %> WIB</span>
            <% if (log.attachmentFile) { %> <!-- Menggunakan log.attachmentFile -->
              <span class="text-indigo-600 font-semibold"><i class="fa-solid fa-paperclip mr-0.5"></i> Ada Lampiran</span>
            <% } %>
          </div>

        </div>
      <% }) %>
    <% } else { %>
      <div class="flex flex-col items-center justify-center h-full text-slate-400 py-16">
        <i class="fa-regular fa-clipboard text-3xl mb-2.5 text-slate-300"></i>
        <p class="text-xs italic font-medium">Belum ada log kerja harian hari ini.</p>
        <p class="text-[10px] text-slate-400 mt-0.5">Semua progress yang diisi akan tampil di sini.</p>
      </div>
    <% } %>
  </div>
  
  <div class="p-3 bg-slate-50/40 border-t border-slate-100 text-center select-none">
    <a href="/daily-activities" class="text-xs font-semibold text-slate-500 hover:text-slate-800 inline-flex items-center gap-1 transition-colors no-underline">
      Buka Lembar Kerja Harian <i class="fa-solid fa-arrow-right text-[10px]"></i>
    </a>
  </div>
</div>
      <% } %>
    </div>

    <!-- KOLOM TENGAH (5/16) - FINANSIAL & DINAS LUAR -->
    <div class="grid-cols-1 lg:col-span-5 flex flex-col gap-6">
      <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden flex flex-col min-h-[160px] justify-between">
        <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white">
          <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-plane-departure text-indigo-500"></i> Anggaran Dinas Luar Anda
          </h5>
          <a href="/trip/me" class="text-[11px] font-semibold text-slate-400 hover:text-slate-700">Semua <i class="fa-solid fa-chevron-right text-[9px] ml-0.5"></i></a>
        </div>
        <div class="p-4 space-y-3 flex-1 flex flex-col justify-center">
          <% if (myTrips && myTrips.length > 0) { %>
            <% const trip = myTrips[0]; %>
            <div class="p-3 bg-slate-50/80 border border-slate-100 rounded-xl flex items-center justify-between gap-2 w-full">
              <div class="min-w-0">
                <p class="text-xs font-semibold text-slate-900 truncate"><%= trip.destination %></p>
                <p class="text-[11px] text-slate-400 font-medium mt-0.5">Dana Ops: <span class="text-slate-700 font-semibold">IDR <%= trip.budget?.total?.toLocaleString('id-ID') || 0 %></span></p>
              </div>
              <div class="text-end shrink-0">
                <span class="inline-flex text-[9px] font-extrabold px-2 py-0.5 rounded-md bg-emerald-50 text-emerald-700 border border-emerald-100 uppercase tracking-wide">
                  <%= trip.status === 'PAYMENT_PROCESSING' ? 'READY' : trip.status.replace(/_/g, ' ') %>
                </span>
              </div>
            </div>
          <% } else { %>
            <div class="text-center p-4 border border-dashed border-slate-200 rounded-xl w-full">
              <p class="text-[11px] text-slate-400 italic">Tidak ada jadwal dinas luar aktif.</p>
            </div>
          <% } %>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-slate-100 p-4.5">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-rose-50 text-rose-500 rounded-xl flex items-center justify-center shrink-0 border border-rose-100/50">
            <i class="fa-solid fa-umbrella-beach text-xs"></i>
          </div>
          <div class="min-w-0 text-xs">
            <div class="text-slate-400 font-semibold uppercase tracking-wider text-[10px]">Libur Kalender Terdekat:</div>
            <% if (nextHoliday) { %>
              <span class="text-slate-900 font-semibold truncate block mt-0.5"><%= nextHoliday.name %></span>
              <span class="text-slate-400 font-semibold text-[11px]">
                <%= new Date(nextHoliday.date).toLocaleDateString('id-ID', { month: 'short', day: 'numeric' }) %>
              </span>
            <% } else { %>
              <span class="text-slate-400 italic block mt-0.5 font-medium">Tidak ada agenda libur dalam waktu dekat.</span>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- KOLOM KANAN (4/16) - MAKLUMAT & PENGUMUMAN PERUSAHAAN -->
   <!-- KOLOM KANAN (4/16) - MAKLUMAT & PENGUMUMAN PERUSAHAAN -->
    <div class="grid-cols-1 lg:col-span-4 flex flex-col gap-6">
      <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden flex flex-col min-h-[460px]">
        <div class="px-4 py-3.5 border-b border-slate-100 bg-white">
          <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-bullhorn text-amber-500"></i> Pengumuman Perusahaan
          </h5>
        </div>
        <div class="p-4 space-y-4 flex-1 overflow-y-auto">
          <% if (latestAnnouncements && latestAnnouncements.length > 0) { %>
            <% latestAnnouncements.forEach(ann => { %>
              <a href="/announcement/<%= ann._id %>" class="group block cursor-pointer border-b border-slate-100/50 last:border-none pb-3 last:pb-0 no-underline">
                
                <!-- Baris Atas: Info Author & Tanggal -->
                <div class="flex items-center justify-between text-[9px] text-slate-400 font-medium select-none mb-1">
                  <span>Oleh: <span class="text-slate-700 font-semibold"><%= ann.authorName %></span></span>
                  <span><%= moment(ann.publishDate || ann.createdAt).format('DD MMM YYYY') %></span>
                </div>

                <!-- Judul + Tag Kategori Resmi/Biasa -->
                <div class="flex items-start gap-1.5 mt-0.5">
                  <% if (ann.category === 'OFFICIAL') { %>
                    <span class="inline-block shrink-0 text-[8px] font-extrabold px-1 py-0.2 rounded bg-rose-50 text-rose-600 border border-rose-100 tracking-wide uppercase select-none">RESMI</span>
                  <% } %>
                  <h6 class="text-xs font-bold text-slate-900 group-hover:text-blue-600 transition-colors line-clamp-1 leading-tight">
                    <%= ann.title %>
                  </h6>
                </div>

                <!-- Konten Singkat -->
                <p class="text-[11px] text-slate-400 line-clamp-3 mt-1 font-medium leading-relaxed break-words">
                  <%= ann.content %>
                </p>

                <!-- Indikator Lampiran Dokumen -->
                <% if (ann.attachment) { %>
                  <div class="mt-1.5 text-[9.5px] text-indigo-600 font-semibold flex items-center gap-0.5 select-none">
                    <i class="fa-solid fa-file-pdf"></i> Lampiran Berkas Dokumen
                  </div>
                <% } %>
              </a>
            <% }) %>
          <% } else { %>
            <div class="flex flex-col items-center justify-center h-full text-slate-400 py-12 select-none">
              <i class="fa-solid fa-bullhorn text-2xl mb-1 text-slate-200"></i>
              <span class="text-[11px] font-medium italic">Belum ada pengumuman resmi.</span>
            </div>
          <% } %>
        </div>
        <div class="p-3 bg-slate-50/40 border-t border-slate-100 text-center select-none">
          <a href="/announcement" class="text-xs font-semibold text-slate-500 hover:text-slate-800 inline-flex items-center gap-1 transition-colors no-underline">
            Lihat Semua Maklumat <i class="fa-solid fa-arrow-right text-[10px]"></i>
          </a>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  // Fungsi Fetch Realtime Rekap Kehadiran
  async function fetchRealtimeAttendanceSummary() {
    try {
      // Panggil endpoint API internal baru
      const response = await fetch('/api/dashboard/attendance-summary');
      if (!response.ok) return;

      const resData = await response.json();
      if (resData.success && resData.rekapAbsen) {
        document.getElementById('realtime-hadir').innerText = resData.rekapAbsen.hadir;
        document.getElementById('realtime-telat').innerText = resData.rekapAbsen.telat;
        document.getElementById('realtime-alpa').innerText = resData.rekapAbsen.alpa;
      }
    } catch (err) {
      console.error("Gagal sinkronisasi data presensi secara realtime:", err);
    }
  }

  function toggleSalaryMask(btn) {
    const salarySpan = document.getElementById('salaryAmount');
    const isMasked = salarySpan.innerText.includes('•••••••');
    const icon = btn.querySelector('.eye-icon');
    const text = btn.querySelector('.eye-text');
    
    if (isMasked) {
      salarySpan.innerText = salarySpan.getAttribute('data-real-value');
      icon.classList.replace('fa-eye', 'fa-eye-slash');
      text.innerText = 'Tutup';
    } else {
      salarySpan.innerText = 'IDR •••••••';
      icon.classList.replace('fa-eye-slash', 'fa-eye');
      text.innerText = 'Lihat';
    }
  }

  function handleClockIn() {
    console.log("Memicu pengambilan koordinat geofencing kantor...");
  }

  document.addEventListener("DOMContentLoaded", function() {
    console.log("Dashboard siap.");
    // Eksekusi pembaruan data secara berkala (setiap 20 detik)
    setInterval(fetchRealtimeAttendanceSummary, 20000);
  });

  function triggerCarryOver() {
    console.log("Memicu fungsi carryOverTasks dari controller harian...");
  }
</script>
<%- layout('layouts/main', { title: 'Input KPI Pegawai' }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8">
  <div class="mx-auto max-w-5xl">
    <%- include('../partials/page-header', {
      section: 'Area Kerja',
      module: 'Performance',
      title: 'Input Penilaian KPI',
      description: 'Kelola penilaian kinerja Pegawai per kuartal secara akurat.'
    }) %>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[800px] text-sm">
          <thead class="bg-slate-50 text-xs tracking-wider text-slate-500 uppercase">
            <tr>
              <th class="px-6 py-4 text-left">Pegawai</th>
              <th class="px-6 py-4 text-left">Unit Kerja</th>
              <th class="px-6 py-4 text-left">Bidang</th>
              <th class="px-6 py-4 text-center">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (employees.length === 0) { %>
            <tr>
              <td colspan="4" class="py-10 text-center text-slate-400">Belum ada data Pegawai</td>
            </tr>
            <% } %> <% employees.forEach(emp => { %> <% const isEvaluated =
            evaluatedIds.includes(emp._id.toString()); const currentMonth = 6; // Set untuk testing
            const isPeriodOpen = [3, 6, 9, 12].includes(currentMonth); %>
            <tr class="transition hover:bg-slate-50">
              <td class="px-6 py-4">
                <div class="font-medium text-slate-800"><%= emp.fullName %></div>
              </td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center rounded-md border border-slate-100 bg-slate-50 px-2 py-0.5 text-[10px] font-semibold text-slate-600">
                  <%= emp.careerData?.unitId?.name || '-' %>
                </span>
              </td>
              <td class="px-6 py-4 text-slate-500"><%= emp.careerData?.bidangId?.name || '-' %></td>

              <td class="px-6 py-4 text-center">
                <% if (isEvaluated) { %>
                <div class="inline-flex items-center gap-1.5 rounded-full border border-emerald-200/50 bg-emerald-50/70 px-2.5 py-1 text-[10px] font-medium text-emerald-600">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                  Sudah Dinilai
                </div>
                <% } else if (!isPeriodOpen) { %>
                <div class="inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[10px] font-medium text-slate-400">
                  Menunggu Kuartal
                </div>
                <% } else { %>
                <a href="/kpi/appraisal-form/<%= emp._id %>" class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-3 py-1.5 text-[11px] font-medium text-white shadow-sm shadow-indigo-200 transition-all hover:bg-blue-700">
                  Nilai Kinerja
                </a>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
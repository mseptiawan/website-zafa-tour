<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-7xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-xl font-medium text-slate-800">
        Perjalanan Saya
      </h1>

      <p class="text-sm text-slate-500 mt-1">
        Daftar pengajuan dinas luar yang kamu ajukan
      </p>
    </div>

    <!-- TABLE CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">

      <div class="overflow-x-auto">

        <table class="w-full text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 border-b border-slate-200">

            <tr class="text-xs uppercase tracking-wide text-slate-500">

              <th class="px-5 py-4 text-left font-medium">Judul</th>
              <th class="px-5 py-4 text-left font-medium">Tujuan</th>
              <th class="px-5 py-4 text-left font-medium">Tanggal</th>
              <th class="px-5 py-4 text-left font-medium">Budget</th>
              <th class="px-5 py-4 text-left font-medium">Status</th>
              <th class="px-5 py-4 text-left font-medium">Aksi</th>

            </tr>

          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% if (trips.length === 0) { %>

              <tr>
                <td colspan="6" class="px-5 py-14 text-center">

                  <div class="text-sm font-medium text-slate-600">
                    Belum ada pengajuan perjalanan
                  </div>

                  <p class="text-xs text-slate-400 mt-1">
                    Silakan buat pengajuan dinas luar terlebih dahulu
                  </p>

                </td>
              </tr>

            <% } %>

            <% trips.forEach(trip => { %>

              <tr class="hover:bg-slate-50 transition">

                <!-- JUDUL -->
                <td class="px-5 py-4 font-medium text-slate-800">
                  <%= trip.title %>
                </td>

                <!-- TUJUAN -->
                <td class="px-5 py-4 text-slate-600">
                  <%= trip.destination %>
                </td>

                <!-- TANGGAL -->
                <td class="px-5 py-4 text-slate-600">

                  <div class="text-xs">

                    <div>
                      <span class="text-slate-400">Mulai:</span>
                      <%= new Date(trip.startDate).toLocaleDateString('id-ID') %>
                    </div>

                    <div>
                      <span class="text-slate-400">Selesai:</span>
                      <%= new Date(trip.endDate).toLocaleDateString('id-ID') %>
                    </div>

                  </div>

                </td>

                <!-- BUDGET -->
                <td class="px-5 py-4 font-medium text-slate-700">
                  Rp <%= Number(trip.budget).toLocaleString('id-ID') %>
                </td>

                <!-- STATUS -->
                <td class="px-5 py-4">

                  <% if (trip.status === 'PENDING') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-amber-50 text-amber-600 border border-amber-100 font-medium">
                      Pending
                    </span>

                  <% } else if (trip.status === 'APPROVED_MANAGER') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-blue-50 text-blue-600 border border-blue-100 font-medium">
                      Manager Approved
                    </span>

                  <% } else if (trip.status === 'APPROVED_DIRECTOR') { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-emerald-50 text-emerald-600 border border-emerald-100 font-medium">
                      Director Approved
                    </span>

                  <% } else { %>

                    <span class="px-2.5 py-1 text-xs rounded-full bg-rose-50 text-rose-600 border border-rose-100 font-medium">
                      Rejected
                    </span>

                  <% } %>

                </td>

                <!-- AKSI -->
                <td class="px-5 py-4">

                  <a
                    href="/trip/detail/<%= trip._id %>"
                    class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-700 text-sm font-medium"
                  >
                    Detail

                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 5l7 7-7 7"/>
                    </svg>

                  </a>

                </td>

              </tr>

            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>
<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50 p-6">
  <div class="max-w-2xl mx-auto">
    <!-- HEADER -->
    <div class="mb-6 text-center">
      <h1 class="text-xl font-medium text-slate-800">Ajukan Cuti</h1>
      <p class="text-sm text-slate-500 mt-1">Lengkapi formulir pengajuan cuti dengan benar</p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-xl p-6">
      <form action="/leave/apply" method="POST" enctype="multipart/form-data" class="space-y-4">
        <!-- JENIS CUTI -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">Jenis Cuti</label>
  <select name="typeId" required class="w-full border px-3 py-2 rounded-lg">

  <% if (leaveTypes && leaveTypes.length > 0) { %>

    <% leaveTypes.forEach(t => { %>
      <option value="<%= t._id %>">
        <%= t.name %>
      </option>
    <% }) %>

  <% } else { %>

    <option disabled>Tidak ada jenis cuti</option>

  <% } %>

</select>
        </div>

        <!-- TANGGAL -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-slate-500 mb-1">Mulai</label>
            <input
              type="date"
              name="startDate"
              required
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
            />
          </div>

          <div>
            <label class="block text-xs text-slate-500 mb-1">Selesai</label>
            <input
              type="date"
              name="endDate"
              required
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
            />
          </div>
        </div>

        <!-- ALASAN -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">Alasan</label>
          <textarea
            name="reason"
            rows="3"
            required
            placeholder="Jelaskan alasan cuti..."
            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-400"
          ></textarea>
        </div>

        <!-- FILE -->
        <div>
          <label class="block text-xs text-slate-500 mb-1">Dokumen (opsional)</label>
          <input
            type="file"
            name="file"
            class="w-full text-sm border border-slate-200 rounded-lg p-2 bg-slate-50"
          />
        </div>

        <!-- BUTTON -->
        <button
          type="submit"
          class="w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium py-2.5 rounded-lg transition"
        >
          Kirim Pengajuan
        </button>
      </form>
    </div>
  </div>
</div>

<%- layout('layouts/main', { title: 'Catat Lembur' }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] px-4 py-5 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0">

    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Lembur', 
        title: 'Catat Lembur', 
        description: 'Isi rincian detail lembur yang dilakukan secara aktual.' 
    }) %>

    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl p-4 sm:p-5 md:p-8 shadow-2xs md:shadow-sm overflow-hidden">
      
      <% if (errors && Object.keys(errors).length > 0) { %>
        <div class="mb-6 p-3.5 rounded-xl bg-rose-50 text-rose-600 text-[13px] border border-rose-100 font-medium">
          <% Object.values(errors).forEach(function(message) { %>
            <div class="flex items-center gap-2"><i class="fa-solid fa-circle-exclamation text-[10px]"></i> <%= message %></div>
          <% }) %>
        </div>
      <% } %>
      
      <form id="overtime-form" action="/overtime/" method="POST" enctype="multipart/form-data" class="space-y-5">

        <div class="space-y-2">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Tanggal Lembur</label>
          <input type="date" id="dateInput" name="date" required min="<%= dateLimit.min %>" max="<%= dateLimit.max %>"
                 class="w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] focus:bg-white focus:border-slate-400 outline-none transition-all text-slate-800" />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Jam Mulai</label>
            <input type="text" id="startTime" name="startTime" required placeholder="16:30" class="timepicker w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] focus:bg-white focus:border-slate-400 outline-none transition-all text-slate-800" />
          </div>
          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Jam Selesai</label>
            <input type="text" id="endTime" name="endTime" required placeholder="21:00" class="timepicker w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] focus:bg-white focus:border-slate-400 outline-none transition-all text-slate-800" />
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Pekerjaan Yang Dilakukan</label>
          <textarea name="workDescription" required rows="4" maxlength="500" placeholder="Jelaskan detail tugas lembur Anda..." 
                    class="w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] focus:bg-white focus:border-slate-400 outline-none resize-none transition-all leading-relaxed text-slate-800"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Lokasi Kerja</label>
            <select id="locationType" name="location[type]" required class="w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] focus:bg-white focus:border-slate-400 outline-none transition-all text-slate-800 appearance-none">
              <option value="OFFICE">Kantor (Office)</option>
              <option value="REMOTE">Remote (WFH)</option>
              <option value="CLIENT_SITE">Lokasi Klien</option>
              <option value="OTHER">Lainnya</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-[12px] font-semibold text-slate-700 tracking-wide">Detail Lokasi</label>
            <input type="text" id="locationDetail" name="location[detail]" required placeholder="Contoh: Gedung A" 
                   class="w-full bg-slate-50/60 border border-slate-200/70 rounded-xl px-4 py-2.5 text-[13px] focus:bg-white focus:border-slate-400 outline-none transition-all text-slate-800" />
          </div>
        </div>

        <div class="space-y-2">
          <label class="block text-[12px] font-semibold text-slate-700 tracking-wide">
            Bukti Lampiran <span class="text-slate-400 font-normal">(Opsional)</span>
          </label>

          <div id="dropzone-empty" class="relative w-full border border-slate-200 border-dashed rounded-xl p-5 bg-slate-50/50 hover:bg-slate-50 transition flex flex-col items-center justify-center text-center">
            <input type="file" name="proofFile" id="file-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="handleFileSelect(this)" />
            <svg class="w-4 h-4 text-slate-400 mb-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" /></svg>
            <span class="text-[12px] font-medium text-slate-600">Pilih Berkas atau Drop File Disini</span>
          </div>

          <div id="dropzone-filled" class="hidden flex items-center justify-between border border-slate-200 rounded-xl p-3.5 bg-white shadow-xs">
            <div class="flex items-center gap-3 min-w-0 flex-1">
              <div class="w-9 h-9 rounded-lg overflow-hidden border border-slate-200/60 bg-slate-50 flex items-center justify-center">
                 <img id="img-preview" class="w-full h-full object-cover hidden" />
                 <svg id="file-icon-fallback" class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625..."/></svg>
              </div>
              <div>
                <div id="name-preview" class="text-[12px] font-semibold text-slate-700 truncate">file.jpg</div>
                <div id="size-preview" class="text-[11px] text-slate-400">0 KB</div>
              </div>
            </div>
            <button type="button" onclick="triggerChangeFile()" class="text-[11px] font-medium text-slate-600 bg-slate-50 border border-slate-200/60 hover:bg-slate-100 px-3 py-1.5 rounded-lg">Ganti</button>
          </div>
        </div>

        <div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-3">
          <a href="/overtime/my" class="px-6 py-2.5 rounded-xl text-[12px] font-semibold text-slate-600 hover:bg-slate-100 transition-colors">Batal</a>
          <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white px-6 py-2.5 rounded-xl text-[12px] font-semibold transition-colors shadow-xs">
            Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
  let currentFileUrl = null;

  function handleFileSelect(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];

      if (currentFileUrl) {
        URL.revokeObjectURL(currentFileUrl);
      }

      currentFileUrl = URL.createObjectURL(file);
      const viewBtn = document.getElementById("view-file-btn");
      viewBtn.href = currentFileUrl;

      document.getElementById("name-preview").textContent = file.name;

      const fileSizeInKB = file.size / 1024;
      if (fileSizeInKB < 1024) {
        document.getElementById("size-preview").textContent = fileSizeInKB.toFixed(1) + " KB";
      } else {
        document.getElementById("size-preview").textContent = (fileSizeInKB / 1024).toFixed(2) + " MB";
      }

      const imgPreview = document.getElementById("img-preview");
      const fileIconFallback = document.getElementById("file-icon-fallback");

      if (file.type.startsWith("image/")) {
        imgPreview.src = currentFileUrl;
        imgPreview.classList.remove("hidden");
        fileIconFallback.classList.add("hidden");
      } else {
        imgPreview.src = "";
        imgPreview.classList.add("hidden");
        fileIconFallback.classList.remove("hidden");
      }

      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
    }
  }

  function triggerChangeFile() {
    document.getElementById("file-input").click();
  }
</script>

<script>
  flatpickr(".timepicker", {
    enableTime: true,
    noCalendar: true,
    dateFormat: "H:i",
    time_24hr: true,
    minTime: "16:30",
    maxTime: "23:59",
  });
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const dateInput = document.getElementById("dateInput");
  dateInput.min = dateInput.getAttribute("min");
  dateInput.max = dateInput.getAttribute("max");
});
</script>

<script>
  const locationType = document.getElementById('locationType');
  const locationDetail = document.getElementById('locationDetail');

  function updateDetailLocation() {
    if (locationType.value === 'OFFICE') {
      locationDetail.value = 'Kantor pusat zafa tour palembang';
    } else {
      if (locationDetail.value === 'Kantor pusat zafa tour palembang') {
          locationDetail.value = '';
      }
    }
  }

  locationType.addEventListener('change', updateDetailLocation);
  document.addEventListener('DOMContentLoaded', updateDetailLocation);
</script>

<script>
  document.getElementById('overtime-form').addEventListener('submit', function (e) {
    const startTimeRaw = document.getElementById('startTime').value;
    const endTimeRaw = document.getElementById('endTime').value;

    if (startTimeRaw && endTimeRaw) {
      const [startHour, startMin] = startTimeRaw.split(':').map(Number);
      const [endHour, endMin] = endTimeRaw.split(':').map(Number);

      const totalStartMinutes = startHour * 60 + startMin;
      const totalEndMinutes = endHour * 60 + endMin;

      if (totalEndMinutes <= totalStartMinutes) {
        e.preventDefault(); 
        alert('Jam Selesai lembur harus lebih besar dari Jam Mulai!');
        return false;
      }
    }
  });
</script>
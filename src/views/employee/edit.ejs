<%- layout('layouts/main', { title: "Edit Karyawan" }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

  <div class="max-w-2xl mx-auto">

    <!-- BREADCRUMB & HEADER -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 mb-2 text-[11px] font-semibold text-slate-400 uppercase tracking-widest">
        <span>Area Kerja</span>
        <span class="text-slate-300">/</span>
        <a href="/employee" class="hover:text-slate-600 transition-colors">Karyawan</a>
        <span class="text-slate-300">/</span>
        <span class="text-slate-900">Edit</span>
      </nav>

      <h1 class="text-2xl font-bold text-slate-900">
        Edit Data Karyawan
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Perbarui informasi profil kerja milik <span class="font-medium text-slate-700"><%= employee.fullName %></span>
      </p>
    </div>

    <!-- CARD CONTAINER -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

      <form action="/api/employee/edit/<%= employee._id %>" method="POST" class="p-8 space-y-6">

        <% if (error) { %>
          <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm border border-red-100">
            <%= error %>
          </div>
        <% } %>

        <!-- SECTION 1: DATA AKUN SISTEM -->
        <div class="space-y-4 pb-4 border-b border-slate-100">
          <h3 class="text-xs font-semibold text-indigo-600 uppercase tracking-wider">Informasi Kredensial & Akun</h3>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- USERNAME (Read Only) -->
            <div class="space-y-1.5">
              <label class="text-[13px] font-medium text-slate-600">Username</label>
              <input type="text" value="@<%= employee.userId?.username %>" readonly
                class="w-full bg-slate-50 border border-slate-200 text-slate-400 rounded-xl px-4 py-3 text-xs outline-none cursor-not-allowed select-none" />
            </div>

            <!-- EMAIL (Read Only) -->
            <div class="space-y-1.5">
              <label class="text-[13px] font-medium text-slate-600">Email Login</label>
              <input type="email" name="email" value="<%= employee.userId?.email %>" readonly
                class="w-full bg-slate-50 border border-slate-200 text-slate-400 rounded-xl px-4 py-3 text-xs outline-none cursor-not-allowed select-none" />
            </div>
          </div>
        </div>

        <!-- SECTION 2: BIODATA & PROFIL PEKERJAAN -->
        <div class="space-y-5">
          <h3 class="text-xs font-semibold text-indigo-600 uppercase tracking-wider">Biodata & Profil Karyawan</h3>

          <!-- NAMA LENGKAP -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-medium text-slate-600">Nama Lengkap</label>
            <input type="text" name="fullName" required value="<%= employee.fullName %>"
              class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 
              focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all" />
          </div>

          <!-- JABATAN / POSISI -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-medium text-slate-600">Jabatan / Posisi</label>
            <select name="positionId" required 
              class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
              <% positions.forEach(p => { %>
                <option value="<%= p._id %>" <%= String(employee.positionId?._id || employee.positionId) === String(p._id) ? 'selected' : '' %>><%= p.name %></option>
              <% }) %>
            </select>
          </div>

          <!-- UNIT & BIDANG (GRID) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[13px] font-medium text-slate-600">Unit Kerja</label>
              <select name="unitId"
                class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
                <option value="">Pilih Unit</option>
                <% units.forEach(u => { %>
                  <option value="<%= u._id %>" <%= String(employee.unitId?._id || employee.unitId) === String(u._id) ? 'selected' : '' %>><%= u.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="space-y-1.5">
              <label class="text-[13px] font-medium text-slate-600">Bidang</label>
              <select name="bidangId"
                class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
                <option value="">Pilih Bidang</option>
                <% bidang.forEach(b => { %>
                  <option value="<%= b._id %>" <%= String(employee.bidangId?._id || employee.bidangId) === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <!-- IKATAN KERJA & GAJI POKOK (GRID) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[13px] font-medium text-slate-600">Status Ikatan Kerja</label>
              <select name="employmentStatus" required 
                class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
                <option value="Tetap" <%= employee.employmentStatus === 'Tetap' ? 'selected' : '' %>>Tetap</option>
                <option value="Kontrak" <%= employee.employmentStatus === 'Kontrak' ? 'selected' : '' %>>Kontrak</option>
                <option value="Magang" <%= employee.employmentStatus === 'Magang' ? 'selected' : '' %>>Magang</option>
              </select>
            </div>

            <div class="space-y-1.5">
              <label class="text-[13px] font-medium text-slate-600">Gaji Pokok (IDR)</label>
              <input type="number" name="baseSalary" value="<%= employee.baseSalary || 0 %>"
                class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 
                focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all" />
            </div>
          </div>

          <!-- GENDER -->
          <div class="space-y-2">
            <label class="text-[13px] font-medium text-slate-600 block">Jenis Kelamin</label>
            <div class="flex items-center gap-6 text-xs font-medium text-slate-500 pt-0.5">
              <label class="flex items-center gap-2 cursor-pointer group">
                <input type="radio" name="gender" value="Laki-Laki" required <%= employee.gender === 'Laki-Laki' ? 'checked' : '' %>
                  class="w-4 h-4 text-blue-600 bg-slate-50 border-slate-300 focus:ring-blue-500/20 focus:ring-offset-0 focus:ring-4 transition-all" />
                <span class="group-hover:text-slate-800 transition-colors">Laki-Laki</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer group">
                <input type="radio" name="gender" value="Perempuan" <%= employee.gender === 'Perempuan' ? 'checked' : '' %>
                  class="w-4 h-4 text-blue-600 bg-slate-50 border-slate-300 focus:ring-blue-500/20 focus:ring-offset-0 focus:ring-4 transition-all" />
                <span class="group-hover:text-slate-800 transition-colors">Perempuan</span>
              </label>
            </div>
          </div>

          <!-- NO TELEPON -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-medium text-slate-600">No HP / WhatsApp</label>
            <input type="tel" name="phoneNumber" placeholder="08xxxxxxxxxx" value="<%= employee.phoneNumber || '' %>"
              class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 
              focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all" />
          </div>

          <!-- ALAMAT -->
          <div class="space-y-1.5">
            <label class="text-[13px] font-medium text-slate-600">Alamat Rumah</label>
            <textarea name="address" rows="3" placeholder="Alamat lengkap tempat tinggal..." 
              class="w-full bg-slate-50/50 border border-slate-200 rounded-xl px-4 py-3 
              focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none resize-none transition-all"><%= employee.address || '' %></textarea>
          </div>
        </div>

        <!-- ACTION BUTTONS -->
        <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
          <!-- BUTTON BATAL -->
          <a href="/employee"
            class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
            Batal
          </a>

          <!-- BUTTON SIMPAN PERUBAHAN -->
          <button type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
            Simpan Perubahan
          </button>
        </div>

      </form>

    </div>

  </div>

</div>
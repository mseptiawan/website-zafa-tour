<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-5xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6 flex items-center justify-between">

      <div>
        <h1 class="text-2xl font-semibold text-slate-800">
          Riwayat Sales Visit
        </h1>
        <p class="text-sm text-slate-500 mt-1">
          Daftar kunjungan yang telah kamu lakukan
        </p>
      </div>

      <a href="/sales/new"
        class="bg-slate-900 hover:bg-black text-white text-sm font-medium px-4 py-2 rounded-lg transition">
        + Tambah Kunjungan
      </a>

    </div>

    <!-- EMPTY -->
    <% if (visits.length === 0) { %>
      <div class="bg-white border border-slate-200 rounded-xl py-14 text-center">
        <p class="text-sm text-slate-500">Belum ada data kunjungan</p>
      </div>
    <% } else { %>

      <!-- LIST -->
      <div class="space-y-3">

        <% visits.forEach(v => { %>

          <div class="bg-white border border-slate-200 rounded-xl px-5 py-4 hover:border-slate-300 transition">

            <div class="flex items-start justify-between gap-4">

              <!-- LEFT -->
              <div class="min-w-0 flex-1">

                <!-- TITLE -->
                <h2 class="text-[15px] font-medium text-slate-800 break-words">
                  <%= v.title %>
                </h2>

                <!-- ADDRESS -->
                <p class="text-sm text-slate-500 mt-1 truncate">
                  <%= v.address %>
                </p>

                <!-- META -->
                <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-3 text-[13px] text-slate-500">

                  <div>
                    <span class="text-slate-400">Meet:</span>
                    <span class="text-slate-700 ml-1">
                      <%= v.meetWith %>
                    </span>
                  </div>

                  <div>
                    <span class="text-slate-400">Waktu:</span>
                    <span class="text-slate-700 ml-1">
                      <%= new Date(v.visitTime).toLocaleDateString("id-ID", {
                        day: "numeric",
                        month: "short",
                        year: "numeric"
                      }) %>
                    </span>
                  </div>

                  <% if (v.attachments && v.attachments.length > 0) { %>
                    <div>
                      <span class="text-slate-400">Lampiran:</span>
                      <span class="text-slate-700 ml-1">
                        <%= v.attachments.length %> file
                      </span>
                    </div>
                  <% } %>

                </div>

                <!-- RESULT -->
                <% if (v.result) { %>
                  <p class="text-xs text-slate-600 mt-3 line-clamp-2">
                    <%= v.result %>
                  </p>
                <% } %>

              </div>

              <!-- RIGHT ACTION -->
              <div class="flex items-start gap-3">

                <!-- EDIT ICON -->
                <%
  const diffHours =
    (new Date() - new Date(v.createdAt)) / (1000 * 60 * 60);
%>

<% if (diffHours <= 24) { %>
  <a href="/sales/<%= v._id %>/edit"
     class="text-slate-400 hover:text-indigo-600 transition">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z"/>
      <path d="M20.71 7.04a1.003 1.003 0 000-1.42l-2.34-2.34a1.003 1.003 0 00-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z"/>
    </svg>
  </a>
<% } %>

              </div>

            </div>

          </div>

        <% }) %>

      </div>

    <% } %>

  </div>

</div>
<%- layout('layouts/main', { title }) %>

<div >
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

    <div class="border border-slate-200/60 md:border-none md:shadow-none">
      <%- include('../partials/page-header', {
        section: 'Area Kerja Admin',
        module: 'Human Resources',
        title: 'Pusat Otorisasi & Transaksi PHK',
        description: 'Evaluasi pengajuan pemutusan hubungan kerja dari HR, penonaktifan akun, beserta arsip keputusan pimpinan.'
      }) %>
    </div>

    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        gridClass: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-2', 
        items: [
          { 
            label: 'Permintaan Aktif (Waiting)', 
            value: stats.totalPending + ' Berkas', 
            unit: '', 
            icon: 'fa-solid fa-clock-rotate-left', 
            labelClass: '!font-medium text-amber-600', 
            valueClass: '!font-semibold text-amber-700', 
            iconBoxClass: 'bg-amber-50 text-amber-500 border border-amber-200/50' 
          },
          { 
            label: 'PHK Disahkan (History)', 
            value: stats.totalApproved + ' Kasus', 
            unit: '', 
            icon: 'fa-solid fa-folder-minus', 
            labelClass: '!font-medium text-slate-400', 
            valueClass: '!font-semibold text-slate-800', 
            iconBoxClass: 'bg-slate-50 text-slate-400 border border-slate-200/50' 
          }
        ]
      }) %>
    </div>

    <div class="w-full bg-white md:bg-transparent border border-slate-200/50 md:border-none p-4 md:p-0 rounded-2xl md:shadow-none select-none">
      <%- include('../partials/_tab-nav', {
        tabs: [
          { 
            id: 'active', 
            label: `Permintaan Aktif (${pendingList.length})`,
            isActive: true 
          },
          { 
            id: 'history', 
            label: `Riwayat Persetujuan (${historyList.length})`,
            isActive: false 
          }
        ]
      }) %>
    </div>

    <div id="tab-content-active" class="tab-pane space-y-4 block opacity-100 transition-all duration-300">
      <div class="bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50 shadow-xs">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Nama Pegawai</th>
                <th class="py-4 px-6">Posisi / Bidang</th>
                <th class="py-4 px-6">Alasan Pengajuan</th>
                <th class="py-4 px-6 text-center">Dokumen</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (pendingList.length === 0) { %>
                <tr>
                  <td colspan="5" class="py-12 text-center text-slate-400 font-medium">
                    Tidak ada permohonan PHK aktif saat ini.
                  </td>
                </tr>
              <% } else { %>
                <% pendingList.forEach(t => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6">
                      <div class="font-bold text-slate-800"><%= t.employeeId?.fullName || 'N/A' %></div>
                    </td>
                    <td class="py-4 px-6">
                      <div class="text-slate-700 font-semibold"><%= t.employeeId?.careerData?.positionId?.name || '-' %></div>
                      <div class="text-[10px] text-slate-400 uppercase tracking-wide">Bidang: <%= t.employeeId?.careerData?.bidangId?.name || '-' %></div>
                    </td>
                    
                    <td class="py-4 px-6 whitespace-normal break-words min-w-[200px] max-w-[300px] text-slate-600 leading-relaxed font-normal">
                      <%= t.reason %>
                    </td>

                    <td class="py-4 px-6 text-center">
                      <% if (t.documentPath) { %>
                        <a href="/uploads/files/<%= t.documentPath.split('/').pop() %>" target="_blank" class="inline-flex items-center gap-1 text-[11px] font-semibold text-blue-600 hover:text-blue-700 hover:underline transition-all">
                          <i class="fa-solid fa-paperclip text-[10px]"></i>
                          <span>Lampiran</span>
                        </a>
                      <% } else { %>
                         <span class="text-[10.5px] text-slate-400 italic">Tanpa Lampiran</span>
                      <% } %>
                    </td>

                    <td class="py-4 px-6 text-center">
                      <form action="/terminations/<%= t._id %>/approve" method="POST" onsubmit="return confirm('Apakah Anda yakin menyetujui PHK ini?');" class="inline m-0">
                        <button type="submit" class="h-8 px-3.5 bg-emerald-600 text-white font-semibold text-[11px] rounded-lg inline-flex items-center gap-1 hover:bg-emerald-700 shadow-sm cursor-pointer">
                          <i class="fa-solid fa-check text-[10px]"></i> Setujui
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane space-y-4 hidden opacity-0 transition-all duration-300">
      <div class="bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50 shadow-xs">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Nama Pegawai</th>
                <th class="py-4 px-6">Posisi / Bidang</th>
                <th class="py-4 px-6">Alasan Resmi</th>
                <th class="py-4 px-6">Otorisator</th>
                <th class="py-4 px-6 text-center">Tanggal Eksekusi</th>
                <th class="py-4 px-6 text-center">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (historyList.length === 0) { %>
                <tr>
                  <td colspan="6" class="py-12 text-center text-slate-400 font-medium">Belum ada riwayat persetujuan selesai.</td>
                </tr>
              <% } else { %>
                <% historyList.forEach(leave => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-4 px-6">
                      <div class="font-bold text-slate-700 line-through decoration-slate-400"><%= leave.employeeId?.fullName || 'N/A' %></div>
                      <span class="text-[9px] font-bold bg-red-50 text-red-600 px-1.5 py-0.5 rounded border border-red-100 inline-block mt-1">NON-AKTIF</span>
                    </td>
                    <td class="py-4 px-6">
                      <div class="text-slate-600 font-semibold"><%= leave.employeeId?.careerData?.positionId?.name || '-' %></div>
                      <div class="text-[10px] text-slate-400">Bidang: <%= leave.employeeId?.careerData?.bidangId?.name || '-' %></div>
                    </td>

                    <td class="py-4 px-6 whitespace-normal break-words min-w-[200px] max-w-[300px] text-slate-500 leading-relaxed font-normal">
                      <%= leave.reason %>
                    </td>

                   <td class="py-4 px-6">
  <div class="font-bold text-slate-800">
    <%= leave.approvedBy?.employeeData?.fullName || leave.approvedBy?.username || 'System' %>
  </div>
</td>

                    <td class="py-4 px-6 text-center text-slate-500">
                      <%= new Date(leave.updatedAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td class="py-4 px-6 text-center">
                      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200/60">
                        Disahkan
                      </span>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>
<script>
  function switchTab(tabName) {
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.add('hidden');
      pane.classList.remove('block', 'opacity-100');
    });

    const activeContent = document.getElementById(`tab-content-${tabName}`);
    if (activeContent) {
      activeContent.classList.remove('hidden');
      activeContent.classList.add('block');
      setTimeout(() => { activeContent.classList.add('opacity-100'); }, 10);
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
      
      btn.classList.add('font-medium', 'text-slate-500', 'hover:text-slate-800');
    });

    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    if (activeBtn) {
      activeBtn.classList.remove('font-medium', 'text-slate-500', 'hover:text-slate-800');
      activeBtn.classList.add('bg-white', 'font-bold', 'text-slate-900', 'shadow-xs');
    }
  }
</script>
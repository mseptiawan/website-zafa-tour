<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lupa Password | Zafa Tour</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/output.css" />
  
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body class="bg-[#f1f5f9] md:bg-[#f8fafc] min-h-screen flex antialiased items-center justify-center md:items-stretch md:justify-start">

  <div class="w-full flex flex-col md:flex-row min-h-screen">

    <div class="w-full md:w-[45%] lg:w-[40%] p-6 sm:p-12 md:p-16 flex flex-col justify-between z-10 my-auto md:my-0 bg-transparent md:bg-white min-h-screen md:min-h-0">
      
      <div class="hidden md:flex items-center gap-2.5">
        <span class="text-slate-900 font-extrabold tracking-tight text-base">Zafa Tour</span>
      </div>

      <div class="w-full max-w-md mx-auto my-auto bg-white md:bg-transparent rounded-[32px] md:rounded-none p-8 sm:p-10 md:p-0 shadow-xl shadow-slate-200/50 md:shadow-none flex flex-col items-center md:items-stretch">
        
        <div class="w-full flex justify-center mb-6">
          <svg class="w-44 h-auto" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="50" y="110" width="100" height="20" rx="10" fill="#1e293b" opacity="0.05"/>
            <circle cx="100" cy="70" r="32" fill="#fef08a" />
            <path d="M100 42 C112 42 122 36 122 36 V64 C122 79 100 89 100 89 C100 89 78 79 78 64 V36 C78 36 88 42 100 42 Z" fill="#fbbf24" />
            <rect x="62" y="70" width="76" height="50" rx="8" fill="#2563eb" />
            <path d="M62 76 L100 98 L138 76" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M148 52 H154 M151 49 V55" stroke="#2563eb" stroke-width="2" stroke-linecap="round"/>
            <path d="M48 82 H54 M51 79 V85" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>

        <div class="text-center w-full mb-6">
          <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Lupa Password</h1>
          <p class="text-xs text-slate-400 font-medium mt-1.5 px-2">Masukkan email akun Anda untuk menerima link reset password</p>
        </div>

        <% if (typeof query !== 'undefined') { %>
          <% if (query?.error === "EMAIL_NOT_FOUND") { %>
            <div class="w-full mb-4 p-3 px-4 bg-rose-50 border border-rose-100 rounded-xl flex items-center gap-2.5 text-rose-800">
              <i data-lucide="shield-alert" class="w-4 h-4 shrink-0 text-rose-500"></i>
              <span class="text-xs font-medium tracking-tight">Email tidak ditemukan</span>
            </div>
          <% } %>

          <% if (query?.error === "SERVER_ERROR") { %>
            <div class="w-full mb-4 p-3 px-4 bg-rose-50 border border-rose-100 rounded-xl flex items-center gap-2.5 text-rose-800">
              <i data-lucide="server-crash" class="w-4 h-4 shrink-0 text-rose-500"></i>
              <span class="text-xs font-medium tracking-tight">Terjadi kesalahan server</span>
            </div>
          <% } %>

          <% if (query?.error === "TOKEN_EXPIRED") { %>
            <div class="w-full mb-4 p-3 px-4 bg-rose-50 border border-rose-100 rounded-xl flex items-center gap-2.5 text-rose-800">
              <i data-lucide="clock-alert" class="w-4 h-4 shrink-0 text-rose-500"></i>
              <span class="text-xs font-medium tracking-tight">Link reset password sudah expired</span>
            </div>
          <% } %>

          <% if (query?.success === "EMAIL_SENT") { %>
            <div class="w-full mb-4 p-3 px-4 bg-emerald-50 border border-emerald-100 rounded-xl flex items-center gap-2.5 text-emerald-800">
              <i data-lucide="check-circle-2" class="w-4 h-4 shrink-0 text-emerald-500"></i>
              <span class="text-xs font-medium tracking-tight">Link reset password telah dikirim ke email Anda</span>
            </div>
          <% } %>
        <% } %>

        <form action="/forgot-password" method="POST" class="w-full space-y-4">
          
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
              <i data-lucide="mail" class="w-4 h-4"></i>
            </div>
            <input
              type="email"
              name="email"
              required
              placeholder="Email"
              autocomplete="username"
              class="w-full pl-11 pr-4 py-3.5 bg-white border border-slate-200 rounded-xl text-sm transition-all focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 placeholder:text-slate-400"
            />
          </div>

          <button 
            type="submit"
            class="w-full py-3.5 bg-[#2563eb] text-white font-semibold text-sm rounded-xl hover:bg-blue-700 active:scale-[0.99] transition-all duration-150 shadow-md shadow-blue-500/10 cursor-pointer flex items-center justify-center gap-2 pt-3"
          >
            <span>Kirim Link Reset</span>
          </button>

        </form>

        <div class="mt-6 text-sm text-center w-full flex justify-center">
          <a href="/" class="text-blue-600 font-bold hover:text-blue-700 transition inline-flex items-center gap-1.5 text-xs">
            <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
            Kembali ke login
          </a>
        </div>
      </div>

      <p class="text-center md:text-left text-xs text-slate-400 font-medium px-0.5 mt-auto md:mt-0 pt-4 w-full">
        &copy; 2026 Zafa Tour. All rights reserved.
      </p>
    </div>

    <div class="hidden md:block relative flex-1 bg-slate-900 overflow-hidden border-l border-slate-200/40">
      
      <img 
        src="https://skvindia.com/wp-content/uploads/2024/09/Types-of-modern-office-interior-design-banner.webp" 
        alt="Zafa Tour Workspace" 
        class="absolute inset-0 w-full h-full object-cover opacity-45 filter brightness-95 contrast-105"
      />

      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/60 to-slate-950/30"></div>

      <div class="absolute top-8 right-8 z-10 p-3 bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 shadow-lg max-w-[140px]">
        <img src="/images/logo.png" alt="Zafa Tour" class="w-full h-auto object-contain filter brightness-0 invert opacity-90"/>
      </div>

      <div class="absolute bottom-16 left-16 right-16 z-10 max-w-lg space-y-4">
        <div class="space-y-2">
          <h2 class="text-3xl font-black text-white leading-tight tracking-tight">
            Sistem Informasi <br />Kepegawaian Terintegrasi.
          </h2>
          <p class="text-[13px] text-slate-300 font-medium leading-relaxed max-w-sm">
            Akses seluruh data operasional, kehadiran, birokrasi cuti, dan manajemen administrasi internal PT Zafa Mulia Mandiri dalam satu dasbor kendali terpusat.
          </p>
        </div>
      </div>

    </div>

  </div>

  <script>
    lucide.createIcons({
      attrs: {
        'stroke-width': 2.2
      }
    });
  </script>

</body>
</html>
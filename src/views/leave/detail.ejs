<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Detail Cuti</title>

  <link rel="stylesheet" href="/css/output.css" />
</head>

<body class="bg-slate-100 p-10">

  <div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow">

    <h1 class="text-2xl font-bold mb-6">Detail Cuti</h1>

    <div class="space-y-4 text-slate-700">

      <p><b>Jenis:</b> <%= leave.type %></p>

      <p><b>Tanggal:</b> <%= leave.startDate %> - <%= leave.endDate %></p>

      <p><b>Jumlah Hari:</b> <%= leave.totalDays %></p>

      <p><b>Alasan:</b> <%= leave.reason %></p>

      <p><b>Status:</b> <%= leave.status %></p>

      <% if (leave.rejectedReason) { %>
        <p class="text-red-500">
          <b>Alasan Ditolak:</b> <%= leave.rejectedReason %>
        </p>
      <% } %>

      <% if (leave.file) { %>
        <div>
          <p class="font-semibold">Bukti:</p>
          <img src="/uploads/<%= leave.file %>"
            class="mt-2 rounded-xl border"/>
        </div>
      <% } %>

    </div>

  </div>

</body>
</html>
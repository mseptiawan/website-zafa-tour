<%- layout('layouts/main', { title }) %>

<style>
  /* =========================================================================
     KONTROL PRINT & LAYOUT MINIMALIS DOKUMEN KUNING
     ========================================================================= */
  #report-print-zone {
    display: none;
  }

  @media print {
    html, body, body * {
      visibility: hidden !important;
      background: transparent !important;
    }
    #report-print-zone, #report-print-zone * {
      visibility: visible !important;
    }
    #report-print-zone {
      display: block !important;
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      color: black !important;
    }
    .yellow-print-header {
      background-color: #facc15 !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color: black !important;
    }
  }

  .formal-print-text {
    font-family: 'Times New Roman', Times, serif;
    font-weight: normal !important;
  }
  .formal-print-text th, .formal-print-text td {
    font-weight: normal !important;
  }
</style>

<div class=" min-h-screen bg-[#f8fafc] p-8 antialiased text-slate-800">
  <div class="mx-auto max-w-7xl space-y-6">

    <!-- HEADER MONITOR UTAMA (PURE CLEAN & FLAT) -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white border border-slate-200/60 rounded-xl p-6 shadow-xs no-print">
      <div>
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block mb-1">Internal Operations</span>
        <h1 class="text-base font-bold tracking-tight text-slate-950">Metrik Kehadiran Kerja</h1>
      </div>
      
      <div class="flex items-center gap-3">
        <!-- FORM FILTER NETRAL -->
        <form method="GET" action="/report/attendance" class="flex items-center gap-2 bg-slate-50 border border-slate-200 rounded-lg p-1">
          <div class="flex items-center gap-2 px-2">
            <i class="fa-solid fa-filter text-slate-400 text-[10px]"></i>
            <input type="date" name="startDate" id="filterStartDate" value="<%= filters.startDate %>" class="bg-transparent text-[11px] font-medium text-slate-600 outline-none">
            <span class="text-slate-300 text-xs">至</span>
            <input type="date" name="endDate" id="filterEndDate" value="<%= filters.endDate %>" class="bg-transparent text-[11px] font-medium text-slate-600 outline-none">
          </div>
          <button type="submit" class="bg-slate-900 hover:bg-slate-800 text-white text-[10px] font-semibold h-7 px-3 rounded-md transition-all">
            Apply
          </button>
        </form>

        <!-- TOMBOL EXPORT MONOKROM -->
        <button onclick="executePrintAttendanceReport()" class="bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-medium h-9 px-4 rounded-lg shadow-xs transition-all flex items-center gap-1.5 cursor-pointer">
          <i class="fa-solid fa-file-pdf text-[12px]"></i> Export PDF
        </button>
      </div>
    </div>

    <!-- DIAGRAM DISTRIBUSI LOKASI MURNI MONOKROM -->
    <% 
      let kantorCount = 0; let luarKantorCount = 0;
      listAttendance.forEach(item => {
        if(item.type === 'KANTOR') kantorCount++;
        if(item.type === 'LUAR KANTOR') luarKantorCount++;
      });
      let totalLoc = (kantorCount + luarKantorCount) || 1;
      let pctKantor = Math.round((kantorCount / totalLoc) * 100);
      let pctLuar = Math.round((luarKantorCount / totalLoc) * 100);
    %>
    <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-xs no-print">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Diagram Distribusi Lokasi Kerja</h3>
        <span class="text-[10px] text-slate-400 font-mono">Total Log: <%= listAttendance.length %> Baris</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Blok Kantor Utama -->
        <div class="p-4 bg-slate-50 border border-slate-200/70 rounded-xl flex items-center justify-between transition-colors hover:bg-slate-100/40">
          <div class="space-y-1">
            <span class="text-[11px] font-semibold text-slate-800 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-900 block"></span> Kantor Utama Palembang
            </span>
            <span class="text-xs text-slate-400 block"><%= kantorCount %> Kali validasi koordinat</span>
          </div>
          <div class="text-right">
            <span class="text-xl font-bold text-slate-900 tracking-tight font-mono"><%= pctKantor %>%</span>
          </div>
        </div>

        <!-- Blok Dinas Luar -->
        <div class="p-4 bg-slate-50 border border-slate-200/70 rounded-xl flex items-center justify-between transition-colors hover:bg-slate-100/40">
          <div class="space-y-1">
            <span class="text-[11px] font-semibold text-slate-700 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-400 block"></span> Dinas Luar / Lapangan
            </span>
            <span class="text-xs text-slate-400 block"><%= luarKantorCount %> Kali pelacakan GPS</span>
          </div>
          <div class="text-right">
            <span class="text-xl font-bold text-slate-700 tracking-tight font-mono"><%= pctLuar %>%</span>
          </div>
        </div>
      </div>
    </div>

    <%
      let userReportMap = {};
      listAttendance.forEach(item => {
        let name = item.fullName;
        if (!name || name === "-" || name.trim() === "") {
          if (item.userId && (item.userId.username || item.userId)) {
            name = item.userId.username || item.userId;
          } else {
            return;
          }
        }
        name = name.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join(' ');

        if(!userReportMap[name]) {
          userReportMap[name] = { hadir: 0, telat: 0, menitTelat: 0, alpa: 0 };
        }
        if(item.status === 'HADIR') userReportMap[name].hadir++;
        if(item.status === 'TELAT') {
          userReportMap[name].telat++;
          userReportMap[name].menitTelat += parseInt(item.lateDuration || 0);
        }
        if(item.status === 'BELUM ABSEN' || item.status === 'ALPHA') {
          userReportMap[name].alpa++;
        }
      });
    %>

    <!-- DIAGRAM GRID KONTEMPORER - FLAT PURE CLEAN (NO-PRINT) -->
    <div class="grid grid-cols-1 gap-4 no-print">
      
      <!-- LAYER ATAS: METRICS CARD FLAT -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <!-- Boks 1 -->
        <div class="bg-white border border-slate-200 rounded-xl p-4 flex flex-col justify-between">
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Presensi Sukses</span>
          <div class="flex items-baseline gap-1.5 mt-2">
            <span class="text-xl font-bold tracking-tight text-slate-950 tabular-nums"><%= analytics.totalHadir %></span>
            <span class="text-[11px] text-slate-400">Log masuk</span>
          </div>
        </div>

        <!-- Boks 2 -->
        <div class="bg-white border border-slate-200 rounded-xl p-4 flex flex-col justify-between">
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Total Keterlambatan</span>
          <div class="flex items-baseline gap-1.5 mt-2">
            <span class="text-xl font-bold tracking-tight text-slate-950 tabular-nums"><%= analytics.totalLateDays %></span>
            <span class="text-[11px] text-slate-400">Hari kerja</span>
          </div>
        </div>

        <!-- Boks 3 -->
        <div class="bg-white border border-slate-200 rounded-xl p-4 flex flex-col justify-between">
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Beban Kebocoran Waktu</span>
          <div class="flex items-baseline gap-1.5 mt-2">
            <span class="text-xl font-bold tracking-tight text-slate-950 tabular-nums"><%= analytics.totalLateMinutes %></span>
            <span class="text-[11px] text-slate-400">Menit terbuang</span>
          </div>
        </div>
      </div>

      <!-- LAYER BAWAH: DIAGRAM KARTU MATRIKS (PURE MONOKROM GRID) -->
      <div class="bg-white border border-slate-200 rounded-xl p-5 space-y-4">
        <div class="flex items-center justify-between border-b border-slate-100 pb-3">
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Matriks Kedisiplinan Pegawai</h3>
          <span class="text-[10px] bg-slate-50 border border-slate-200 px-2 py-0.5 rounded text-slate-600 font-medium tracking-wide">ATTENDANCE DATA SHEET</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
          <% Object.keys(userReportMap).sort().forEach((name) => { 
               let uData = userReportMap[name];
          %>
            <!-- Semua kartu seragam memakai bg-slate-50 tanpa highlight warna mencolok -->
            <div class="p-3 bg-slate-50 border border-slate-200 rounded-xl text-xs space-y-2 transition-all hover:bg-white hover:shadow-[0_4px_12px_rgba(0,0,0,0.02)]">
              
              <span class="font-bold text-slate-900 block border-b border-slate-200/60 pb-1.5 truncate"><%= name %></span>
              
              <div class="flex justify-between items-center text-slate-500 font-mono text-[11px]">
                <div class="space-y-0.5">
                  <span class="block">Hadir : <span class="text-slate-900 font-medium"><%= uData.hadir %>d</span></span>
                  <span class="block">Telat : <span class="text-slate-900 font-medium"><%= uData.telat %>x</span></span>
                </div>
                <div class="text-right border-l border-slate-200 pl-3">
                  <span class="block text-[9px] text-slate-400 uppercase tracking-wider">Potongan</span>
                  <span class="block font-bold text-slate-900">-<%= uData.menitTelat %>m</span>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

    </div>

    <!-- CONTAINER CETAK FORMAL KUNING -->
    <div id="report-print-zone" class="bg-white p-2 space-y-6 text-black formal-print-text"></div>

  </div>
</div>

<script>
  const clientAttendanceData = <%- JSON.stringify(listAttendance) %>;

  function executePrintAttendanceReport() {
    const sDate = document.getElementById('filterStartDate').value;
    const eDate = document.getElementById('filterEndDate').value;

    let dynamicSummaryMap = {};
    let dynamicTotalHadir = 0;
    let dynamicTotalLateDays = 0;
    let dynamicTotalLateMinutes = 0;

    clientAttendanceData.forEach(item => {
      let name = item.fullName;
      if (!name || name === "-" || name.trim() === "") {
        if (item.userId && (item.userId.username || item.userId)) {
          name = item.userId.username || item.userId;
        } else {
          return; 
        }
      }
      name = name.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join(' ');

      if (!dynamicSummaryMap[name]) {
        dynamicSummaryMap[name] = { hadir: 0, telat: 0, menitTelat: 0, alpa: 0, sakitIzin: 0 };
      }

      let currentStatus = item.status ? item.status.toUpperCase() : "ALPHA";

      if (item.isMissing || currentStatus === 'BELUM ABSEN' || currentStatus === 'ALPHA') {
        dynamicSummaryMap[name].alpa++;
      } 
      else if (currentStatus === 'HADIR') {
        dynamicSummaryMap[name].hadir++;
        dynamicTotalHadir++;
      } 
      else if (currentStatus === 'TELAT') {
        dynamicSummaryMap[name].telat++;
        let minutes = parseInt(item.lateDuration || 0);
        dynamicSummaryMap[name].menitTelat += minutes;
        
        dynamicTotalLateDays++;
        dynamicTotalLateMinutes += minutes;
      } 
      else if (currentStatus === 'SAKIT' || currentStatus === 'IZIN' || currentStatus === 'CUTI') {
        dynamicSummaryMap[name].sakitIzin++;
      }
    });

    let summaryRowsHTML = '';
    Object.keys(dynamicSummaryMap).sort().forEach(name => {
      const uData = dynamicSummaryMap[name];
      summaryRowsHTML += `
        <tr class="h-8" style="font-family: 'Times New Roman', Times, serif;">
          <td class="p-2 border-r border-black" style="font-weight: normal !important; text-align: left;">${name}</td>
          <td class="p-2 text-center border-r border-black" style="font-weight: normal !important;">${uData.hadir} Hari</td>
          <td class="p-2 text-center border-r border-black" style="font-weight: normal !important;">${uData.telat} Kali</td>
          <td class="p-2 text-right border-r border-black" style="font-weight: normal !important;">${uData.menitTelat} Menit</td>
          <td class="p-2 text-center" style="font-weight: normal !important;">${uData.alpa} Hari</td>
        </tr>`;
    });

    const finalPrintTemplate = `
      <div class="flex justify-between items-start">
        <div class="border border-black px-6 py-1 mt-2">
          <span class="text-xs tracking-wide" style="color: #f43f5e; font-weight: normal !important;">Dokumen Audit Internal</span>
        </div>
        <div class="text-center space-y-0.5">
          <div class="inline-flex flex-col items-center justify-center">
            <span class="text-2xl tracking-tighter" style="font-family: 'Times New Roman', Times, serif; font-weight: normal !important;">ZM</span>
            <span class="text-[8px] tracking-widest uppercase -mt-1" style="font-weight: normal !important;">ZAFA TOUR</span>
          </div>
          <div class="text-[10px] uppercase tracking-tight" style="font-weight: normal !important;">Zafa Mulia Mandiri</div>
        </div>
      </div>

      <div class="pt-1">
        <h2 class="text-xs" style="font-weight: normal !important; text-align: left;">PT Zafa Mulia Mandiri</h2>
      </div>

      <div class="space-y-0.5" style="text-align: left;">
        <h3 class="text-xs" style="font-weight: normal !important;">Laporan Rekapitulasi Absensi Pegawai</h3>
        <p class="text-xs" style="font-weight: normal !important;">Periode Saring : ${sDate} s/d ${eDate}</p>
      </div>

      <div class="grid grid-cols-3 gap-4 text-xs pt-2">
        <div class="border border-black p-2" style="text-align: left;">
          <span class="block text-[10px] text-gray-500">Total Hadir Perusahaan</span>
          <span class="text-sm" style="font-weight: normal !important;">${dynamicTotalHadir} Rekor</span>
        </div>
        <div class="border border-black p-2" style="text-align: left;">
          <span class="block text-[10px] text-gray-500">Total Kasus Terlambat</span>
          <span class="text-sm" style="font-weight: normal !important;">${dynamicTotalLateDays} Hari</span>
        </div>
        <div class="border border-black p-2" style="text-align: left;">
          <span class="block text-[10px] text-gray-500">Akumulasi Menit Terlambat</span>
          <span class="text-sm" style="font-weight: normal !important;">${dynamicTotalLateMinutes} Menit</span>
        </div>
      </div>

      <div class="border border-black mt-4">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="yellow-print-header border-b border-black">
              <th class="p-2 border-r border-black font-normal text-left" style="font-weight: normal !important; width: 35%;">Nama Pegawai</th>
              <th class="p-2 border-r border-black text-center font-normal" style="font-weight: normal !important;">Hadir Tepat Waktu</th>
              <th class="p-2 border-r border-black text-center font-normal" style="font-weight: normal !important;">Frekuensi Telat</th>
              <th class="p-2 border-r border-black text-center font-normal" style="font-weight: normal !important;">Durasi Terlambat</th>
              <th class="p-2 text-center font-normal" style="font-weight: normal !important;">Jumlah Alpa/Mangkir</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-black">
            ${summaryRowsHTML}
          </tbody>
        </table>
      </div>

      <div class="pt-6 flex justify-between items-start text-xs">
        <div class="text-[10px] text-gray-400 italic">
          *Dokumen diunduh secara digital melalui Sistem HRIS Kantor Utama Palembang.
        </div>
        <div class="text-center pr-12 space-y-12">
          <span class="block" style="font-weight: normal !important;">Manager Administrasi (HRD)</span>
          <span class="block border-t border-black pt-1 w-40" style="font-weight: normal !important;">Otorisasi Sistem</span>
        </div>
      </div>
    `;

    const printZone = document.getElementById('report-print-zone');
    if (printZone) {
      printZone.innerHTML = finalPrintTemplate;
      window.print();
    }
  }
</script>
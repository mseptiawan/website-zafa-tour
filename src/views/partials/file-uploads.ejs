<% 
  const id = typeof inputId !== 'undefined' ? inputId : 'file-upload-' + Math.random().toString(36).substr(2, 9);
  const name = typeof inputName !== 'undefined' ? inputName : 'file';
  const labelText = typeof label !== 'undefined' ? label : 'Dokumen Pendukung';
  const isRequired = typeof required !== 'undefined' ? required : false;
  const acceptTypes = typeof accept !== 'undefined' ? accept : '.pdf,.jpg,.jpeg,.png';
  const maxTextStr = typeof maxText !== 'undefined' ? maxText : 'PDF, JPG, PNG (Maks. 2MB)';
  const errorMsg = typeof error !== 'undefined' ? error : null;
  const oldFileUrl = typeof oldFile !== 'undefined' ? oldFile : null;
  const hasOldFile = !!oldFileUrl;
%>

<div class="space-y-1.5" data-file-upload>
  <label class="block text-[11.5px] font-semibold tracking-wide">
    <%= labelText %> 
    <% if (isRequired) { %>
      <span class="text-rose-500 font-bold">*</span>
    <% } %>
  </label>
  
  <div class="relative group">
    <input type="file" 
           name="<%= name %>" 
           id="<%= id %>" 
           accept="<%= acceptTypes %>" 
           class="file-upload-input absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10 <%= hasOldFile ? 'hidden' : '' %>"
           <%= isRequired && !hasOldFile ? 'required' : '' %> 
           data-required="<%= isRequired %>" />
    
    <div class="dropzone-empty w-full border border-slate-200 rounded-xl px-4 py-3 bg-slate-50/50 group-hover:bg-slate-50 group-hover:border-slate-300 transition-all flex items-center justify-between gap-3 <%= hasOldFile ? 'hidden' : '' %>">
      <div class="flex items-center gap-2.5 min-w-0">
        <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
        </svg>
        <div class="truncate">
          <span class="text-[12.5px] font-medium text-slate-600 block leading-tight">Pilih atau drop berkas</span>
          <span class="text-[10.5px] text-slate-400 block mt-0.5"><%= maxTextStr %></span>
        </div>
      </div>
      <span class="text-[11px] font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded-md shrink-0 transition-colors group-hover:bg-blue-100/70">Browse</span>
    </div>

    <div class="dropzone-filled <%= hasOldFile ? '' : 'hidden' %> flex items-center justify-between gap-3 border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-xs">
      <div class="flex items-center gap-3 min-w-0 flex-1">
        <div class="w-8 h-8 rounded-lg bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0 text-[11px]">
          <% if (hasOldFile && oldFileUrl.endsWith('.pdf')) { %>
            <i class="fa-solid fa-file-pdf text-rose-500"></i>
          <% } else if (hasOldFile && (oldFileUrl.endsWith('.jpg') || oldFileUrl.endsWith('.jpeg') || oldFileUrl.endsWith('.png'))) { %>
            <i class="fa-solid fa-file-image text-blue-500"></i>
          <% } else { %>
            <i class="fa-solid fa-file-lines text-slate-400"></i>
          <% } %>
        </div>
        <div class="min-w-0 flex-1">
          <p class="file-name text-[12.5px] font-medium text-slate-700 truncate">
            <%= hasOldFile ? oldFileUrl.split('/').pop() : 'nama-file.pdf' %>
          </p>
          <p class="file-size text-[10.5px] text-slate-400 font-medium leading-none mt-0.5">
            <%= hasOldFile ? 'Berkas tersimpan' : '0 KB' %>
          </p>
        </div>
      </div>
      
      <div class="flex items-center gap-1.5 shrink-0 relative z-20">
        <a href="<%= hasOldFile ? oldFileUrl : '#' %>" 
           target="_blank" 
           class="btn-view-file text-[11px] font-medium text-slate-600 bg-slate-50 hover:bg-slate-100 border border-slate-200 px-2.5 py-1.5 rounded-lg transition-colors <%= hasOldFile ? '' : 'hidden' %>">
          View
        </a>
        <button type="button" class="btn-change-file text-[11px] font-medium text-slate-600 bg-slate-50 hover:bg-slate-100 border border-slate-200 px-2.5 py-1.5 rounded-lg transition-colors">
          Ganti
        </button>
        <button type="button" class="btn-reset-file text-[11px] font-medium text-rose-600 bg-rose-50 hover:bg-rose-100 border border-rose-200/40 px-2.5 py-1.5 rounded-lg transition-colors hidden">
          Hapus
        </button>
      </div>
    </div>
  </div>
  
  <% if (errorMsg) { %>
    <p class="text-[11px] font-medium text-rose-500 pl-0.5"><%= errorMsg %></p>
  <% } %>
</div>
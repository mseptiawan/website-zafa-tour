<%- layout('layouts/main', { title }) %>

<div class="min-h-screen md:ml-72 bg-slate-50/60  md:p-8 antialiased">
  <div class="max-w-none mx-auto">

    <% 
      const APPROVER_ROLES = ["MANAGER_ADMINISTRASI", "WAKIL_DIREKTUR", "DIREKTUR_UTAMA", "MANAGER_KEUANGAN"];
      const isManagement = APPROVER_ROLES.includes((user.role || '').toUpperCase());
      const backLink = isManagement ? '/overtime/management' : '/overtime/my';
    %>

    <a href="<%= backLink %>" class="inline-flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-800 mb-6 transition-colors group">
      <svg class="w-4 h-4 transform group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Kembali
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

      <div class="lg:col-span-2 space-y-6">
        
        <div class="bg-white border border-slate-200/60 rounded-2xl shadow-[0_4px_20px_-5px_rgba(0,0,0,0.05)] overflow-hidden">
          <div class="px-5 py-5 md:px-8 md:py-6 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center border border-slate-100 text-slate-600 shrink-0">
                <i class="fa-solid fa-user-clock text-base"></i>
              </div>
              <div class="min-w-0">
                <h1 class="text-[15px] font-semibold text-slate-900 tracking-tight leading-tight mb-1.5 truncate">
                  <%= employee?.fullName || overtime.employeeName || 'Detail Aktivitas Lembur' %>
                </h1>
                <p class="text-[10px] md:text-[11px] font-medium text-slate-500 uppercase tracking-wider truncate">
                  Bidang: <%= employee?.careerData?.bidangId?.name || 'Tidak Ada' %>
                </p>
                <p class="text-[10px] md:text-[11px] font-medium text-slate-500 uppercase tracking-wider mt-0.5 truncate">
                  Unit: <%= employee?.careerData?.unitId?.name || 'Tidak Ada' %>
                </p>
              </div>
            </div>
            
            <% 
              const status = (overtime.status || '').toUpperCase();
              let badgeStyle = 'bg-amber-50 text-amber-700 border-amber-200';
              if (status === 'APPROVED') badgeStyle = 'bg-emerald-50 text-emerald-700 border-emerald-200';
              if (status === 'REJECTED') badgeStyle = 'bg-rose-50 text-rose-700 border-rose-200';
            %>
            <span class="w-max px-3 py-1 rounded-full font-semibold text-[10px] uppercase tracking-wider border <%= badgeStyle %>">
              <%= overtime.status %>
            </span>
          </div>

          <div class="p-5 md:p-8 space-y-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-6">
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Tanggal Lembur</div>
                <div class="text-[14px] md:text-[15px] font-semibold text-slate-900">
                  <%= new Date(overtime.date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                </div>
              </div>
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Jam Pelaksanaan</div>
                <div class="text-[14px] md:text-[15px] font-semibold text-slate-900 tabular-nums">
                  <%= overtime.startTime %> - <%= overtime.endTime %>
                </div>
              </div>
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Total Durasi</div>
                <div class="text-[14px] md:text-[15px] font-semibold text-slate-900"><%= overtime.totalHours %> Jam</div>
              </div>
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Lokasi Kerja</div>
                <div class="text-[13px] font-semibold text-slate-900 flex flex-wrap items-center gap-1">
                  <span class="px-2 py-0.5 text-[9px] border rounded bg-slate-50 border-slate-200 inline-block font-bold text-slate-600 uppercase">
                    <%= overtime.location?.type || 'OFFICE' %>
                  </span>
                  <span class="text-slate-600 font-medium truncate"><%= overtime.location?.detail || '-' %></span>
                </div>
              </div>
            </div>

            <div class="pt-4 border-t border-slate-100 space-y-4">
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Deskripsi Pekerjaan</div>
                <p class="text-[13px] text-slate-600 leading-relaxed whitespace-normal break-words bg-slate-50 border border-slate-100 p-4 rounded-xl">
                  <%= overtime.workDescription || '-' %>
                </p>
              </div>
              <div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">Hasil / Deliverable Pekerjaan</div>
                <p class="text-[13px] text-slate-600 leading-relaxed whitespace-normal break-words bg-slate-50 border border-slate-100 p-4 rounded-xl italic">
                  "<%= overtime.result || '-' %>"
                </p>
              </div>
            </div>

            <div class="pt-6 border-t border-slate-100">
              <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-3">Lampiran Bukti Kerja</div>
              <% if (overtime.proofFile) { %>
              <div class="flex flex-col sm:flex-row gap-3 sm:items-center justify-between border border-slate-100 rounded-xl p-3 bg-slate-50/50 hover:border-slate-300 transition-colors">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-8 h-8 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-400 shrink-0">
                    <i class="fa-solid fa-file-image text-[12px]"></i>
                  </div>
                  <span class="text-[12px] font-medium text-slate-700 truncate"><%= overtime.proofFile %></span>
                </div>
                <a href="/uploads/files/<%= overtime.proofFile %>" target="_blank" class="text-center text-[10px] font-semibold text-blue-600 bg-blue-50 px-3 py-1.5 rounded-lg transition hover:bg-blue-100 block sm:inline-block w-full sm:w-auto">VIEW LAMIRAN</a>
              </div>
              <% } else { %>
              <div class="flex flex-col items-center justify-center p-6 rounded-2xl bg-gradient-to-b from-slate-50 to-white border border-slate-200">
                <div class="w-12 h-12 rounded-2xl bg-amber-50 flex items-center justify-center mb-3">
                  <i class="fa-solid fa-file-circle-xmark text-amber-500 text-lg"></i>
                </div>
                <h4 class="text-xs font-semibold text-slate-700 mb-1">Bukti lampiran tidak tersedia</h4>
                <p class="text-[11px] text-slate-500 text-center max-w-[220px] leading-relaxed">Pegawai tidak menyertakan file pendukung visual saat input lembur.</p>
              </div>
              <% } %>
            </div>

          </div>
        </div>

        <div class="bg-white border border-slate-200/60 rounded-2xl shadow-[0_4px_20px_-5px_rgba(0,0,0,0.05)] overflow-hidden">
  <div class="px-5 py-4 md:px-8 md:py-6 border-b border-slate-100">
    <h3 class="text-[11px] font-semibold text-slate-900 uppercase tracking-widest">Informasi Snapshot Sistem Payroll</h3>
  </div>

  <!-- TABLE MODE: Aktif dari layar grid SM ke atas -->
  <div class="hidden sm:block overflow-x-auto">
    <table class="w-full text-left">
      <thead class="bg-slate-50/50 text-[10px] uppercase text-slate-400 font-semibold tracking-widest">
        <tr>
          <th class="px-6 md:px-8 py-4">Periode Gaji</th>
          <th class="px-6 md:px-8 py-4">Rate Snapshot</th>
          <th class="px-6 md:px-8 py-4">Multiplier</th>
          <th class="px-6 md:px-8 py-4">Status Penguncian</th>
          <th class="px-6 md:px-8 py-4 text-right">Estimasi Upah</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-6 md:px-8 py-4 text-[12px] font-semibold text-slate-700">
            <%= overtime.payrollPeriodId || 'Belum Ditentukan' %>
          </td>
          <td class="px-6 md:px-8 py-4 text-[12px] font-medium text-slate-600 tabular-nums">
            Rp <%= (overtime.overtimeRateSnapshot || 0).toLocaleString('id-ID') %>
          </td>
          <td class="px-6 md:px-8 py-4 text-[12px] font-bold text-slate-800">
            x<%= overtime.multiplierSnapshot || 1.5 %>
          </td>
          <td class="px-6 md:px-8 py-4">
            <% 
              const payStatus = (overtime.payrollStatus || 'PENDING').toUpperCase();
              let payBadge = 'bg-slate-100 text-slate-600';
              if (payStatus === 'LOCKED') payBadge = 'bg-amber-50 text-amber-700 border border-amber-100';
              if (payStatus === 'PAID') payBadge = 'bg-emerald-50 text-emerald-700 border border-emerald-100';
            %>
            <span class="text-[10px] font-bold px-2.5 py-0.5 rounded-md uppercase <%= payBadge %>">
              <%= payStatus %>
            </span>
          </td>
          <td class="px-6 md:px-8 py-4 text-[12px] font-bold text-slate-900 tabular-nums text-right">
            <% const estimatedPay = (overtime.overtimeRateSnapshot || 0) * (overtime.multiplierSnapshot || 1.5) * (overtime.totalHours || 0); %>
            Rp <%= estimatedPay.toLocaleString('id-ID') %>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- CARD LIST MODE: Aktif khusus di layar HP (Mobile-first layout) -->
  <div class="block sm:hidden p-5 space-y-4 divide-y divide-slate-100">
    <div class="flex justify-between items-center pb-3">
      <div>
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Periode Gaji</p>
        <p class="text-xs font-semibold text-slate-800 mt-0.5"><%= overtime.payrollPeriodId || 'Belum Ditentukan' %></p>
      </div>
      <div class="text-right">
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider mb-1">Status Penguncian</p>
        <% 
          const mPayStatus = (overtime.payrollStatus || 'PENDING').toUpperCase();
          let mPayBadge = 'bg-slate-100 text-slate-600';
          if (mPayStatus === 'LOCKED') mPayBadge = 'bg-amber-50 text-amber-700 border border-amber-100';
          if (mPayStatus === 'PAID') mPayBadge = 'bg-emerald-50 text-emerald-700 border border-emerald-100';
        %>
        <span class="text-[9px] font-bold px-2 py-0.5 rounded-md uppercase <%= mPayBadge %>">
          <%= mPayStatus %>
        </span>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 pt-3 pb-3">
      <div>
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Rate Snapshot</p>
        <p class="text-xs font-medium text-slate-600 mt-0.5 tabular-nums">Rp <%= (overtime.overtimeRateSnapshot || 0).toLocaleString('id-ID') %> /Jam</p>
      </div>
      <div class="text-right">
        <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Multiplier</p>
        <p class="text-xs font-bold text-slate-800 mt-0.5">x<%= overtime.multiplierSnapshot || 1.5 %></p>
      </div>
    </div>

    <div class="flex justify-between items-center pt-3 bg-slate-50/50 -mx-5 px-5 py-3 border-t border-slate-100">
      <p class="text-xs font-bold text-slate-700">Estimasi Total Upah</p>
      <p class="text-sm font-extrabold text-indigo-600 tabular-nums">
        <% const mEstimatedPay = (overtime.overtimeRateSnapshot || 0) * (overtime.multiplierSnapshot || 1.5) * (overtime.totalHours || 0); %>
        Rp <%= mEstimatedPay.toLocaleString('id-ID') %>
      </p>
    </div>
  </div>

</div>
        <% 
          const isPendingForMe = overtime.status === 'SUBMITTED' && (overtime.requiredManagerRole || '').toUpperCase() === (user.role || '').toUpperCase(); 
        %>
        <% if (isPendingForMe) { %>
        <div class="bg-white/90 backdrop-blur-xl rounded-2xl p-5 md:p-8 border border-slate-200 shadow-[0_10px_40px_rgba(0,0,0,0.06)]">
          <h3 class="text-sm font-semibold text-slate-800 mb-4 flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
              <i class="fa-solid fa-check-double text-blue-700"></i>
            </div>
            Evaluasi Verifikasi Lembur Pegawai
          </h3>
          
          <textarea id="evaluation-note" rows="4" class="w-full text-sm text-slate-700 bg-slate-50 border border-slate-200 rounded-2xl p-4 mb-4 focus:ring-2 focus:ring-indigo-500 outline-none transition" placeholder="Masukkan catatan atau alasan verifikasi berkas lembur..."></textarea>

          <div class="flex flex-col sm:flex-row items-center justify-end gap-3 w-full">
            <form action="/overtime/approval/<%= overtime._id %>/reject" method="POST" onsubmit="appendNoteBeforeSubmit(this)" class="w-full sm:w-auto">
              <input type="hidden" name="note" class="hidden-note-field">
              <button type="submit" class="w-full cursor-pointer px-5 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 text-xs font-bold hover:bg-slate-50 transition active:scale-[0.98]">
                Tolak Pengajuan
              </button>
            </form>

            <form action="/overtime/approval/<%= overtime._id %>/manager" method="POST" onsubmit="appendNoteBeforeSubmit(this)" class="w-full sm:w-auto">
              <input type="hidden" name="note" class="hidden-note-field">
              <button type="submit" class="w-full cursor-pointer px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold shadow-md transition active:scale-[0.98]">
                Terima & Setujui
              </button>
            </form>
          </div>
        </div>
        <% } %>

      </div>

      <div class="space-y-6">
        <div class="bg-white border border-slate-200/60 rounded-xl shadow-sm p-5 md:p-6">
          <div class="mb-6">
            <h2 class="text-xs font-bold text-slate-900 uppercase tracking-wider">Jejak Log Pemeriksaan</h2>
            <p class="text-[10px] text-slate-400 mt-0.5">Alur verifikasi lembur berjenjang</p>
          </div>
          
          <div class="relative pl-6 space-y-8 before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-100">
            <% if (!overtime.approvalHistory || overtime.approvalHistory.length === 0) { %>
              <p class="text-[11px] text-slate-400 italic">Belum ada jejak log terekam.</p>
            <% } else { %>
              <% overtime.approvalHistory.forEach((app, index) => { %>
              <div class="relative mb-6">
                <div class="absolute -left-[27px] top-0 w-6 h-6 rounded-full border-4 border-white flex items-center justify-center z-10
                  <%= app.action === 'APPROVED' ? 'bg-emerald-500' : app.action === 'REJECTED' ? 'bg-rose-500' : 'bg-amber-400' %>">
                  <span class="text-[8px] text-white font-bold"><%= index + 1 %></span>
                </div>
                <div class="flex flex-col gap-1 min-w-0">
                  <div class="flex items-center justify-between gap-2">
                    <span class="text-[11px] font-bold text-slate-900 tracking-wide uppercase truncate"><%= app.role || app.action %></span>
                    <span class="shrink-0 text-[8px] md:text-[9px] font-bold px-2 py-0.5 rounded-full uppercase border <%= app.action === 'APPROVED' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : app.action === 'REJECTED' ? 'bg-rose-50 text-rose-700 border-rose-200' : 'bg-amber-50 text-amber-700 border-amber-200' %>">
                      <%= app.action %>
                    </span>
                  </div>
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-[10px] text-slate-500">
                    <span class="font-semibold text-slate-700 truncate max-w-[120px]"><%= app.by?.fullName || 'Sistem / Pemohon' %></span>
                    <span class="text-slate-300 hidden sm:inline">|</span>
                    <span class="text-[9px]"><%= app.at ? new Date(app.at).toLocaleString('id-ID', {day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit'}) : 'Menunggu' %></span>
                  </div>
                  <% if (app.note) { %>
                  <div class="mt-2 text-[10px] bg-slate-50 p-2.5 rounded-lg border border-slate-100 text-slate-600 italic whitespace-normal break-words">"<%= app.note %>"</div>
                  <% } %>
                </div>
              </div>
              <% }) %>
            <% } %>

            <div class="relative mt-4 pl-3 border-l border-slate-200 text-[11px] text-slate-400">
              <span class="block sm:inline">Waktu Pengajuan Awal:</span> 
              <b class="text-slate-600 font-semibold block sm:inline"><%= new Date(overtime.createdAt).toLocaleString('id-ID') %></b>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  function appendNoteBeforeSubmit(formElement) {
    const noteValue = document.getElementById('evaluation-note').value;
    const hiddenInput = formElement.querySelector('.hidden-note-field');
    if (hiddenInput) {
      hiddenInput.value = noteValue;
    }
  }
</script>
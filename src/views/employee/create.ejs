<%- layout('layouts/main', { title: "Tambah Pegawai" }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

  <div class="max-w-2xl mx-auto">

    <!-- BREADCRUMB & HEADER -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 mb-2 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
        <span>Area Kerja</span>
        <span class="text-slate-300">/</span>
        <span class="text-slate-900">Pegawai</span>
      </nav>

      <h1 class="text-2xl font-bold text-slate-900">
        Tambah Pegawai
      </h1>
      <p class="text-sm text-slate-500 mt-1">
        Isi data Pegawai baru dengan lengkap
      </p>
    </div>

    <!-- CARD -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

      <form action="/api/employee/create"  method="POST" class="p-8 space-y-6">

        <!-- NAMA LENGKAP -->
        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">
            Nama Lengkap
          </label>
          <input type="text" name="fullName" required placeholder="Contoh: Budi Santoso" 
            class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none transition-all" />
        </div>

        <!-- POSITION -->
        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">
            Jabatan / Posisi
          </label>
          <select name="positionId" required 
            class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
            <option value="" disabled selected hidden>Pilih Jabatan</option>
            <% positions.forEach(p => { %>
              <option value="<%= p._id %>"><%= p.name %></option>
            <% }) %>
          </select>
        </div>

        <!-- UNIT & BIDANG (GRID) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">
              Unit Kerja
            </label>
            <select name="unitId" required 
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
              focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
              outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
              <option value="" disabled selected hidden>Pilih Unit</option>
              <% units.forEach(u => { %>
                <option value="<%= u._id %>"><%= u.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="space-y-1.5">
            <label class="text-[13px] font-bold text-slate-700">
              Bidang
            </label>
            <select name="bidangId" required 
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
              focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
              outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
              <option value="" disabled selected hidden>Pilih Bidang</option>
              <% bidang.forEach(b => { %>
                <option value="<%= b._id %>"><%= b.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <!-- STATUS Pegawai -->
        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">
            Status Pegawai
          </label>
          <select name="employmentStatus" required 
            class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px] bg-[right_16px_center] bg-no-repeat">
            <option value="" disabled selected hidden>Pilih Status Ikatan Kerja</option>
            <option value="Tetap">Tetap</option>
            <option value="Kontrak">Kontrak</option>
            <option value="Magang">Magang</option>
          </select>
        </div>

        <!-- JENIS KELAMIN -->
        <div class="space-y-2">
          <label class="text-[13px] font-bold text-slate-700 block">
            Jenis Kelamin
          </label>
          <div class="flex items-center gap-6 text-xs font-medium text-slate-600 pt-1">
            <label class="flex items-center gap-2 cursor-pointer group">
              <input type="radio" name="gender" value="Laki-Laki" required 
                class="w-4 h-4 text-blue-600 bg-slate-50 border-slate-300 focus:ring-blue-500/20 focus:ring-offset-0 focus:ring-4 transition-all" />
              <span class="group-hover:text-slate-900 transition-colors">Laki-Laki</span>
            </label>

            <label class="flex items-center gap-2 cursor-pointer group">
              <input type="radio" name="gender" value="Perempuan" 
                class="w-4 h-4 text-blue-600 bg-slate-50 border-slate-300 focus:ring-blue-500/20 focus:ring-offset-0 focus:ring-4 transition-all" />
              <span class="group-hover:text-slate-900 transition-colors">Perempuan</span>
            </label>
          </div>
        </div>

        <!-- NO HP -->
        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">
            No HP / WhatsApp
          </label>
          <input type="tel" name="phoneNumber" placeholder="Contoh: 08xxxxxxxxxx" 
            class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none transition-all" />
        </div>

        <!-- ALAMAT -->
        <div class="space-y-1.5">
          <label class="text-[13px] font-bold text-slate-700">
            Alamat Tinggal
          </label>
          <textarea name="address" rows="3" placeholder="Tuliskan alamat domisili lengkap saat ini..." 
            class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 
            focus:bg-white text-xs focus:ring-4 focus:ring-slate-100 focus:border-slate-400
            outline-none resize-none transition-all"></textarea>
        </div>

        <!-- OPERASIONAL BUTTONS -->
        <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
          
          <!-- BUTTON BATAL -->
          <a href="/employee"
            class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
            Batal
          </a>

          <!-- BUTTON SIMPAN (Sesuai Warna Biru Standar) -->
          <button type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
            Simpan Pegawai
          </button>

        </div>

      </form>

    </div>

  </div>

</div>
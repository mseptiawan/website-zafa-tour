<%- layout('layouts/main', { title }) %>

<% 
  // =========================================================================
  // CONFIGURATION UNTUK DESAIN BADGE STATUS DI MOBILE & DESKTOP
  // =========================================================================
  const getStatusConfig = (status) => {
    switch(status) {
      case 'PENDING':
        return { label: 'Pending', badge: 'bg-amber-50 text-amber-600 border-amber-200/50', dot: 'bg-amber-500' };
      case 'APPROVED':
        return { label: 'Approved', badge: 'bg-emerald-50 text-emerald-600 border-emerald-200/50', dot: 'bg-emerald-500 animate-pulse' };
      case 'REJECTED':
        return { label: 'Rejected', badge: 'bg-rose-50 text-rose-600 border-rose-200/50', dot: 'bg-rose-500' };
      case 'CANCELLED':
        return { label: 'Cancelled', badge: 'bg-slate-50 text-slate-500 border-slate-200', dot: 'bg-slate-400' };
      case 'CANCELLATION_PENDING':
        return { label: 'Cancel Pending', badge: 'bg-purple-50 text-purple-600 border-purple-200/50', dot: 'bg-purple-500' };
      default:
        return { label: status, badge: 'bg-slate-50 text-slate-600 border-slate-200/50', dot: 'bg-slate-500' };
    }
  };
%>

<div>
  <div class="w-full max-w-none mx-auto space-y-5 md:space-y-8">

    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 border border-slate-200/60 p-4 rounded-2xl bg-white md:bg-transparent md:border-none md:p-0">
      <div class="flex-1 min-w-0">
        <%- include('../partials/page-header', { 
          section: 'Area Kerja', 
          module: 'Kehadiran', 
          title: 'Pusat Administrasi Cuti', 
          description: 'Persetujuan permohonan staf, arsip riwayat, beserta konfigurasi hari libur nasional secara terpusat.' 
        }) %>
      </div>

      <div class="flex shrink-0 items-center w-full lg:w-auto hidden md:block">
        <form id="form-sync-saldo" action="/leave/manage-requests/generate-balances" method="POST" onsubmit="triggerSyncLeaveModal(event)" class="flex items-center justify-between sm:justify-start gap-4 bg-slate-50 border border-slate-200/60 md:bg-white p-2.5 pl-4 rounded-2xl w-full max-w-none lg:max-w-sm">
          <input type="hidden" name="year" value="<%= selectedYear %>">
          <div class="text-[11px] text-slate-500 leading-tight hidden sm:block font-medium whitespace-nowrap">
            Reset & sesuaikan jatah (12 hari) <br /> untuk tahun <%= selectedYear %>
          </div>
          <button type="submit" class="bg-slate-900 hover:bg-slate-800 text-white font-bold text-[12px] h-9 px-4 rounded-xl  transition-all active:scale-[0.98] flex items-center gap-2 whitespace-nowrap cursor-pointer w-full sm:w-auto justify-center">
            <i class="fa-solid fa-rotate text-[10px] text-slate-300"></i> Sync Saldo <%= selectedYear %>
          </button>
        </form>
      </div>
    </div>

    <div class="w-full">
      <%- include('../partials/_stats-grid', {
        gridClass: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
        items: [
          { 
            label: 'Menunggu Review', 
            value: activeLeaves.filter(l => l.status !== 'CANCELLATION_PENDING').length, 
            unit: ' Berkas', 
            icon: 'fa-solid fa-hourglass-half', 
            labelClass: '!font-medium text-blue-600', 
            valueClass: '!font-medium text-blue-800', 
            iconBoxClass: 'bg-blue-50 text-blue-500 border border-blue-200/50',
            wrapperClass: 'hover:border-blue-500/40 transition duration-200'
          },
          { 
            label: 'Pembatalan', 
            value: activeLeaves.filter(l => l.status === 'CANCELLATION_PENDING').length, 
            unit: ' Berkas', 
            icon: 'fa-solid fa-ban', 
            labelClass: '!font-medium text-rose-600', 
            valueClass: '!font-medium text-rose-700', 
            iconBoxClass: 'bg-rose-50 text-rose-500 border border-rose-200/50',
            wrapperClass: 'hover:border-rose-500/40 transition duration-200'
          },
          { 
            label: 'Agenda Kalender', 
            value: holidays.filter(h => h.isActive).length, 
            unit: ' Aktif', 
            icon: 'fa-solid fa-calendar-check', 
            labelClass: '!font-medium text-amber-600', 
            valueClass: '!font-medium text-slate-900', 
            iconBoxClass: 'bg-amber-50 text-amber-500 border border-amber-200/50',
            wrapperClass: 'hover:border-amber-500/40 transition duration-200'
          }
        ]
      }) %>
    </div>

   <div class="flex flex-col gap-3.5 w-full bg-white md:bg-transparent border border-slate-200/50 md:border-none p-4 md:p-0 rounded-2xl md:rounded-none select-none">
      <div class="flex items-center justify-between gap-3 w-full md:hidden">
        <h3 class="text-[14px] font-medium text-slate-800 tracking-tight">Otorisasi Manajemen</h3>
      </div>

      <div class="hidden md:block w-full">
        <%- include('../partials/_tab-nav', {
          tabs: [
            { id: 'active', label: `Permintaan Aktif (${activeLeaves.length})`, isActive: true },
            { id: 'history', label: `Riwayat Selesai (${historyLeaves.length})`, isActive: false },
            { id: 'calendar', label: `Kelola Kalender (${holidays.length})`, isActive: false }
          ]
        }) %>
      </div>

      <div class="block md:hidden w-full">
        <%- include('../partials/_tab-nav', {
          tabs: [
            { id: 'active', label: `Permintaan Aktif (${activeLeaves.length})`, isActive: true },
            { id: 'history', label: `Riwayat Selesai (${historyLeaves.length})`, isActive: false }
          ]
        }) %>
      </div>
    </div>

    <div id="tab-content-active" class="tab-pane block opacity-100 transition-all duration-300 transform translate-y-0 space-y-4">
      
      <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50 ">
       
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Nama Pegawai</th>
                <th class="py-4 px-6">Jenis Pengajuan</th>
                <th class="py-4 px-6">Tipe Cuti</th>
                <th class="py-4 px-6">Tanggal Pelaksanaan</th>
                <th class="py-4 px-6 text-center">Durasi</th>
                <th class="py-4 px-6 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (activeLeaves.length === 0) { %>
                <tr>
                  <td colspan="6" class="py-12 text-center text-slate-400 font-medium">
                    <div class="flex flex-col items-center justify-center space-y-2 py-4">
                      <i class="fa-regular fa-circle-check text-xl text-emerald-500"></i>
                      <span>Bersih! Tidak ada permohonan cuti aktif yang memerlukan tindakan Anda.</span>
                    </div>
                  </td>
                </tr>
              <% } else { %>
                <% activeLeaves.forEach(leave => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors group">
                    <td class="py-4 px-6 font-semibold text-slate-800">
                      <%= leave.userId && leave.userId.employeeData ? leave.userId.employeeData.fullName : "Pegawai" %>
                    </td>
                    <td class="py-4 px-6">
                      <% if (leave.status === 'CANCELLATION_PENDING') { %>
                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-rose-50 text-rose-700 border border-rose-100">
                          <span class="h-1 w-1 rounded-full bg-rose-500 animate-pulse"></span> Minta Batal
                        </span>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-blue-50 text-blue-700 border border-blue-100">
                          <span class="h-1 w-1 rounded-full bg-blue-500 animate-pulse"></span> Cuti Baru
                        </span>
                      <% } %>
                    </td>
                    <td class="py-4 px-6 font-medium">
                      <span class="px-2 py-0.5 rounded bg-slate-100 text-[11px] text-slate-600 font-semibold"><%= leave.leaveTypeId?.name || '-' %></span>
                    </td>
                    <td class="py-4 px-6 text-slate-500 font-medium whitespace-nowrap tabular-nums">
                      <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %>
                      <span class="text-slate-300 mx-1">s/d</span>
                      <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                    </td>
                    <td class="py-4 px-6 text-center font-bold text-blue-600 tabular-nums"><%= leave.totalDays %> Hari</td>
                    <td class="py-4 px-6">
                      <div class="flex items-center justify-center">
                        <a href="/leave/detail/<%= leave._id %>" title="Periksa Berkas" class="inline-flex h-8 px-3.5 items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white text-xs font-semibold text-slate-600  transition-all group-hover:border-blue-500 group-hover:text-blue-600 active:scale-[0.97]">
                          <span><%= leave.status === 'CANCELLATION_PENDING' ? 'Periksa Pembatalan' : 'Periksa Cuti' %></span>
                          <i class="fa-solid fa-chevron-right text-[10px] text-slate-400 group-hover:text-blue-500"></i>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-3.5 w-full">
        <% if (activeLeaves.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
            <p class="text-[12px] font-medium text-slate-400">Tidak ada permohonan cuti aktif</p>
          </div>
        <% } else { %>
          <% activeLeaves.forEach(leave => { %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5 ">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight">
                    <%= leave.userId && leave.userId.employeeData ? leave.userId.employeeData.fullName : "Pegawai" %>
                  </h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                    <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                  </p>
                </div>
                
                <% if (leave.status === 'CANCELLATION_PENDING') { %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-bold bg-rose-50 text-rose-700 border border-rose-100 shrink-0">
                    <span class="h-1 w-1 rounded-full bg-rose-500 animate-pulse"></span> Minta Batal
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-bold bg-blue-50 text-blue-700 border border-blue-100 shrink-0">
                    <span class="h-1 w-1 rounded-full bg-blue-500 animate-pulse"></span> Cuti Baru
                  </span>
                <% } %>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
                <div>
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Tipe Cuti</p>
                  <p class="text-[12px] font-semibold text-slate-700 mt-0.5 truncate"><%= leave.leaveTypeId?.name || '-' %></p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Durasi Pengajuan</p>
                  <p class="text-[13px] font-semibold text-blue-600 mt-0.5 tabular-nums"><%= leave.totalDays %> Hari</p>
                </div>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-500">
                  <i class="fa-solid fa-clock-rotate-left mr-1 text-slate-400"></i>Otorisasi Atasan
                </span>
                <a href="/leave/detail/<%= leave._id %>" class="h-8 px-4 bg-blue-50  text-blue-600f text-[11px] font-semibold rounded-lg flex items-center justify-center tracking-wide active:scale-95 transition-all select-none">
                  <%= leave.status === 'CANCELLATION_PENDING' ? 'TINJAU BATAL' : 'PERIKSA' %>
                </a>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div id="tab-content-history" class="tab-pane hidden opacity-0 transition-all duration-300 transform translate-y-2 space-y-4">
      
      <div class="hidden md:block bg-white rounded-2xl overflow-hidden w-full border border-slate-200/50 ">
        
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[13px]">
            <thead>
              <tr class="bg-slate-50/70 border-b border-slate-200/50 text-[11px] font-semibold text-slate-400 uppercase tracking-wider select-none">
                <th class="py-4 px-6">Nama Pegawai</th>
                <th class="py-4 px-6">Jenis Pengajuan</th>
                <th class="py-4 px-6">Tipe Cuti</th>
                <th class="py-4 px-6">Tanggal Pelaksanaan</th>
                <th class="py-4 px-6 text-center">Durasi</th>
                <th class="py-4 px-6 text-center">Status Final</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white font-medium text-slate-600">
              <% if (historyLeaves.length === 0) { %>
                <tr>
                  <td colspan="6" class="py-12 text-center text-slate-400 font-medium">
                    <div class="flex flex-col items-center justify-center space-y-2 py-4">
                      <i class="fa-regular fa-folder text-xl text-slate-300"></i>
                      <span>Belum ada riwayat arsip pemrosesan dokumen cuti.</span>
                    </div>
                  </td>
                </tr>
              <% } else { %>
                <% historyLeaves.forEach(leave => { %>
                  <tr class="hover:bg-slate-50/40 transition-colors">
                    <td class="py-4 px-6 font-semibold text-slate-800">
                      <%= leave.userId && leave.userId.employeeData ? leave.userId.employeeData.fullName : "Pegawai" %>
                    </td>
                    <td class="py-4 px-6">
                      <% if (leave.status === 'CANCELLED') { %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-amber-50 text-amber-700 border border-amber-200/50">
                          <i class="fa-solid fa-ban text-[9px]"></i> Minta Batal
                        </span>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-blue-50 text-blue-700 border border-blue-200/50">
                          <i class="fa-solid fa-file-circle-plus text-[9px]"></i> Cuti Baru
                        </span>
                      <% } %>
                    </td>
                    <td class="py-4 px-6">
                      <span class="px-2 py-0.5 rounded bg-slate-100 text-xs text-slate-600 font-medium"><%= leave.leaveTypeId?.name || '-' %></span>
                    </td>
                    <td class="py-4 px-6 text-slate-500 font-medium whitespace-nowrap tabular-nums">
                      <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %>
                      <span class="text-slate-300 mx-1">s/d</span>
                      <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                    </td>
                    <td class="py-4 px-6 text-center font-semibold text-slate-700 tabular-nums"><%= leave.totalDays %> Hari</td>
                    <td class="py-4 px-6 text-center whitespace-nowrap">
                      <% if (leave.status === 'APPROVED' || leave.status === 'PENDING' || leave.status === 'CANCELLATION_PENDING' || leave.status === 'CANCELLED') { %>
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200/60 ">
                          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Disetujui
                        </span>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold bg-rose-50 text-rose-700 border border-rose-200/60 ">
                          <span class="h-1.5 w-1.5 rounded-full bg-rose-500"></span> Ditolak
                        </span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="block md:hidden space-y-3.5 w-full">
        <% if (historyLeaves.length === 0) { %>
          <div class="bg-white border border-slate-200/60 rounded-2xl py-10 text-center px-4">
            <p class="text-[12px] font-medium text-slate-400">Belum ada arsip riwayat selesai</p>
          </div>
        <% } else { %>
          <% historyLeaves.forEach(leave => { %>
            <div class="bg-white border border-slate-200/60 rounded-2xl p-4 space-y-3.5 ">
              <div class="flex items-center justify-between gap-2">
                <div>
                  <h4 class="text-[13px] font-semibold text-slate-800 tracking-tight">
                    <%= leave.userId && leave.userId.employeeData ? leave.userId.employeeData.fullName : "Pegawai" %>
                  </h4>
                  <p class="text-[11px] text-slate-400 font-medium mt-0.5">
                    <%= new Date(leave.startDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short'}) %> -
                    <%= new Date(leave.endDate).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                  </p>
                </div>
                <% if (leave.status === 'APPROVED' || leave.status === 'PENDING' || leave.status === 'CANCELLATION_PENDING' || leave.status === 'CANCELLED') { %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200/60  shrink-0">
                    Disetujui
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[9.5px] font-bold bg-rose-50 text-rose-700 border border-rose-200/60  shrink-0">
                    Ditolak
                  </span>
                <% } %>
              </div>

              <div class="bg-slate-50/60 rounded-xl px-3.5 py-2.5 border border-slate-200/30 grid grid-cols-2 gap-2 text-xs">
                <div>
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Jenis Agenda</p>
                  <p class="text-[12px] font-semibold text-slate-700 mt-0.5 truncate">
                    <%= leave.status === 'CANCELLED' ? 'Minta Batal' : 'Cuti Baru' %>
                  </p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">Total Durasi</p>
                  <p class="text-[13px] font-semibold text-slate-800 mt-0.5 tabular-nums"><%= leave.totalDays %> Hari</p>
                </div>
              </div>

              <div class="flex items-center justify-between gap-2 pt-0.5">
                <span class="text-[11px] font-medium text-slate-400">
                  <i class="fa-solid fa-box-archive mr-1"></i>Arsip Tinjauan
                </span>
                <span class="text-[11px] bg-slate-100 px-2 py-1 rounded text-slate-600 font-semibold text-xs tracking-wide">
                  <%= leave.leaveTypeId?.name || '-' %>
                </span>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div id="tab-content-calendar" class="tab-pane hidden opacity-0 transition-all duration-300 transform translate-y-2">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

        <div class="bg-white p-5 rounded-2xl border border-slate-200 ">
          <h3 id="form-calendar-title" class="text-xs font-bold text-slate-800 tracking-wide uppercase mb-4 flex items-center gap-2">
            <i class="fa-solid fa-calendar-plus text-blue-600"></i> Tambah Hari Libur
          </h3>

          <% if (user.role !== 'WAKIL_DIREKTUR') { %>
            <div class="p-3 bg-amber-50 rounded-xl text-[11px] text-amber-800 border border-amber-200/50 mb-4 font-medium leading-relaxed">
              <i class="fa-solid fa-circle-info text-amber-600 mr-0.5"></i> Form dinonaktifkan. Hanya divisi/role <strong>WAKIL_DIREKTUR</strong> yang memiliki hak modifikasi kalender perusahaan.
            </div>
          <% } %>

          <form id="holiday-form" action="/leave/manage-calendar/create?tab=calendar" method="POST" class="space-y-4">
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Nama Hari Libur / Agenda</label>
              <input type="text" name="name" id="form-name" required placeholder="Contoh: Cuti Bersama Lebaran" class="w-full rounded-xl border-slate-200 border p-2.5 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800 font-medium" <%= user.role !== 'WAKIL_DIREKTUR' ? 'disabled' : '' %>>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Mulai Tanggal</label>
                <input type="date" name="date" id="form-date" required class="w-full rounded-xl border-slate-200 border p-2.5 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800 font-medium" <%= user.role !== 'WAKIL_DIREKTUR' ? 'disabled' : '' %>>
              </div>
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Selesai (Opsional)</label>
                <input type="date" name="endDate" id="form-enddate" class="w-full rounded-xl border-slate-200 border p-2.5 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800 font-medium" <%= user.role !== 'WAKIL_DIREKTUR' ? 'disabled' : '' %>>
              </div>
            </div>

            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Kategori Libur</label>
              <select name="type" id="form-type" required class="w-full rounded-xl border-slate-200 border p-2.5 text-xs bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none text-slate-800 font-bold" <%= user.role !== 'WAKIL_DIREKTUR' ? 'disabled' : '' %>>
                <option value="NATIONAL">Nasional (Tanggal Merah)</option>
                <option value="COMPANY">Internal Perusahaan</option>
                <option value="RELIGIOUS">Keagamaan</option>
              </select>
            </div>

            <div class="space-y-2 p-3 bg-slate-50/60 rounded-xl border border-slate-100 text-xs">
              <label class="flex items-center gap-2 text-slate-700 cursor-pointer font-semibold">
                <input type="checkbox" name="isDeductLeave" id="form-deduct" value="true" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500/20" <%= user.role !== 'WAKIL_DIREKTUR' ? 'disabled' : '' %>>
                <span>Potong Kuota Cuti Tahunan?</span>
              </label>
              <p id="form-deduct-info" class="text-[11px] mt-1 font-medium transition-all duration-200 leading-relaxed"></p>
            </div>

            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Keterangan</label>
              <textarea name="description" id="form-description" rows="2" placeholder="Catatan opsional..." class="w-full rounded-xl border-slate-200 border p-2.5 text-xs focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none placeholder-slate-400 text-slate-800 font-medium" <%= user.role !== 'WAKIL_DIREKTUR' ? 'disabled' : '' %>></textarea>
            </div>

            <div class="flex flex-col gap-2 pt-1">
              <button type="submit" id="form-submit-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 rounded-xl text-xs  transition duration-150 flex items-center justify-center gap-1.5" <%= user.role !== 'WAKIL_DIREKTUR' ? 'disabled' : 'style=cursor:pointer' %>>
                <i class="fa-solid fa-floppy-disk"></i> Simpan Agenda
              </button>
              <button type="button" id="form-cancel-btn" onclick="resetFormToCreate()" class="w-full hidden bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold py-2.5 rounded-xl text-xs transition duration-150 text-center cursor-pointer">
                Batal Edit (Buat Baru)
              </button>
            </div>
          </form>
        </div>

        <div class="bg-white p-5 rounded-2xl border border-slate-200  lg:col-span-2">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
            <h3 class="text-xs font-bold text-slate-800 tracking-wide uppercase">Agenda Terdaftar Tahun <%= selectedYear %></h3>
            <form method="GET" action="/leave/manage-requests">
              <input type="hidden" name="tab" value="calendar">
              <select name="year" onchange="this.form.submit()" class="border border-slate-200 rounded-xl py-1.5 px-3 text-xs font-bold text-slate-700 bg-white focus:outline-none cursor-pointer  w-full sm:w-auto">
                <% const yr = new Date().getFullYear(); %>
                <option value="<%= yr %>" <%= selectedYear === yr ? 'selected' : '' %>><%= yr %></option>
                <option value="<%= yr + 1 %>" <%= selectedYear === (yr + 1) ? 'selected' : '' %>><%= yr + 1 %></option>
              </select>
            </form>
          </div>

          <% if (holidays.length !== 0) { %>
            <div class="flex flex-wrap gap-1 mb-4 bg-slate-100/80 p-1 rounded-xl w-fit">
              <button type="button" onclick="filterQuarter('ALL')" class="q-btn px-3 py-1.5 text-[11px] font-bold rounded-lg bg-white text-blue-600  transition-all duration-150 cursor-pointer">Semua</button>
              <button type="button" onclick="filterQuarter('Q1')" class="q-btn px-3 py-1.5 text-[11px] font-medium rounded-lg text-slate-600 hover:text-slate-800 transition-all duration-150 cursor-pointer">Q1 (Jan-Mar)</button>
              <button type="button" onclick="filterQuarter('Q2')" class="q-btn px-3 py-1.5 text-[11px] font-medium rounded-lg text-slate-600 hover:text-slate-800 transition-all duration-150 cursor-pointer">Q2 (Apr-Jun)</button>
              <button type="button" onclick="filterQuarter('Q3')" class="q-btn px-3 py-1.5 text-[11px] font-medium rounded-lg text-slate-600 hover:text-slate-800 transition-all duration-150 cursor-pointer">Q3 (Jul-Sep)</button>
              <button type="button" onclick="filterQuarter('Q4')" class="q-btn px-3 py-1.5 text-[11px] font-medium rounded-lg text-slate-600 hover:text-slate-800 transition-all duration-150 cursor-pointer">Q4 (Okt-Des)</button>
            </div>
          <% } %>

          <div class="space-y-2.5 max-h-[500px] overflow-y-auto pr-1" id="holiday-list-container">
            <% if (holidays.length === 0) { %>
              <div class="text-center py-12 text-slate-400 text-xs font-medium">Belum ada agenda libur terdaftar.</div>
            <% } else { %>
              <% holidays.forEach(h => { %>
                <% const hMonth = new Date(h.date).getMonth(); %>
                <div class="holiday-card flex items-center justify-between p-3.5 rounded-xl border border-slate-100 bg-slate-50/40 transition duration-150 <%= !h.isActive ? 'opacity-50 bg-slate-200/30' : 'hover:border-slate-200/80 hover:bg-white hover:' %>" data-month="<%= hMonth %>">
                  <div class="flex items-center gap-4">
                    <div class="p-2.5 rounded-xl text-center font-bold text-xs min-w-[56px] tabular-nums border <%= !h.isActive ? 'bg-slate-200 text-slate-500 border-slate-300' : h.isDeductLeave ? 'bg-rose-50 text-rose-700 border-rose-100' : 'bg-blue-50 text-blue-700 border-blue-100' %>">
                      <span class="block text-sm font-black leading-tight"><%= new Date(h.date).toLocaleDateString('id-ID', { day: '2-digit' }) %></span>
                      <span class="block text-[9px] font-bold uppercase tracking-wider mt-0.5"><%= new Date(h.date).toLocaleDateString('id-ID', { month: 'short' }) %></span>
                    </div>
                    <div>
                      <h4 class="font-bold text-slate-800 text-xs flex items-center gap-2">
                        <%= h.name %>
                        <% if(!h.isActive) { %>
                          <span class="text-[9px] bg-slate-400 text-white font-bold px-1.5 py-0.5 rounded-sm">Diarsipkan</span>
                        <% } %>
                      </h4>
                      <p class="text-[11px] text-slate-400 mt-0.5 font-medium"><%= h.description || 'Tidak ada deskripsi tambahan' %></p>
                      <div class="flex flex-wrap gap-1.5 mt-1.5">
                        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-md bg-slate-200/70 text-slate-600 uppercase tracking-wider"><%= h.type %></span>
                        <% if(h.isDeductLeave) { %>
                          <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-md bg-rose-100/70 text-rose-600 flex items-center gap-0.5">
                            <i class="fa-solid fa-scissors text-[8px]"></i> Potong Cuti
                          </span>
                        <% } %>
                      </div>
                    </div>
                  </div>

                  <% const isWakilDirektur = user && user.role === 'WAKIL_DIREKTUR'; %>
                  <% if (isWakilDirektur) { %>
                    <div class="flex items-center gap-1.5">
                      <button type="button" onclick="prepareEditHoliday('<%= encodeURIComponent(JSON.stringify(h)) %>')" class="text-blue-600 hover:text-blue-800 p-2 rounded-xl hover:bg-blue-50/80 transition duration-150 cursor-pointer" title="Ubah data">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                        </svg>
                      </button>
                      <button type="button" onclick="toggleHolidayStatus('<%= h._id %>', <%= h.isActive %>)" class="p-2 rounded-xl transition duration-150 cursor-pointer <%= h.isActive ? 'text-amber-600 hover:text-amber-800 hover:bg-amber-50' : 'text-emerald-600 hover:text-emerald-800 hover:bg-emerald-50' %>" title="<%= h.isActive ? 'Arsipkan agenda' : 'Aktifkan kembali' %>">
                        <% if (h.isActive) { %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
                          </svg>
                        <% } else { %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                          </svg>
                        <% } %>
                      </button>
                    </div>
                  <% } %>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<script>
 

  // ==========================================
  // LOGIC SINKRONISASI KATEGORI & POTONG CUTI
  // ==========================================
  function handleTypeChange() {
    const typeSelect = document.getElementById('form-type');
    const deductCheckbox = document.getElementById('form-deduct');
    const deductInfo = document.getElementById('form-deduct-info');

    if (!typeSelect || !deductCheckbox) return;

    const value = typeSelect.value;
    const parentLabel = deductCheckbox.parentElement;

    if (value === 'COMPANY') {
      deductCheckbox.checked = true;
      deductCheckbox.disabled = true;
      if (parentLabel) parentLabel.className = 'flex items-center gap-2 text-slate-700 cursor-not-allowed opacity-75 font-semibold';
      if (deductInfo) {
        deductInfo.innerHTML = '<i class="fa-solid fa-circle-exclamation text-amber-500 mr-1"></i> Kebijakan Perusahaan: Cuti bersama internal otomatis memotong kuota tahunan Pegawai.';
        deductInfo.className = "text-[11px] mt-1 font-medium text-amber-600 leading-relaxed";
      }
    } else if (value === 'NATIONAL') {
      deductCheckbox.checked = false;
      deductCheckbox.disabled = true;
      if (parentLabel) parentLabel.className = 'flex items-center gap-2 text-slate-700 cursor-not-allowed opacity-50 font-semibold';
      if (deductInfo) {
        deductInfo.innerHTML = '<i class="fa-solid fa-circle-check text-emerald-500 mr-1"></i> Sesuai Regulasi: Libur nasional / tanggal merah resmi tidak memotong kuota cuti.';
        deductInfo.className = "text-[11px] mt-1 font-medium text-emerald-600 leading-relaxed";
      }
    } else if (value === 'RELIGIOUS') {
      deductCheckbox.disabled = false;
      if (parentLabel) parentLabel.className = 'flex items-center gap-2 text-slate-700 cursor-pointer font-semibold';
      if (deductInfo) {
        deductInfo.innerHTML = '<i class="fa-solid fa-circle-info text-blue-500 mr-1"></i> Opsional: Silakan tentukan apakah agenda keagamaan ini memotong kuota cuti tahunan atau tidak.';
        deductInfo.className = "text-[11px] mt-1 font-medium text-blue-600 leading-relaxed";
      }
    }
  }

  function prepareEditHoliday(holidayDataRaw) {
    const holiday = JSON.parse(decodeURIComponent(holidayDataRaw));
    document.getElementById('form-calendar-title').innerHTML = '<i class="fa-solid fa-pen-to-square text-blue-600"></i> Edit Hari Libur';
    document.getElementById('holiday-form').action = `/leave/manage-calendar/update/${holiday._id}?tab=calendar`;
    document.getElementById('form-submit-btn').innerHTML = '<i class="fa-solid fa-check"></i> Simpan Perubahan';
    document.getElementById('form-cancel-btn').classList.remove('hidden');
    document.getElementById('form-name').value = holiday.name;
    document.getElementById('form-date').value = new Date(holiday.date).toISOString().split('T')[0];

    if (holiday.endDate) {
      document.getElementById('form-enddate').value = new Date(holiday.endDate).toISOString().split('T')[0];
    } else {
      document.getElementById('form-enddate').value = '';
    }

    document.getElementById('form-type').value = holiday.type;

    handleTypeChange();
    document.getElementById('form-deduct').checked = holiday.isDeductLeave;
    document.getElementById('form-description').value = holiday.description || '';

    document.getElementById('holiday-form').scrollIntoView({
      behavior: 'smooth'
    });
  }

  function resetFormToCreate() {
    document.getElementById('form-calendar-title').innerHTML = '<i class="fa-solid fa-calendar-plus text-blue-600"></i> Tambah Hari Libur';
    document.getElementById('holiday-form').action = '/leave/manage-calendar/create?tab=calendar';
    document.getElementById('form-submit-btn').innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Simpan Agenda';
    document.getElementById('form-cancel-btn').classList.add('hidden');
    document.getElementById('holiday-form').reset();

    handleTypeChange();
  }

  async function toggleHolidayStatus(id, currentStatus) {
    const message = currentStatus ?
      "Apakah Anda yakin ingin mengarsipkan hari libur ini? Data tidak akan terhapus namun dinonaktifkan dari sistem berjalan." :
      "Aktifkan kembali hari libur yang telah diarsipkan ini?";

    if (!confirm(message)) return;
    try {
      const response = await fetch(`/leave/manage-calendar/toggle/${id}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json'
        }
      });
      const result = await response.json();
      if (result.success) {
        window.location.href = window.location.pathname + '?tab=calendar';
      } else {
        alert("Gagal memproses data: " + result.message);
      }
    } catch (err) {
      console.error(err);
      alert("Gagal menghubungi server database.");
    }
  }

  document.addEventListener("DOMContentLoaded", function() {
    const typeSelect = document.getElementById('form-type');

    if (typeSelect) {
      typeSelect.addEventListener('change', handleTypeChange);
    }

    const currentUrlParams = new URLSearchParams(window.location.search);
    const activeTab = currentUrlParams.get('tab');

    if (activeTab) {
      switchTab(activeTab);
    } else if (currentUrlParams.has('year')) {
      switchTab('calendar');
    }

    handleTypeChange();
  });

  function filterQuarter(quarter) {
    const buttons = document.querySelectorAll('.q-btn');
    const targetButton = window.event ? window.event.currentTarget : null;
    buttons.forEach(btn => {
      btn.className = "q-btn px-3 py-1.5 text-[11px] font-medium rounded-lg text-slate-600 hover:text-slate-800 transition-all duration-150 cursor-pointer";
    });
    if (targetButton) {
      targetButton.className = "q-btn px-3 py-1.5 text-[11px] font-bold rounded-lg bg-white text-blue-600  transition-all duration-150 cursor-pointer";
    }

    document.querySelectorAll('.holiday-card').forEach(card => {
      const month = parseInt(card.getAttribute('data-month'));

      if (quarter === 'ALL') {
        card.classList.remove('hidden');
      } else if (quarter === 'Q1' && month >= 0 && month <= 2) {
        card.classList.remove('hidden');
      } else if (quarter === 'Q2' && month >= 3 && month <= 5) {
        card.classList.remove('hidden');
      } else if (quarter === 'Q3' && month >= 6 && month <= 8) {
        card.classList.remove('hidden');
      } else if (quarter === 'Q4' && month >= 9 && month <= 11) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }

  function triggerSyncLeaveModal(event) {
    event.preventDefault();
    const form = event.target;

    openConfirmModal({
      title: "Reset & Sync Saldo Cuti",
      message: "Apakah Anda yakin ingin melakukan generate/reset saldo seluruh Pegawai pada tahun <%= selectedYear %>?",
      confirmText: "Ya, Sinkronisasikan",
      confirmClass: "bg-slate-900 hover:bg-slate-800 rounded-xl text-sm font-medium transition cursor-pointer", 
      onConfirm: () => {
        form.submit();
      }
    });
  }
</script>
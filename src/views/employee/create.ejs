<%- layout('layouts/main', { title: "Tambah Karyawan" }) %>

<div class="max-w-6xl mx-auto min-h-screen bg-white p-8 antialiased ml-72">

<%- include('../partials/page-header', {
  section: 'Area Kerja',
  module: 'Tambah Karyawan',
  title: 'Daftarkan Karyawan Baru',
  description: 'Langkah awal pembuatan akun kredensial dan penempatan posisi kerja staf baru.'
}) %>

<% if (typeof error !== 'undefined' && error && error !== 'null' && error !== null) { %>
  <div class="border-l-2 border-rose-500 bg-rose-50/50 text-rose-700 px-4 py-3 rounded-r-md text-xs mb-8 font-medium">
    <%= error %>
  </div>
<% } %>

  <form action="/api/employee/create" method="POST" class="space-y-10">

   <% const formErrors = typeof errors !== 'undefined' ? errors : {} %>
<% const oldData = typeof old !== 'undefined' ? old : {} %>

<!-- Section 1: Identitas -->
<div class="space-y-5">
  <div class="pb-2 border-b border-slate-100">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400">
      1. Identitas Pribadi & Kredensial Akun
    </h3>
  </div>

  <div class="grid md:grid-cols-2 gap-x-6 gap-y-4">
    <!-- Nama Lengkap -->
    <div class="space-y-1.5">
      <label class="label-custom">Nama Lengkap <span class="text-rose-500">*</span></label>
      <input name="fullName" type="text" placeholder="Nama sesuai KTP" value="<%= oldData.fullName || '' %>" required class="input-custom <%= formErrors.fullName ? 'border-rose-400 focus:border-rose-500' : '' %>"/>
      <% if (formErrors.fullName) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.fullName %></p>
      <% } %>
    </div>

    <!-- Nomor KTP -->
    <div class="space-y-1.5">
      <label class="label-custom">Nomor KTP (NIK) <span class="text-rose-500">*</span></label>
      <input name="nomor_ktp" type="text" maxlength="16" placeholder="16 digit NIK" value="<%= oldData.nomor_ktp || '' %>" required class="input-custom <%= formErrors.nomor_ktp ? 'border-rose-400 focus:border-rose-500' : '' %>"/>
      <% if (formErrors.nomor_ktp) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.nomor_ktp %></p>
      <% } %>
    </div>

    <!-- Email -->
    <div class="space-y-1.5">
      <label class="label-custom">Email Utama Aplikasi <span class="text-rose-500">*</span></label>
      <input name="email" type="email" placeholder="nama@zafamulia.com" value="<%= oldData.email || '' %>" required class="input-custom <%= formErrors.email ? 'border-rose-400 focus:border-rose-500' : '' %>"/>
      <% if (formErrors.email) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.email %></p>
      <% } %>
    </div>

    <!-- Role -->
    <div class="space-y-1.5">
      <label class="label-custom">Hak Akses Sistem (Role) <span class="text-rose-500">*</span></label>
      <select name="roleId" required class="input-custom <%= formErrors.roleId ? 'border-rose-400 focus:border-rose-500' : '' %>">
        <option value="" disabled <%= !oldData.roleId ? 'selected' : '' %>>Pilih Hak Akses</option>
        <% roles.forEach(r => { %>
          <option value="<%= r._id %>" <%= String(oldData.roleId) === String(r._id) ? 'selected' : '' %>><%= r.name %></option>
        <% }) %>
      </select>
      <% if (formErrors.roleId) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.roleId %></p>
      <% } %>
    </div>

    <!-- Jenis Kelamin -->
    <div class="space-y-1.5">
      <label class="label-custom">Jenis Kelamin <span class="text-rose-500">*</span></label>
      <select name="jenis_kelamin" required class="input-custom <%= formErrors.jenis_kelamin ? 'border-rose-400 focus:border-rose-500' : '' %>">
        <option value="" disabled <%= !oldData.jenis_kelamin ? 'selected' : '' %>>Pilih Jenis Kelamin</option>
        <option value="Laki-Laki" <%= oldData.jenis_kelamin === 'Laki-Laki' ? 'selected' : '' %>>Laki-Laki</option>
        <option value="Perempuan" <%= oldData.jenis_kelamin === 'Perempuan' ? 'selected' : '' %>>Perempuan</option>
      </select>
      <% if (formErrors.jenis_kelamin) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.jenis_kelamin %></p>
      <% } %>
    </div>

    <!-- Agama -->
    <div class="space-y-1.5">
      <label class="label-custom">Agama <span class="text-rose-500">*</span></label>
      <select name="agama" required class="input-custom <%= formErrors.agama ? 'border-rose-400 focus:border-rose-500' : '' %>">
        <option value="" disabled <%= !oldData.agama ? 'selected' : '' %>>Pilih Agama</option>
        <option value="Islam" <%= oldData.agama === 'Islam' ? 'selected' : '' %>>Islam</option>
        <option value="Kristen" <%= oldData.agama === 'Kristen' ? 'selected' : '' %>>Kristen</option>
        <option value="Katolik" <%= oldData.agama === 'Katolik' ? 'selected' : '' %>>Katolik</option>
        <option value="Hindu" <%= oldData.agama === 'Hindu' ? 'selected' : '' %>>Hindu</option>
        <option value="Buddha" <%= oldData.agama === 'Buddha' ? 'selected' : '' %>>Buddha</option>
      </select>
      <% if (formErrors.agama) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.agama %></p>
      <% } %>
    </div>
  </div>
</div>

<!-- Section 2: Kedinasan -->
<div class="space-y-5 pt-4">
  <div class="pb-2 border-b border-slate-100">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400">
      2. Struktur Penempatan & Karir
    </h3>
  </div>

  <div class="grid md:grid-cols-2 gap-x-6 gap-y-4">
    <!-- Jabatan -->
    <div class="space-y-1.5">
      <label class="label-custom">Jabatan Struktural <span class="text-rose-500">*</span></label>
      <select name="positionId" required class="input-custom <%= formErrors.positionId ? 'border-rose-400 focus:border-rose-500' : '' %>">
        <option value="" disabled <%= !oldData.positionId ? 'selected' : '' %>>Pilih Jabatan</option>
        <% positions.forEach(p => { %>
          <option value="<%= p._id %>" <%= String(oldData.positionId) === String(p._id) ? 'selected' : '' %>><%= p.name %></option>
        <% }) %>
      </select>
      <% if (formErrors.positionId) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.positionId %></p>
      <% } %>
    </div>

    <!-- Unit Kerja -->
    <div class="space-y-1.5">
      <label class="label-custom">Unit Kantor Penempatan <span class="text-rose-500">*</span></label>
      <select name="unitId" required class="input-custom <%= formErrors.unitId ? 'border-rose-400 focus:border-rose-500' : '' %>">
        <option value="" disabled <%= !oldData.unitId ? 'selected' : '' %>>Pilih Unit Kantor</option>
        <% units.forEach(u => { %>
          <option value="<%= u._id %>" <%= String(oldData.unitId) === String(u._id) ? 'selected' : '' %>><%= u.name %></option>
        <% }) %>
      </select>
      <% if (formErrors.unitId) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.unitId %></p>
      <% } %>
    </div>

    <!-- Bidang Kerja -->
    <div class="space-y-1.5">
      <label class="label-custom">Bidang Kerja <span class="text-rose-500">*</span></label>
      <select name="bidangId" required class="input-custom <%= formErrors.bidangId ? 'border-rose-400 focus:border-rose-500' : '' %>">
        <option value="" disabled <%= !oldData.bidangId ? 'selected' : '' %>>Pilih Bidang Kerja</option>
        <% bidang.forEach(b => { %>
          <option value="<%= b._id %>" <%= String(oldData.bidangId) === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
        <% }) %>
      </select>
      <% if (formErrors.bidangId) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.bidangId %></p>
      <% } %>
    </div>

    <!-- Status Pegawai -->
    <div class="space-y-1.5">
      <label class="label-custom">Status Kepegawaian Awal <span class="text-rose-500">*</span></label>
      <select name="status_pegawai" required class="input-custom <%= formErrors.status_pegawai ? 'border-rose-400 focus:border-rose-500' : '' %>">
        <option value="" disabled <%= !oldData.status_pegawai ? 'selected' : '' %>>Pilih Status</option>
        <option value="Pegawai Tetap" <%= oldData.status_pegawai === 'Pegawai Tetap' ? 'selected' : '' %>>Pegawai Tetap</option>
        <option value="Pegawai Kontrak" <%= oldData.status_pegawai === 'Pegawai Kontrak' ? 'selected' : '' %>>Pegawai Kontrak</option>
        <option value="Magang / Intern" <%= oldData.status_pegawai === 'Magang / Intern' ? 'selected' : '' %>>Magang / Intern</option>
      </select>
      <% if (formErrors.status_pegawai) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.status_pegawai %></p>
      <% } %>
    </div>

    <!-- Tanggal Bergabung -->
    <div class="space-y-1.5">
      <label class="label-custom">Tanggal Mulai Bergabung <span class="text-rose-500">*</span></label>
      <input type="date" name="tanggal_mulai_bergabung" value="<%= oldData.tanggal_mulai_bergabung || '' %>" required class="input-custom <%= formErrors.tanggal_mulai_bergabung ? 'border-rose-400 focus:border-rose-500' : '' %>"/>
      <% if (formErrors.tanggal_mulai_bergabung) { %>
        <p class="text-[11px] font-medium text-rose-500 mt-1"><%= formErrors.tanggal_mulai_bergabung %></p>
      <% } %>
    </div>
  </div>
</div>

    <!-- Action Buttons -->
    <div class="flex justify-end items-center gap-3 pt-6 border-t border-slate-100">
      <a href="/employee" 
         class="text-xs font-medium text-slate-500 px-4 py-2.5 rounded-md border border-slate-200 hover:bg-slate-50 hover:text-slate-700 transition-colors">
        Batal
      </a>
      <button type="submit" 
              class="text-xs font-medium text-white bg-blue-500 px-5 py-2.5 rounded-md hover:bg-blue-600 active:bg-blue-700 transition-colors tracking-wide">
        Simpan Karyawan
      </button>
    </div>

  </form>
</div>

<style>
  .label-custom {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: #64748b;
  }
  .input-custom {
    width: 100%;
    padding: 9px 12px;
    font-size: 12px;
    font-weight: 400;
    color: #0f172a;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    background-color: #ffffff;
    outline: none;
    transition: border-color 0.15s ease-in-out;
  }
  .input-custom:focus {
    border-color: #3b82f6;
  }
  select.input-custom {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2394a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 12px center;
    background-size: 12px;
    padding-right: 32px;
  }
</style>
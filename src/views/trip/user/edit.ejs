<%- layout('layouts/main', { title }) %>

  <% const isRejected=trip.status==="REJECTED" ; const action=isRejected ? `/trip/${trip._id}/resubmit` :
    `/trip/${trip._id}`; const method=isRejected ? "POST" : "PUT" ; const lastReject=trip.approvals ?.slice() .reverse()
    .find(a=> a.status === "REJECTED");
    %>

    <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

      <div class="max-w-2xl mx-auto">

        <!-- HEADER -->
        <div class="mb-8">

          <nav class="flex items-center gap-2 mb-2 text-[11px] font-semibold text-slate-400 uppercase tracking-widest">
            <span>Area Kerja</span>
            <span>/</span>
            <span>Trip</span>
            <span>/</span>
            <span class="text-slate-700">
              <%= isRejected ? "Resubmit" : "Edit" %>
            </span>
          </nav>

          <h1 class="text-2xl font-semibold text-slate-800">
            <%= isRejected ? "Resubmit Pengajuan Dinas" : "Edit Pengajuan Dinas" %>
          </h1>

          <p class="text-sm text-slate-500 mt-1">
            <%= isRejected ? "Perbaiki pengajuan yang ditolak lalu ajukan kembali"
              : "Perbarui data pengajuan perjalanan dinas" %>
          </p>

        </div>

        <!-- ALERT -->
        <% if (isRejected) { %>

          <div class="mb-6 bg-red-50 border border-red-200 rounded-2xl p-5">

            <div class="text-sm font-semibold text-red-700">
              Pengajuan Ditolak
            </div>

            <p class="text-sm text-red-600 mt-1">
              Perbaiki data pengajuan sebelum diajukan kembali.
            </p>

            <% if (lastReject?.note) { %>

              <div class="mt-4 bg-white border border-red-100 rounded-xl p-4">

                <div class="text-[11px] font-semibold uppercase tracking-wider text-red-500 mb-2">
                  Catatan Penolakan
                </div>

                <div class="text-sm text-slate-700 leading-relaxed">
                  <%= lastReject.note %>
                </div>

              </div>

              <% } %>

          </div>

          <% } %>

            <!-- CARD -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

              <form action="<%= action %>?_method=<%= method %>" method="POST" class="p-8 space-y-6">

                <!-- TITLE -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Judul Perjalanan
                  </label>

                  <input type="text" name="title" value="<%= trip.title %>" minlength="5" maxlength="100" required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                </div>

                <!-- PURPOSE -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Tujuan Perjalanan
                  </label>

                  <select name="purpose" required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all">

                    <option value="">Pilih tujuan</option>

                    <option value="KUNJUNGAN_SALES" <%=trip.purpose==="KUNJUNGAN_SALES" ? "selected" : "" %>>
                      Kunjungan Sales
                    </option>

                    <option value="RAPAT" <%=trip.purpose==="RAPAT" ? "selected" : "" %>>
                      Rapat
                    </option>

                    <option value="PELATIHAN" <%=trip.purpose==="PELATIHAN" ? "selected" : "" %>>
                      Pelatihan
                    </option>

                    <option value="SURVEI" <%=trip.purpose==="SURVEI" ? "selected" : "" %>>
                      Survei
                    </option>

                    <option value="LAINNYA" <%=trip.purpose==="LAINNYA" ? "selected" : "" %>>
                      Lainnya
                    </option>

                  </select>

                </div>

                <!-- DATE -->
                <div class="grid grid-cols-2 gap-4">

                  <div class="space-y-1.5">

                    <label class="text-[13px] font-semibold text-slate-700">
                      Tanggal Mulai
                    </label>

                    <input type="date" name="startDate"
                      value="<%= trip.startDate ? new Date(trip.startDate).toISOString().split('T')[0] : '' %>" required
                      class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                  </div>

                  <div class="space-y-1.5">

                    <label class="text-[13px] font-semibold text-slate-700">
                      Tanggal Selesai
                    </label>

                    <input type="date" name="endDate"
                      value="<%= trip.endDate ? new Date(trip.endDate).toISOString().split('T')[0] : '' %>" required
                      class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                  </div>

                </div>

                <!-- DESTINATION -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Tujuan / Lokasi
                  </label>

                  <input type="text" name="destination" value="<%= trip.destination %>" minlength="3" maxlength="150"
                    required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                </div>

                <!-- DESCRIPTION -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Deskripsi
                  </label>

                  <textarea name="description" rows="4" minlength="10" maxlength="1000" required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none resize-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all"><%= trip.description %></textarea>

                </div>

                <!-- BUDGET -->
               <%
  // Logika normalisasi data budget lama vs baru di level UI
  let savedItems = [];
  let currentTotal = 0;

  if (trip.budget && typeof trip.budget === 'object' && Array.isArray(trip.budget.items)) {
    savedItems = trip.budget.items;
    currentTotal = trip.budget.total || 0;
  } else if (typeof trip.budget === 'number' && trip.budget > 0) {
    // Jalur fallback: Konversi data angka lama jadi format item default
    savedItems = [{ title: 'Anggaran Pengajuan (Data Lama)', allocatedAmount: trip.budget, description: '' }];
    currentTotal = trip.budget;
  } else {
    // Default jika data kosong melompong
    savedItems = [{ title: '', allocatedAmount: 0, description: '' }];
  }
%>

<div class="space-y-3" id="budget-section">
  <div class="flex items-center justify-between">
    <label class="text-[13px] font-semibold text-slate-700">
      Rincian Budget Kunjungan
    </label>
    <button type="button" id="add-budget-item" class="inline-flex items-center gap-1 text-[11.5px] font-bold text-blue-600 hover:text-blue-700 transition-colors">
      <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Tambah Item
    </button>
  </div>

  <div id="budget-items-container" class="space-y-2.5">
    <% savedItems.forEach(function(item, idx) { %>
      <div class="budget-item bg-slate-50/50 border border-slate-200/60 rounded-xl p-3.5 space-y-2 relative group/item">
        <div class="grid grid-cols-12 gap-2.5">
          <div class="col-span-7">
            <input type="text" name="budget[items][<%= idx %>][title]" value="<%= item.title %>" placeholder="Nama pengeluaran..." required
              class="w-full bg-white border border-slate-200 rounded-lg text-[11.5px] px-3 py-2 text-slate-700 outline-none focus:ring-2 focus:ring-slate-100 focus:border-slate-400 transition-all" />
          </div>
          <div class="col-span-5 pr-7">
            <input type="text" placeholder="Rp 0" value="Rp <%= (item.allocatedAmount || 0).toLocaleString('id-ID') %>" oninput="formatCurrency(this)"
              class="budget-amount-display w-full bg-white border border-slate-200 rounded-lg text-[11.5px] px-3 py-2 text-slate-700 text-right outline-none focus:ring-2 focus:ring-slate-100 focus:border-slate-400 transition-all" />
            <input type="hidden" name="budget[items][<%= idx %>][allocatedAmount]" class="budget-amount-raw" value="<%= item.allocatedAmount || 0 %>" />
          </div>
        </div>
        <div>
          <input type="text" name="budget[items][<%= idx %>][description]" value="<%= item.description %>" placeholder="Keterangan opsional..."
            class="w-full bg-white border border-slate-200 rounded-lg text-[11px] px-3 py-1.5 text-slate-500 outline-none focus:ring-2 focus:ring-slate-100 focus:border-slate-400 transition-all" />
        </div>
        <button type="button" onclick="removeBudgetItem(this)" class="delete-budget-btn absolute top-3 right-3 text-slate-400 hover:text-red-500 transition-colors <%= savedItems.length === 1 ? 'hidden' : '' %>">
          <svg class="w-4 h-4 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-16v1a3 3 0 003 3h10M9 7h6" />
          </svg>
        </button>
      </div>
    <% }); %>
  </div>

  <div class="flex justify-between items-center bg-slate-100/60 rounded-xl px-4 py-2.5 text-[12px]">
    <span class="font-medium text-slate-500">Estimasi Total Budget:</span>
    <span id="budget-total-display" class="font-bold text-slate-800">Rp <%= currentTotal.toLocaleString('id-ID') %></span>
  </div>
</div>

                <!-- MEET WITH -->
                <div class="space-y-1.5">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Bertemu Dengan
                  </label>

                  <input type="text" name="meetWith" value="<%= trip.meetWith || '' %>"
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                </div>

                <!-- TIMELINE -->
                <div class="space-y-2">

                  <label class="text-[13px] font-semibold text-slate-700">
                    Timeline Perjalanan
                  </label>

                  <div id="timelineBox" class="space-y-2">

                    <% if (trip.timeline && trip.timeline.length) { %>

                      <% trip.timeline.forEach((t, i)=> { %>

                        <div class="flex gap-2 timeline-item">

                          <input type="text" name="timeline[<%= i %>][address]" value="<%= t.address %>" required
                            class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all" />

                          <input type="hidden" name="timeline[<%= i %>][order]" value="<%= i + 1 %>" />

                          <button type="button" onclick="removeTimeline(this)"
                            class="px-3 rounded-xl bg-red-50 text-red-500 hover:bg-red-100 transition">
                            ✕
                          </button>

                        </div>

                        <% }) %>

                          <% } %>

                  </div>

                  <button type="button" onclick="addTimeline()" class="text-sm text-indigo-600 hover:text-indigo-700">
                    + Tambah Timeline
                  </button>

                </div>

                <!-- SUBMIT -->
                <div class="pt-4 border-t border-slate-100">

                  <button type="submit" class="
              w-full
              text-white
              py-3
              rounded-xl
              text-sm
              font-medium
              transition-all

              <%= isRejected
                ? 'bg-red-600 hover:bg-red-700'
                : 'bg-slate-900 hover:bg-slate-800'
              %>
            ">
                    <%= isRejected ? "Ajukan Ulang Pengajuan" : "Simpan Perubahan" %>
                  </button>

                </div>

              </form>

            </div>

      </div>

    </div>

    <script>
     let timelineIndex = <%= trip.timeline ? trip.timeline.length : 0 %>;
  let budgetItemIndex = <%= savedItems.length %>; // Mulai melacak dari jumlah item yang ada saat ini

  // 1. FUNGSI FORMAT CURRENCY (Menggunakan logika regex lama lu)
  function formatCurrency(input) {
    let value = input.value.replace(/\D/g, ""); 
    
    let rawInput = input.closest('.col-span-5').querySelector('.budget-amount-raw');
    rawInput.value = value; // Simpan angka bersih ke hidden input

    if (!value) {
      input.value = "";
      calculateTotalBudget();
      return;
    }

    input.value = "Rp " + Number(value).toLocaleString("id-ID");
    calculateTotalBudget();
  }

  // 2. FUNGSI HITUNG TOTAL ESTIMASI BUDGET
  function calculateTotalBudget() {
    let total = 0;
    document.querySelectorAll('.budget-amount-raw').forEach(input => {
      total += Number(input.value || 0);
    });
    document.getElementById('budget-total-display').innerText = 'Rp ' + total.toLocaleString('id-ID');
  }

  // 3. EVENT LISTENER: TOMBOL TAMBAH BARIS ITEM BUDGET BARU
  document.getElementById('add-budget-item').addEventListener('click', function() {
    const container = document.getElementById('budget-items-container');
    
    const newItem = document.createElement('div');
    newItem.className = 'budget-item bg-slate-50/50 border border-slate-200/60 rounded-xl p-3.5 space-y-2 relative group/item';
    newItem.innerHTML = `
      <div class="grid grid-cols-12 gap-2.5">
        <div class="col-span-7">
          <input type="text" name="budget[items][${budgetItemIndex}][title]" placeholder="Nama pengeluaran..." required
            class="w-full bg-white border border-slate-200 rounded-lg text-[11.5px] px-3 py-2 text-slate-700 outline-none focus:ring-2 focus:ring-slate-100 focus:border-slate-400 transition-all" />
        </div>
        <div class="col-span-5 pr-7">
          <input type="text" placeholder="Rp 0" oninput="formatCurrency(this)"
            class="budget-amount-display w-full bg-white border border-slate-200 rounded-lg text-[11.5px] px-3 py-2 text-slate-700 text-right outline-none focus:ring-2 focus:ring-slate-100 focus:border-slate-400 transition-all" />
          <input type="hidden" name="budget[items][${budgetItemIndex}][allocatedAmount]" class="budget-amount-raw" value="0" />
        </div>
      </div>
      <div>
        <input type="text" name="budget[items][${budgetItemIndex}][description]" placeholder="Keterangan opsional..."
          class="w-full bg-white border border-slate-200 rounded-lg text-[11px] px-3 py-1.5 text-slate-500 outline-none focus:ring-2 focus:ring-slate-100 focus:border-slate-400 transition-all" />
      </div>
      <button type="button" onclick="removeBudgetItem(this)" class="delete-budget-btn absolute top-3 right-3 text-slate-400 hover:text-red-500 transition-colors">
        <svg class="w-4 h-4 stroke-[1.8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-16v1a3 3 0 003 3h10M9 7h6" />
        </svg>
      </button>
    `;
    
    container.appendChild(newItem);
    budgetItemIndex++;
    toggleDeleteButtons();
  });

  // 4. FUNGSI HAPUS BARIS
  function removeBudgetItem(button) {
    const itemRow = button.closest('.budget-item');
    itemRow.remove();
    reIndexItems();
    calculateTotalBudget();
    toggleDeleteButtons();
  }

  // 5. HIDDEN/SHOW TOMBOL HAPUS
  function toggleDeleteButtons() {
    const rows = document.querySelectorAll('.budget-item');
    rows.forEach(row => {
      const btn = row.querySelector('.delete-budget-btn');
      if (rows.length === 1) {
        btn.classList.add('hidden');
      } else {
        btn.classList.remove('hidden');
      }
    });
  }

  // 6. RE-INDEXING NAMESPACE INPUT SETELAH PROSES HAPUS ROW
  function reIndexItems() {
    const rows = document.querySelectorAll('.budget-item');
    budgetItemIndex = 0;
    rows.forEach((row, idx) => {
      row.querySelector('input[name*="[title]"]').setAttribute('name', `budget[items][${idx}][title]`);
      row.querySelector('input[class*="budget-amount-raw"]').setAttribute('name', `budget[items][${idx}][allocatedAmount]`);
      row.querySelector('input[name*="[description]"]').setAttribute('name', `budget[items][${idx}][description]`);
      budgetItemIndex = idx + 1;
    });
  }
      // ADD TIMELINE
      function addTimeline() {

        const box = document.getElementById("timelineBox");

        const div = document.createElement("div");

        div.className = "flex gap-2 timeline-item";

        div.innerHTML = `
      <input
        type="text"
        name="timeline[${timelineIndex}][address]"
        placeholder="Alamat berikutnya"
        required
        class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all"
      />

      <input
        type="hidden"
        name="timeline[${timelineIndex}][order]"
        value="${timelineIndex + 1}"
      />

      <button
        type="button"
        onclick="removeTimeline(this)"
        class="px-3 rounded-xl bg-red-50 text-red-500 hover:bg-red-100 transition"
      >
        ✕
      </button>
    `;

        box.appendChild(div);

        timelineIndex++;
      }

      // REMOVE
      function removeTimeline(btn) {
        btn.parentElement.remove();
      }
    </script>
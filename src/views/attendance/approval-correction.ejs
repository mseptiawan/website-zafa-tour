<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-6">

  <div class="max-w-7xl mx-auto">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-xl font-medium text-slate-800">
        Approval Koreksi Absensi
      </h1>

      <p class="text-sm text-slate-500 mt-1">
        Kelola pengajuan koreksi absensi karyawan
      </p>
    </div>

    <!-- TABLE -->
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">

      <div class="overflow-x-auto">

        <table class="w-full text-sm">

          <!-- HEADER -->
          <thead class="bg-slate-50 border-b border-slate-200">

            <tr class="text-xs text-slate-500 uppercase tracking-wide">

              <th class="px-5 py-4 text-left">Karyawan</th>
              <th class="px-5 py-4 text-left">Tanggal</th>
              <th class="px-5 py-4 text-left">Alasan</th>
              <th class="px-5 py-4 text-left">Jam</th>
              <th class="px-5 py-4 text-left">Penjelasan</th>
              <th class="px-5 py-4 text-left">Status</th>
              <th class="px-5 py-4 text-left">Aksi</th>

            </tr>

          </thead>

          <!-- BODY -->
          <tbody class="divide-y divide-slate-100">

            <% data.forEach(d => { %>

              <tr class="hover:bg-slate-50 transition">

                <!-- KARYAWAN -->
                <td class="px-5 py-4 font-medium text-slate-700">
                  <%= d.userId?.username %>
                </td>

                <!-- TANGGAL -->
                <td class="px-5 py-4 text-slate-600">

                  <% if (d.startDate) { %>

                    <%= new Date(d.startDate).toLocaleDateString('id-ID', {
                      day: '2-digit',
                      month: 'short',
                      year: 'numeric'
                    }) %>

                  <% } else { %>

                    <span class="text-slate-400">-</span>

                  <% } %>

                </td>

                <!-- ALASAN (SELECT VALUE) -->
                <td class="px-5 py-4">

                  <span class="text-xs px-2 py-1 rounded-full bg-slate-100 text-slate-600 border border-slate-200">
                    <%= d.reasonType %>
                  </span>

                </td>

                <!-- JAM -->
                <td class="px-5 py-4 text-slate-600">

                  <div class="text-xs">
                    <div>
                      <span class="text-slate-400">Mulai:</span>
                      <%= d.startTime %>
                    </div>

                    <div>
                      <span class="text-slate-400">Selesai:</span>
                      <%= d.endTime %>
                    </div>
                  </div>

                </td>

                <!-- PENJELASAN -->
                <td class="px-5 py-4 text-slate-600 max-w-xs">

                  <p class="line-clamp-2">
                    <%= d.reason || '-' %>
                  </p>

                </td>

                <!-- STATUS -->
                <td class="px-5 py-4">

                  <div class="flex items-center gap-2">

                    <% if (d.status === "APPROVED") { %>

                      <i data-lucide="check-circle" class="w-4 h-4 text-emerald-500"></i>
                      <span class="text-sm text-slate-600">Approved</span>

                    <% } else if (d.status === "REJECTED") { %>

                      <i data-lucide="x-circle" class="w-4 h-4 text-rose-500"></i>
                      <span class="text-sm text-slate-600">Rejected</span>

                    <% } else { %>

                      <i data-lucide="clock" class="w-4 h-4 text-amber-500"></i>
                      <span class="text-sm text-slate-600">Pending</span>

                    <% } %>

                  </div>

                </td>

                <!-- AKSI -->
                <td class="px-5 py-4">

                  <% if (d.status === "PENDING") { %>

                    <div class="flex gap-2">

                      <!-- APPROVE -->
                      <form action="/attendance/correction/<%= d._id %>/APPROVED" method="POST">
                        <button class="p-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700">
                          ✔
                        </button>
                      </form>

                      <!-- REJECT -->
                      <form action="/attendance/correction/<%= d._id %>/REJECTED" method="POST">
                        <button class="p-2 bg-white border border-rose-200 text-rose-500 rounded-lg hover:bg-rose-50">
                          ✕
                        </button>
                      </form>

                    </div>

                  <% } else { %>

                    <span class="text-xs text-slate-400">Selesai</span>

                  <% } %>

                </td>

              </tr>

            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>
<%- layout('layouts/main', { title }) %>

<div >
  <div class="mx-auto max-w-none space-y-6">

    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 border-b border-slate-200 pb-5">
      <div class="min-w-0">
        <h1 class="text-xl font-bold tracking-tight text-slate-900">Rekapitulasi Penggajian Karyawan</h1>
        <p class="text-xs text-slate-500 mt-1">Pantauan akumulasi pengeluaran bruto, beban potongan fiskal, dan total gaji bersih tim.</p>
      </div>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full lg:w-auto shrink-0">
        <form method="GET" action="/report/payroll" class="flex flex-1 sm:flex-none items-center gap-2 bg-white border border-slate-200 rounded-lg p-1 h-9 shadow-xs">
          <div class="flex items-center gap-1 px-2 text-xs font-medium text-slate-600">
            <span class="text-slate-400">Periode:</span>
            <input type="month" name="periodMonth" value="<%= filters.periodMonth %>" class="bg-transparent outline-none cursor-pointer font-semibold text-slate-700">
          </div>
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium h-7 px-3 rounded-md transition-colors cursor-pointer">
            Saring
          </button>
        </form>

        <a href="/report/payroll/download-pdf?periodMonth=<%= filters.periodMonth %>" 
           class="bg-white hover:bg-slate-50 text-slate-700 text-xs font-medium h-9 px-4 rounded-lg border border-slate-200 shadow-xs flex items-center justify-center gap-2 transition-colors no-underline">
          Cetak Dokumen (PDF)
        </a>
      </div>
    </div>

    <%
      const statItems = [
        { label: 'Akumulasi Gaji Bruto', value: new Intl.NumberFormat('id-ID').format(analytics.totalEarnings) },
        { label: 'Total Retensi & Potongan', value: new Intl.NumberFormat('id-ID').format(analytics.totalDeductions) },
        { label: 'Beban Bersih (Take Home Pay)', value: new Intl.NumberFormat('id-ID').format(analytics.totalNet) }
      ];
    %>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 select-none">
      <% statItems.forEach((item, index) => { %>
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-2xs">
          <span class="text-xs font-medium text-slate-500 block"><%= item.label %></span>
          <div class="mt-2 flex items-baseline gap-1">
            <span class="text-xs font-medium text-slate-400">Rp</span>
            <span class="text-3xl font-semibold tracking-tight text-slate-900 tabular-nums"><%= item.value %></span>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-2xs">
      <div class="p-6 border-b border-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Matriks Penggajian Pegawai</h3>
        <p class="text-xs text-slate-400 mt-0.5">Daftar komparatif rincian pendapatan kotor, potongan wajib, dan upah bersih harian karyawan.</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-xs whitespace-nowrap">
          <thead>
            <tr class="bg-slate-50 text-slate-500 font-semibold border-b border-slate-200">
              <th class="p-4 pl-6">Nama Karyawan</th>
              <th class="p-4 text-center">Status Berkas</th>
              <th class="p-4 text-right">Pendapatan Bruto</th>
              <th class="p-4 text-right">Total Potongan</th>
              <th class="p-4 text-right pr-6">Net Take Home Pay</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 text-slate-700 font-medium">
            <% if (listPayroll && listPayroll.length > 0) { %>
              <% listPayroll.forEach((p) => { 
                   let empName = p.employeeId && p.employeeId.fullName ? p.employeeId.fullName : "Anonim";
              %>
                <tr class="hover:bg-slate-50/50 transition-colors">
                  <td class="p-4 pl-6 font-semibold text-slate-900"><%= empName %></td>
                  <td class="p-4 text-center">
                    <span class="inline-flex px-2 py-0.5 rounded text-[10px] font-bold tracking-wide uppercase <%= p.status === 'PAID' ? 'bg-green-50 text-green-700 border border-green-100' : 'bg-slate-100 text-slate-600' %>">
                      <%= p.status %>
                    </span>
                  </td>
                  <td class="p-4 text-right tabular-nums text-slate-600">Rp <%= new Intl.NumberFormat('id-ID').format(p.totalEarnings) %></td>
                  <td class="p-4 text-right tabular-nums text-slate-600">Rp <%= new Intl.NumberFormat('id-ID').format(p.totalDeductions) %></td>
                  <td class="p-4 text-right pr-6 tabular-nums font-mono font-semibold text-slate-900">
                    Rp <%= new Intl.NumberFormat('id-ID').format(p.netTakeHomePay) %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="p-8 text-center text-slate-400 font-normal">Belum ada data slip gaji yang di-generate (Tutup Buku) untuk periode ini.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
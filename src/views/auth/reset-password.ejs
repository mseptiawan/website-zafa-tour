<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password | Zafa Tour</title>
  <link rel="stylesheet" href="/css/output.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center p-4">

  <div class="w-full max-w-sm bg-white p-8 rounded-2xl shadow-sm border border-slate-200">

    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-slate-900">Reset Password</h1>
      <p class="text-sm text-slate-500 mt-2">Masukkan password baru Anda</p>
    </div>

    <% if (typeof errors !== 'undefined' && Object.keys(errors).length > 0) { %>
      <div class="w-full mb-6 p-4 bg-red-50 border border-red-100 rounded-xl flex flex-col gap-1.5 text-red-600 font-medium text-sm">
        <% Object.values(errors).forEach(err => { %>
          <div class="flex items-center gap-2">
            <i data-lucide="shield-alert" class="w-4 h-4 shrink-0 text-red-500"></i>
            <span class="tracking-tight"><%= err %></span>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="w-full mb-6 p-4 bg-red-50 border border-red-100 rounded-xl flex flex-col gap-1.5 text-red-600 font-medium text-sm">
        <% error.forEach(msg => { %>
          <div class="flex items-center gap-2">
            <i data-lucide="shield-alert" class="w-4 h-4 shrink-0 text-red-500"></i>
            <span class="tracking-tight"><%= msg %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
    <form action="/reset-password" method="POST" class="space-y-4">
      <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>" />

      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Password Baru</label>
        <input
          type="password"
          name="password"
          placeholder="••••••••"
          class="w-full border border-slate-300 p-3 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all outline-none text-sm"
          required
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Konfirmasi Password</label>
        <input
          type="password"
          name="confirmPassword"
          placeholder="••••••••"
          class="w-full border border-slate-300 p-3 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all outline-none text-sm"
          required
        />
      </div>

      <button
        type="submit"
        class="w-full bg-blue-600 text-white py-3 rounded-xl font-semibold hover:bg-blue-700 active:scale-[0.98] transition-all shadow-md shadow-blue-200 cursor-pointer text-sm"
      >
        Simpan Password
      </button>
    </form>

    <div class="text-center mt-6 text-sm">
      <a href="/login" class="text-slate-600 hover:text-blue-600 transition font-medium">
        &larr; Kembali
      </a>
    </div>

  </div>

  <script>
    // Inisialisasi ikon Lucide jika dibutuhkan di dalam komponen error
    lucide.createIcons({
      attrs: {
        'stroke-width': 2.2
      }
    });
  </script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zafa Tour</title>

  <link rel="stylesheet" href="/css/output.css" />
  <!-- Tambahkan CDN Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body {
      margin: 0;
      font-family: system-ui, sans-serif;
      background: #f1f5f9;
      height: 100vh;
      display: flex;
    }
    .submit{
      background: #1e2d41;
    }
    .wrapper {
      width: 950px;
      margin: auto;
      display: flex;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(128, 119, 119, 0.08);
    }

    /* LEFT SIDE */
    .left {
      flex: 1;
      background: #dfdd88;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 30px;
    }

    .left img {
      width: 80%;
      max-width: 350px;
      object-fit: contain;
    }

    /* RIGHT SIDE */
    .right {
      flex: 1;
      padding: 50px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .title {
      text-align: center;
      margin-bottom: 25px;
    }

    .title h1 {
      margin: 0;
      font-size: 22px;
      color: #0f172a;
    }

    .title p {
      margin: 4px 0 0;
      font-size: 12px;
      color: #64748b;
    }

    input {
      padding: 11px 12px;
      border: 1px solid #cbd5e1;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      width: 100%; /* Pastikan input memenuhi container */
      box-sizing: border-box;
    }

    input:focus {
      border-color: #2563eb;
    }

    /* Style Tambahan untuk Password Wrapper */
    .password-container {
      position: relative;
      width: 100%;
    }

    .toggle-password {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #64748b;
      display: flex;
      align-items: center;
    }

    button {
      padding: 11px;
      border-radius: 8px;
      border: 1px solid #2563eb;
      background: #2563eb;
      color: #fff;
      font-weight: 500;
      cursor: pointer;
      margin-top: 10px;
    }

    button:hover {
      background: #1d4ed8;
    }

    .options {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      margin-top: 10px;
    }

    .options label {
      display: flex;
      align-items: center;
      gap: 6px;
      color: #475569;
    }

    .options input[type="checkbox"] {
        width: auto;
    }

    a {
      color: #2563eb;
      text-decoration: none;
    }

    .error {
      color: #d11414;
      padding: 10px;
      border-radius: 8px;
      font-size: 12px;
      margin-bottom: 12px;
    }

    /* MOBILE */
    @media (max-width: 768px) {
      .wrapper {
        flex-direction: column;
        width: 90%;
      }

      .left {
        padding: 20px;
      }

      .left img {
        max-width: 200px;
      }

      .right {
        padding: 25px;
      }
    }
  </style>
</head>

<body>

  <div class="wrapper">

    <!-- LEFT IMAGE -->
    <div class="left">
      <img src="/images/zafa.png" alt="Zafa Tour" class=""/>
    </div>

    <!-- RIGHT FORM -->
    <div class="right">

      <div class="title font-medium">
        <h1>Zafa Tour</h1>
        <p>Sistem Informasi Kepegawaian Terintegrasi</p>
      </div>

      <!-- ERROR MESSAGE -->
      <% if (query?.error) { %>
        <div class="error">
          Login gagal, silakan cek username/email atau password
        </div>
      <% } %>

      <form action="/login" method="POST" style="display:flex; flex-direction:column; gap:12px;">

        <input
          type="text"
          name="identifier"
          placeholder="Username atau Email"
        />

        <!-- PASSWORD FIELD DENGAN TOGGLE -->
        <div class="password-container">
          <input
            id="passwordInput"
            type="password"
            name="password"
            placeholder="Password"
          />
          <span class="toggle-password" id="toggleIcon">
            <i data-lucide="eye"></i>
          </span>
        </div>

        <div class="options">

          <label>
            <input type="checkbox" name="remember" />
            Ingat saya ( 3 Hari )
          </label>

          <a href="/forgot-password">Lupa password?</a>

        </div>

        <button type="submit">
          Login
        </button>

      </form>

    </div>

  </div>

  <script>
    // Inisialisasi Lucide Icons
  lucide.createIcons({
    attrs: {
        width: 18,
        height: 18,
        'stroke-width': 2 // Ketebalan garis icon
    }
});

    const passwordInput = document.getElementById('passwordInput');
    const toggleIcon = document.getElementById('toggleIcon');

    toggleIcon.addEventListener('click', () => {
      // Toggle tipe input
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';

      // Ganti icon (Eye ke EyeOff atau sebaliknya)
      toggleIcon.innerHTML = isPassword 
        ? '<i data-lucide="eye-off"></i>' 
        : '<i data-lucide="eye"></i>';
      
      // Render ulang icon baru
      lucide.createIcons();
    });
  </script>

</body>
</html>
<%- layout('layouts/main', { title: title }) %>

<!-- 
  Kunci Layout: 
  - ml-72 untuk konsistensi sidebar
  - max-w-5xl karena tabel biasanya butuh ruang lebih luas
-->
<div class="ml-72 min-h-screen bg-slate-50 p-8">
  <div class="max-w-5xl mx-auto">

    <!-- HEADER SECTION -->
    <div class="mb-8 flex justify-between items-end">
      <div>
        <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">
          Riwayat Absensi
        </h1>
        <p class="text-slate-500 mt-2 font-medium">
          Pantau catatan kehadiran dan ketepatan waktu Anda.
        </p>
      </div>
      <div class="bg-white px-4 py-2 rounded-2xl border border-slate-200 shadow-sm text-sm font-semibold text-slate-600">
        Total Log: <%= data.length %>
      </div>
    </div>

    <!-- TABLE CARD -->
    <div class="bg-white/80 backdrop-blur-xl rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-white overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
           <tr class="bg-slate-100 border border-slate-200 rounded-xl overflow-hidden">
  
  <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-500">
    Tanggal
  </th>

  <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-500">
    Check In
  </th>

  <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-500">
    Check Out
  </th>

  <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-500">
    Status
  </th>

  <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-500 text-center">
    Verifikasi
  </th>

  <th class="p-4 text-xs font-bold uppercase tracking-widest text-slate-500">
    Aksi
  </th>

</tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            <% if (data.length > 0) { %>
              <% data.forEach(d => { %>
                <tr class="hover:bg-slate-50/50 transition-colors group">
                  
                  <!-- TANGGAL -->
                  <td class="p-6">
                    <div class="flex flex-col">
                      <span class="font-bold text-slate-700">
                        <%= d.createdAt.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                      </span>
                      <span class="text-xs text-slate-400 font-medium">Hari ini</span>
                    </div>
                  </td>

                  <!-- CHECK IN -->
                  <td class="p-6">
                    <div class="flex items-center gap-2 text-slate-600 font-semibold text-sm">
                      <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                      <%= d.checkIn ? d.checkIn.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : "--:--" %>
                    </div>
                  </td>

                  <!-- CHECK OUT -->
                  <td class="p-6">
                    <div class="flex items-center gap-2 text-slate-600 font-semibold text-sm">
                      <div class="w-1.5 h-1.5 rounded-full bg-rose-500"></div>
                      <%= d.checkOut ? d.checkOut.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : "--:--" %>
                    </div>
                  </td>

                  <!-- STATUS -->
                  <td class="p-6">
                    <% if (d.status === 'TELAT') { %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-rose-50 text-rose-600 border border-rose-100">
                        <%= d.status %>
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-600 border border-emerald-100">
                        <%= d.status %>
                      </span>
                    <% } %>
                  </td>

                  <!-- FOTO / VERIFIKASI -->
                  <td class="p-6">
                    <div class="flex justify-center">
                      <% if (d.photo) { %>
                        <div class="relative group/img">
                          <img 
                            src="<%= d.photo %>" 
                            class="w-12 h-12 rounded-xl object-cover border-2 border-white shadow-md group-hover/img:scale-110 transition-transform duration-300"
                          >
                          <div class="absolute inset-0 bg-indigo-600/20 opacity-0 group-hover/img:opacity-100 rounded-xl transition-opacity flex items-center justify-center">
                            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-width="2" />
                              <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke-width="2" />
                            </svg>
                          </div>
                        </div>
                      <% } else { %>
                        <span class="text-slate-300 italic text-xs">No Image</span>
                      <% } %>
                    </div>
                      
                  </td>
                    <td>
                        <a href="/attendance/detail/<%= d._id %>" 
   class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-600 bg-indigo-50 rounded-lg hover:bg-indigo-100 hover:text-indigo-700 transition">
   Detail
   <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
       d="M9 5l7 7-7 7"/>
   </svg>
</a>
                    </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="p-20 text-center text-slate-400 font-medium italic">
                  Belum ada data absensi untuk ditampilkan.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- FOOTER INFO -->
    <p class="text-center text-slate-400 text-xs mt-8">
      Data riwayat di atas diperbarui secara real-time setiap kali Anda melakukan Check In/Out.
    </p>
  </div>
</div>
<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-[#FCFCFD] p-4 md:p-8 antialiased selection:bg-blue-50 selection:text-blue-600">
  <div class="max-w-6xl mx-auto mt-16 md:mt-0">

  <%- include('../partials/page-header', { 
    section: 'Area Kerja', 
    module: 'Informasi', 
    title: 'Pengumuman', 
    description: 'Pantau seluruh informasi internal, kebijakan manajemen, dan rilis berita terbaru perusahaan.' 
}) %>

    <% if(announcements.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

        <% announcements.forEach(a => { %>
          <a href="/announcement/<%= a._id %>"
            class="group relative flex flex-col justify-between bg-white border border-slate-200/60 rounded-2xl p-6 transition-all duration-300 hover:border-blue-500/30 hover:bg-white shadow-sm hover:shadow-xl hover:shadow-blue-900/[0.03] min-h-[240px]">

            <div>
              <div class="flex items-center gap-2 mb-4 flex-wrap">
                <% if(a.isPinned) { %>
                  <span class="inline-flex items-center gap-1 bg-amber-50 text-amber-700 border border-amber-200/40 px-2.5 py-1 rounded-lg text-[10px] font-bold tracking-wider uppercase">
                    📌 Pinned
                  </span>
                <% } %>

                <% if(a.category === "OFFICIAL") { %>
                  <span class="inline-flex items-center bg-blue-50 text-blue-700 border border-blue-200/40 px-2.5 py-1 rounded-lg text-[10px] font-bold tracking-wider uppercase">
                    Official
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center bg-slate-50 text-slate-600 border border-slate-200/50 px-2.5 py-1 rounded-lg text-[10px] font-bold tracking-wider uppercase">
                    General
                  </span>
                <% } %>
              </div>

              <h2 class="text-[16px] font-bold text-slate-900 leading-snug break-words mb-2 group-hover:text-blue-600 transition-colors line-clamp-2 tracking-tight">
                <%= a.title %>
              </h2>

              <p class="text-[13px] text-slate-500 leading-relaxed break-words line-clamp-3 mb-6">
                <%= a.content %>
              </p>
            </div>

            <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-8 h-8 rounded-xl bg-slate-50 border border-slate-200/70 flex-shrink-0 flex items-center justify-center text-[12px] font-bold text-slate-700 uppercase group-hover:bg-blue-50 group-hover:border-blue-200/50 group-hover:text-blue-600 transition-colors">
                  <%= a.createdBy?.employeeData?.fullName ? a.createdBy?.employeeData.fullName.charAt(0) : '?' %>
                </div>

                <div class="flex flex-col min-w-0">
                  <span class="text-[12px] font-bold text-slate-800 truncate">
                    <%= a.createdBy?.employeeData?.fullName || 'Tidak Diketahui' %>
                  </span>
                  <span class="text-[11px] text-slate-400 font-medium mt-0.5">
                    <%= new Date(a.createdAt).toLocaleDateString("id-ID", { day: "2-digit", month: "short", year: "numeric" }) %>
                  </span>
                </div>
              </div>

              <div class="w-7 h-7 rounded-lg bg-slate-50 flex items-center justify-center border border-transparent group-hover:bg-blue-50 group-hover:border-blue-100 transition-all duration-200">
                <svg class="w-3.5 h-3.5 text-slate-400 group-hover:text-blue-600 transform group-hover:translate-x-0.5 transition-all duration-200 stroke-[2.5]"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>

          </a>
        <% }) %>

      </div>

    <% } else { %>
      <div class="bg-white border border-slate-200/60 rounded-2xl py-20 text-center shadow-sm">
        <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-slate-400 border border-slate-100">
          <svg class="w-6 h-6 stroke-[1.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-slate-800">Belum Ada Pengumuman</h3>
        <p class="text-slate-400 text-[12px] mt-1 max-w-xs mx-auto">Seluruh rilis informasi internal penting dari manajemen akan tampil di sini.</p>
      </div>
    <% } %>

    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between mt-10 px-6 py-4 bg-white border border-slate-200/60 rounded-2xl shadow-sm text-sm">
        <div class="text-slate-500 font-medium">
          Halaman <span class="font-bold text-slate-900"><%= pagination.page %></span> dari <span class="font-bold text-slate-900"><%= pagination.totalPages %></span>
        </div>

        <div class="flex items-center gap-2">
          <a href="?page=<%= pagination.page - 1 %>"
            class="px-4 py-2.5 rounded-xl border text-[12px] font-bold transition-all flex items-center gap-1.5 <%= pagination.hasPrev ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 active:scale-[0.98]' : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
            <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Prev
          </a>

          <a href="?page=<%= pagination.page + 1 %>"
            class="px-4 py-2.5 rounded-xl border text-[12px] font-bold transition-all flex items-center gap-1.5 <%= pagination.hasNext ? 'text-slate-700 bg-white border-slate-200 hover:bg-slate-50 active:scale-[0.98]' : 'text-slate-300 border-slate-100 bg-slate-50/50 pointer-events-none' %>">
            Next
            <svg class="w-3.5 h-3.5 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    <% } %>

  </div>
</div>
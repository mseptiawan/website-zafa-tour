<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In | Zafa Tour</title>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <link rel="stylesheet" href="/css/output.css" />
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body class="bg-white min-h-screen flex antialiased">

  <div class="w-full flex flex-col md:flex-row">

    <!-- LEFT SIDE: LOGIN FORM PANEL -->
    <div class="w-full md:w-[45%] p-8 sm:p-12 md:p-16 flex flex-col justify-between bg-white z-10 shadow-xl md:shadow-none">
      
      <!-- Top Brand Mark -->
      <div class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-xl bg-blue-600 flex items-center justify-center shadow-sm">
          <i data-lucide="plane-takeoff" class="w-4 h-4 text-white"></i>
        </div>
        <span class="text-slate-900 font-bold tracking-tight text-base">Zafa Tour</span>
      </div>

      <!-- Center Auth Form -->
      <div class="w-full max-w-md mx-auto my-auto py-12">
        <div class="mb-8">
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Sign In</h1>
          <p class="text-sm text-slate-500 mt-2">Selamat datang kembali! Silakan masuk ke akun Anda.</p>
        </div>

        <!-- ERROR MESSAGE BANNER -->
        <% if (query?.error) { %>
          <div class="mb-6 p-3.5 bg-rose-50 border border-rose-100 rounded-xl flex items-center gap-3 text-rose-800 animate-fade-in">
            <i data-lucide="shield-alert" class="w-4 h-4 shrink-0 text-rose-500"></i>
            <span class="text-xs font-medium">Login gagal, silakan cek username/email atau password.</span>
          </div>
        <% } %>

        <!-- FORM -->
        <form action="/login" method="POST" class="space-y-4">
          
          <!-- Input Identifier -->
          <div class="space-y-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wider">Username / Email</label>
            <input
              type="text"
              name="identifier"
              required
              placeholder="Username atau Email"
              class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm transition-all bounding-box focus:outline-none focus:border-blue-600 focus:bg-white focus:ring-4 focus:ring-blue-50"
            />
          </div>

          <!-- Input Password -->
          <div class="space-y-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wider">Password</label>
            <div class="relative">
              <input
                id="passwordInput"
                type="password"
                name="password"
                required
                placeholder="Password"
                class="w-full pl-4 pr-12 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm transition-all focus:outline-none focus:border-blue-600 focus:bg-white focus:ring-4 focus:ring-blue-50"
              />
              <button 
                type="button" 
                id="toggleIcon"
                class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 transition cursor-pointer"
              >
                <i data-lucide="eye" class="w-4 h-4"></i>
              </button>
            </div>
          </div>

          <!-- Options Grid -->
          <div class="flex items-center justify-between text-xs pt-1">
            <label class="flex items-center gap-2 text-slate-500 cursor-pointer select-none">
              <input 
                type="checkbox" 
                name="remember" 
                class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500/20 accent-blue-600 cursor-pointer"
              />
              <span>Ingat saya (3 Hari)</span>
            </label>
            <a href="/forgot-password" class="font-semibold text-blue-600 hover:text-blue-700 transition">Lupa password?</a>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit"
            class="w-full pt-3 pb-3 bg-blue-600 text-white font-semibold text-sm rounded-xl hover:bg-blue-700 active:scale-[0.99] transition-all duration-150 shadow-md shadow-blue-600/10 cursor-pointer flex items-center justify-center gap-2 mt-4"
          >
            <span>Masuk</span>
          </button>

        </form>
      </div>

      <!-- Bottom Copyright -->
      <p class="text-left text-xs text-slate-400">
        &copy; 2026 Zafa Tour.
      </p>
    </div>

    <!-- RIGHT SIDE: HERO PANEL -->
    <div class="hidden md:flex flex-1 bg-slate-50 relative items-center justify-center p-12 overflow-hidden border-l border-slate-100">
      
      <!-- Soft Blue Gradient Background Lights -->
      <div class="absolute top-12 left-1/4 w-[500px] h-[500px] bg-blue-500/10 rounded-full filter blur-[100px]"></div>
      <div class="absolute bottom-12 right-1/4 w-[400px] h-[400px] bg-indigo-500/10 rounded-full filter blur-[100px]"></div>

      <!-- Main Central Card Card -->
      <div class="relative z-10 max-w-md w-full text-center flex flex-col items-center">
        <!-- Floating Logo Area -->
        <div class="mb-6 p-6 bg-white rounded-3xl shadow-lg shadow-slate-200/60 max-w-[280px] border border-slate-100/80">
          <img src="/images/zafa.png" alt="Zafa Tour" class="w-full h-auto object-contain filter drop-shadow-sm"/>
        </div>

        <div class="space-y-2">
          <h3 class="text-xl font-bold text-slate-900 tracking-tight">Sistem Informasi Kepegawaian Terintegrasi</h3>
          <p class="text-sm text-slate-500 leading-relaxed max-w-sm mx-auto">
            Akses seluruh data operasional, kehadiran, penugasan, dan pengelolaan administrasi internal dalam satu platform.
          </p>
        </div>
      </div>

    </div>

  </div>

  <!-- Lucide Icon Interactivity Logic -->
  <script>
    lucide.createIcons({
      attrs: {
        'stroke-width': 2
      }
    });

    const passwordInput = document.getElementById('passwordInput');
    const toggleIcon = document.getElementById('toggleIcon');

    toggleIcon.addEventListener('click', () => {
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';

      toggleIcon.innerHTML = isPassword 
        ? '<i data-lucide="eye-off" class="w-4 h-4"></i>' 
        : '<i data-lucide="eye" class="w-4 h-4"></i>';
      
      lucide.createIcons();
    });
  </script>

</body>
</html>
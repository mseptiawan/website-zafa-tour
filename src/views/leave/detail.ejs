<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50/60 p-10">
  <div class="max-w-4xl mx-auto">

    <!-- HEADER -->
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-bold text-slate-800 tracking-tight">
        Detail Pengajuan Cuti
      </h1>
      <p class="text-slate-500 mt-2 text-sm font-medium">
        Informasi lengkap pengajuan cuti karyawan
      </p>
    </div>

    <!-- CARD -->
    <div class="relative overflow-hidden bg-white rounded-3xl border border-slate-100 shadow-[0_15px_40px_rgba(0,0,0,0.06)] p-8">

      <!-- dekorasi -->
      <div class="absolute -top-12 -right-12 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-12 -left-12 w-40 h-40 bg-blue-500/10 rounded-full blur-3xl"></div>

      <!-- GRID -->
      <div class="relative grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- JENIS -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            Jenis Cuti
          </p>
          <h2 class="text-lg font-bold text-slate-800 mt-1">
            <%= leave.type %>
          </h2>
        </div>

        <!-- STATUS -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            Status
          </p>

          <div class="mt-2">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border
              <%= leave.status === 'Approved'
                ? 'bg-emerald-50 text-emerald-700 border-emerald-200'
                : leave.status === 'Rejected'
                ? 'bg-rose-50 text-rose-700 border-rose-200'
                : 'bg-amber-50 text-amber-700 border-amber-200' %>">
              <%= leave.status %>
            </span>
          </div>
        </div>

        <!-- TANGGAL MULAI -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            Tanggal Mulai
          </p>
          <h2 class="text-slate-700 font-semibold mt-1">
            <%= new Date(leave.startDate).toLocaleDateString("id-ID") %>
          </h2>
        </div>

        <!-- TANGGAL SELESAI -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            Tanggal Selesai
          </p>
          <h2 class="text-slate-700 font-semibold mt-1">
            <%= new Date(leave.endDate).toLocaleDateString("id-ID") %>
          </h2>
        </div>

        <!-- DURASI -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            Durasi
          </p>
          <h2 class="text-slate-800 font-bold mt-1 text-lg">
            <%= leave.totalDays %> Hari
          </h2>
        </div>

        <!-- CREATED -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            Tanggal Pengajuan
          </p>
          <h2 class="text-slate-700 font-semibold mt-1">
            <%= new Date(leave.createdAt).toLocaleDateString("id-ID") %>
          </h2>
        </div>

      </div>

      <!-- ALASAN -->
      <div class="mt-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2">
          Alasan Cuti
        </p>

        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5 text-slate-700 leading-relaxed text-sm">
          <%= leave.reason %>
        </div>
      </div>

      <!-- FILE -->
      <% if (leave.file) { %>
      <div class="mt-8">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2">
          Lampiran
        </p>

        <div class="flex items-center justify-between bg-slate-50 border border-slate-100 rounded-2xl p-5">

          <div>
            <p class="font-semibold text-slate-700 text-sm">
              File Lampiran
            </p>
            <p class="text-xs text-slate-400 mt-1">
              Dokumen pendukung pengajuan
            </p>
          </div>

          <a
            href="/uploads/<%= leave.file %>"
            target="_blank"
            class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-sm font-semibold transition"
          >
            Lihat
          </a>

        </div>
      </div>
      <% } %>

      <!-- BACK BUTTON -->
      <div class="mt-10">
        <a
          href="/leave/my"
          class="inline-flex items-center gap-2 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2.5 rounded-xl text-sm font-semibold transition"
        >
          ← Kembali
        </a>
      </div>

    </div>
  </div>
</div>
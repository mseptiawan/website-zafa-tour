<%- layout('layouts/main') -%>

<div class="container-fluid py-6 pl-4 pr-6 ml-72 min-h-screen relative z-10 text-slate-800 bg-slate-50/50 selection:bg-blue-500 selection:text-white">
  
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-950">Dashboard Zafa Tour</h1>
      <p class="text-sm text-slate-500 mt-0.5">
        Selamat datang kembali, <span class="font-semibold text-slate-900"><%= user.fullName %></span> 
        <span class="text-[11px] bg-slate-200/80 px-2 py-0.5 rounded-md text-slate-700 ml-1 font-semibold tracking-wide">[Peran: <%= user.role %>]</span>
      </p>
    </div>
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center gap-2 bg-blue-600 px-4 py-2 text-xs font-semibold text-white rounded-xl shadow-sm shadow-blue-600/10 uppercase tracking-wider">
        <i class="fa-solid fa-calendar-day text-sm"></i> Tahun Buku: <%= new Date().getFullYear() %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-16 gap-6">
    
    <div class="lg:col-span-7 flex flex-col gap-6">
      
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white">
      <h5 class="text-xs font-semibold tracking-wide text-slate-900 uppercase flex items-center gap-2">
  <i class="fa-solid fa-user-clock text-slate-400"></i> Presensi Hari Ini
</h5>
          <span class="text-[11px] font-semibold text-slate-400 bg-slate-50 px-2.5 py-1 rounded-lg border border-slate-100">
            <%= new Date().toLocaleDateString('id-ID', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
          </span>
        </div>
        <div class="p-5">
          <div class="flex flex-col sm:flex-row gap-6 items-center">
            <div class="text-center sm:text-left sm:border-r sm:border-slate-100 sm:pr-6 flex flex-col justify-center items-center sm:items-start shrink-0">
              <h2 class="text-3xl font-semibold tracking-tight text-slate-950 mb-0.5">08:00 <span class="text-sm font-medium text-slate-400">WIB</span></h2>
              <p class="text-[11px] text-slate-400 font-medium mb-4">Batas Masuk Kantor Zafa Tour</p>
              <div class="flex gap-2.5">
                <button onclick="handleClockIn()" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-xs px-3.5 py-2.5 rounded-xl shadow-sm transition-all active:scale-95">
                  <i class="fa-solid fa-sign-in-alt"></i> Clock In
                </button>
                <button class="inline-flex items-center gap-2 bg-slate-100 text-slate-400 font-semibold text-xs px-3.5 py-2.5 rounded-xl cursor-not-allowed" disabled>
                  <i class="fa-solid fa-sign-out-alt"></i> Clock Out
                </button>
              </div>
            </div>
            <div class="w-full">
              <p class="text-center text-[10px] font-semibold text-slate-400 uppercase tracking-widest mb-3">Rekap Kehadiran Bulan Ini</p>
              <div class="grid grid-cols-3 gap-2 text-center">
                <div class="bg-emerald-50/40 p-2.5 rounded-xl border border-emerald-100/30">
                  <span class="block text-lg font-semibold text-emerald-600">20</span>
                  <small class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Hadir</small>
                </div>
                <div class="bg-amber-50/40 p-2.5 rounded-xl border border-amber-100/30">
                  <span class="block text-lg font-semibold text-amber-600">1</span>
                  <small class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Telat</small>
                </div>
                <div class="bg-rose-50/40 p-2.5 rounded-xl border border-rose-100/30">
                  <span class="block text-lg font-semibold text-rose-600">0</span>
                  <small class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Alpa</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden flex flex-col">
        <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white">
          <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-list-check text-indigo-600"></i> Log Kerja & Aktivitas Harian
          </h5>
          <button onclick="triggerCarryOver()" class="text-[10px] font-semibold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 px-2.5 py-1 rounded-lg border border-indigo-100/50 transition-colors">
            <i class="fa-solid fa-arrows-spin mr-1"></i> Carry Over Kemarin
          </button>
        </div>
        <div class="p-4 space-y-2.5 max-h-[290px] overflow-y-auto">
          <div class="p-3 bg-slate-50/80 rounded-xl border border-slate-100 flex items-center justify-between gap-3">
            <div class="min-w-0">
              <span class="inline-flex text-[9px] font-extrabold px-1.5 py-0.2 rounded bg-blue-50 text-blue-600 border border-blue-100 uppercase tracking-wide">Core Task</span>
              <p class="text-xs font-semibold text-slate-900 truncate mt-1">Slicing UI Beranda Aplikasi Zafa Mobile dengan Expo</p>
            </div>
            <span class="inline-flex items-center text-[10px] font-semibold px-2 py-0.5 rounded-md bg-amber-50 text-amber-700 border border-amber-100 shrink-0 uppercase tracking-wide">
              In Progress
            </span>
          </div>

          <div class="p-3 bg-slate-50/80 rounded-xl border border-slate-100 flex items-center justify-between gap-3">
            <div class="min-w-0">
              <span class="inline-flex text-[9px] font-extrabold px-1.5 py-0.2 rounded bg-purple-50 text-purple-600 border border-purple-100 uppercase tracking-wide">Meeting</span>
              <p class="text-xs font-semibold text-slate-900 truncate mt-1">Koordinasi Validasi Flow Modul Pengajuan Cuti Staf Khusus</p>
            </div>
            <span class="inline-flex items-center text-[10px] font-semibold px-2 py-0.5 rounded-md bg-emerald-50 text-emerald-700 border border-emerald-100 shrink-0 uppercase tracking-wide">
              Completed
            </span>
          </div>
        </div>
        <div class="p-3 bg-slate-50/40 border-t border-slate-100 text-center">
          <a href="/daily-log" class="text-xs font-semibold text-slate-500 hover:text-slate-800 inline-flex items-center gap-1 transition-colors">
            Buka Lembar Kerja Harian <i class="fa-solid fa-arrow-right text-[10px]"></i>
          </a>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 bg-white">
          <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-thumbtack text-rose-500"></i> Delegasi Tugas Khusus Pimpinan
          </h5>
        </div>
        <div class="p-4 space-y-2.5">
          <div class="p-3 bg-rose-50/30 border border-rose-100/50 rounded-xl flex justify-between items-start gap-4">
            <div class="min-w-0">
              <p class="text-xs font-semibold text-slate-900 truncate">Uji Coba Radius Geofencing di Kantor Cabang Kenten</p>
              <p class="text-[11px] text-slate-400 mt-0.5 font-medium">Batas Selesai: <span class="text-slate-600 font-semibold">Besok, 17:00</span></p>
            </div>
            <a href="/assignment/my" class="text-[11px] font-semibold text-rose-600 bg-rose-50 hover:bg-rose-100 px-2.5 py-1 rounded-lg shrink-0 border border-rose-100 transition-colors">
              Lihat Detail
            </a>
          </div>
        </div>
      </div>

    </div>

    <div class="lg:col-span-5 flex flex-col gap-6">
      
      <div class="grid grid-cols-1 gap-6">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
         <div class="px-4 py-3 border-b border-slate-100 bg-white">
  <h6 class="text-xs font-semibold tracking-wide text-slate-900 uppercase flex items-center gap-2">
    <i class="fa-solid fa-wallet text-slate-400"></i> Slip Gaji Terakhir
  </h6>
</div>
          <div class="p-5 flex justify-between items-center bg-white">
            <div>
              <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide">Periode Mei 2026</p>
              <span class="text-lg font-semibold text-slate-950 tracking-widest block mt-0.5">IDR •••••••</span>
            </div>
            <a href="#" class="inline-flex items-center gap-1 text-xs font-semibold text-blue-600 bg-blue-50 hover:bg-blue-100 px-3 py-2 rounded-xl border border-blue-100/30 transition-colors">
              <i class="fa-solid fa-eye"></i> Lihat
            </a>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100 bg-white">
            <h6 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
              <i class="fa-solid fa-chart-line text-amber-500"></i> Penilaian Kinerja Karyawan (KPI)
            </h6>
          </div>
          <div class="p-5 bg-white">
            <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wide mb-2.5">Capaian Target Terakhir</p>
            <div class="w-full bg-slate-100 rounded-full h-2">
              <div class="bg-amber-500 h-2 rounded-full" style="width: 85%"></div>
            </div>
            <div class="flex justify-between items-center text-[11px] font-semibold text-slate-400 mt-2.5">
              <span>Skor Akumulasi: <span class="text-slate-900 font-semibold">85%</span></span>
              <span class="text-amber-700 bg-amber-50 px-2 py-0.5 rounded-md font-semibold text-[10px] uppercase border border-amber-100/50">Sangat Baik</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white">
          <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-plane-departure text-indigo-500"></i> Anggaran Dinas Luar Anda
          </h5>
          <a href="/trip/my" class="text-[11px] font-semibold text-slate-400 hover:text-slate-700">Semua <i class="fa-solid fa-chevron-right text-[9px] ml-0.5"></i></a>
        </div>
        <div class="p-4 space-y-3">
          <div class="p-3 bg-slate-50/80 border border-slate-100 rounded-xl flex items-center justify-between gap-2">
            <div class="min-w-0">
              <p class="text-xs font-semibold text-slate-900 truncate">Kunjungan Vendor Sistem HRIS Jakarta</p>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5">Dana Ops: <span class="text-slate-700 font-semibold">IDR 4.500.000</span></p>
            </div>
            <div class="text-end shrink-0">
              <span class="inline-flex text-[9px] font-extrabold px-2 py-0.5 rounded-md bg-emerald-50 text-emerald-700 border border-emerald-100 uppercase tracking-wide">
                READY
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 bg-white">
          <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-map-location-dot text-sky-500"></i> Laporan Kunjungan Sales
          </h5>
        </div>
        <div class="p-4 space-y-3">
          <div class="flex items-start gap-3 p-2 bg-slate-50/50 rounded-xl border border-slate-100/50">
            <div class="w-8 h-8 rounded-lg bg-sky-50 border border-sky-100 flex items-center justify-center text-sky-600 font-semibold shrink-0">
              <i class="fa-solid fa-building-user text-xs"></i>
            </div>
            <div class="min-w-0 text-xs">
              <p class="font-semibold text-slate-900 truncate">Kunjungan Instansi Dinas Pendidikan Sumsel</p>
              <p class="text-[11px] text-slate-400 font-medium mt-0.5">Oleh: <span class="text-slate-600">Tim Sales Zafa</span></p>
            </div>
          </div>
        </div>
        <div class="p-3 bg-slate-50/40 border-t border-slate-100 text-center">
          <a href="/sales/my" class="text-xs font-semibold text-slate-500 hover:text-slate-800 inline-flex items-center gap-1 transition-colors">
            Input Log Kunjungan Baru <i class="fa-solid fa-plus text-[10px]"></i>
          </a>
        </div>
      </div>

    </div>

    <div class="lg:col-span-4 flex flex-col gap-6">
      
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden flex flex-col">
  <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-white">
    <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
      <i class="fa-solid fa-stamp text-blue-600"></i> Persetujuan Dokumen
    </h5>
    <span class="inline-flex items-center text-[10px] font-semibold bg-slate-50 border border-slate-200/50 rounded-lg px-2 py-0.5 text-slate-500 uppercase tracking-wide">
      Panel Atasan
    </span>
  </div>
  
  <% if (["MANAGER", "HR", "PIMPINAN"].includes(user.role)) { %>
    <div class="flex border-b border-slate-100 bg-slate-50/50 p-1 gap-1">
      <button id="approval-tab" class="flex-1 text-center py-2 text-[11px] font-semibold rounded-lg transition-all text-blue-600 bg-white shadow-sm border border-slate-100" type="button">
        Lembur Staf (<%= pendingOvertimeApprovals.length %>)
      </button>
      <button id="delegation-tab" class="flex-1 text-center py-2 text-[11px] font-semibold rounded-lg transition-all text-slate-400 hover:text-slate-700" type="button">
        Dinas Luar (<%= pendingTripApprovals.length %>)
      </button>
    </div>
  <% } %>

  <div class="p-4">
    <div id="tab-approval" class="block max-h-56 overflow-y-auto space-y-3 pr-0.5">
      <% if (pendingOvertimeApprovals && pendingOvertimeApprovals.length > 0) { %>
        <% pendingOvertimeApprovals.forEach(ovr => { %>
          <div class="p-3 bg-slate-50/80 hover:bg-slate-50 border border-slate-100 rounded-xl flex items-start justify-between gap-2 transition-colors">
            <div class="min-w-0">
              <div class="text-xs font-semibold text-slate-900 truncate">
                <%= ovr.employeeName %>
              </div>
              <div class="text-[10px] text-slate-400 font-semibold mt-0.5">
                Tanggal: <%= ovr.date %> • <span class="text-indigo-600 font-semibold"><%= ovr.totalHours %> Jam</span>
              </div>
            </div>
            <a href="/overtime/approval" class="text-[10px] font-semibold text-white bg-blue-600 hover:bg-blue-700 px-2.5 py-1 rounded-md shadow-sm shrink-0 self-center">Periksa</a>
          </div>
        <% }) %>
      <% } else { %>
        <div class="text-center py-6 text-slate-400 flex flex-col items-center justify-center">
          <i class="fa-solid fa-circle-check text-slate-200 text-xl mb-1"></i>
          <span class="text-[11px] font-semibold">Tidak ada antrean lembur.</span>
        </div>
      <% } %>
    </div>

    <div id="tab-tab-delegation" class="hidden max-h-56 overflow-y-auto space-y-3 pr-0.5">
      <% if (pendingTripApprovals && pendingTripApprovals.length > 0) { %>
        <% pendingTripApprovals.forEach(trip => { %>
          <div class="p-3 bg-slate-50/80 hover:bg-slate-50 border border-slate-100 rounded-xl flex items-start justify-between gap-2 transition-colors">
            <div class="min-w-0">
              <div class="text-xs font-semibold text-slate-900 truncate">
                <%= trip.userId ? trip.userId.username : 'Karyawan' %>
              </div>
              <div class="text-[10px] text-slate-400 font-medium mt-0.5 truncate">
                Tujuan: <%= trip.destination || 'Dinas Luar' %>
              </div>
            </div>
            <a href="/trip/approval" class="text-[10px] font-semibold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 px-2.5 py-1 rounded-md border border-indigo-100 shrink-0 self-center">Review</a>
          </div>
        <% }) %>
      <% } else { %>
        <div class="text-center py-6 text-slate-400 flex flex-col items-center justify-center">
          <i class="fa-solid fa-plane text-slate-200 text-xl mb-1"></i>
          <span class="text-[11px] font-semibold">Tidak ada antrean dinas luar.</span>
        </div>
      <% } %>
    </div>
  </div>

  <div class="p-4 bg-slate-50/50 border-t border-slate-100 text-[11px] mt-auto flex justify-between items-center">
    <a href="/overtime/apply" class="inline-flex items-center gap-1 font-semibold text-blue-600 hover:text-blue-700">
      <i class="fa-solid fa-plus-circle"></i> Ajukan Lembur
    </a>
    <a href="/overtime/my" class="text-slate-400 hover:text-slate-600 font-semibold">Riwayat Anda <i class="fa-solid fa-chevron-right text-[8px]"></i></a>
  </div>
</div>

      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-rose-50 text-rose-500 rounded-xl flex items-center justify-center shrink-0 border border-rose-100/50">
            <i class="fa-solid fa-umbrella-beach text-xs"></i>
          </div>
          <div class="min-w-0 text-xs">
            <div class="text-slate-400 font-semibold uppercase tracking-wider text-[10px]">Libur Kalender Terdekat:</div>
            <% if (nextHoliday) { %>
              <span class="text-slate-900 font-semibold truncate block mt-0.5"><%= nextHoliday.name %></span>
              <span class="text-slate-400 font-semibold text-[11px]">
                <%= new Date(nextHoliday.date).toLocaleDateString('id-ID', { month: 'short', day: 'numeric' }) %>
              </span>
              <% if(nextHoliday.isDeductLeave) { %>
                <span class="inline-flex items-center text-[8px] font-extrabold bg-rose-50 text-rose-600 border border-rose-100 px-1 py-0.2 rounded ml-1 uppercase">Potong Kuota</span>
              <% } %>
            <% } else { %>
              <span class="text-slate-400 italic block mt-0.5 font-medium">Tidak ada agenda libur dalam waktu dekat.</span>
            <% } %>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-4 py-3.5 border-b border-slate-100 bg-white">
          <h5 class="text-xs font-semibold tracking-wider text-slate-900 uppercase flex items-center gap-2">
            <i class="fa-solid fa-bullhorn text-amber-500"></i> Pengumuman Perusahaan
          </h5>
        </div>
        <div class="p-4 space-y-3">
          <div class="group cursor-pointer">
            <span class="text-[9px] font-semibold text-slate-400">Dipasang: 22 Mei 2026</span>
            <h6 class="text-xs font-semibold text-slate-900 group-hover:text-blue-600 transition-colors mt-0.5 line-clamp-1">Kebijakan Operasional Pendampingan Jemaah Haji Kantor Zafa Tour</h6>
            <p class="text-[11px] text-slate-400 line-clamp-2 mt-1 font-medium">Diberitahukan kepada seluruh staf operasional divisi pendampingan jemaah luar daerah...</p>
          </div>
        </div>
        <div class="p-3 bg-slate-50/40 border-t border-slate-100 text-center">
          <a href="/announcement" class="text-xs font-semibold text-slate-500 hover:text-slate-800 inline-flex items-center gap-1 transition-colors">
            Lihat Semua Maklumat <i class="fa-solid fa-arrow-right text-[10px]"></i>
          </a>
        </div>
      </div>

    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Logika Switcher Tab Atasan/HR bawaan Tailwind
  const appTab = document.getElementById('approval-tab');
  const delTab = document.getElementById('delegation-tab');
  const appPanel = document.getElementById('tab-approval');
  const delPanel = document.getElementById('tab-tab-delegation');

  appTab?.addEventListener('click', function (e) {
    e.preventDefault();
    appPanel.classList.remove('hidden');
    appPanel.classList.add('block');
    delPanel.classList.remove('block');
    delPanel.classList.add('hidden');
    this.classList.add('text-blue-600', 'bg-white', 'shadow-sm', 'border', 'border-slate-100');
    this.classList.remove('text-slate-400', 'hover:text-slate-700');
    delTab.classList.remove('text-blue-600', 'bg-white', 'shadow-sm', 'border', 'border-slate-100');
    delTab.classList.add('text-slate-400', 'hover:text-slate-700');
  });

  delTab?.addEventListener('click', function (e) {
    e.preventDefault();
    delPanel.classList.remove('hidden');
    delPanel.classList.add('block');
    appPanel.classList.remove('block');
    appPanel.classList.add('hidden');
    this.classList.add('text-blue-600', 'bg-white', 'shadow-sm', 'border', 'border-slate-100');
    this.classList.remove('text-slate-400', 'hover:text-slate-700');
    appTab.classList.remove('text-blue-600', 'bg-white', 'shadow-sm', 'border', 'border-slate-100');
    appTab.classList.add('text-slate-400', 'hover:text-slate-700');
  });

  // Contoh fungsi handler interaksi AJAX bawaan controller Anda
  function handleClockIn() {
    console.log("Memicu pengambilan koordinat geofencing kantor...");
  }

  function triggerCarryOver() {
    console.log("Memicu fungsi carryOverTasks dari controller harian...");
  }
</script>
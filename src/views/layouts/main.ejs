<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />

    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    <link rel="manifest" href="/images/site.webmanifest" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  </head>

  <body
    class="bg-[#f1f5f9] text-slate-800 antialiased selection:bg-indigo-50 selection:text-indigo-600 h-screen overflow-hidden"
  >
    <div class="flex h-screen w-screen overflow-hidden">
      
      <%- include('../partials/sidebar') %>

      <main class="flex-1 px-8 py-5 flex flex-col pt-20 h-full overflow-y-auto relative">
        
     <div class="absolute top-5 right-8 z-[100]" id="notificationDropdown">
  <button
    id="notifButton"
    class="relative flex items-center justify-center w-10 h-10 bg-white hover:bg-slate-50 border border-slate-200/80 rounded-xl shadow-sm transition-all duration-200 focus:outline-none active:scale-[0.96] group"
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      class="text-slate-600 group-hover:text-slate-900 transition-colors stroke-[2.2]"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
    </svg>
    
    <span
      id="notifBadge"
      class="hidden absolute top-2 right-2 h-2 w-2 rounded-full bg-amber-500 ring-2 ring-white"
    >
      <span class="absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75 animate-ping"></span>
    </span>
  </button>

  <div
    id="notifMenu"
    class="hidden absolute right-0 mt-2.5 w-96 bg-white rounded-2xl border border-slate-200/70 shadow-xl shadow-slate-950/[0.05] z-[100] flex flex-col origin-top-right transition-all duration-200"
  >
    <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white rounded-t-2xl">
      <h1 class="text-[13px] font-bold tracking-tight text-slate-950 flex items-center gap-2">
        Notifikasi
        <span
          id="notifCountText"
          class="hidden inline-flex items-center justify-center bg-blue-600 text-white font-bold text-[10px] px-2 py-0.5 rounded-md min-w-[18px]"
        >
          0
        </span>
      </h1>
      <button
        id="markAllReadBtn"
        class="text-[11px] font-bold text-blue-600 hover:text-blue-700 transition-colors"
      >
        Tandai semua dibaca
      </button>
    </div>
    
    <div
      id="notifContainer"
      class="divide-y divide-slate-50 max-h-[380px] overflow-y-auto"
    >
      <div class="p-6 text-center text-xs font-medium text-slate-400">
        Memuat notifikasi...
      </div>
    </div>
  </div>
</div>
        <div class="flex-1"><%- body -%></div>
      </main>
    </div>

    <div
      id="custom-confirm-modal"
      class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 antialiased"
    >
      <div
        id="modal-overlay"
        class="absolute inset-0 bg-slate-950/40 backdrop-blur-[2px] transition-opacity"
      ></div>

      <div
        class="relative bg-white rounded-2xl max-w-sm w-full p-6 shadow-xl border border-slate-100 transform scale-95 opacity-0 transition-all duration-200 ease-out flex flex-col items-center text-center"
      >
        <button
          id="modal-close-x"
          class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 rounded-lg p-1 hover:bg-slate-50 transition focus:outline-none"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <div id="modal-icon-container" class="w-14 h-14 rounded-full flex items-center justify-center mb-4">
          <svg id="modal-icon-danger" class="w-7 h-7 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <svg id="modal-icon-success" class="w-7 h-7 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h3 id="modal-title" class="text-base font-bold text-slate-900 mb-2"></h3>
        <p id="modal-text" class="text-[13px] text-slate-500 leading-relaxed mb-6 px-2"></p>

        <div class="grid grid-cols-2 gap-3 w-full border-t border-slate-100 pt-4">
          <button
            id="modal-cancel-btn"
            class="w-full inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-slate-600 border border-slate-200/80 rounded-xl py-2.5 text-xs font-semibold transition active:scale-[0.98] cursor-pointer focus:outline-none"
          >
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <span id="modal-cancel-text">Batal</span>
          </button>
          <button
            id="modal-confirm-btn"
            class="w-full inline-flex items-center justify-center gap-2 text-white rounded-xl py-2.5 text-xs font-semibold transition active:scale-[0.98] cursor-pointer shadow-sm focus:outline-none"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span id="modal-confirm-text">Konfirmasi</span>
          </button>
        </div>
      </div>
    </div>

    <script src="/js/customalert-handler.js"></script>
    <script src="/js/sidebar-handler.js"></script>

    <script src="/js/notification-handler.js"></script>
  </body>
</html>
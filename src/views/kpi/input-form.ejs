<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8">
  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">
        Penilaian KPI - <%= employee.fullName %>
      </h1>
      <p class="text-slate-500 mt-2 font-medium">
        <%= employee.unitId?.name %> - <%= employee.positionId?.name %>
      </p>
    </div>

    <!-- CARD -->
    <div class="relative overflow-hidden bg-white/80 backdrop-blur-xl rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-white p-6">

      <!-- dekorasi -->
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-indigo-500/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl"></div>

      <!-- 🔥 FIX 1: Tambahkan action URL ke route POST target -->
      <form action="/kpi/input/<%= employee._id %>" method="POST" class="relative">

        <!-- 🔥 FIX 2: Tambahkan input periode dan templateId agar backend bisa baca -->
        <div class="mb-6 flex gap-4 items-center">
          <div class="w-48">
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Periode Penilaian</label>
            <input 
              type="month" 
              name="periode" 
              required 
              value="2026-05" 
              class="w-full bg-slate-50 border border-slate-200 text-slate-700 px-3 py-2 rounded-xl focus:outline-none focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition font-medium"
            >
          </div>
          <!-- Hidden input untuk melempar ID template induk -->
          <input type="hidden" name="kpiTemplateId" value="<%= kpiDetails[0]?.kpiTemplateId %>">
        </div>

        <div class="overflow-x-auto">

          <table class="w-full text-sm">

            <!-- HEADER TABLE -->
            <thead>
              <tr class="text-left text-xs uppercase tracking-widest text-slate-400 border-b border-slate-200">
                <th class="py-4 px-3">Area Kinerja</th>
                <th class="py-4 px-3">Indikator</th>
                <th class="py-4 px-3 text-center">Bobot</th>
                <th class="py-4 px-3 text-center w-32">Nilai (0-100)</th>
              </tr>
            </thead>

            <!-- BODY -->
            <tbody class="divide-y divide-slate-100">

              <% kpiDetails.forEach((kpi) => { %>

                <tr class="hover:bg-slate-50/60 transition">

                  <!-- AREA -->
                  <td class="py-4 px-3 font-semibold text-slate-700">
                    <%= kpi.areaKinerja %>
                  </td>

                  <!-- INDIKATOR -->
                  <td class="py-4 px-3 text-slate-600">
                    <%= kpi.indikator %>
                  </td>

                  <!-- BOBOT -->
                  <td class="py-4 px-3 font-medium text-slate-600 text-center">
                    <%= kpi.bobot %>%
                  </td>

                  <!-- Input NILAI -->
<td class="py-4 px-3 text-center">
  <!-- Kita gunakan nama ini agar menjadi Object { score: "..." } di req.body -->
  <input
    type="number"
    name="scores[<%= kpi._id %>][score]" 
    min="0"
    max="100"
    required
    placeholder="0-100"
    class="w-24 bg-slate-50 border border-slate-200 text-slate-700 px-3 py-2 text-center rounded-xl focus:outline-none focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition font-bold text-indigo-600"
  />
</td>

                </tr>

              <% }) %>

            </tbody>

          </table>

        </div>

        <!-- BUTTON -->
        <div class="mt-8 flex justify-end">
          <button
            type="submit"
            class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-2xl shadow-lg shadow-indigo-500/20 transition transform hover:-translate-y-1 active:scale-95 cursor-pointer"
          >
            Simpan Penilaian
          </button>
        </div>

      </form>

    </div>
  </div>
</div>
<%- layout('layouts/main', { title }) %>

  <div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">

    <div class="max-w-2xl mx-auto">

      <div class="mb-8">
        <nav class="flex items-center gap-2 mb-2 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
          <span>Workspace</span>
          <span class="text-slate-300">/</span>
          <a href="/leave/my-history" class="hover:text-slate-600 transition">Leave Request</a>
        </nav>

        <h1 class="text-2xl font-bold text-slate-900">
          <%= mode==='CREATE' ? 'Input Pengajuan Cuti' : (mode==='EDIT' ? 'Ubah Pengajuan Cuti' : 'Ajukan Ulang Cuti' )
            %>
        </h1>

        <p class="text-[14px] text-slate-500 mt-1">
          Pastikan informasi rentang tanggal dan sisa kuota Anda telah sesuai sebelum mengirimkan form.
        </p>
      </div>

      <!-- INFO BANNER: SISA KUOTA CUTI -->
      <div class="mb-6 p-5 bg-white border border-slate-200 rounded-2xl shadow-sm flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="p-2.5 bg-emerald-50 text-emerald-600 rounded-xl">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z">
              </path>
            </svg>
          </div>
          <div>
            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Hak Kuota Cuti Anda</p>
            <p class="text-[13px] font-medium text-slate-500 mt-0.5">Tahun Periode Berjalan</p>
          </div>
        </div>
        <div class="text-right">
          <span class="text-3xl font-bold text-emerald-600 tabular-nums">
            <%= leaveBalance.remaining %>
          </span>
          <span class="text-[13px] font-bold text-emerald-700/80 ml-1">Hari Tersisa</span>
        </div>
      </div>

      <!-- CARD FORM -->
      <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

        <% let formAction="/leave/apply" ; if (mode==='EDIT' ) formAction="/leave/update/" + leave._id; if
          (mode==='RESUBMIT' ) formAction="/leave/apply" ; %>

          <form action="<%= formAction %>" method="POST" enctype="multipart/form-data" class="p-8 space-y-6">

            <% if (typeof error !=='undefined' && error) { %>
              <div class="p-4 rounded-xl bg-red-50 text-red-600 text-sm border border-red-100">
                <%= error %>
              </div>
              <% } %>

                <!-- KATEGORI CUTI -->
               <div class="space-y-1.5">
  <label class="text-[13px] font-bold text-slate-700">
    Kategori / Tipe Cuti <span class="text-red-500">*</span>
  </label>

  <div class="relative w-full" id="leave-dropdown">
    <!-- Hidden Input: Jika mode EDIT, isi dengan ID dari leaveTypeId yang sudah di-populate -->
    <input type="hidden" name="leaveTypeId" id="leaveTypeId" 
      value="<%= (mode === 'EDIT' && leave.leaveTypeId) ? leave.leaveTypeId._id : '' %>" required>

    <!-- Trigger Button -->
    <button type="button" onclick="toggleLeaveDropdown()"
      class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] font-medium text-slate-800 text-left flex items-center justify-between outline-none focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 transition-all">
      
      <!-- Label Tombol: Jika mode EDIT, langsung tampilkan nama kategorinya -->
      <span id="leave-label" class="<%= (mode === 'EDIT' && leave.leaveTypeId) ? 'text-slate-800 font-semibold' : 'text-slate-600' %>">
        <%= (mode === 'EDIT' && leave.leaveTypeId) ? leave.leaveTypeId.name : '-- Silahkan pilih jenis cuti --' %>
      </span>

      <svg id="leave-arrow" class="w-4 h-4 text-slate-400 transition-transform duration-200" fill="none"
        stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>

    <!-- Dropdown Menu -->
    <div id="leave-menu"
      class="hidden absolute z-30 w-full mt-2 bg-white border border-slate-200 rounded-xl shadow-lg p-1.5 space-y-0.5">
      <% leaveTypes.forEach(type => { %>
        <button type="button" onclick="selectLeave('<%= type._id %>', '<%= type.name %>')"
          class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-700 hover:bg-slate-50 rounded-lg transition-colors">
          <%= type.name %>
        </button>
      <% }) %>
    </div>
  </div>
</div>
                <!-- RENTANG TANGGAL -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div class="space-y-1.5">
                    <label class="text-[13px] font-bold text-slate-700">
                      Tanggal Mulai <span class="text-red-500">*</span>
                    </label>
                    <input type="date" id="startDate" name="startDate" required
                      class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] text-slate-800 focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all"
                      value="<%= leave ? new Date(leave.startDate).toISOString().split('T')[0] : '' %>">

                    <!-- PESAN PERINGATAN -->
                    <p id="date-warning" class="hidden text-[11px] text-red-500 font-medium pl-1">
                      ⚠️ Pengajuan cuti harus dilakukan minimal 7 hari sebelum tanggal mulai.
                    </p>
                  </div>

                  <div class="space-y-1.5">
                    <label class="text-[13px] font-bold text-slate-700">
                      Tanggal Selesai <span class="text-red-500">*</span>
                    </label>
                    <input type="date" id="endDate" name="endDate" required
                      class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] text-slate-800 focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none transition-all"
                      value="<%= leave ? new Date(leave.endDate).toISOString().split('T')[0] : '' %>">
                  </div>
                </div>

                <!-- TOTAL HARI (READONLY) -->
                <div class="space-y-1.5">
                  <label class="text-[13px] font-bold text-slate-700">
                    Durasi Pengajuan Cuti
                  </label>
                  <div class="relative flex items-center">
                    <input type="number" id="totalDays" name="totalDays" readonly required
                      class="w-full bg-slate-100 border border-slate-200 rounded-xl pl-4 pr-24 py-3 text-[14px] font-bold text-slate-800 outline-none select-none"
                      value="<%= leave ? leave.totalDays : 0 %>" />
                    <!-- Tambahkan id="duration-label-text" di bawah ini -->
                    <span id="duration-label-text"
                      class="absolute right-4 text-[11px] font-bold uppercase tracking-widest text-slate-400">
                      Hari Kerja
                    </span>
                  </div>
                </div>

                <!-- HANDOVER USER -->
                <div class="space-y-1.5" id="handover-wrapper">
                  <div class="flex justify-between items-center">
                    <label class="text-[13px] font-bold text-slate-700">
                      Delegasi Pengganti / Handover
                    </label>
                    <span
                      class="text-[10px] font-bold bg-slate-100 text-slate-500 px-2.5 py-0.5 rounded-full uppercase tracking-wider">
                      Opsional
                    </span>
                  </div>

                  <!-- Search Input -->
                  <div class="relative w-full">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                      <svg class="w-4 h-4 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                      </svg>
                    </div>
                    <input type="text" id="handover-search" placeholder="Cari rekan handover..."
                      onkeyup="filterHandoverList()"
                      class="w-full bg-slate-50/60 border border-slate-200/60 rounded-xl pl-10 pr-4 py-3 text-[13px] font-medium text-slate-700 placeholder-slate-400 outline-none focus:bg-white focus:border-slate-300 focus:ring-4 focus:ring-slate-100/70 transition-all shadow-sm shadow-slate-100/50" />
                  </div>

                 <div id="handover-list"
    class="border border-slate-200/60 rounded-xl p-1.5 max-h-56 overflow-y-auto bg-slate-50/50 space-y-0.5 shadow-inner shadow-slate-50">

    <% 
      // Filter daftar karyawan untuk mengecualikan owner
      const excludedOwners = ['rafika fitrianti', 'gusti diansyah'];
      const filteredEmployees = employees.filter(emp => 
        emp.employeeData && 
        !excludedOwners.includes(emp.employeeData.fullName.toLowerCase())
      );

      filteredEmployees.forEach(emp => { 
    %>
        <label
          class="handover-item flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white border border-transparent hover:border-slate-200/40 cursor-pointer transition-all duration-150 group"
          data-name="<%= emp.employeeData.fullName.toLowerCase() %>">

          <!-- Radio Button -->
          <input type="radio" name="handoverUserId" value="<%= emp._id %>" <%=(leave &&
            leave.handoverUserId && leave.handoverUserId.toString()===emp._id.toString()) ? 'checked'
            : '' %>
          class="w-4 h-4 text-blue-600 border-slate-300 focus:ring-blue-100 cursor-pointer
          accent-blue-600 transition-colors" />

          <div class="flex flex-col">
            <span
              class="text-[13px] font-medium text-slate-700 group-hover:text-slate-900 transition-colors">
              <%= emp.employeeData.fullName %>
            </span>
            <span class="text-[10px] text-slate-400 font-medium">@<%= emp.username %></span>
          </div>
        </label>
    <% }) %>
  </div>

                  <p class="text-[11px] text-slate-400 pl-1 leading-normal">
                    Sistem memerlukan persetujuan dari rekan handover sebelum diteruskan ke alur otorisasi manajerial.
                  </p>
                </div>

                <!-- ALASAN CUTI -->
                <div class="space-y-1.5">
                  <label class="text-[13px] font-bold text-slate-700">
                    Alasan atau Keterangan Tambahan <span class="text-red-500">*</span>
                  </label>
                  <textarea name="reason" rows="4" placeholder="Jelaskan alasan pengajuan cuti Anda secara detail..."
                    required
                    class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-[14px] text-slate-800 focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-400 outline-none resize-none transition-all"><%= leave ? leave.reason : '' %></textarea>
                </div>

              <div class="space-y-1.5">
  <label class="block text-[13px] font-bold text-slate-700">
    Surat Keterangan / Lampiran <span id="label-required-star" class="text-red-500 hidden">*</span>
    <span id="label-optional-text" class="text-slate-400 font-normal ml-0.5">(Opsional)</span>
  </label>

  <!-- EMPTY STATE: Sembunyikan jika dalam mode EDIT dan file attachment ada -->
  <div id="dropzone-empty"
    class="<%= (mode === 'EDIT' && leave.documentPath) ? 'hidden' : 'relative' %> w-full border border-slate-200 border-dashed rounded-xl p-6 bg-white hover:bg-slate-50/50 transition flex flex-col items-center justify-center text-center">

    <input type="file" name="attachments" id="file-input" accept="image/*,.pdf,.docx"
      class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
      onchange="handleFileSelect(this)" />

    <svg class="w-5 h-5 text-slate-400 mb-2" fill="none" stroke="currentColor" stroke-width="1.5"
      viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round"
        d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
    </svg>

    <span class="text-[13px] font-medium text-slate-600">
      Pilih Berkas atau Drop File Disini
    </span>

    <span class="text-xs text-slate-400 mt-0.5">
      PNG, JPG, PDF, atau DOCX (maks 5MB)
    </span>
  </div>

  <!-- FILLED STATE: Munculkan langsung jika dalam mode EDIT dan file attachment ada -->
  <div id="dropzone-filled"
    class="<%= (mode === 'EDIT' && leave.documentPath) ? 'flex' : 'hidden' %> items-center justify-between border border-slate-200 rounded-xl px-4 py-3 bg-white shadow-sm">

    <div class="flex items-center gap-3 min-w-0 flex-1">
      <div
        class="w-10 h-10 rounded-lg overflow-hidden border border-slate-200 bg-slate-50 flex-shrink-0 flex items-center justify-center">
        
        <!-- Cek tipe file dari field leave.documentPath -->
        <% 
          let isImage = false;
          if (mode === 'EDIT' && leave.documentPath) {
            const ext = leave.documentPath.split('.').pop().toLowerCase();
            isImage = ['png', 'jpg', 'jpeg', 'webp', 'gif'].includes(ext);
          }
        %>
        
        <img id="img-preview" src="<%= (mode === 'EDIT' && leave.documentPath) ? leave.documentPath : '' %>" 
          class="w-full h-full object-cover <%= isImage ? '' : 'hidden' %>" />
        
        <svg id="file-icon-fallback" class="w-5 h-5 text-slate-400 <%= isImage ? 'hidden' : '' %>" fill="none" stroke="currentColor"
          stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
        </svg>
      </div>

      <div class="min-w-0 flex-1">
        <div id="name-preview" class="text-[13px] font-medium text-slate-700 truncate">
          <%= (mode === 'EDIT' && leave.documentPath) ? leave.documentPath.split('/').pop() : 'file_name.jpg' %>
        </div>
        <div id="size-preview" class="text-xs text-slate-400 mt-0.5">
          <%= (mode === 'EDIT' && leave.documentPath) ? 'Berkas Tersimpan' : '0 KB' %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-2 ml-4 flex-shrink-0">
      <a id="view-file-btn" href="<%= (mode === 'EDIT' && leave.documentPath) ? leave.documentPath : '#' %>" target="_blank"
        class="text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100/70 px-2.5 py-1.5 rounded-lg transition">
        View
      </a>
      <button type="button" onclick="triggerChangeFile()"
        class="text-xs font-medium text-slate-600 bg-slate-50 hover:bg-slate-100 px-2.5 py-1.5 rounded-lg transition">
        Ganti File
      </button>
    </div>
  </div>
</div>
                <!-- BUTTON PANELS -->
                <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
                  <a href="/leave/my-history"
                    class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm shadow-slate-100/50 active:scale-[0.98]">
                    Batal
                  </a>

                  <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm shadow-blue-100/50 active:scale-[0.98] cursor-pointer">
                    <%= mode==='CREATE' ? 'Kirim Pengajuan' : (mode==='EDIT' ? 'Simpan Perubahan' : 'Kirim Ulang Form' )
                      %>
                  </button>
                </div>

          </form>
      </div>

    </div>
  </div>
  <script>
    const startInput = document.getElementById('startDate');
    const endInput = document.getElementById('endDate');
    const totalInput = document.getElementById('totalDays');
    const fileInput = document.getElementById('file-input');

    let currentFileUrl = null;

    // --- 1. LOGIC PERHITUNGAN HARI ---
    function calculateDays() {
      const leaveLabel = document.getElementById('leave-label').textContent.toLowerCase();

      // Jika tipe adalah melahirkan, panggil fungsi khusus
      if (leaveLabel.includes('melahirkan')) {
        calculateMaternityDuration();
        return;
      }

      // Kalkulasi normal
      if (startInput.value && endInput.value) {
        const start = new Date(startInput.value);
        const end = new Date(endInput.value);
        const diffTime = end - start;
        totalInput.value = diffTime >= 0 ? Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1 : 0;
      }
    }

    function calculateMaternityDuration() {
      if (startInput.value) {
        const start = new Date(startInput.value);
        const end = new Date(start);
        end.setDate(start.getDate() + 90 - 1);
        endInput.value = end.toISOString().split('T')[0];
        totalInput.value = 90;
      }
    }

    startInput.addEventListener('change', calculateDays);
    endInput.addEventListener('change', calculateDays);

    // --- 2. LOGIC UI STATE (SAKIT / MELAHIRKAN / NORMAL) ---
    function handleLeaveTypeChange(typeName) {
      const name = typeName.toLowerCase();
      const starLabel = document.getElementById('label-required-star');
      const optionalLabel = document.getElementById('label-optional-text');
      const durationLabelText = document.getElementById('duration-label-text');

      // Kondisi Melahirkan
      if (name.includes('melahirkan')) {
        if (durationLabelText) durationLabelText.textContent = "Hari Kalender";
        endInput.readOnly = true;
        endInput.classList.add('bg-slate-100', 'select-none');
        endInput.classList.remove('bg-slate-50');

        calculateMaternityDuration();

        fileInput.required = false;
        if (starLabel) starLabel.classList.add('hidden');
        if (optionalLabel) optionalLabel.classList.remove('hidden');
      }
      // Kondisi Sakit
      else if (name.includes('sakit')) {
        resetMaternityFormState(durationLabelText);
        fileInput.required = true;
        if (starLabel) starLabel.classList.remove('hidden');
        if (optionalLabel) optionalLabel.classList.add('hidden');
      }
      // Kondisi Normal
      else {
        resetMaternityFormState(durationLabelText);
        fileInput.required = false;
        if (starLabel) starLabel.classList.add('hidden');
        if (optionalLabel) optionalLabel.classList.remove('hidden');
        calculateDays();
      }
    }

    function resetMaternityFormState(durationLabelText) {
      if (durationLabelText) durationLabelText.textContent = "Hari Kerja";
      endInput.readOnly = false;
      endInput.classList.remove('bg-slate-100', 'select-none');
      endInput.classList.add('bg-slate-50');
    }

    // --- 3. CUSTOM DROPDOWN INTERACTION ---
    function toggleLeaveDropdown() {
      const menu = document.getElementById('leave-menu');
      const arrow = document.getElementById('leave-arrow');
      menu.classList.toggle('hidden');
      arrow.classList.toggle('rotate-180');
    }

   function selectLeave(id, name) {
  // 1. Set ID ke hidden input untuk dikirim ke backend
  document.getElementById('leaveTypeId').value = id;
  
  // 2. Ambil element label button
  const label = document.getElementById('leave-label');
  label.textContent = name;
  
  // 3. Sesuaikan warna teks (Hapus text-slate-600 bawaan placeholder, ganti ke text-slate-800)
  label.classList.remove('text-slate-600');
  label.classList.add('text-slate-800', 'font-semibold'); // Ditambah font-semibold supaya tegas seperti saat mode EDIT

  // 4. Tutup menu dropdown
  toggleLeaveDropdown();
  
  // 5. Jalankan logic dynamic UI bawaanmu (misal memunculkan input upload jika Cuti Sakit, dll.)
  handleLeaveTypeChange(name); 
}

    // Tutup dropdown jika klik di luar
    window.addEventListener('click', function (e) {
      const dropdown = document.getElementById('leave-dropdown');
      if (dropdown && !dropdown.contains(e.target)) {
        document.getElementById('leave-menu').classList.add('hidden');
        document.getElementById('leave-arrow').classList.remove('rotate-180');
      }
    });

    // --- 4. FILE UPLOAD LOGIC ---
    function handleFileSelect(input) {
      if (input.files && input.files.length > 0) {
        const file = input.files[0];
        if (currentFileUrl) URL.revokeObjectURL(currentFileUrl);

        currentFileUrl = URL.createObjectURL(file);
        document.getElementById("view-file-btn").href = currentFileUrl;
        document.getElementById("name-preview").textContent = file.name;
        document.getElementById("size-preview").textContent = (file.size / 1024 / 1024).toFixed(2) + " MB";

        const imgPreview = document.getElementById("img-preview");
        const fileIconFallback = document.getElementById("file-icon-fallback");

        if (file.type.startsWith("image/")) {
          imgPreview.src = currentFileUrl;
          imgPreview.classList.remove("hidden");
          fileIconFallback.classList.add("hidden");
        } else {
          imgPreview.classList.add("hidden");
          fileIconFallback.classList.remove("hidden");
        }

        document.getElementById("dropzone-empty").classList.add("hidden");
        document.getElementById("dropzone-filled").classList.remove("hidden");
        if (document.getElementById('label-required-star')) document.getElementById('label-required-star').classList.add('hidden');
      }
    }

    // Auto-trigger on Load (untuk Edit mode)
    document.addEventListener("DOMContentLoaded", () => {
      const initialLabel = document.getElementById('leave-label').textContent;
      if (initialLabel && !initialLabel.includes('--')) {
        handleLeaveTypeChange(initialLabel);
      }
    });

    function filterHandoverList() {
      const searchInput = document.getElementById('handover-search').value.toLowerCase();
      const items = document.getElementsByClassName('handover-item');

      for (let item of items) {
        const name = item.getAttribute('data-name');
        if (name.includes(searchInput)) {
          item.style.display = "flex";
        } else {
          item.style.display = "none";
        }
      }
    }

    function validateDateGap() {
      const startDate = new Date(startInput.value);
      const today = new Date();

      // Set time ke 00:00:00 agar perbandingan akurat
      today.setHours(0, 0, 0, 0);

      // Hitung selisih dalam milidetik
      const diffTime = startDate - today;
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

      // Tampilkan peringatan jika kurang dari 7 hari
      const warningDiv = document.getElementById('date-warning');
      const submitBtn = document.querySelector('button[type="submit"]');

      if (diffDays < 7 && startInput.value !== "") {
        if (warningDiv) warningDiv.classList.remove('hidden');
        // Nonaktifkan tombol submit jika ingin memaksa user
        // submitBtn.disabled = true; 
      } else {
        if (warningDiv) warningDiv.classList.add('hidden');
        // submitBtn.disabled = false;
      }
    }

    // Tambahkan event listener ke startDate
    startInput.addEventListener('change', () => {
      validateDateGap();
      calculateDays();
    });
function triggerChangeFile() {
  // 1. Reset input file agar kosong kembali
  const fileInput = document.getElementById('file-input');
  fileInput.value = '';

  // 2. Tukar class visibility dropzone
  const emptyZone = document.getElementById('dropzone-empty');
  const filledZone = document.getElementById('dropzone-filled');

  emptyZone.classList.remove('hidden');
  emptyZone.classList.add('relative'); // Mengembalikan properti relative untuk input click-layer


  // 3. Kembalikan preview gambar & icon ke mode basic default
  document.getElementById('img-preview').classList.add('hidden');
  document.getElementById('file-icon-fallback').classList.remove('hidden');
}
document.addEventListener("DOMContentLoaded", () => {
  const hasAttachment = "<%= (leave && leave.documentPath) ? '1' : '0' %>";

  if (hasAttachment === "1") {
    document.getElementById("dropzone-empty").classList.add("hidden");
    document.getElementById("dropzone-filled").classList.remove("hidden");

    const fileUrl = "<%= leave ? leave.documentPath : '' %>";
    const fileName = fileUrl.split('/').pop();

    document.getElementById("view-file-btn").href = fileUrl;
    document.getElementById("name-preview").textContent = fileName;
    document.getElementById("size-preview").textContent = "Berkas Tersimpan";
  }
});
  </script>
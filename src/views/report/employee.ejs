<%- layout('layouts/main', { title }) %>

<style>
  /* =========================================================================
     DESAIN PREMIUM & KONTROL CETAK ELEGAN
     ========================================================================= */
  #report-print-zone {
    display: none;
  }

  /* Efek Glassmorphism Halus untuk UI Monitor */
  .dashboard-card {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.8);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
    transition: all 0.2s ease-in-out;
  }
  .dashboard-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
    border-color: rgba(191, 219, 254, 1); 
  }

  @media print {
    html, body, body * {
      visibility: hidden !important;
      background: transparent !important;
    }
    
    #report-print-zone, #report-print-zone * {
      visibility: visible !important;
    }
    
    #report-print-zone {
      display: block !important;
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      border: none !important;
      box-shadow: none !important;
      color: #0f172a !important;
    }

    .yellow-print-header {
      background-color: #fef08a !important; 
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color: #1e293b !important;
    }

    tr { page-break-inside: avoid; }
  }

  .formal-print-text {
    color: #1e293b;
  }
</style>

<div class="min-h-screen ml-72 bg-[#f8fafc] p-8 antialiased text-slate-800">
  <div class="mx-auto max-w-7xl space-y-8">

    <div class="mb-6 border-b border-slate-200/60 pb-5 no-print">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        
        <div class="grow">
          <%- include('../partials/page-header', { 
              section: 'Operasional Internal', 
              module: 'Informasi', 
              title: 'Daftar Data Karyawan', 
              description: 'Halaman terpusat untuk melihat profil ringkas dan sebaran biodata rekan-rekan kerja.' 
          }) %>
        </div>

        <div class="flex items-center gap-3 self-end md:self-center shrink-0">
          <button onclick="executePrintEmployeeReport()" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold h-10 px-5 rounded-xl shadow-xs transition-all flex items-center gap-2 cursor-pointer active:scale-95">
            <i class="fa-solid fa-file-pdf text-sm"></i> Cetak Data Karyawan
          </button>
        </div>

      </div>
    </div>

    <% 
      let lakiCount = 0; let perempuanCount = 0;
      employees.forEach(emp => {
        if(emp.jenis_kelamin === 'Laki-Laki') lakiCount++;
        if(emp.jenis_kelamin === 'Perempuan') perempuanCount++;
      });
      let totalEmp = employees.length || 1;
      let pctLaki = Math.round((lakiCount / totalEmp) * 100);
      let pctPerempuan = Math.round((perempuanCount / totalEmp) * 100);
    %>
    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 shadow-xs no-print space-y-4 select-none">
      <div class="flex items-center justify-between border-b border-slate-100 pb-3">
        <div>
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Komposisi Gender Karyawan</h3>
          <p class="text-[11px] text-slate-500">Perimbangan profil tim berdasarkan jenis kelamin</p>
        </div>
        <span class="text-xs bg-slate-50 text-slate-600 font-bold px-3 py-1 rounded-lg border border-slate-200/60">
          Total: <%= employees.length %> Orang
        </span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="dashboard-card p-4 rounded-xl flex items-center justify-between bg-white border border-slate-100">
          <div class="flex items-center gap-3.5 min-w-0">
            <div class="w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center shrink-0 text-blue-600">
              <i class="fa-solid fa-mars text-sm"></i>
            </div>
            <div class="min-w-0">
              <span class="text-xs font-bold text-slate-900 block mb-0.5">Laki-Laki</span>
              <span class="text-[11px] text-slate-500 block truncate font-medium"><%= lakiCount %> Rekan kerja</span>
            </div>
          </div>
          <div class="text-right shrink-0">
            <span class="inline-flex items-center justify-center bg-blue-50 text-blue-700 font-bold px-2.5 py-1 rounded-md text-xs border border-blue-100">
              <%= pctLaki %>%
            </span>
          </div>
        </div>

        <div class="dashboard-card p-4 rounded-xl flex items-center justify-between bg-white border border-slate-100">
          <div class="flex items-center gap-3.5 min-w-0">
            <div class="w-10 h-10 rounded-xl bg-blue-50/60 border border-blue-100/70 flex items-center justify-center shrink-0 text-blue-400">
              <i class="fa-solid fa-venus text-sm"></i>
            </div>
            <div class="min-w-0">
              <span class="text-xs font-bold text-slate-900 block mb-0.5">Perempuan</span>
              <span class="text-[11px] text-slate-500 block truncate font-medium"><%= perempuanCount %> Rekan kerja</span>
            </div>
          </div>
          <div class="text-right shrink-0">
            <span class="inline-flex items-center justify-center bg-blue-50 text-blue-600 font-bold px-2.5 py-1 rounded-md text-xs border border-blue-100">
              <%= pctPerempuan %>%
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white border border-slate-200/80 rounded-2xl p-6 space-y-4 no-print">
      <div class="flex items-center justify-between border-b border-slate-100 pb-3">
        <div>
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Biodata Lengkap Karyawan</h3>
          <p class="text-[11px] text-slate-500">Informasi ringkas profil dan status pernikahan setiap anggota tim</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% employees.forEach((emp) => { %>
          <div class="dashboard-card p-4 rounded-xl text-xs space-y-3">
            <div class="flex justify-between items-start border-b border-slate-100 pb-2">
              <div class="truncate pr-2">
                <span class="font-bold text-slate-900 block truncate text-sm">
                  <%= emp.fullName %>
                </span>
              </div>
              <span class="text-[10px] bg-blue-50 border border-blue-200 px-2.5 py-0.5 rounded font-bold text-blue-700 shrink-0 shadow-3xs">
                <%= emp.employeeIdNumber %>
              </span>
            </div>
            
            <div class="space-y-1.5 text-[11px]">
              <div class="flex justify-between">
                <span class="text-slate-400 font-medium">Jenis Kelamin</span>
                <span class="text-slate-800 font-semibold"><%= emp.jenis_kelamin %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-400 font-medium">Tempat Lahir</span>
                <span class="text-slate-800 font-semibold truncate max-w-[140px] text-right"><%= emp.tempat_lahir %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-400 font-medium">Status</span>
                <span class="text-slate-800 font-semibold"><%= emp.status_pernikahan %></span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div id="report-print-zone" class="bg-white p-4 space-y-6 text-black formal-print-text"></div>

  </div>
</div>

<script>
  const clientEmployeeData = <%- JSON.stringify(employees) %>;

  function executePrintEmployeeReport() {
    let employeeRowsHTML = '';
    
    clientEmployeeData.forEach((emp, idx) => {
      employeeRowsHTML += `
        <tr style="border-bottom: 0.5px solid #000;">
          <td class="p-2 border-r border-black text-center">${idx + 1}</td>
          <td class="p-2 border-r border-black text-left">${emp.employeeIdNumber}</td>
          <td class="p-2 border-r border-black text-left" style="font-weight: bold !important;">${emp.fullName}</td>
          <td class="p-2 border-r border-black text-center">${emp.jenis_kelamin}</td>
          <td class="p-2 border-r border-black text-left">${emp.tempat_lahir}</td>
          <td class="p-2 text-center">${emp.status_pernikahan}</td>
        </tr>`;
    });

    const finalPrintTemplate = `
      <div class="flex justify-between items-center border-b-2 border-black pb-4">
        <div class="text-left">
          <div class="text-xl font-bold uppercase tracking-tight">PT ZAFA MULIA MANDIRI</div>
          <div class="text-[10px] tracking-wide text-gray-600">Jalan Utama Kantor Pusat, Kota Palembang</div>
          <div class="text-[9px] text-gray-500">Sistem Aplikasi Karyawan Terintegrasi</div>
        </div>
        <div class="text-right flex flex-col items-end">
          <div class="border border-black px-4 py-1 rounded-sm bg-slate-50">
            <span class="text-[10px] font-bold tracking-widest uppercase text-slate-700">DATA UTAMA</span>
          </div>
          <span class="text-[16px] font-bold tracking-widest text-amber-500 mt-1">ZAFA TOUR</span>
        </div>
      </div>

      <div class="pt-4 flex justify-between items-end text-xs">
        <div class="space-y-0.5">
          <h2 class="text-sm font-bold uppercase tracking-wide">Laporan Data Karyawan Aktif</h2>
          <p class="text-gray-600">Status Dokumen: Keperluan Arsip Internal Kerja</p>
        </div>
        <div class="text-right text-[11px]">
          <div>Tanggal Cetak: <span class="font-bold">${new Date().toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span></div>
        </div>
      </div>

      <div class="border-2 border-black mt-4 overflow-hidden rounded-xs">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="yellow-print-header border-b-2 border-black">
              <th class="p-2 border-r border-black text-center font-bold" style="width: 5%;">NO</th>
              <th class="p-2 border-r border-black text-left font-bold" style="width: 15%;">ID KARYAWAN</th>
              <th class="p-2 border-r border-black text-left font-bold" style="width: 35%;">NAMA LENGKAP</th>
              <th class="p-2 border-r border-black text-center font-bold" style="width: 15%;">GENDER</th>
              <th class="p-2 border-r border-black text-left font-bold" style="width: 15%;">TEMPAT LAHIR</th>
              <th class="p-2 text-center font-bold" style="width: 15%;">STATUS</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-black bg-white">
            ${employeeRowsHTML}
          </tbody>
        </table>
      </div>

      <div class="pt-8 flex justify-between items-start text-xs">
        <div class="text-[9px] text-gray-400 italic max-w-sm">
          *Data yang tercantum di atas diambil langsung dari sistem administrasi personalia kantor pusat PT Zafa Mulia Mandiri secara sah.
        </div>
        <div class="text-center pr-8 space-y-16">
          <div class="space-y-1">
            <span class="block font-medium">Palembang, ${new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            <span class="block font-bold uppercase">Manajer Administrasi / HRD</span>
          </div>
          <div class="inline-block border-t-2 border-black pt-1 px-8 font-bold">
            Verifikasi Aplikasi HRIS
          </div>
        </div>
      </div>
    `;

    const printZone = document.getElementById('report-print-zone');
    if (printZone) {
      printZone.innerHTML = finalPrintTemplate;
      window.print();
    }
  }
</script>
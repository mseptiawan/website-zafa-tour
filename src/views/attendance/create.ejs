<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 min-h-screen bg-slate-50 p-8">
  <div class="max-w-xl mx-auto">
    <div class="mb-8 text-center">
      <h1 class="text-xl font-semibold text-slate-800">Absensi Kamera (Zafa Tour)</h1>
      <p class="text-sm text-slate-400 mt-1" id="camera-instruction">Pastikan posisi wajah sudah tepat</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-6">
      
      <% if (already && hasCheckedOut) { %>
        <div class="text-center py-6 space-y-4">
          <div class="w-12 h-12 mx-auto flex items-center justify-center rounded-full bg-emerald-50 text-emerald-600 font-bold">✔</div>
          <h2 class="text-sm font-medium text-slate-800">Absensi Hari Ini Selesai</h2>
          <p class="text-xs text-slate-400">Anda sudah melakukan check-in dan check-out untuk hari ini.</p>
          <a href="/attendance/history" class="inline-block px-4 py-2 text-xs font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition">Lihat Riwayat</a>
        </div>

      <% } else { %>
        <div class="space-y-5">
          <div class="relative bg-slate-100 rounded-xl overflow-hidden aspect-video border border-slate-200">
            <video id="video" autoplay playsinline muted class="w-full h-full object-cover"></video>
            <canvas id="canvas" class="hidden"></canvas>
            
            </div>
          </div>

          <% if (!already) { %>
            <button type="button" onclick="submitAttendance(event, 'checkin')" id="btn-submit"
              class="w-full py-2.5 text-sm font-semibold bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition shadow-sm">
               Check-In
            </button>
          <% } else { %>
            <button type="button" onclick="submitAttendance(event, 'checkout')" id="btn-submit"
              class="w-full py-2.5 text-sm font-semibold bg-rose-600 text-white rounded-xl hover:bg-rose-700 transition shadow-sm">
              Check-Out 
            </button>
          <% } %>
        </div>
      <% } %>

    </div>
  </div>
</div>

<script>
let stream = null, lat = null, lng = null;
const video = document.getElementById("video");
const canvas = document.getElementById("canvas");

const isAlreadyCheckIn = <%- already %>;
const isAlreadyCheckOut = <%- hasCheckedOut %>;

async function submitAttendance(event, actionType) {
  const btn = event.currentTarget;
  const originalText = btn.innerText;
  
  btn.disabled = true; 
  btn.innerText = "Tunggu sebentar...";

  try {
    const pos = await getLocation();
    lat = pos.lat; 
    lng = pos.lng;
    
    canvas.width = video.videoWidth; 
    canvas.height = video.videoHeight;
    canvas.getContext("2d").drawImage(video, 0, 0, canvas.width, canvas.height);
    const blob = await new Promise(resolve => canvas.toBlob(resolve, "image/jpeg", 0.8));
    
    const formData = new FormData();
    formData.append("photo", blob, `${actionType}_selfie.jpg`);
    formData.append("lat", lat);
    formData.append("lng", lng);
    
    if (actionType === 'checkin') {
      const noteInput = document.getElementById("note");
      formData.append("note", noteInput ? noteInput.value : "");
    }

    const targetUrl = actionType === 'checkin' ? "/attendance/checkin" : "/attendance/checkout";
    
    const res = await fetch(targetUrl, { method: "POST", body: formData });
    const data = await res.json();
    
   if (data.success) {
      openModal({
        title: "Berhasil",
        text: data.message,
        confirmText: "Lihat Riwayat",
        cancelText: "Tutup",
        type: "success"
      });
      
      document.getElementById("modal-confirm-btn").onclick = () => {
        window.location.href = "/attendance/history";
      };
    } else {
      openModal({
        title: "Gagal",
        text: data.message,
        confirmText: "Coba Lagi",
        cancelText: "Batal",
        type: "danger"
      });
      
      btn.disabled = false; 
      btn.innerText = originalText;
    }
  } catch (e) { 
    openModal({
      title: "Gagal",
      text: "Gagal memproses absensi. Pastikan GPS aktif & izin kamera diberikan.",
      confirmText: "Coba Lagi",
      cancelText: "Batal",
      type: "danger"
    });
    btn.disabled = false; 
    btn.innerText = originalText; 
  }
}

function getLocation() {
  return new Promise((resolve, reject) => {
    if (!navigator.geolocation) return reject(new Error("GPS tidak didukung browser"));
    navigator.geolocation.getCurrentPosition(
      p => resolve({ lat: p.coords.latitude, lng: p.coords.longitude }), 
      err => reject(err), 
      { enableHighAccuracy: true, timeout: 10000 }
    );
  });
}

async function startCamera() {
  if (isAlreadyCheckIn && isAlreadyCheckOut) return;
  if (!video) return; 

  try {
    stream = await navigator.mediaDevices.getUserMedia({ 
      video: { width: 640, height: 480, facingMode: "user" } 
    });
    video.srcObject = stream;
  } catch (err) { 
    document.getElementById("camera-instruction").innerText = "Gagal memuat modul kamera. Berikan izin akses kamera.";
    document.getElementById("camera-instruction").classList.add("text-rose-500");
  }
}

function stopCamera() {
  if (!stream) return;
  stream.getTracks().forEach(track => track.stop());
}

startCamera();
document.addEventListener("visibilitychange", () => document.hidden ? stopCamera() : startCamera());
</script>
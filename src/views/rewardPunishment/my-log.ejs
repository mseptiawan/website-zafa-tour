<%- layout('layouts/main', { title }) %>

<div class="min-h-screen ml-0 md:ml-72 bg-slate-50/50 py-5 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-none mx-auto mt-4 md:mt-0 space-y-6">

    <%- include('../partials/page-header', { 
        section: 'Informasi Karyawan', 
        module: 'Kepegawaian', 
        title: 'Riwayat Reward & Punishment Saya', 
        description: 'Daftar rekam jejak prestasi (reward) dan sanksi regulasi (punishment) Anda yang diterbitkan oleh manajemen.' 
    }) %>

    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[750px]">
          <thead class="bg-slate-50/70 text-slate-500 text-[11px] uppercase tracking-wider border-b border-slate-100">
            <tr>
              <th class="text-left px-6 py-4 font-bold">No. SK Resmi</th>
              <th class="text-left px-6 py-4 font-bold">Kategori & Aturan</th>
              <th class="text-left px-6 py-4 font-bold">Alasan / Penjelasan Aturan</th>
              <th class="text-right px-6 py-4 font-bold">Dampak Finansial</th>
              <th class="text-left px-6 py-4 font-bold">Tanggal Diterbitkan</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 text-[13px]">
            <% if (!logs || !logs.length) { %>
              <tr>
                <td colspan="5" class="text-center py-12 text-slate-400">
                  Belum ada catatan riwayat Reward atau Punishment untuk Anda.
                </td>
              </tr>
            <% } else { %>
              <% logs.forEach((log, index) => { %>
                <tr class="hover:bg-slate-50/40 transition-colors">
                  <td class="px-6 py-4 font-semibold text-slate-700 select-all"><%= log.skNumber %></td>
                  <td class="px-6 py-4">
                    <span class="px-2 py-0.5 rounded-md text-[10px] font-bold border <%= log.typeId?.category === 'REWARD' ? 'bg-blue-50 border-blue-200 text-blue-700' : 'bg-purple-50 border-purple-200 text-purple-700' %>">
                      <%= log.typeId?.category %>
                    </span>
                    <span class="ml-1.5 text-slate-800 font-medium"><%= log.typeId?.name %></span>
                  </td>
                  
                  <td class="px-6 py-4 max-w-[260px]">
                    <div class="flex items-center space-x-2">
                      <p class="text-slate-700 font-normal truncate">
                        <%= log.reason %>
                      </p>
                      <button 
                        type="button"
                        class="open-reason-modal text-blue-600 hover:text-blue-700 bg-blue-50 hover:bg-blue-100 p-1 rounded-md transition-colors flex-shrink-0"
                        data-sk="<%= log.skNumber %>"
                        data-category="<%= log.typeId?.category %>"
                        data-rule="<%= log.typeId?.name %>"
                        data-reason="<%= log.reason %>"
                        title="Lihat Detail Alasan"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                      </button>
                    </div>
                  </td>

                  <td class="px-6 py-4 text-right font-bold tabular-nums <%= (log.typeId?.financialImpact || 0) >= 0 ? 'text-emerald-600' : 'text-rose-600' %>">
                    <%= (log.typeId?.financialImpact || 0) >= 0 ? '+' : '' %><%= new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", minimumFractionDigits: 0 }).format(log.typeId?.financialImpact || 0) %>
                  </td>
                  <td class="px-6 py-4 text-slate-500"><%= new Date(log.dateIssued).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<div id="reasonModal" class="fixed inset-0 z-[150] hidden dynamic-modal-fade">
  <div id="modalOverlay" class="absolute inset-0 bg-slate-900/40 backdrop-blur-xs transition-opacity"></div>
  
  <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div class="bg-white rounded-2xl shadow-2xl border border-slate-200/80 max-w-md w-full overflow-hidden transform scale-95 opacity-0 transition-all duration-200 ease-out pointer-events-auto" id="modalContent">
      
      <div class="px-6 py-4 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
        <div>
          <span id="modalBadge" class="px-2 py-0.5 rounded-md text-[10px] font-bold border"></span>
          <h3 class="text-sm font-bold text-slate-800 mt-1" id="modalTitleRule">Detail Aturan</h3>
        </div>
        <button id="closeModal" class="text-slate-400 hover:text-slate-600 p-1.5 rounded-xl hover:bg-slate-200/50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div class="p-6 space-y-4">
        <div>
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-1">No. SK Resmi</label>
          <p id="modalSkNumber" class="text-sm font-semibold text-slate-700 select-all"></p>
        </div>
        <div>
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Alasan / Penjelasan Lengkap</label>
          <div class="bg-slate-50 border border-slate-100 rounded-xl p-3.5 text-[13.5px] text-slate-700 leading-relaxed max-h-60 overflow-y-auto whitespace-pre-line" id="modalReasonText">
          </div>
        </div>
      </div>
      
      <div class="px-6 py-3.5 bg-slate-50 border-t border-slate-100 flex justify-end">
        <button id="closeModalBtn" class="px-4 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl text-xs font-semibold hover:bg-slate-50 active:bg-slate-100 transition-colors shadow-xs">
          Tutup
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('reasonModal');
    const modalContent = document.getElementById('modalContent');
    const overlay = document.getElementById('modalOverlay');
    const closeBtn = document.getElementById('closeModal');
    const closeBtn2 = document.getElementById('closeModalBtn');
    
    // Elemen pengisi data di dalam modal
    const modalBadge = document.getElementById('modalBadge');
    const modalTitleRule = document.getElementById('modalTitleRule');
    const modalSkNumber = document.getElementById('modalSkNumber');
    const modalReasonText = document.getElementById('modalReasonText');

    // Fungsi Buka Modal
    function openModal(button) {
      const sk = button.getAttribute('data-sk');
      const category = button.getAttribute('data-category');
      const rule = button.getAttribute('data-rule');
      const reason = button.getAttribute('data-reason');

      // Set data ke dalam modal
      modalSkNumber.textContent = sk;
      modalTitleRule.textContent = rule;
      modalReasonText.textContent = reason;
      modalBadge.textContent = category;

      // Styling badge dinamis sesuai kategori
      if (category === 'REWARD') {
        modalBadge.className = "px-2 py-0.5 rounded-md text-[10px] font-bold border bg-blue-50 border-blue-200 text-blue-700";
      } else {
        modalBadge.className = "px-2 py-0.5 rounded-md text-[10px] font-bold border bg-purple-50 border-purple-200 text-purple-700";
      }

      // Jalankan animasi tampil
      modal.classList.remove('hidden');
      setTimeout(() => {
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      }, 10);
    }

    // Fungsi Tutup Modal
    function closeModal() {
      modalContent.classList.remove('scale-100', 'opacity-100');
      modalContent.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 150);
    }

    // Event Listener untuk semua tombol baris tabel
    document.querySelectorAll('.open-reason-modal').forEach(button => {
      button.addEventListener('click', () => openModal(button));
    });

    // Event Listener untuk tutup modal
    closeBtn.addEventListener('click', closeModal);
    closeBtn2.addEventListener('click', closeModal);
    overlay.addEventListener('click', closeModal);

    // ESC key untuk close modal
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  });
</script>
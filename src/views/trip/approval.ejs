<%- layout('layouts/main', { title }) %>

<div style="margin-left:280px; padding:32px; font-family:'Inter', system-ui, -apple-system, sans-serif; background:#f1f5f9; min-height:100vh; color: #1e293b;">

  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <div>
      <h2 style="font-size:24px; font-weight:700; margin:0; letter-spacing: -0.02em;">Persetujuan Dinas Luar</h2>
      <p style="margin: 4px 0 0; color: #64748b; font-size: 14px;">Kelola dan tinjau semua pengajuan perjalanan dinas tim Anda.</p>
    </div>
  </div>

  <div style="background:#fff; border:none; border-radius:16px; overflow:hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);">

    <table style="width:100%; border-collapse:collapse; font-size:14px; min-width:900px;">
      <thead>
        <tr style="background:#f8fafc; border-bottom: 1px solid #e2e8f0;">
          <th style="padding:16px 20px; text-align:left; color:#475569; font-weight:600;">Pengaju</th>
          <th style="padding:16px 20px; text-align:left; color:#475569; font-weight:600;">Judul Kegiatan</th>
          <th style="padding:16px 20px; text-align:left; color:#475569; font-weight:600;">Tujuan</th>
            <% if (user.role === "HR") { %>
      <th>Delegasi</th>
    <% } %>
          <th style="padding:16px 20px; text-align:left; color:#475569; font-weight:600;">Estimasi Budget</th>
          <th style="padding:16px 20px; text-align:left; color:#475569; font-weight:600;">Status</th>
          <th style="padding:16px 20px; text-align:center; color:#475569; font-weight:600;">Aksi</th>
        </tr>
      </thead>

      <tbody>
        <% trips.forEach(t => { %>
          <tr class="table-row" style="border-bottom: 1px solid #f1f5f9; transition: all 0.2s;">
            <td style="padding:16px 20px;">
              <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:32px; height:32px; background:#e0e7ff; color:#4338ca; border-radius:8px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:12px;">
                  <%= (t.userId?.username || 'U').substring(0,1).toUpperCase() %>
                </div>
                <span style="font-weight:600;"><%= t.userId?.username || '-' %></span>
              </div>
            </td>
            <td style="padding:16px 20px; color:#334155;"><%= t.title %></td>
            <td style="padding:16px 20px; color:#64748b;"><%= t.destination || '-' %></td>
             <% if (user.role === "HR") { %>

    <td>

      <% if (t.delegation?.active) { %>

        <span style="
          padding:6px 10px;
          border-radius:999px;
          background:#fef3c7;
          color:#92400e;
          font-size:12px;
          font-weight:600;
        ">
          Pimpinan → HR
        </span>

      <% } else { %>

        -

      <% } %>

    </td>

  <% } %>
            <td style="padding:16px 20px; font-weight:600; color:#0f172a;">
              Rp <%= (t.budget || 0).toLocaleString('id-ID') %>
            </td>
            <td style="padding:16px 20px;">
              <span style="
                padding:6px 12px;
                border-radius:8px;
                font-size:12px;
                font-weight:600;
                display: inline-flex;
                align-items: center;
                gap: 5px;
                background:
                  <%= t.status === 'APPROVED' ? '#dcfce7'
                  : t.status === 'REJECTED' ? '#fee2e2'
                  : '#dbeafe' %>;
                color:
                  <%= t.status === 'APPROVED' ? '#15803d'
                  : t.status === 'REJECTED' ? '#b91c1c'
                  : '#1d4ed8' %>;
              ">
                <span style="width:6px; height:6px; border-radius:50%; background:currentColor;"></span>
                <%= t.status %>
              </span>
            </td>
            <td style="padding:16px 20px; text-align:center;">
              <button
                type="button"
                onclick="openModal('<%= t._id %>')"
                class="btn-review">
                Tinjau
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- MODAL CONTAINER -->
<div id="modalContainer"></div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

  .table-row:hover {
    background-color: #f8fafc;
  }

  .btn-review {
    padding:8px 16px; 
    background:#4f46e5; 
    color:#fff; 
    border:none; 
    border-radius:10px; 
    cursor:pointer; 
    font-weight:600;
    font-size:13px;
    transition: all 0.2s;
    box-shadow: 0 2px 4px rgba(79, 70, 229, 0.2);
  }

  .btn-review:hover {
    background:#4338ca;
    transform: translateY(-1px);
    box-shadow: 0 4px 6px rgba(79, 70, 229, 0.3);
  }

  .modal-overlay {
    position:fixed;
    inset:0;
    background:rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(4px);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:9999;
    padding: 20px;
  }

  .modal-box {
    width:100%;
    max-width:600px;
    background:#fff;
    border-radius:20px;
    padding:28px;
    max-height:90vh;
    overflow:auto;
    box-shadow:0 25px 50px -12px rgba(0,0,0,0.25);
    animation: modalIn 0.3s ease-out;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .modal-header {
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f1f5f9;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }

  .detail-item label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .detail-item p {
    margin: 0;
    font-weight: 500;
    color: #1e293b;
  }

  .timeline-card {
    background: #f8fafc;
    border-radius: 12px;
    padding: 16px;
    border: 1px solid #e2e8f0;
  }

  .timeline-item {
    padding: 8px 0;
    border-left: 2px solid #e2e8f0;
    padding-left: 16px;
    position: relative;
    font-size: 13px;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 12px;
    width: 12px;
    height: 12px;
    background: #4f46e5;
    border-radius: 50%;
    border: 3px solid #fff;
  }

  .btn-approve { background:#16a34a; color:#fff; padding:12px 20px; border:none; border-radius:12px; font-weight:600; cursor:pointer; flex: 1; transition: 0.2s; }
  .btn-reject { background:#fff; color:#dc2626; padding:12px 20px; border:1px solid #fee2e2; border-radius:12px; font-weight:600; cursor:pointer; flex: 1; transition: 0.2s; }
  .btn-approve:hover { background:#15803d; transform: translateY(-1px); }
  .btn-reject:hover { background:#fef2f2; }
</style>

<script>
  

// Logic Tetap Sama, Hanya Struktur RenderModal yang dipercantik
function openModal(id){
  const trip = getTripData(id);
  document.getElementById("modalContainer").innerHTML = renderModal(trip);
  document.getElementById("modal-"+id).style.display = "flex";
}

function closeModal(id){
  document.getElementById("modal-"+id).style.display = "none";
}

function getTripData(id){
  return window.__TRIPS__.find(t => t._id === id);
}

window.__TRIPS__ = <%- JSON.stringify(trips) %>;
window.__USER__ = <%- JSON.stringify(user) %>;
function renderModal(t){
  return `
  <div id="modal-${t._id}" class="modal-overlay" onclick="if(event.target===this) closeModal('${t._id}')">
    <div class="modal-box">
      <div class="modal-header">
        <div style="font-size:18px; font-weight:700;">Detail Tinjauan Perjalanan</div>
        <button onclick="closeModal('${t._id}')" style="border:none;background:#f1f5f9;width:32px;height:32px;border-radius:50%;cursor:pointer;color:#64748b;">✕</button>
      </div>

      <div class="detail-grid">
        <div class="detail-item" style="grid-column: span 2;">
          <label>Judul Pengajuan</label>
          <p style="font-size:16px; font-weight:600;">${t.title}</p>
        </div>
        <div class="detail-item">
          <label>Pengaju</label>
          <p>${t.userId?.username || '-'}</p>
        </div>
        <div class="detail-item">
          <label>Estimasi Budget</label>
          <p>Rp ${Number(t.budget || 0).toLocaleString('id-ID')}</p>
        </div>
        <div class="detail-item">
          <label>Destinasi</label>
          <p>${t.destination || '-'}</p>
        </div>
        <div class="detail-item">
          <label>Durasi</label>
          <p>${new Date(t.startDate).toLocaleDateString('id-ID')} - ${new Date(t.endDate).toLocaleDateString('id-ID')}</p>
        </div>
      </div>

      <div class="detail-item" style="margin-bottom:20px;">
        <label>Tujuan & Deskripsi</label>
        <p style="font-weight:400; line-height:1.6; color:#475569;">${t.description || '-'}</p>
      </div>

      <div style="margin-bottom:24px;">
        <label style="display: block; font-size: 12px; font-weight: 700; color: #94a3b8; text-transform: uppercase; margin-bottom: 8px;">Rencana Lokasi (Timeline)</label>
        <div class="timeline-card">
          ${(t.timeline || []).map(x => `<div class="timeline-item">${x.address}</div>`).join('')}
        </div>
      </div>

     <div style="display:flex; gap:12px; flex-wrap:wrap;">

  <!-- APPROVE -->
  <button
    onclick="approve('${t._id}')"
    class="btn-approve"
  >
    Setujui Pengajuan
  </button>

  <!-- REJECT -->
  <button
    onclick="showReject('${t._id}')"
    class="btn-reject"
  >
    Tolak
  </button>

  ${
  window.__USER__.role === "PIMPINAN" &&
  t.currentStep === "PIMPINAN"
  ? `
    <form
      action="/trip/${t._id}/delegate"
      method="POST"
      style="flex:1;"
    >
      <button
        type="submit"
        class="btn-delegate"
        style="width:100%;"
      >
        Delegasikan ke HR
      </button>
    </form>
  `
  : ""
}

</div>

      <div id="reject-area-${t._id}" style="display:none; margin-top:20px; border-top: 1px solid #f1f5f9; padding-top:20px;">
        <label style="display: block; font-size: 12px; font-weight: 700; color: #b91c1c; text-transform: uppercase; margin-bottom: 8px;">Alasan Penolakan</label>
        <textarea id="note-${t._id}" placeholder="Berikan alasan mengapa pengajuan ditolak..." 
          style="width:100%; border:1px solid #fee2e2; border-radius:12px; padding:12px; font-family:inherit; min-height:80px; margin-bottom:12px; outline:none;"></textarea>
        <button onclick="submitReject('${t._id}')" style="width:100%; background:#dc2626; color:#fff; border:none; padding:12px; border-radius:12px; font-weight:600; cursor:pointer;">Konfirmasi Tolak Pengajuan</button>
      </div>
    </div>
  </div>`;
}

// FUNGSI JAVASCRIPT (SAMA DENGAN SEBELUMNYA)
async function approve(id){
  if(!confirm("Setujui pengajuan ini?")) return;
  await fetch(`/trip/approval/${id}`, {
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body: JSON.stringify({ action:"APPROVE" })
  });
  location.reload();
}

function showReject(id){
  document.getElementById("reject-area-"+id).style.display = "block";
}

async function submitReject(id){
  const note = document.getElementById("note-"+id).value;
  if(!note) return alert("Mohon isi alasan penolakan.");
  
  await fetch(`/trip/approval/${id}`, {
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body: JSON.stringify({ action:"REJECT", note })
  });
  location.reload();
}
</script>
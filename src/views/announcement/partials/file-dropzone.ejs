<% 
  // Ambil nilai default jika variabel opsional tidak dikirim dari parent view
  const label = typeof labelName !== 'undefined' ? labelName : 'Dokumen Pendukung';
  const name = typeof inputName !== 'undefined' ? inputName : 'document';
  const hasDocument = (typeof oldFile !== 'undefined' && oldFile);
%>

<div class="space-y-2">
  <label class="block text-[12px] font-semibold text-slate-700 tracking-wide">
    <%= label %> 
    <span id="required-mark" class="text-rose-500 hidden">*</span>
    <span id="optional-mark" class="text-slate-400 font-normal">(Opsional)</span>
  </label>
  <div class="relative">
    <input type="file" name="<%= name %>" id="file-upload" accept=".pdf,.jpg,.jpeg,.png" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="updateFileName(this)" />
    
    <div id="dropzone-empty" class="w-full border border-slate-200 border-dashed rounded-xl p-5 bg-slate-50/50 hover:bg-slate-50 transition flex flex-col items-center text-center <%= hasDocument ? 'hidden' : '' %>">
      <svg class="w-4 h-4 text-slate-400 mb-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
      </svg>
      <span class="text-[12px] font-medium text-slate-600">Pilih Berkas atau Drop File Disini</span>
      <span class="text-[11px] text-slate-400 mt-0.5">PDF, JPG, JPEG, atau PNG (Maks. 2MB)</span>
    </div>

    <div id="dropzone-filled" class="<%= hasDocument ? '' : 'hidden' %> flex flex-col sm:flex-row sm:items-center justify-between gap-3 border border-slate-200 rounded-xl p-3.5 bg-white shadow-xs">
      <div class="flex items-center gap-3 min-w-0 flex-1">
        <div class="w-9 h-9 rounded-lg bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="min-w-0 flex-1">
          <div id="name-preview" class="text-[12px] font-semibold text-slate-700 truncate">
            <%= hasDocument ? oldFile.split('/').pop() : 'file.pdf' %>
          </div>
          <div id="size-preview" class="text-[11px] text-slate-400 mt-0.5">
            <%= hasDocument ? 'Berkas Tersimpan' : '0 KB' %>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0 w-full sm:w-auto relative z-20">
        <a id="view-file-btn" href="<%= hasDocument ? oldFile : '#' %>" target="_blank" class="text-[11px] font-medium text-center text-slate-700 bg-slate-100 hover:bg-slate-200/80 px-3 py-1.5 rounded-lg flex-1 sm:flex-initial transition-colors">View</a>
        <button type="button" onclick="document.getElementById('file-upload').click()" class="text-[11px] font-medium text-slate-600 bg-slate-50 border border-slate-200/60 hover:bg-slate-100 px-3 py-1.5 rounded-lg flex-1 sm:flex-initial transition-colors">Ganti</button>
      </div>
    </div>
  </div>
  <% if (typeof errors !== 'undefined' && errors[name]) { %>
    <p class="text-[11px] font-medium text-rose-600 mt-1 pl-0.5"><%= errors[name] %></p>
  <% } %>
</div>

<script>
  // Fungsi penangan file diletakkan di partial agar otomatis ikut dipanggil
  function updateFileName(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];
      document.getElementById("name-preview").textContent = file.name;
      document.getElementById("size-preview").textContent = (file.size / 1024).toFixed(1) + " KB";
      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
      document.getElementById("view-file-btn").href = URL.createObjectURL(file);
    } else {
      <% if (!hasDocument) { %>
        document.getElementById("dropzone-empty").classList.remove("hidden");
        document.getElementById("dropzone-filled").classList.add("hidden");
      <% } %>
    }
  }
</script>
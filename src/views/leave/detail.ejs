<% layout('layouts/main') -%>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8">
  <div class="max-w-4xl mx-auto">

    <!-- HEADER -->
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">
        Detail Pengajuan Cuti
      </h1>
      <p class="text-slate-500 mt-2 font-medium">
        Informasi lengkap pengajuan cuti karyawan
      </p>
    </div>

    <!-- CARD -->
    <div class="relative overflow-hidden bg-white/80 backdrop-blur-xl rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-white p-8">

      <!-- dekorasi -->
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-indigo-500/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl"></div>

      <!-- GRID -->
      <div class="relative grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- JENIS CUTI -->
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400">
            Jenis Cuti
          </p>
          <h2 class="font-bold text-lg mt-1 text-slate-800">
            <%= leave.type %>
          </h2>
        </div>

        <!-- STATUS -->
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400">
            Status
          </p>

          <div class="mt-2">
            <span
              class="px-3 py-1 rounded-full text-xs font-semibold
              <%= leave.status === 'Approved'
                ? 'bg-emerald-100 text-emerald-700'
                : leave.status === 'Rejected'
                ? 'bg-red-100 text-red-700'
                : 'bg-yellow-100 text-yellow-700' %>
              "
            >
              <%= leave.status %>
            </span>
          </div>
        </div>

        <!-- TANGGAL -->
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400">
            Tanggal Mulai
          </p>
          <h2 class="font-semibold mt-1 text-slate-700">
            <%= new Date(leave.startDate).toLocaleDateString("id-ID") %>
          </h2>
        </div>

        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400">
            Tanggal Selesai
          </p>
          <h2 class="font-semibold mt-1 text-slate-700">
            <%= new Date(leave.endDate).toLocaleDateString("id-ID") %>
          </h2>
        </div>

        <!-- DURASI -->
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400">
            Durasi
          </p>
          <h2 class="font-semibold mt-1 text-slate-700">
            <%= leave.totalDays %> Hari
          </h2>
        </div>

        <!-- CREATED -->
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400">
            Tanggal Pengajuan
          </p>
          <h2 class="font-semibold mt-1 text-slate-700">
            <%= new Date(leave.createdAt).toLocaleDateString("id-ID") %>
          </h2>
        </div>

      </div>

      <!-- ALASAN -->
      <div class="mt-10">
        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">
          Alasan Cuti
        </p>

        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5 text-slate-700 leading-relaxed">
          <%= leave.reason %>
        </div>
      </div>

      <!-- FILE -->
      <% if(leave.file){ %>
        <div class="mt-8">
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">
            Lampiran Bukti
          </p>

          <div class="bg-slate-50 border border-slate-100 rounded-2xl p-5 flex items-center justify-between">

            <div>
              <p class="font-semibold text-slate-700">
                <%= leave.file %>
              </p>
              <p class="text-xs text-slate-400 mt-1">
                File pendukung pengajuan cuti
              </p>
            </div>

            <a
              href="/uploads/<%= leave.file %>"
              target="_blank"
              class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition"
            >
              Lihat File
            </a>

          </div>
        </div>
      <% } %>

      <!-- BUTTON -->
      <div class="mt-10">
        <a
          href="/leave/my"
          class="inline-flex items-center gap-2 bg-slate-200 hover:bg-slate-300 text-slate-700 px-5 py-3 rounded-xl text-sm font-semibold transition"
        >
          ← Kembali
        </a>
      </div>

    </div>
  </div>
</div>
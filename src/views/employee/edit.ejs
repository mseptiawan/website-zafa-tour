<%- layout('layouts/main', { title: isMandiri ? "Edit Profil Mandiri" : "Edit Data Pegawai" }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 p-4 sm:p-6 md:p-10 antialiased pb-24 md:pb-8 text-slate-800">
  <div class="w-full max-w-none mx-auto space-y-6">

    <%- include('../partials/page-header', {
      section: 'Area Kerja',
      module: isMandiri ? 'Profil Saya' : 'Kepegawaian',
      title: isMandiri ? 'Edit Profil Mandiri' : 'Edit Data Pegawai',
      description: isMandiri ? 'Perbarui informasi kontak, alamat, dokumen sertifikasi, dan anggota keluarga Anda.' : 'Kelola berkas personal, struktur kedinasan, kontak darurat, serta informasi payroll pegawai.'
    }) %>

    <div id="units-data" data-json="<%= JSON.stringify(units || []) %>" data-employee-id="<%= employee._id %>" class="hidden"></div>

    <div id="global-error" class="border-l-2 border-rose-500 bg-rose-50/50 text-rose-700 px-4 py-3 rounded-r-md text-xs font-medium hidden"></div>

    <div class="border-b border-slate-200 overflow-x-auto">
      <nav class="flex flex-col md:flex-row gap-2 md:gap-6 min-w-full pb-px">
        <% if (!isMandiri) { %>
        <button type="button" data-tab="pribadi" class="tab-btn w-full md:w-auto text-left md:text-center border-b-2 border-blue-600 py-3 px-3 md:px-1 text-xs font-bold tracking-wider uppercase text-blue-600 transition-all">Data Pribadi</button>
        <button type="button" data-tab="karir" class="tab-btn w-full md:w-auto text-left md:text-center border-b-2 border-transparent py-3 px-3 md:px-1 text-xs font-bold tracking-wider uppercase text-slate-500 hover:text-slate-700 hover:border-slate-300 transition-all">Karir & Struktur</button>
        <% } %>

        <button type="button" data-tab="kontak" class="tab-btn w-full md:w-auto text-left md:text-center border-b-2 <%= isMandiri ? 'border-blue-600 text-blue-600 font-bold' : 'border-transparent text-slate-500' %> py-3 px-3 md:px-1 text-xs font-bold tracking-wider uppercase hover:text-slate-700 hover:border-slate-300 transition-all">Kontak & Alamat</button>
        <button type="button" data-tab="dokumen" class="tab-btn w-full md:w-auto text-left md:text-center border-b-2 border-transparent py-3 px-3 md:px-1 text-xs font-bold tracking-wider uppercase text-slate-500 hover:text-slate-700 hover:border-slate-300 transition-all">Dokumen</button>

        <% if (!isMandiri) { %>
        <button type="button" data-tab="pendidikan" class="tab-btn w-full md:w-auto text-left md:text-center border-b-2 border-transparent py-3 px-3 md:px-1 text-xs font-bold tracking-wider uppercase text-slate-500 hover:text-slate-700 hover:border-slate-300 transition-all">Pendidikan</button>
        <% } %>

        <button type="button" data-tab="keluarga" class="tab-btn w-full md:w-auto text-left md:text-center border-b-2 border-transparent py-3 px-3 md:px-1 text-xs font-bold tracking-wider uppercase text-slate-500 hover:text-slate-700 hover:border-slate-300 transition-all">Keluarga</button>
        <button type="button" data-tab="finansial" class="tab-btn w-full md:w-auto text-left md:text-center border-b-2 border-transparent py-3 px-3 md:px-1 text-xs font-bold tracking-wider uppercase text-slate-500 hover:text-slate-700 hover:border-slate-300 transition-all">Finansial</button>
      </nav>
    </div>

    <div class="bg-white p-5 md:p-8 rounded-2xl border border-slate-200">

      <% if (!isMandiri) { %>
      <div id="content-pribadi" class="tab-content space-y-6">
        <form id="form-pribadi" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">

            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Email Akun (Sistem)</label>
              <input type="email" value="<%= employee.userId?.email || 'Tidak terhubung ke akun' %>" readonly class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-500 border border-slate-200 rounded-xl bg-slate-100 cursor-not-allowed outline-hidden" />
              <p class="text-[9px] text-slate-400">Email tidak dapat diubah melalui profil personal.</p>
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nama Lengkap <span class="text-rose-500">*</span></label>
              <input name="fullName" type="text" value="<%= employee.fullName %>" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nomor KTP (NIK) <span class="text-rose-500">*</span></label>
              <input name="nomor_ktp" type="text" maxlength="16" value="<%= employee.nomor_ktp %>" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Tempat Lahir</label>
              <input name="tempat_lahir" type="text" value="<%= employee.tempat_lahir || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Tanggal Lahir</label>
              <input name="tanggal_lahir" type="date" value="<%= employee.tanggal_lahir ? employee.tanggal_lahir.toISOString().split('T')[0] : '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Jenis Kelamin <span class="text-rose-500">*</span></label>
              <select name="jenis_kelamin" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
                <option value="Laki-Laki" <%= employee.jenis_kelamin === 'Laki-Laki' ? 'selected' : '' %>>Laki-Laki</option>
                <option value="Perempuan" <%= employee.jenis_kelamin === 'Perempuan' ? 'selected' : '' %>>Perempuan</option>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Agama <span class="text-rose-500">*</span></label>
              <select name="agama" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
                <% ['Islam', 'Kristen', 'Katolik', 'Hindu', 'Buddha', 'Khonghucu'].forEach(ag => { %>
                <option value="<%= ag %>" <%= employee.agama === ag ? 'selected' : '' %>><%= ag %></option>
                <% }) %>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Golongan Darah</label>
              <select name="golongan_darah" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
                <option value="" <%= !employee.golongan_darah ? 'selected' : '' %>>-</option>
                <% ['A', 'B', 'AB', 'O'].forEach(goldar => { %>
                <option value="<%= goldar %>" <%= employee.golongan_darah === goldar ? 'selected' : '' %>><%= goldar %></option>
                <% }) %>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Status Pernikahan</label>
              <select name="status_pernikahan" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
                <option value="" <%= !employee.status_pernikahan ? 'selected' : '' %>>-</option>
                <% ['Lajang', 'Menikah', 'Cerai'].forEach(sp => { %>
                <option value="<%= sp %>" <%= employee.status_pernikahan === sp ? 'selected' : '' %>><%= sp %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="flex justify-end pt-4">
            <button type="submit" class="w-full sm:w-auto text-xs font-bold uppercase tracking-wider text-white bg-blue-600 px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors">Perbarui Data Pribadi</button>
          </div>
        </form>
      </div>

    <div id="content-karir" class="tab-content space-y-6 hidden">
  <form id="form-karir" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
      <div class="space-y-1.5">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Jabatan Struktural <span class="text-rose-500">*</span></label>
        <select name="positionId" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
          <option value="" disabled>Pilih Jabatan</option>
          <% (positions || []).forEach(p => { %>
          <% const employeePositionId = employee.careerData?.positionId?._id || employee.careerData?.positionId; %>
          <option value="<%= p._id %>" <%= String(employeePositionId) === String(p._id) ? 'selected' : '' %>>
            <%= p.name %>
          </option>
          <% }) %>
        </select>
      </div>

      <div class="space-y-1.5">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Bidang Kerja <span class="text-rose-500">*</span></label>
        <select id="select-bidang" name="bidangId" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
          <option value="" disabled <%= !employee.careerData?.bidangId ? 'selected' : '' %>>Pilih Bidang</option>
          <% (bidang || []).forEach(b => { %>
          <% 
              const currentBidangId = employee.careerData?.bidangId?._id || employee.careerData?.bidangId;
              const isSelected = String(currentBidangId) === String(b._id);
            %>
          <option value="<%= b._id %>" <%= isSelected ? 'selected' : '' %>><%= b.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="space-y-1.5">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Unit Kantor Penempatan <span class="text-rose-500">*</span></label>
        <% const currentUnitId = employee.careerData?.unitId?._id || employee.careerData?.unitId || ''; %>
        <select id="select-unit" name="unitId" required data-old="<%= currentUnitId %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none"></select>
      </div>

      <div class="space-y-1.5">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Status Kepegawaian Awal <span class="text-rose-500">*</span></label>
        <select id="select-status" name="status_pegawai" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
          <% ['Pegawai Tetap', 'Pegawai Kontrak', 'Magang / Intern', 'Pensiun'].forEach(st => { %>
          <option value="<%= st %>" <%= employee.careerData?.status_pegawai === st ? 'selected' : '' %>><%= st %></option>
          <% }) %>
        </select>
      </div>

      <div class="space-y-1.5">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Lokasi Wilayah Penempatan <span class="text-rose-500">*</span></label>
        <select name="penempatan" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
          <option value="" disabled <%= !employee.careerData?.penempatan ? 'selected' : '' %>>Pilih Penempatan</option>
          <% ['Kantor Pusat Palembang', 'Bengkulu', 'Lampung', 'Jawa Barat', 'Sumatera Selatan Barat'].forEach(loc => { %>
          <option value="<%= loc %>" <%= employee.careerData?.penempatan === loc ? 'selected' : '' %>><%= loc %></option>
          <% }) %>
        </select>
      </div>

      <div class="space-y-1.5">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Tanggal Mulai Bergabung <span class="text-rose-500">*</span></label>
        <input type="date" name="tanggal_mulai_bergabung" value="<%= employee.careerData?.tanggal_mulai_bergabung ? employee.careerData.tanggal_mulai_bergabung.toISOString().split('T')[0] : '' %>" required class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
      </div>

      <div class="space-y-1.5 md:col-span-2">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Status Akun Pegawai <span class="text-rose-500">*</span></label>
        <% const currentStatus = employee.userId?.status || 'Active'; %>
        <select disabled class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-400 border border-slate-200 rounded-xl bg-slate-100 cursor-not-allowed appearance-none">
          <option value="Active" <%= currentStatus === 'Active' ? 'selected' : '' %>>Active / Aktif</option>
          <option value="Inactive" <%= currentStatus === 'Inactive' ? 'selected' : '' %>>Inactive / Nonaktif</option>
          <option value="Suspended" <%= currentStatus === 'Suspended' ? 'selected' : '' %>>Suspended / Ditangguhkan</option>
        </select>
        <input type="hidden" name="status" value="<%= currentStatus %>">
      </div>

      <div id="wrapper-kontrak" class="space-y-1.5 hidden md:col-span-2">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Tanggal Berakhir Kontrak / Magang <span class="text-rose-500">*</span></label>
        <input type="date" id="input-tanggal-kontrak" name="tanggal_berakhir_kontrak" value="<%= employee.careerData?.tanggal_berakhir_kontrak ? employee.careerData.tanggal_berakhir_kontrak.toISOString().split('T')[0] : '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
      </div>
    </div>
    <div class="flex justify-end pt-4">
      <button type="submit" class="w-full sm:w-auto text-xs font-bold uppercase tracking-wider text-white bg-blue-600 px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors">Perbarui Struktur & Karir</button>
    </div>
  </form>
</div>
<% } %>

      <div id="content-kontak" class="tab-content space-y-6 <%= isMandiri ? '' : 'hidden' %>">
        <form id="form-kontak" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nomor Telepon Pegawai</label>
              <input name="nomor_telp" type="text" value="<%= employee.contactData?.nomor_telp || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nama Kontak Darurat</label>
              <input name="nama_kontak_darurat" type="text" value="<%= employee.contactData?.nama_kontak_darurat || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Hubungan Kontak Darurat</label>
              <input name="hubungan_kontak_darurat" type="text" value="<%= employee.contactData?.hubungan_kontak_darurat || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nomor Kontak Darurat</label>
              <input name="nomor_kontak_darurat" type="text" value="<%= employee.contactData?.nomor_kontak_darurat || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="grid-cols-1 md:col-span-2 space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Alamat Domisili Lengkap</label>
              <textarea name="alamat" rows="3" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden pt-2"><%= employee.contactData?.alamat || '' %></textarea>
            </div>
          </div>
          <div class="flex justify-end pt-4">
            <button type="submit" class="w-full sm:w-auto text-xs font-bold uppercase tracking-wider text-white bg-blue-600 px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors">Perbarui Kontak</button>
          </div>
        </form>
      </div>

      <div id="content-dokumen" class="tab-content space-y-6 hidden">
        <form id="form-dokumen" class="space-y-6" enctype="multipart/form-data">
          <% if (!isMandiri) { %>
          <div class="bg-slate-50/50 p-4 md:p-5 rounded-xl border border-slate-100 space-y-4">
            <h4 class="text-xs font-bold text-slate-800 uppercase tracking-wide mb-2">Dokumen Utama Pegawai</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
              <div class="space-y-1.5">
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Berkas KTP (PDF/IMG)</label>
                <input name="file_ktp" type="file" class="w-full px-[14px] py-2.5 text-xs font-medium text-slate-900 border border-slate-200 rounded-xl bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all outline-hidden" />
                <% if (employee.documentData?.file_ktp) { %>
                <p class="text-[10px] text-blue-600 font-medium mt-1"><a href="<%= employee.documentData.file_ktp %>" target="_blank">👁 Lihat KTP Saat Ini</a></p>
                <% } %>
              </div>

              <div class="space-y-1.5">
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Berkas Kartu Keluarga (PDF/IMG)</label>
                <input name="file_kk" type="file" class="w-full px-[14px] py-2.5 text-xs font-medium text-slate-900 border border-slate-200 rounded-xl bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all outline-hidden" />
                <% if (employee.documentData?.file_kk) { %>
                <p class="text-[10px] text-blue-600 font-medium mt-1"><a href="<%= employee.documentData.file_kk %>" target="_blank">👁 Lihat KK Saat Ini</a></p>
                <% } %>
              </div>

              <div class="space-y-1.5">
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Berkas SKCK Aktif</label>
                <input name="file_skck" type="file" class="w-full px-[14px] py-2.5 text-xs font-medium text-slate-900 border border-slate-200 rounded-xl bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all outline-hidden" />
                <% if (employee.documentData?.file_skck) { %>
                <p class="text-[10px] text-blue-600 font-medium mt-1"><a href="<%= employee.documentData.file_skck %>" target="_blank">👁 Lihat SKCK Saat Ini</a></p>
                <% } %>
              </div>
              <div class="space-y-1.5">
                <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Tanggal Kadaluarsa SKCK</label>
                <input name="tanggal_kadaluarsa_skck" type="date" value="<%= employee.documentData?.tanggal_kadaluarsa_skck ? employee.documentData.tanggal_kadaluarsa_skck.toISOString().split('T')[0] : '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all outline-hidden" />
              </div>
            </div>
          </div>
          <% } %>

          <div class="space-y-4">
            <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 pb-2 border-b border-slate-100">
              <h4 class="text-xs font-bold text-slate-800 uppercase tracking-wide">Sertifikat Kompetensi / Keahlian</h4>
              <button type="button" id="btn-add-cert" class="text-[11px] font-bold bg-slate-100 text-slate-700 hover:bg-slate-200 px-3 py-1.5 rounded-lg transition-all">+ Tambah Sertifikat</button>
            </div>

            <div id="cert-container" class="space-y-4">
              <% if (employee.documentData && employee.documentData.sertifikat_kompetensi && employee.documentData.sertifikat_kompetensi.length > 0) { %>
              <% employee.documentData.sertifikat_kompetensi.forEach((cert, index) => { %>
              <div class="cert-row grid grid-cols-1 md:grid-cols-3 gap-3 bg-slate-50 p-4 rounded-xl relative border border-slate-100">
                <div class="space-y-1"><label class="text-[10px] text-slate-400 font-bold uppercase">Nama Sertifikat</label><input type="text" name="sertifikat_kompetensi[<%= index %>][nama_sertifikat]" value="<%= cert.nama_sertifikat || '' %>" class="w-full px-[14px] py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" /></div>
                <div class="space-y-1"><label class="text-[10px] text-slate-400 font-bold uppercase">Penerbit / Lembaga</label><input type="text" name="sertifikat_kompetensi[<%= index %>][penerbit]" value="<%= cert.penerbit || '' %>" class="w-full px-[14px] py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" /></div>
                <div class="space-y-1"><label class="text-[10px] text-slate-400 font-bold uppercase">Nomor Sertifikat</label><input type="text" name="sertifikat_kompetensi[<%= index %>][nomor_sertifikat]" value="<%= cert.nomor_sertifikat || '' %>" class="w-full px-[14px] py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" /></div>
                <div class="space-y-1"><label class="text-[10px] text-slate-400 font-bold uppercase">Tanggal Terbit</label><input type="date" name="sertifikat_kompetensi[<%= index %>][tanggal_terbit]" value="<%= cert.tanggal_terbit ? cert.tanggal_terbit.toISOString().split('T')[0] : '' %>" class="w-full px-[14px] py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" /></div>
                <div class="space-y-1"><label class="text-[10px] text-slate-400 font-bold uppercase">Tanggal Kadaluarsa</label><input type="date" name="sertifikat_kompetensi[<%= index %>][tanggal_kadaluarsa]" value="<%= cert.tanggal_kadaluarsa ? cert.tanggal_kadaluarsa.toISOString().split('T')[0] : '' %>" class="w-full px-[14px] py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" /></div>

                <div class="space-y-1">
                  <label class="text-[10px] text-slate-400 font-bold uppercase">Upload File Sertifikat (Baru)</label>
                  <input type="file" name="file_sertifikat_<%= index %>" class="w-full px-[14px] py-1.5 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" />
                  <input type="hidden" name="sertifikat_kompetensi[<%= index %>][file_sertifikat_old]" value="<%= cert.file_sertifikat || '' %>" />
                  <% if (cert.file_sertifikat) { %>
                  <p class="text-[10px] text-blue-600 font-medium mt-1 truncate"><a href="<%= cert.file_sertifikat %>" target="_blank">👁 Lihat Berkas</a></p>
                  <% } %>
                </div>

                <button type="button" class="btn-remove-cert absolute top-2 right-2 text-rose-500 hover:text-rose-700 text-lg font-bold">×</button>
              </div>
              <% }) %>
              <% } %>
            </div>
          </div>

          <div class="flex justify-end pt-4">
            <button type="submit" class="w-full sm:w-auto text-xs font-bold uppercase tracking-wider text-white bg-blue-600 px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors">Unggah & Simpan Dokumen</button>
          </div>
        </form>
      </div>

      <% if (!isMandiri) { %>
      <div id="content-pendidikan" class="tab-content space-y-6 hidden">
        <form id="form-pendidikan" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Pendidikan Terakhir</label>
              <select name="pendidikan_terakhir" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
                <option value="">-</option>
                <% ['SMA/SMK', 'D3', 'D4', 'S1', 'S2', 'S3'].forEach(edu => { %>
                <option value="<%= edu %>" <%= employee.educationData?.pendidikan_terakhir === edu ? 'selected' : '' %>><%= edu %></option>
                <% }) %>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Institusi Pendidikan / Sekolah</label>
              <input name="institusi_pendidikan" type="text" value="<%= employee.educationData?.institusi_pendidikan || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Jurusan / Program Studi</label>
              <input name="jurusan" type="text" value="<%= employee.educationData?.jurusan || '' %>" placeholder="Misal: Sistem Informasi, Akuntansi" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Tahun Kelulusan</label>
              <input name="tahun_kelulusan" type="number" value="<%= employee.educationData?.tahun_kelulusan || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Lampiran Berkas Ijazah</label>
              <input name="file_ijazah" type="file" class="w-full px-[14px] py-2.5 text-xs font-medium text-slate-900 border border-slate-200 rounded-xl bg-white outline-hidden" />
              <% if (employee.educationData?.file_ijazah) { %>
              <div class="mt-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                <p class="text-[11px] text-slate-500 mb-1">Berkas ijazah saat ini:</p>
                <a href="<%= employee.educationData.file_ijazah %>" target="_blank" class="text-xs font-medium text-blue-600 hover:underline">Buka Dokumen Ijazah</a>
              </div>
              <% } %>
            </div>
          </div>
          <div class="flex justify-end pt-4">
            <button type="submit" class="w-full sm:w-auto text-xs font-bold uppercase tracking-wider text-white bg-blue-600 px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors">Perbarui Akademis</button>
          </div>
        </form>
      </div>
      <% } %>

      <div id="content-keluarga" class="tab-content space-y-6 hidden">
        <form id="form-keluarga" class="space-y-6">
          <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 pb-2 border-b border-slate-100">
            <h4 class="text-xs font-bold text-slate-800 uppercase tracking-wide">Daftar Anggota Keluarga Inti</h4>
            <button type="button" id="btn-add-family" class="text-[11px] font-bold bg-slate-100 text-slate-700 hover:bg-slate-200 px-3 py-1.5 rounded-lg transition-all">+ Tambah Baris</button>
          </div>

          <div id="family-container" class="space-y-4">
            <% if (employee.familyData && employee.familyData.length > 0) { %>
            <% employee.familyData.forEach((member, index) => { %>
            <div class="family-row grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3 bg-slate-50 p-4 rounded-xl relative border border-slate-100">

              <div class="space-y-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase">Nama</label>
                <input type="text" name="anggota_keluarga[<%= index %>][nama]" value="<%= member.nama %>" class="w-full px-3 py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" required />
              </div>

              <div class="space-y-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase">Hubungan</label>
                <select name="anggota_keluarga[<%= index %>][hubungan]" class="w-full px-3 py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden appearance-none" required>
                  <option value="" disabled>Pilih</option>
                  <% ['Suami', 'Istri', 'Anak', 'Orang Tua', 'Saudara Kandung'].forEach(h => { %>
                  <option value="<%= h %>" <%= member.hubungan === h ? 'selected' : '' %>><%= h %></option>
                  <% }) %>
                </select>
              </div>

              <div class="space-y-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase">NIK</label>
                <input type="text" maxlength="16" name="anggota_keluarga[<%= index %>][nik]" value="<%= member.nik %>" class="w-full px-3 py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" />
              </div>

              <div class="space-y-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase">Jenis Kelamin</label>
                <select name="anggota_keluarga[<%= index %>][jenis_kelamin]" class="w-full px-3 py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden appearance-none">
                  <option value="">-</option>
                  <% ['Laki-laki', 'Perempuan'].forEach(jk => { %>
                  <option value="<%= jk %>" <%= member.jenis_kelamin === jk ? 'selected' : '' %>><%= jk %></option>
                  <% }) %>
                </select>
              </div>

              <div class="space-y-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase">Tgl Lahir</label>
                <input type="date" name="anggota_keluarga[<%= index %>][tanggal_lahir]" value="<%= member.tanggal_lahir ? new Date(member.tanggal_lahir).toISOString().split('T')[0] : '' %>" class="w-full px-3 py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" />
              </div>

              <div class="space-y-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase">Pekerjaan</label>
                <input type="text" name="anggota_keluarga[<%= index %>][pekerjaan]" value="<%= member.pekerjaan || '' %>" class="w-full px-3 py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden" />
              </div>

              <div class="space-y-1">
                <label class="text-[10px] text-slate-400 font-bold uppercase">Tanggungan?</label>
                <select name="anggota_keluarga[<%= index %>][status_tanggungan]" class="w-full px-3 py-2 text-xs font-medium border border-slate-200 rounded-xl bg-white outline-hidden appearance-none">
                  <option value="false" <%= member.status_tanggungan === false ? 'selected' : '' %>>Tidak</option>
                  <option value="true" <%= member.status_tanggungan === true ? 'selected' : '' %>>Ya</option>
                </select>
              </div>

              <button type="button" class="btn-remove-family absolute top-2 right-2 text-rose-500 hover:text-rose-700 text-lg font-bold">×</button>
            </div>
            <% }) %>
            <% } %>
          </div>

          <div class="flex justify-end pt-4">
            <button type="submit" class="w-full sm:w-auto text-xs font-bold uppercase tracking-wider text-white bg-blue-600 px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors">Simpan Anggota Keluarga</button>
          </div>
        </form>
      </div>

      <div id="content-finansial" class="tab-content space-y-6 hidden">
        <form id="form-finansial" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nama Bank</label>
              <select name="nama_bank" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden appearance-none">
                <option value="">-- Pilih Bank --</option>
                <% 
                  const daftarBank = [
                    "BCA", "Mandiri", "BRI", "BNI", "BSI (Bank Syariah Indonesia)", 
                    "CIMB Niaga", "Permata", "Danamon", "Tabungan Pensiunan Nasional (BTPN/Jenius)"
                  ]; 
                %>
                <% daftarBank.forEach(bank => { %>
                <option value="<%= bank %>" <%= employee.financialData?.nama_bank === bank ? 'selected' : '' %>><%= bank %></option>
                <% }) %>
              </select>
            </div>
            <div class="space-y-1.5"><label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nomor Rekening</label><input name="nomor_rekening" type="text" value="<%= employee.financialData?.nomor_rekening || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" /></div>
            <div class="space-y-1.5"><label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nama Pemilik Rekening</label><input name="nama_pemilik_rekening" type="text" value="<%= employee.financialData?.nama_pemilik_rekening || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" /></div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nomor NPWP</label>
              <input name="npwp" type="text" value="<%= old?.npwp || employee.financialData?.npwp || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden <%= errors?.npwp ? 'border-red-500' : 'border-slate-200' %>" />
              <% if (errors?.npwp) { %>
              <p class="text-red-500 text-xs mt-1"><%= errors.npwp %></p>
              <% } %>
            </div>

            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Nomor BPJS Ketenagakerjaan</label>
              <input name="bpjstk" type="text" value="<%= old?.bpjstk || employee.financialData?.bpjstk || '' %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden <%= errors?.bpjstk ? 'border-red-500' : 'border-slate-200' %>" />
              <% if (errors?.bpjstk) { %>
              <p class="text-red-500 text-xs mt-1"><%= errors.bpjstk %></p>
              <% } %>
            </div>
            <% if (!isMandiri) { %>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Gaji Pokok (Rp) <span class="text-rose-500">*</span></label>
              <input name="basicSalary" type="number" min="0" required placeholder="Contoh: 5000000" value="<%= employee.financialData?.basicSalary || 0 %>" class="w-full px-[14px] py-2.5 text-sm font-semibold text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <div class="space-y-1.5">
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider">Overtime Rate (per jam)</label>
              <input name="overtimeRate" type="number" min="0" step="1000" value="<%= employee.financialData?.overtimeRate || 0 %>" class="w-full px-[14px] py-2.5 text-sm font-medium text-slate-900 border border-slate-200 rounded-xl bg-slate-50/70 focus:bg-white focus:border-slate-500 focus:ring-3 focus:ring-slate-500/10 transition-all duration-200 outline-hidden" />
            </div>
            <% } %>
          </div>
          <div class="flex justify-end pt-4">
            <button type="submit" class="w-full sm:w-auto text-xs font-bold uppercase tracking-wider text-white bg-blue-600 px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors">Perbarui Data Finansial</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="/js/edit-employee.js" defer></script>
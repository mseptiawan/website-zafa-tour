<div class="bg-white rounded-2xl border border-slate-200/60 p-1.5 shadow-xs inline-flex items-center gap-1">
  <% tabs.forEach((tab, index) => { %>
    <button type="button" 
      onclick="switchTab('<%= tab.id %>')" 
      id="tab-btn-<%= tab.id %>" 
      class="tab-btn px-5 py-2.5 text-xs rounded-xl transition-all duration-200 outline-none cursor-pointer <%= index === 0 ? 'font-bold bg-blue-600 text-white shadow-xs' : 'font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50' %>">
      <%= tab.label %>
    </button>
  <% }) %>
</div>

<script>
  function switchTab(tabName) {
    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.replace('block', 'hidden');
      pane.classList.add('opacity-0', 'translate-y-2');
    });

    const activeContent = document.getElementById(`tab-content-${tabName}`);
    if (activeContent) {
      activeContent.classList.remove('hidden');
      setTimeout(() => {
        activeContent.classList.add('block');
        activeContent.classList.remove('opacity-0', 'translate-y-2');
        activeContent.classList.add('opacity-100', 'translate-y-0');
      }, 10);
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.className = "tab-btn px-5 py-2.5 text-xs font-medium rounded-xl text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-all duration-200 outline-none cursor-pointer";
    });

    const activeBtn = document.getElementById(`tab-btn-${tabName}`);
    if (activeBtn) {
      activeBtn.className = "tab-btn px-5 py-2.5 text-xs font-bold rounded-xl bg-blue-600 text-white shadow-xs transition-all duration-200 outline-none cursor-pointer";
    }
  }
</script>
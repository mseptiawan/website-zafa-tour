<%- layout('layouts/main', { title }) %>

<div class="ml-0 md:ml-72 min-h-screen bg-slate-50/50 md:bg-[#FCFCFD] py-5 md:p-10 antialiased text-slate-800 pb-24 md:pb-8 rounded-2xl overflow-hidden">
  <div class="w-full max-w-2xl mx-auto mt-4 md:mt-0">

    <%- include('../partials/page-header', { 
        section: 'Monitoring', 
        module: 'Sales Visits', 
        title: 'Edit Kunjungan Sales', 
        description: 'Perbarui data dan lampiran laporan kunjungan yang sudah dibuat.' 
    }) %>

    <div class="bg-white border border-slate-200/60 md:border-slate-200/80 rounded-2xl p-4 sm:p-5 md:p-8 shadow-2xs md:shadow-sm overflow-hidden">
      
      <form action="/sales/<%= visit._id %>/edit" method="POST" enctype="multipart/form-data" class="space-y-5">

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="p-3.5 rounded-xl bg-rose-50 text-rose-600 text-[13px] border border-rose-100 font-medium">
          <%= error %>
        </div>
        <% } %>

        <%- include('./partials/sales-form-fields', { visit: visit, errors: typeof errors !== 'undefined' ? errors : {} }) %>

        <div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-3">
          <a href="/sales/my" class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-5 py-2.5 text-[12px] font-semibold transition-colors shadow-2xs">
            Batal
          </a>
          <button type="submit" class="w-auto text-center bg-blue-500 text-white px-6 py-2.5 rounded-xl text-[12px] font-semibold transition-colors shadow-xs cursor-pointer">
            Update
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<script>
  let currentFileUrl = null;

  function handleFileSelect(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];
      if (currentFileUrl) { URL.revokeObjectURL(currentFileUrl); }
      currentFileUrl = URL.createObjectURL(file);
      
      const viewBtn = document.getElementById("view-file-btn");
      if (viewBtn) { viewBtn.href = currentFileUrl; }

      document.getElementById("name-preview").textContent = file.name;
      const fileSizeInKB = file.size / 1024;
      document.getElementById("size-preview").textContent = fileSizeInKB < 1024 ? fileSizeInKB.toFixed(1) + " KB" : (fileSizeInKB / 1024).toFixed(2) + " MB";

      const imgPreview = document.getElementById("img-preview");
      const fileIconFallback = document.getElementById("file-icon-fallback");

      if (file.type.startsWith("image/")) {
        imgPreview.src = currentFileUrl;
        imgPreview.classList.remove("hidden");
        if (fileIconFallback) fileIconFallback.classList.add("hidden");
      } else {
        imgPreview.src = "";
        imgPreview.classList.add("hidden");
        if (fileIconFallback) fileIconFallback.classList.remove("hidden");
      }

      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
    }
  }

  window.addEventListener("beforeunload", () => {
    if (currentFileUrl) { URL.revokeObjectURL(currentFileUrl); }
  });
</script>
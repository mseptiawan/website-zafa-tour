<%- layout('layouts/main', { title }) %>

<!-- MD-KAN BG: Di mobile full putih bersih tanpa pembatas kaku, di desktop layout mengambang ramah -->
<div class="ml-0 min-h-screen  md:ml-72 md:bg-[#FCFCFD] p-4 md:p-8 antialiased text-slate-800 pb-24 md:pb-8 ">
  <div class="w-full max-w-2xl mx-auto mt-16 md:mt-0">

    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Announcements', 
        title: 'Buat Pengumuman', 
        description: 'Publikasikan informasi internal untuk tim Anda.' 
    }) %>

    <!-- BORDER & BACKGROUND: Di mobile dibuat flat minimalis, di desktop barulah membentuk card modern -->
    <div class="bg-white border-0 md:border md:border-slate-200/80 rounded-2xl md:shadow-sm mt-2 md:mt-5">
      <form method="POST" action="/announcement/" enctype="multipart/form-data" class="py-4 md:p-8 space-y-5">

        <!-- Input Judul -->
        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700">Judul Pengumuman</label>
          <input type="text" name="title" placeholder="Ketik judul di sini..." value="<%= old?.title || '' %>" 
                 class="w-full bg-slate-50 border <%= (typeof errors !== 'undefined' && errors?.title) ? 'border-rose-400 focus:ring-rose-100/50 focus:border-rose-500' : 'border-slate-200/80 focus:ring-slate-100 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] placeholder:text-slate-400/80 focus:bg-white outline-none transition-all focus:ring-4 text-slate-800" />

          <% if (typeof errors !== 'undefined' && errors?.title) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1"><%= errors.title %></p>
          <% } %>
        </div>

        <!-- Dropdown Kategori -->
        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700">Kategori</label>
          <div class="relative w-full" id="category-dropdown">
            <% 
              let currentCatValue = old?.category || 'LIGHT';
              let currentCatLabel = '🍃 Pengumuman Ringan';
              if (currentCatValue === 'OFFICIAL') {
                currentCatLabel = '⚖️ Pengumuman Resmi';
              }
            %>
            <input type="hidden" name="category" id="category-value" value="<%= currentCatValue %>" >
            <button type="button" onclick="toggleCategoryDropdown()" 
                    class="w-full bg-slate-50 border <%= (typeof errors !== 'undefined' && errors?.category) ? 'border-rose-400 focus:ring-rose-100/50 focus:border-rose-500' : 'border-slate-200/80 focus:ring-slate-100 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] text-slate-700 text-left flex items-center justify-between outline-none focus:bg-white focus:ring-4 transition-all">
              <span id="category-label" class="flex items-center gap-2">
                <%= currentCatLabel %>
              </span>
              <svg id="category-arrow" class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="category-menu" class="hidden absolute z-30 w-full mt-1.5 bg-white border border-slate-200/80 rounded-xl shadow-lg p-1.5 space-y-0.5">
              <button type="button" onclick="selectCategory('LIGHT', '🍃 Pengumuman Ringan')" class="w-full text-left px-3 py-2 text-[13px] font-medium text-slate-600 hover:bg-slate-50 rounded-lg flex items-center gap-2">
                <span>🍃</span> Pengumuman Ringan
              </button>
              <% if (user.role === "DIREKTUR_UTAMA") { %>
                <button type="button" onclick="selectCategory('OFFICIAL', '⚖️ Pengumuman Resmi')" class="w-full text-left px-3 py-2 text-[13px] font-medium text-slate-600 hover:bg-slate-50 rounded-lg flex items-center gap-2">
                  <span>⚖️</span> Pengumuman Resmi
                </button>
              <% } %>
            </div>
          </div>
          <% if (typeof errors !== 'undefined' && errors?.category) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1"><%= errors.category %></p>
          <% } %>
        </div>

        <!-- Input Isi -->
        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700">Isi Pengumuman</label>
          <textarea name="content" rows="6" placeholder="Tulis detail informasi di sini..." 
                    class="w-full bg-slate-50 border <%= (typeof errors !== 'undefined' && errors?.content) ? 'border-rose-400 focus:ring-rose-100/50 focus:border-rose-500' : 'border-slate-200/80 focus:ring-slate-100 focus:border-slate-400' %> rounded-xl px-4 py-2.5 text-[13px] placeholder:text-slate-400/80 focus:bg-white outline-none resize-none transition-all focus:ring-4 leading-relaxed text-slate-800"><%= old?.content || '' %></textarea>

          <% if (typeof errors !== 'undefined' && errors?.content) { %>
            <p class="text-[11px] font-medium text-rose-600 mt-1"><%= errors.content %></p>
          <% } %>
        </div>

        <!-- Input Lampiran File -->
        <div class="space-y-1.5">
          <label class="text-[12px] font-semibold text-slate-700">Lampiran <span class="text-slate-400 font-normal">(Opsional)</span></label>
          <div class="relative">
            <input type="file" name="attachment" id="file-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="handleFileSelect(this)" />
            <div id="dropzone-empty" class="w-full border border-slate-200 border-dashed rounded-xl p-5 bg-slate-50/50 hover:bg-slate-50 transition flex flex-col items-center text-center">
              <svg class="w-4 h-4 text-slate-400 mb-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
              </svg>
              <span class="text-[12px] font-medium text-slate-600">Pilih Berkas atau Drop File Disini</span>
              <span class="text-[11px] text-slate-400 mt-0.5">PNG, JPG, PDF (maks 5MB)</span>
            </div>
            <div id="dropzone-filled" class="hidden flex flex-col sm:flex-row sm:items-center justify-between gap-3 border border-slate-200 rounded-xl p-3.5 bg-white shadow-xs">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-9 h-9 rounded-lg bg-slate-50 border border-slate-200/60 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <div id="name-preview" class="text-[12px] font-medium text-slate-700 truncate">file.pdf</div>
                  <div id="size-preview" class="text-[11px] text-slate-400 mt-0.5">0 KB</div>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0 w-full sm:w-auto relative z-20">
                <a id="view-file-btn" href="#" target="_blank" class="text-[11px] font-medium text-center text-slate-700 bg-slate-100 hover:bg-slate-200/80 px-3 py-1.5 rounded-lg flex-1 sm:flex-initial transition-colors">View</a>
                <button type="button" onclick="document.getElementById('file-input').click()" class="text-[11px] font-medium text-slate-600 bg-slate-50 border border-slate-200/60 hover:bg-slate-100 px-3 py-1.5 rounded-lg flex-1 sm:flex-initial transition-colors">Ganti</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Tombol Action: Ganti Biru Pasaran ke Slate-800 yang Lebih Mahal & Profesional -->
        <div class="pt-5 border-t border-slate-100 flex flex-col-reverse sm:flex-row items-center justify-end gap-2.5">
          <a href="/announcement" class="w-full sm:w-auto text-center bg-white hover:bg-slate-50 text-slate-600 border border-slate-200/80 rounded-xl px-5 py-2 text-[12px] font-medium transition-colors">Batal</a>
          <button type="submit" class="w-full sm:w-auto text-center bg-slate-800 hover:bg-slate-900 text-white px-6 py-2 rounded-xl text-[12px] font-medium transition-colors shadow-xs">Publish</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function handleFileSelect(input) {
    if (input.files && input.files.length > 0) {
      const file = input.files[0];
      document.getElementById("name-preview").textContent = file.name;
      document.getElementById("size-preview").textContent = (file.size / 1024).toFixed(1) + " KB";
      document.getElementById("dropzone-empty").classList.add("hidden");
      document.getElementById("dropzone-filled").classList.remove("hidden");
      document.getElementById("view-file-btn").href = URL.createObjectURL(file);
    }
  }

  function toggleCategoryDropdown() {
    const menu = document.getElementById('category-menu');
    menu.classList.toggle('hidden');
    document.getElementById('category-arrow').classList.toggle('rotate-180');
  }

  function selectCategory(value, label) {
    document.getElementById('category-value').value = value;
    document.getElementById('category-label').innerHTML = label;
    toggleCategoryDropdown();
  }
</script>
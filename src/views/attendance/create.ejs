<%- layout('layouts/main', { title: title }) %>

<div class=" min-h-screen bg-slate-50 p-8">
  <div class="max-w-xl mx-auto">
   <div class="mb-8 text-center space-y-1.5">
  <h1 class="text-xl font-bold tracking-tight text-slate-900">Pencatatan Kehadiran Kerja</h1>
  <p class="text-[13px] font-medium text-slate-400" id="camera-instruction">
    <i class="fa-solid fa-face-viewfinder mr-1 text-slate-300"></i> Posisikan wajah Anda tepat pada area kamera
  </p>
</div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-6">
      
      <% if (already && hasCheckedOut) { %>
       <div class="text-center py-8 px-4 space-y-5 flex flex-col items-center justify-center">
  <div class="relative flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600 border border-emerald-100 shadow-sm animate-bounce-short">
    <i class="fa-solid fa-calendar-check text-xl"></i>
    <span class="absolute -top-1 -right-1 flex h-3 w-3">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
      <span class="relative inline-flex h-3 w-3 rounded-full bg-emerald-500"></span>
    </span>
  </div>

  <div class="space-y-1">
    <h2 class="text-base font-bold text-slate-900 tracking-tight">Sesi Kehadiran Selesai</h2>
    <p class="text-[13px] font-medium text-slate-400 max-w-xs mx-auto leading-relaxed">
      Anda telah melengkapi pencatatan <span class="text-emerald-600 font-semibold">Check-In</span> dan <span class="text-emerald-600 font-semibold">Check-Out</span> untuk hari ini.
    </p>
  </div>

  <a href="/attendance/history" 
     class="inline-flex items-center gap-2 px-4 py-2.5 text-xs font-semibold text-slate-700 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 hover:text-slate-900 shadow-2xs transition-all active:scale-[0.98]">
    <i class="fa-solid fa-clock-rotate-left text-slate-400 text-[11px]"></i> 
    Buka Riwayat Kehadiran
  </a>
</div>

      <% } else { %>
        <div class="space-y-5">
          <div class="relative bg-slate-100 rounded-xl overflow-hidden aspect-video border border-slate-200">
            <video id="video" autoplay playsinline muted class="w-full h-full object-cover"></video>
            <canvas id="canvas" class="hidden"></canvas>
            
            </div>
          </div>

          <% if (!already) { %>
            <button type="button" onclick="submitAttendance(event, 'checkin')" id="btn-submit"
              class="w-full py-2.5 text-sm font-semibold bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition shadow-sm">
               Check-In
            </button>
          <% } else { %>
            <button type="button" onclick="submitAttendance(event, 'checkout')" id="btn-submit"
              class="w-full py-2.5 text-sm font-semibold bg-rose-600 text-white rounded-xl hover:bg-rose-700 transition shadow-sm">
              Check-Out 
            </button>
          <% } %>
        </div>
      <% } %>

    </div>
  </div>
</div>
<script>
let stream = null, lat = null, lng = null;
const video = document.getElementById("video");
const canvas = document.getElementById("canvas");

const isAlreadyCheckIn = <%- already %>;
const isAlreadyCheckOut = <%- hasCheckedOut %>;

// 🌟 FIX 1: Implementasi fungsi showMessage menggunakan Toast Kustom Global Anda
function showMessage(type, message) {
  if (type === "success") {
    triggerGlobalToast({
      title: "Berhasil",
      message: message,
      type: "success"
    });
  } else {
    triggerGlobalToast({
      title: "Gagal",
      message: message,
      type: "error"
    });
  }
}

async function submitAttendance(event, actionType) {
  const btn = event.currentTarget;
  const originalText = btn.innerText;

  btn.disabled = true;
  btn.innerText = "Tunggu sebentar...";

  try {
    const pos = await getLocation();
    lat = pos.lat;
    lng = pos.lng;

    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext("2d").drawImage(video, 0, 0, canvas.width, canvas.height);

    const blob = await new Promise(resolve =>
      canvas.toBlob(resolve, "image/jpeg", 0.8)
    );

    const formData = new FormData();
    formData.append("photo", blob, `${actionType}_selfie.jpg`);
    formData.append("lat", lat);
    formData.append("lng", lng);

    if (actionType === "checkin") {
      const noteInput = document.getElementById("note");
      formData.append("note", noteInput ? noteInput.value : "");
    }

    // 🌟 FIX 2: Sesuaikan route URL ini jika di backend Anda menggunakan tanda strip (check-in / check-out)
    const targetUrl =
      actionType === "checkin"
        ? "/attendance/checkin"
        : "/attendance/checkout";

    const res = await fetch(targetUrl, { method: "POST", body: formData });
    const data = await res.json();

    if (data.success) {
      showMessage("success", data.message);
      
      // 🌟 FIX 3: Matikan kamera segera demi privasi pengguna
      stopCamera();

      // 🌟 FIX 4: Beri delay 1.5 detik agar animasi toast sempat tampil sebelum pindah halaman
      setTimeout(() => {
        window.location.href = "/attendance/history";
      }, 1500);
      
    } else {
      showMessage("error", data.message);
      btn.disabled = false;
      btn.innerText = originalText;
    }

  } catch (e) {
    console.error(e);
    showMessage("error", "Gagal memproses absensi. Cek GPS & kamera.");
    btn.disabled = false;
    btn.innerText = originalText;
  }
}

function getLocation() {
  return new Promise((resolve, reject) => {
    if (!navigator.geolocation)
      return reject(new Error("GPS tidak didukung browser"));

    navigator.geolocation.getCurrentPosition(
      p => resolve({
        lat: p.coords.latitude,
        lng: p.coords.longitude
      }),
      err => reject(err),
      { enableHighAccuracy: true, timeout: 10000 }
    );
  });
}

async function startCamera() {
  if (isAlreadyCheckIn && isAlreadyCheckOut) return;
  if (!video) return;

  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { width: 640, height: 480, facingMode: "user" }
    });

    video.srcObject = stream;
  } catch (err) {
    document.getElementById("camera-instruction").innerText =
      "Gagal memuat kamera. Aktifkan izin kamera.";
    document.getElementById("camera-instruction").classList.add("text-rose-500");
  }
}

function stopCamera() {
  if (!stream) return;
  stream.getTracks().forEach(track => track.stop());
}

startCamera();

document.addEventListener("visibilitychange", () => {
  document.hidden ? stopCamera() : startCamera();
});
</script>
<%- layout('layouts/main', { title: title }) %>

<div class="ml-72 p-6">
  <!-- HEADER -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-800">
        Semua Penugasan
      </h1>

      <p class="text-sm text-slate-500 mt-1">
        Monitoring seluruh penugasan karyawan
      </p>
    </div>

    <a
      href="/assignment/create"
      class="bg-slate-900 hover:bg-slate-800 text-white text-sm px-4 py-2 rounded-xl transition"
    >
      + Buat Penugasan
    </a>
  </div>

  <!-- LIST -->
  <div class="space-y-4">

    <% if(assignments.length === 0) { %>

      <div class="bg-white border border-slate-200 rounded-2xl p-8 text-center">
        <p class="text-sm text-slate-500">
          Belum ada data penugasan
        </p>
      </div>

    <% } %>

    <% assignments.forEach(a => { %>

      <a
        href="/assignment/<%= a._id %>"
        class="block bg-white border border-slate-200 rounded-2xl p-5 hover:border-indigo-300 hover:shadow-sm transition"
      >
        <!-- TOP -->
        <div class="flex items-start justify-between gap-4">

          <div>
            <!-- TITLE -->
            <h2 class="text-sm font-semibold text-slate-800">
              <%= a.title %>
            </h2>

            <!-- DESCRIPTION -->
            <p class="text-xs text-slate-500 mt-1 line-clamp-2">
              <%= a.description || '-' %>
            </p>
          </div>

          <!-- STATUS -->
          <div>
            <% if(a.status === "ACTIVE") { %>

              <span
                class="text-[11px] bg-emerald-100 text-emerald-600 px-3 py-1 rounded-full font-medium"
              >
                ACTIVE
              </span>

            <% } else { %>

              <span
                class="text-[11px] bg-slate-200 text-slate-600 px-3 py-1 rounded-full font-medium"
              >
                COMPLETED
              </span>

            <% } %>
          </div>
        </div>

        <!-- INFO -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-5">

          <!-- TYPE -->
          <div>
            <p class="text-[11px] text-slate-400 uppercase">
              Tipe
            </p>

            <p class="text-sm text-slate-700 mt-1">
              <%= a.type %>
            </p>
          </div>

          <!-- LOCATION -->
          <div>
            <p class="text-[11px] text-slate-400 uppercase">
              Lokasi
            </p>

            <p class="text-sm text-slate-700 mt-1">
              <%= a.location || '-' %>
            </p>
          </div>

          <!-- START -->
          <div>
            <p class="text-[11px] text-slate-400 uppercase">
              Mulai
            </p>

            <p class="text-sm text-slate-700 mt-1">
              <%= new Date(a.startDate).toLocaleDateString("id-ID") %>
            </p>
          </div>

          <!-- END -->
          <div>
            <p class="text-[11px] text-slate-400 uppercase">
              Selesai
            </p>

            <p class="text-sm text-slate-700 mt-1">
              <%= new Date(a.endDate).toLocaleDateString("id-ID") %>
            </p>
          </div>

        </div>

        <!-- EMPLOYEE -->
        <div class="mt-5 border-t pt-4">

          <p class="text-[11px] text-slate-400 uppercase mb-3">
            Karyawan Ditugaskan
          </p>

          <div class="flex flex-wrap gap-2">

            <% a.employees.forEach(e => { %>

              <div
                class="bg-slate-100 px-3 py-2 rounded-xl"
              >
                <div class="text-xs font-medium text-slate-700">
                  <%= e.fullName %>
                </div>

                <span class="text-[11px] text-slate-400">
                  ID: <%= e.employeeCode || '-' %>
                </span>
              </div>

            <% }) %>

          </div>
        </div>

        <!-- FILE -->
        <% if(a.attachment) { %>

          <div class="mt-4">
            <span
              class="text-[11px] bg-indigo-50 text-indigo-500 px-3 py-1 rounded-full"
            >
              Ada Surat Penugasan
            </span>
          </div>

        <% } %>

      </a>

    <% }) %>

  </div>
</div>
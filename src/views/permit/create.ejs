<%- layout('layouts/main', { title }) %>

<div class="ml-72 min-h-screen bg-slate-50/50 p-8 antialiased">
  <div class="max-w-2xl mx-auto">

    <%- include('../partials/page-header', { 
        section: 'Area Kerja', 
        module: 'Perizinan', 
        title: 'Pengajuan Izin & Cuti', 
        description: 'Form permohonan izin absensi atau cuti karyawan' 
    }) %>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm">

      <form action="/permit" method="POST" enctype="multipart/form-data" class="p-8 space-y-6">

        <div class="space-y-1.5">
          <label class="text-[13px] font-semibold text-slate-700">
            Jenis Izin / Cuti
          </label>

          <div class="relative w-full" id="custom-dropdown">
            <input type="hidden" name="type" id="leave-type-value" value="<%= typeof oldData !== 'undefined' && oldData.type ? oldData.type : '' %>" required>

            <button type="button" onclick="toggleDropdown()" class="w-full bg-slate-50/60 border <%= typeof errors !== 'undefined' && errors.type ? 'border-rose-400 focus:ring-rose-100' : 'border-slate-200/60 focus:ring-slate-100/70' %> rounded-xl px-4 py-3 text-[13px] font-medium text-slate-700 text-left flex items-center justify-between outline-none hover:bg-slate-50 hover:border-slate-300 focus:bg-white focus:border-slate-300 focus:ring-4 transition-all duration-200 cursor-pointer shadow-sm">
              <span id="dropdown-label" class="<%= typeof oldData !== 'undefined' && oldData.type ? 'text-slate-700' : 'text-slate-400 text-xs' %>">
                <%= typeof oldData !== 'undefined' && oldData.type ? (oldData.type === 'SAKIT' ? 'Izin Sakit (Dengan Surat Dokter)' : oldData.type === 'PENDAMPINGAN_MELAHIRKAN' ? 'Izin Mendampingi Istri Melahirkan' : oldData.type === 'MUSIBAH' ? 'Izin Terkena Musibah / Kemalangan' : 'Izin Keperluan Mendesak / Hal Penting') : 'Pilih jenis permohonan izin' %>
              </span>
              <svg id="dropdown-arrow" class="w-4 h-4 text-slate-400 stroke-[2] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <div id="dropdown-menu" class="hidden absolute z-30 w-full mt-2 bg-white border border-slate-200/50 rounded-xl shadow-xl p-1.5 space-y-0.5 origin-top transform opacity-0 scale-95 transition-all duration-150 backdrop-blur-sm">
              <button type="button" onclick="selectOption('SAKIT', 'Izin Sakit (Dengan Surat Dokter)')" class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                <span>Izin Sakit (Dengan Surat Dokter)</span>
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
              <button type="button" onclick="selectOption('PENDAMPINGAN_MELAHIRKAN', 'Izin Mendampingi Istri Melahirkan')" class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                <span>Izin Mendampingi Istri Melahirkan</span>
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
              <button type="button" onclick="selectOption('MUSIBAH', 'Izin Terkena Musibah / Kemalangan')" class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                <span>Izin Terkena Musibah / Kemalangan</span>
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
              <button type="button" onclick="selectOption('PENTING', 'Izin Keperluan Mendesak / Hal Penting')" class="w-full text-left px-3 py-2.5 text-[13px] font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg flex items-center justify-between group transition-colors">
                <span>Izin Keperluan Mendesak / Hal Penting</span>
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
              </button>
            </div>
          </div>
          <% if (typeof errors !== 'undefined' && errors.type) { %>
            <p class="text-[11px] font-medium text-rose-500 mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <%= errors.type %>
            </p>
          <% } %>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-semibold text-slate-700">Tanggal Ketidakhadiran</label>
          <input type="date" id="permitDate" name="date" value="<%= typeof oldData !== 'undefined' && oldData.date ? oldData.date : '' %>" required class="w-full bg-slate-50 border <%= typeof errors !== 'undefined' && errors.date ? 'border-rose-400 focus:ring-rose-100' : 'border-slate-200 focus:border-slate-400' %> rounded-xl text-xs px-4 py-3 text-slate-700 outline-none focus:bg-white focus:ring-4 transition-all" />
          <p class="text-[10px] text-slate-400 font-medium">Sifatnya insidental, pilih hari ini saat halangan terjadi.</p>
          <% if (typeof errors !== 'undefined' && errors.date) { %>
            <p class="text-[11px] font-medium text-rose-500 mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <%= errors.date %>
            </p>
          <% } %>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-semibold text-slate-700">
            Alasan Pengajuan
          </label>
          <textarea name="reason" rows="4" required placeholder="Berikan alasan detail atau keterangan permohonan izin Anda di sini..." class="w-full bg-slate-50 border <%= typeof errors !== 'undefined' && errors.reason ? 'border-rose-400 focus:ring-rose-100' : 'border-slate-200 focus:border-slate-400' %> rounded-xl text-xs px-4 py-3 text-slate-700 outline-none resize-none focus:bg-white focus:ring-4 transition-all"><%= typeof oldData !== 'undefined' && oldData.reason ? oldData.reason : '' %></textarea>
          <% if (typeof errors !== 'undefined' && errors.reason) { %>
            <p class="text-[11px] font-medium text-rose-500 mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <%= errors.reason %>
            </p>
          <% } %>
        </div>

        <div class="space-y-1.5">
          <label class="text-[13px] font-semibold text-slate-700 flex items-center gap-1">
            <span>Dokumen Pendukung</span>
            <span id="required-mark" class="text-rose-500 hidden">*</span>
            <span id="optional-mark" class="text-slate-400 font-normal">(Opsional)</span>
          </label>

          <div class="group relative border-2 border-dashed <%= typeof errors !== 'undefined' && errors.document ? 'border-rose-300 bg-rose-50/20' : 'border-slate-200 hover:border-blue-400 bg-slate-50/50 hover:bg-white' %> rounded-2xl p-6 transition-all duration-200 text-center cursor-pointer">
            <input type="file" name="document" id="file-upload" accept=".pdf,.jpg,.jpeg,.png" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="updateFileName(this)" />

            <div class="space-y-2 pointer-events-none">
              <div class="mx-auto w-10 h-10 rounded-xl bg-slate-100 group-hover:bg-blue-50 text-slate-400 group-hover:text-blue-500 flex items-center justify-center transition-colors">
                <svg class="w-5 h-5 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
                </svg>
              </div>

              <div class="text-xs font-medium text-slate-600">
                Klik untuk upload atau drag dan drop berkas
              </div>
              <p id="file-info" class="text-[11px] text-slate-400">PDF, JPG, JPEG, atau PNG (Maks. 2MB)</p>
            </div>
          </div>
          <% if (typeof errors !== 'undefined' && errors.document) { %>
            <p class="text-[11px] font-medium text-rose-500 mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <%= errors.document %>
            </p>
          <% } %>
        </div>

        <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
          <a href="/permit" class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/80 rounded-xl px-6 py-2.5 text-[13px] font-medium transition-all shadow-sm active:scale-[0.98]">
            Batal
          </a>

          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-7 py-2.5 rounded-xl text-[13px] font-medium transition-all shadow-sm active:scale-[0.98] cursor-pointer">
            <%= typeof mode !== 'undefined' ? (mode === 'CREATE' ? 'Ajukan Izin' : 'Simpan Perubahan') : 'Ajukan Izin' %>
          </button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  function toggleDropdown() {
    const menu = document.getElementById('dropdown-menu');
    const arrow = document.getElementById('dropdown-arrow');

    if (menu.classList.contains('hidden')) {
      menu.classList.remove('hidden');
      setTimeout(() => {
        menu.classList.remove('opacity-0', 'scale-95');
        menu.classList.add('opacity-100', 'scale-100');
      }, 10);
      arrow.classList.add('rotate-180');
    } else {
      closeDropdown();
    }
  }

  function closeDropdown() {
    const menu = document.getElementById('dropdown-menu');
    const arrow = document.getElementById('dropdown-arrow');

    menu.classList.remove('opacity-100', 'scale-100');
    menu.classList.add('opacity-0', 'scale-95');
    arrow.classList.remove('rotate-180');

    setTimeout(() => {
      menu.classList.add('hidden');
    }, 150);
  }

  function selectOption(value, label) {
    document.getElementById('leave-type-value').value = value;
    const labelEl = document.getElementById('dropdown-label');
    labelEl.textContent = label;
    labelEl.classList.remove('text-slate-400');
    labelEl.classList.add('text-slate-700');
    
    const fileUpload = document.getElementById('file-upload');
    const requiredMark = document.getElementById('required-mark');
    const optionalMark = document.getElementById('optional-mark');

    if (value === 'SAKIT') {
      fileUpload.required = true;
      requiredMark.classList.remove('hidden');
      optionalMark.classList.add('hidden');
    } else {
      fileUpload.required = false;
      requiredMark.classList.add('hidden');
      optionalMark.classList.remove('hidden');
    }

    closeDropdown();
  }

  window.addEventListener('click', function(e) {
    const dropdown = document.getElementById('custom-dropdown');
    if (dropdown && !dropdown.contains(e.target)) {
      closeDropdown();
    }
  });

  function updateFileName(input) {
    const fileInfo = document.getElementById('file-info');
    if (input.files && input.files.length > 0) {
      const fileName = input.files[0].name;
      fileInfo.textContent = `File terpilih: ${fileName}`;
      fileInfo.classList.remove('text-slate-400');
      fileInfo.classList.add('text-blue-600', 'font-semibold');
    } else {
      fileInfo.textContent = "PDF, JPG, JPEG, atau PNG (Maks. 2MB)";
      fileInfo.classList.remove('text-blue-600', 'font-semibold');
      fileInfo.classList.add('text-slate-400');
    }
  }

  const today = new Date();
  const yyyy = today.getFullYear();
  const mm = String(today.getMonth() + 1).padStart(2, '0'); 
  const dd = String(today.getDate()).padStart(2, '0');
  const formattedToday = `${yyyy}-${mm}-${dd}`;

  const tomorrow = new Date(today);
  tomorrow.setDate(tomorrow.getDate() + 1);
  const tYyyy = tomorrow.getFullYear();
  const tMm = String(tomorrow.getMonth() + 1).padStart(2, '0');
  const tDd = String(tomorrow.getDate()).padStart(2, '0');
  const formattedTomorrow = `${tYyyy}-${tMm}-${tDd}`;

  const permitDateInput = document.getElementById('permitDate');
  permitDateInput.min = formattedToday;
  permitDateInput.max = formattedTomorrow;

  if (!permitDateInput.value) {
    permitDateInput.value = formattedToday;
  }

  document.addEventListener('DOMContentLoaded', function() {
    const currentValue = document.getElementById('leave-type-value').value;
    if (currentValue) {
      const fileUpload = document.getElementById('file-upload');
      const requiredMark = document.getElementById('required-mark');
      const optionalMark = document.getElementById('optional-mark');
      if (currentValue === 'SAKIT') {
        fileUpload.required = true;
        requiredMark.classList.remove('hidden');
        optionalMark.classList.add('hidden');
      }
    }
  });
</script>